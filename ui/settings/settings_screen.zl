#define SETTINGS_ROW_CRT_CURVATURE 12
#define SETTINGS_ROW_CRT_BRIGHTNESS 13
#define SETTINGS_ROW_VHS_WAVES 14
#define SETTINGS_ROW_VHS_DAMAGE 15
#define SETTINGS_ROW_BG_STARS_AMOUNT 16
#define SETTINGS_ROW_BG_STARS_MODE 17
