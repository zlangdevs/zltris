#define THEME_MGR_FOCUS_NAME 1
#define THEME_MGR_FOCUS_FIELD 2
#define THEME_MGR_FOCUS_WHEEL 3
#define THEME_MGR_FOCUS_BRIGHTNESS 4
#define THEME_MGR_FOCUS_BUTTONS 5

#define THEME_MGR_BUTTON_NEW 0
#define THEME_MGR_BUTTON_DELETE 1
#define THEME_MGR_BUTTON_CLOSE 2

#define SETTINGS_ACTION_NONE 0
#define SETTINGS_ACTION_BACK 1

struct SettingsState {
    selected_row i32,
    scroll f32,
    controls_expanded bool,
    controls_anim f32,
    video_expanded bool,
    video_anim f32,
    audio_expanded bool,
    audio_anim f32,
    picker_open bool,
    picker_scroll f32,
    picker_selected i32,
    picker_count i32,
    picker_names arr<u8, 6144>,
    mouse_last_x f32,
    mouse_last_y f32,
    keyboard_nav_lock bool,
    song_picker_open bool,
    song_picker_scroll f32,
    song_picker_selected i32,
    theme_custom_active bool,
    theme_mgr_open bool,
    theme_mgr_focus i32,
    theme_mgr_selected i32,
    theme_mgr_scroll f32,
    theme_mgr_field i32,
    theme_mgr_name_edit bool,
    theme_mgr_name arr<u8, CUSTOM_THEME_NAME_MAX>,
    theme_mgr_name_cursor i32,
    theme_mgr_brightness f32,
    theme_mgr_hue f32,
    theme_mgr_saturation f32,
    theme_mgr_button i32,
}

fun init(self: SettingsState) >> SettingsState {
    SettingsState next = self;
    next.selected_row = SETTINGS_ROW_THEME;
    next.scroll = 0.0;
    next.controls_expanded = g_settings_controls_expanded;
    next.controls_anim = 0.0 as f32;
    if next.controls_expanded {next.controls_anim = 1.0 as f32;}
    next.video_expanded = g_settings_video_expanded;
    next.video_anim = 0.0 as f32;
    if next.video_expanded {next.video_anim = 1.0 as f32;}
    next.audio_expanded = g_settings_audio_expanded;
    next.audio_anim = 0.0 as f32;
    if next.audio_expanded {next.audio_anim = 1.0 as f32;}
    next.picker_open = false;
    next.picker_scroll = 0.0 as f32;
    next.picker_selected = 0;
    next.picker_count = 0;
    next.mouse_last_x = 0.0 as f32;
    next.mouse_last_y = 0.0 as f32;
    next.keyboard_nav_lock = false;
    next.song_picker_open = false;
    next.song_picker_scroll = 0.0 as f32;
    next.song_picker_selected = 0;
    next.theme_custom_active = false;
    next.theme_mgr_open = false;
    next.theme_mgr_focus = THEME_MGR_FOCUS_LIST;
    next.theme_mgr_selected = 0;
    next.theme_mgr_scroll = 0.0 as f32;
    next.theme_mgr_field = 0;
    next.theme_mgr_name_edit = false;
    next.theme_mgr_name[0] = 0;
    next.theme_mgr_name_cursor = 0;
    next.theme_mgr_brightness = 1.0 as f32;
    next.theme_mgr_hue = 0.0 as f32;
    next.theme_mgr_saturation = 0.0 as f32;
    next.theme_mgr_button = THEME_MGR_BUTTON_NEW;
    return next;
}

SettingsState g_settings = {0};

#define SETTINGS_BG_GRID 18
#define SETTINGS_BG_PHASES 16

fun settingsInit() >> void {
    g_settings = g_settings.init();
}

fun settingsActionNone() >> i32 { return SETTINGS_ACTION_NONE; }
fun settingsActionBack() >> i32 { return SETTINGS_ACTION_BACK; }

fun absi(v: i32) >> i32 {
    if v < 0 {return -v;}
    return v;
}

fun maxi(a: i32, b: i32) >> i32 {
    if a > b {return a;}
    return b;
}

fun maxf(a: f32, b: f32) >> f32 {
    if a > b {return a;}
    return b;
}

fun minf(a: f32, b: f32) >> f32 {
    if a < b {return a;}
    return b;
}

fun posMod(v: i32, m: i32) >> i32 {
    if m <= 0 {return 0;}
    i32 r = v % m;
    if r < 0 {r += m;}
    return r;
}

fun hash32(v: i32) >> i32 {
    i32 x = v * 1664525 + 1013904223;
    x = x ^ (x >> 16);
    if x < 0 {x = -x;}
    return x;
}

fun triWave01(v: f32) >> f32 {
    f32 t = fractf(v);
    if t < (0.5 as f32) {return t * (2.0 as f32);}
    return ((1.0 as f32) - t) * (2.0 as f32);
}

fun pulseBand(distance: f32, width: f32) >> f32 {
    if width <= (0.0 as f32) {return 0.0 as f32;}
    return clamp01((1.0 as f32) - distance / width);
}

fun zltrisGlyphFilled(letter: i32, col: i32, row: i32) >> bool {
    if col < 0 || col >= 5 || row < 0 || row >= 7 {return false;}

    if (letter == 0) {
        if row == 0 || row == 6 {return true;}
        if row == 1 {return col == 3;}
        if row == 2 {return col == 2;}
        if row == 3 {return col == 2;}
        if row == 4 {return col == 1;}
        return col == 0;
    }

    if letter == 1 {return col == 0 || row == 6;}

    if letter == 2 {return row == 0 || col == 2;}

    if (letter == 3) {
        if col == 0 {return true;}
        if row == 0 || row == 3 {return col <= 3;}
        if col == 3 && row < 3 {return true;}
        if row >= 3 && col == row - 2 {return true;}
        return false;
    }

    if letter == 4 {return row == 0 || row == 6 || col == 2;}

    if row == 0 || row == 3 || row == 6 {return true;}
    if row < 3 {return col == 0;}
    return col == 4;
}

fun chevronGlyphFilled(right_dir: bool, col: i32, row: i32) >> bool {
    if col < 0 || col >= 5 || row < 0 || row >= 7 {return false;}

    i32 band = row;
    if band > 3 {band = 6 - row;}

    if right_dir {return col == band || col == (band + 1);}
    return col == (4 - band) || col == (3 - band);
}

fun drawImpulseGridBackground(font: Font, theme: Theme) >> void {
    i64 left = visibleBaseLeft();
    i64 right = visibleBaseRight();
    i64 top = 0;
    i64 bottom = 920;
    i64 step = SETTINGS_BG_GRID;

    f32 t = GetTime() as f32;
    f32 span_x = (right - left) as f32;
    f32 span_y = (bottom - top) as f32;
    if span_x < (1.0 as f32) {span_x = 1.0 as f32;}
    if span_y < (1.0 as f32) {span_y = 1.0 as f32;}

    f32 cx = ((left + right) as f32) * (0.5 as f32);
    f32 cy = ((top + bottom) as f32) * (0.5 as f32);

    f32 impulse_time = 1.5 as f32;
    f32 pause_time = 1.0 as f32;
    f32 cycle_time = impulse_time + pause_time;
    i32 cycle_idx = (t / cycle_time) as i32;
    f32 cycle_local = t - (cycle_idx as f32) * cycle_time;
    bool in_pause = cycle_local >= impulse_time;
    f32 p = cycle_local / impulse_time;
    p = clamp01(p);
    f32 envelope = (0.34 as f32) + triWave01(p) * (0.66 as f32);

    i32 block_idx = cycle_idx / SETTINGS_BG_PHASES;
    i32 pos_in_block = posMod(cycle_idx, SETTINGS_BG_PHASES);
    i32 step_pick = posMod(hash32(block_idx + 311), 4);
    i32 phase_step = 1;
    if (step_pick == 1) {phase_step = 5;} else if (step_pick == 2) {
        phase_step = 9;
    } else if (step_pick == 3) {
        phase_step = 13;
    }
    i32 shift = posMod(hash32(block_idx + 911), SETTINGS_BG_PHASES);
    i32 phase = posMod(shift + pos_in_block * phase_step, SETTINGS_BG_PHASES);
    i32 color_pick = posMod(hash32(cycle_idx + 97), 7);
    i32 corner_pick = posMod(hash32(cycle_idx + 555), 4);
    i32 block_size = 2;
    if posMod(hash32(cycle_idx + 777), 2) == 1 {block_size = 3;}
    i32 corner_pick2 = posMod(hash32(cycle_idx + 1333), 4);
    i32 lane_span = 3 + posMod(hash32(cycle_idx + 1666), 4);

    i32 text_chars = 6;
    i32 glyph_w = 5;
    i32 glyph_h = 7;
    i32 glyph_gap = 1;
    i32 text_grid_w = text_chars * glyph_w + (text_chars - 1) * glyph_gap;
    i32 text_grid_h = glyph_h;
    f32 text_w_base = (text_grid_w as f32) * (step as f32);
    f32 text_h_base = (text_grid_h as f32) * (step as f32);
    f32 start_x = (left as f32) - text_w_base - (1.0 as f32) * (step as f32);
    f32 end_x = (right as f32) + (1.0 as f32) * (step as f32);
    f32 travel_p = p;
    if travel_p > (1.0 as f32) {travel_p = 1.0 as f32;}
    f32 text_x = start_x + (end_x - start_x) * travel_p;
    f32 text_y = cy - text_h_base * (0.5 as f32);

    f32 lr_pos = (left as f32) - (120.0 as f32) + p * (span_x + (240.0 as f32));
    f32 rl_pos = (right as f32) + (120.0 as f32) - p * (span_x + (240.0 as f32));
    f32 tb_pos = (top as f32) - (120.0 as f32) + p * (span_y + (240.0 as f32));
    f32 bt_pos = (bottom as f32) + (120.0 as f32) - p * (span_y + (240.0 as f32));

    f32 diag_min = ((left + top) as f32) - (140.0 as f32);
    f32 diag_span = span_x + span_y + (280.0 as f32);
    f32 d1_pos = diag_min + p * diag_span;

    f32 anti_min = ((left - bottom) as f32) - (140.0 as f32);
    f32 anti_span = span_x + span_y + (280.0 as f32);
    f32 d2_pos = anti_min + p * anti_span;

    f32 x_radius = p * (maxf(span_x, span_y) * (0.7 as f32) + (160.0 as f32));
    f32 center_travel = p * (span_y * (0.62 as f32) + (180.0 as f32));

    i32 grid_w = ((span_x / (step as f32)) as i32) + 2;
    i32 grid_h = ((span_y / (step as f32)) as i32) + 2;
    i32 center_ix = grid_w / 2;
    i32 center_iy = grid_h / 2;
    i32 max_ring = maxi(center_ix, center_iy) + 3;

    for i64 y = top - step; y < bottom + step; y += step {
        for i64 x = left - step; x < right + step; x += step {
            f32 gx = x as f32;
            f32 gy = y as f32;

            f32 e = 0.0 as f32;
            u32 impulse_color = theme.panel_stroke;
            u32 accent_color = theme.text_main;

            if (color_pick == 0) {
                impulse_color = theme.panel_stroke;
                accent_color = theme.text_main;
            } else if (color_pick == 1) {
                impulse_color = theme.text_muted;
                accent_color = theme.piece_o;
            } else if (color_pick == 2) {
                impulse_color = theme.piece_i;
                accent_color = theme.text_main;
            } else if (color_pick == 3) {
                impulse_color = theme.piece_t;
                accent_color = theme.text_muted;
            } else if (color_pick == 4) {
                impulse_color = theme.piece_o;
                accent_color = theme.piece_s;
            } else if (color_pick == 5) {
                impulse_color = theme.piece_s;
                accent_color = theme.piece_z;
            } else {
                impulse_color = theme.piece_z;
                accent_color = theme.text_main;
            }

            if (!in_pause) {
                if (phase == 0) {e = pulseBand(absf(gx - lr_pos), 54.0 as f32);} else if (phase == 1) {
                    e = pulseBand(absf(gx - rl_pos), 54.0 as f32);
                } else if (phase == 2) {
                    e = pulseBand(absf(gy - tb_pos), 48.0 as f32);
                } else if (phase == 3) {
                    e = pulseBand(absf(gy - bt_pos), 48.0 as f32);
                } else if (phase == 4) {
                    e = pulseBand(absf((gx + gy) - d1_pos), 54.0 as f32);
                } else if (phase == 5) {
                    e = pulseBand(absf((gx - gy) - d2_pos), 54.0 as f32);
                } else if (phase == 6) {
                    f32 arm = x_radius;

                    f32 tip_rx = cx + arm;
                    f32 back_rx = tip_rx - gx;
                    f32 e_right = 0.0 as f32;
                    if (back_rx >= (0.0 as f32)) {
                        f32 d_right = absf(absf(gy - cy) - back_rx);
                        e_right = pulseBand(d_right, 18.0 as f32);
                    }

                    f32 tip_lx = cx - arm;
                    f32 back_lx = gx - tip_lx;
                    f32 e_left = 0.0 as f32;
                    if (back_lx >= (0.0 as f32)) {
                        f32 d_left = absf(absf(gy - cy) - back_lx);
                        e_left = pulseBand(d_left, 18.0 as f32);
                    }

                    f32 tip_ty = cy - arm;
                    f32 back_ty = gy - tip_ty;
                    f32 e_up = 0.0 as f32;
                    if (back_ty >= (0.0 as f32)) {
                        f32 d_up = absf(absf(gx - cx) - back_ty);
                        e_up = pulseBand(d_up, 18.0 as f32);
                    }

                    f32 tip_by = cy + arm;
                    f32 back_by = tip_by - gy;
                    f32 e_down = 0.0 as f32;
                    if (back_by >= (0.0 as f32)) {
                        f32 d_down = absf(absf(gx - cx) - back_by);
                        e_down = pulseBand(d_down, 18.0 as f32);
                    }

                    e = maxf(maxf(e_left, e_right), maxf(e_up, e_down));
                } else {
                    if (phase == 7) {
                        f32 ex = (gx - cx) / (90.0 as f32) + p * (2.2 as f32);
                        f32 w_shape = (triWave01(ex) - (0.5 as f32)) * (78.0 as f32);
                        f32 w_up = cy - center_travel + w_shape;
                        f32 w_dn = cy + center_travel - w_shape;
                        e = maxf(pulseBand(absf(gy - w_up), 20.0 as f32), pulseBand(absf(gy - w_dn), 20.0 as f32));
                    } else if (phase == 8) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 ix = gx_i;
                        i32 iy = gy_i;
                        if (corner_pick == 1) {ix = grid_w - gx_i;} else if (corner_pick == 2) {
                            iy = grid_h - gy_i;
                        } else if (corner_pick == 3) {
                            ix = grid_w - gx_i;
                            iy = grid_h - gy_i;
                        }

                        i32 bx = (gx_i + 4096) / block_size;
                        i32 by = (gy_i + 4096) / block_size;
                        bool checker = posMod(bx + by, 2) == 0;

                        f32 total_d = (grid_w + grid_h) as f32;
                        f32 d = (ix + iy) as f32;
                        f32 fill_front = p * (2.0 as f32) * total_d;
                        if fill_front > total_d {fill_front = total_d;}
                        f32 clear_front = (0.0 as f32);
                        if p > (0.5 as f32) {clear_front = (p - (0.5 as f32)) * (2.0 as f32) * total_d;}

                        if checker && d <= fill_front && d >= clear_front {e = (0.42 as f32) + pulseBand(absf(d - fill_front), 16.0 as f32) * (0.58 as f32);}

                        impulse_color = theme.text_main;
                        accent_color = theme.piece_o;
                    } else if (phase == 9) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 dx_i = absi(gx_i - center_ix);
                        i32 dy_i = absi(gy_i - center_iy);
                        i32 ring = maxi(dx_i, dy_i);
                        f32 ring_wave = p * (max_ring as f32);
                        f32 ring_band = pulseBand(absf((ring as f32) - ring_wave), 2.2 as f32);

                        i32 lane = posMod(gx_i + gy_i + cycle_idx, 3);
                        if (lane == 0) {e = ring_band;} else if (lane == 1) {
                            e = ring_band * (0.74 as f32);
                        } else {
                            e = ring_band * (0.46 as f32);
                        }

                        impulse_color = theme.piece_i;
                        accent_color = theme.piece_z;
                    } else if (phase == 10) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 bx = (gx_i + 4096) / block_size;
                        i32 by = (gy_i + 4096) / block_size;
                        i32 lane = posMod(bx - by + cycle_idx, lane_span);
                        f32 lane_target = p * (lane_span as f32);
                        f32 lane_e = pulseBand(absf((lane as f32) - lane_target), 1.1 as f32);
                        f32 beat = triWave01((bx + by) as f32 * (0.17 as f32) + p * (2.0 as f32));
                        e = lane_e * ((0.35 as f32) + beat * (0.65 as f32));
                        impulse_color = theme.piece_t;
                        accent_color = theme.text_main;
                    } else if (phase == 11) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 dx_i = absi(gx_i - center_ix);
                        i32 gate = posMod(dx_i + cycle_idx, lane_span + 2);
                        f32 gate_target = p * ((lane_span + 2) as f32);
                        f32 gate_e = pulseBand(absf((gate as f32) - gate_target), 1.2 as f32);
                        f32 row_blink = triWave01((gy_i as f32) * (0.15 as f32) + p * (3.0 as f32));
                        e = gate_e * ((0.30 as f32) + row_blink * (0.70 as f32));
                        impulse_color = theme.text_muted;
                        accent_color = theme.piece_o;
                    } else if (phase == 12) {
                        f32 dx = absf(gx - cx);
                        f32 dy = absf(gy - cy);

                        f32 plus_mask = maxf(pulseBand(dx, 24.0 as f32), pulseBand(dy, 24.0 as f32));
                        f32 flash_env = pulseBand(p, 0.24 as f32);
                        f32 plus_flash = plus_mask * ((0.52 as f32) + flash_env * (0.90 as f32));

                        f32 diag_line = pulseBand(absf(dx - dy), 18.0 as f32);
                        f32 diag_dist = (dx + dy) * (0.5 as f32);
                        f32 diag_wave = pulseBand(absf(diag_dist - x_radius), 44.0 as f32);
                        f32 corner_impulse = diag_line * diag_wave;

                        f32 center_burst = pulseBand(dx + dy, 20.0 as f32) * flash_env;
                        e = maxf(maxf(plus_flash, corner_impulse), center_burst);
                        impulse_color = theme.text_main;
                        accent_color = theme.piece_i;
                    } else if (phase == 13) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 ix = gx_i;
                        i32 iy = gy_i;
                        if (corner_pick2 == 1) {ix = grid_w - gx_i;} else if (corner_pick2 == 2) {
                            iy = grid_h - gy_i;
                        } else if (corner_pick2 == 3) {
                            ix = grid_w - gx_i;
                            iy = grid_h - gy_i;
                        }
                        i32 ring = maxi(ix, iy);
                        f32 ring_front = p * (maxi(grid_w, grid_h) as f32);
                        f32 ring_e = pulseBand(absf((ring as f32) - ring_front), 1.8 as f32);
                        i32 hash_gate = posMod(hash32(ix * 73 + iy * 131 + cycle_idx * 17), 5);
                        if (hash_gate == 0 || hash_gate == 2) {e = ring_e;} else {
                            e = ring_e * (0.42 as f32);
                        }
                        impulse_color = theme.piece_s;
                        accent_color = theme.piece_z;
                    } else if (phase == 14) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 r3 = posMod(gx_i + cycle_idx, 3);
                        i32 c3 = posMod(gy_i + cycle_idx, 3);
                        bool cluster = (r3 == 0 && c3 == 0) || (r3 == 1 && c3 == 1) || (r3 == 2 && c3 == 2);
                        f32 travel = p * (span_x + span_y + 260.0 as f32);
                        f32 sweep = pulseBand(absf((gx + gy) - ((left + top) as f32 + travel)), 70.0 as f32);
                        if (cluster) {e = sweep;} else {
                            e = sweep * (0.36 as f32);
                        }
                        impulse_color = theme.piece_o;
                        accent_color = theme.text_main;
                    } else {
                        f32 rx = gx - text_x;
                        f32 ry = gy - text_y;
                        i32 ix = (rx / (step as f32)) as i32;
                        i32 iy = (ry / (step as f32)) as i32;

                        bool inside = rx >= (0.0 as f32) && ry >= (0.0 as f32) && rx < text_w_base && ry < text_h_base;
                        if (inside) {
                            i32 char_span = glyph_w + glyph_gap;
                            i32 letter = ix / char_span;
                            i32 col = ix % char_span;
                            if (letter >= 0 && letter < text_chars && col < glyph_w) {
                                if zltrisGlyphFilled(letter, col, iy) {e = 1.0 as f32;}
                            }
                        }

                        impulse_color = theme.text_main;
                        accent_color = theme.piece_t;
                    }
                }
            }

            f32 idle_breathe = triWave01(t * (0.26 as f32) + ((x + y) as f32) / (430.0 as f32));
            fillRect(x, y, step - 2, step - 2, alphaColor(theme.board_grid, (0.11 as f32) + idle_breathe * (0.04 as f32)));

            if (e > (0.0 as f32)) {
                f32 ea = e * envelope;
                i64 center_x = x + step / 2;
                i64 center_y = y + step / 2;
                f32 glow_r = uiS(step) as f32 * ((0.9 as f32) + ea * (1.2 as f32));

                DrawCircleGradient(
                    uiX(center_x),
                    uiY(center_y),
                    glow_r,
                    toColor(alphaColor(impulse_color, (0.20 as f32) + ea * (0.62 as f32))),
                    toColor(alphaColor(theme.bg_outer, 0.0 as f32))
                );

                DrawCircleGradient(
                    uiX(center_x),
                    uiY(center_y),
                    glow_r * (0.52 as f32),
                    toColor(alphaColor(accent_color, (0.18 as f32) + ea * (0.52 as f32))),
                    toColor(alphaColor(theme.bg_outer, 0.0 as f32))
                );

                fillRect(x + 1, y + 1, step - 4, step - 4, alphaColor(impulse_color, (0.20 as f32) + ea * (0.68 as f32)));
                fillRect(x + 3, y + 3, step - 8, step - 8, alphaColor(accent_color, (0.12 as f32) + ea * (0.40 as f32)));
            }
        }
    }

    font;
}

fun clampf(v: f32, min_v: f32, max_v: f32) >> f32 {
    if v < min_v {return min_v;}
    if v > max_v {return max_v;}
    return v;
}

fun cstrLen(s: ptr<u8>) >> i32 {
    i32 n = 0;
    for (s[n] != 0) {n += 1;}
    return n;
}

fun cstrEq(a: ptr<u8>, b: ptr<u8>) >> bool {
    i32 i = 0;
    for (true) {
        if a[i] != b[i] {return false;}
        if a[i] == 0 {return true;}
        i += 1;
    }
    return true;
}

fun copyFixed(dst: ptr<u8>, src: ptr<u8>, cap: i32) >> void {
    i32 i = 0;
    for (i < cap - 1 && src[i] != 0) {
        dst[i] = src[i];
        i += 1;
    }
    dst[i] = 0;
}

fun endsWithFrag(name: ptr<u8>) >> bool {
    i32 len = cstrLen(name);
    if len < 5 {return false;}
    if name[len - 5] != ('.' as u8) {return false;}
    if name[len - 4] != ('f' as u8) {return false;}
    if name[len - 3] != ('r' as u8) {return false;}
    if name[len - 2] != ('a' as u8) {return false;}
    if name[len - 1] != ('g' as u8) {return false;}
    return true;
}

fun pickerNamePtr(index: i32) >> ptr<u8> {
    if index < 0 || index >= CUSTOM_SHADER_LIST_MAX {return &g_settings.picker_names[0];}
    return &g_settings.picker_names[index * CUSTOM_SHADER_NAME_MAX];
}

fun clearPickerList() >> void {
    g_settings.picker_count = 0;
    g_settings.picker_selected = 0;
    g_settings.picker_scroll = 0.0 as f32;
    for i32 i = 0; i < CUSTOM_SHADER_LIST_MAX * CUSTOM_SHADER_NAME_MAX; i++ {g_settings.picker_names[i] = 0 as u8;}
}

fun addPickerName(name: ptr<u8>) >> void {
    if g_settings.picker_count >= CUSTOM_SHADER_LIST_MAX {return;}
    ptr<u8> dst = pickerNamePtr(g_settings.picker_count);
    copyFixed(dst, name, CUSTOM_SHADER_NAME_MAX);
    g_settings.picker_count += 1;
}

fun openShaderPicker(current_name: ptr<u8>) >> void {
    clearPickerList();

    ptr<void> dir = openDir("assets/shaders");
    if dir != (0 as ptr<void>) {
        for (true) {
            ptr<DirEntry> ent = readDirEntry(dir);
            if ent == (0 as ptr<DirEntry>) {break;}
            ptr<u8> name = &ent.d_name[0];
            if name[0] == ('.' as u8) {continue;}
            if cstrEq(name, "default") {continue;}
            if !endsWithFrag(name) {continue;}
            addPickerName(name);
        }
        closeDir(dir);
    }

    for i32 i = 0; i < g_settings.picker_count; i++ {
        if cstrEq(pickerNamePtr(i), current_name) {
            g_settings.picker_selected = i;
            break;
        }
    }
    g_settings.picker_open = true;
}

fun closeShaderPicker() >> void {
    g_settings.picker_open = false;
}

fun musicModeLabel(mode: i32) >> ptr<u8> {
    if mode == MUSIC_MODE_CUSTOM {return "Custom";}
    return "Builtin";
}

fun openSongPicker() >> void {
    g_settings.song_picker_open = true;
    g_settings.song_picker_scroll = 0.0 as f32;
    g_settings.song_picker_selected = 0;
}

fun closeSongPicker() >> void {
    g_settings.song_picker_open = false;
    buildDisabledBufFromFlags();
}

fun colorRf(color: u32) >> f32 {return (color & 255) as f32 / 255.0 as f32;}
fun colorGf(color: u32) >> f32 {return ((color >> 8) & 255) as f32 / 255.0 as f32;}
fun colorBf(color: u32) >> f32 {return ((color >> 16) & 255) as f32 / 255.0 as f32;}
fun colorAf(color: u32) >> f32 {return ((color >> 24) & 255) as f32 / 255.0 as f32;}

fun sqrtApprox(v: f32) >> f32 {
    if v <= 0.0 as f32 {return 0.0 as f32;}
    f32 x = v;
    if x < 1.0 as f32 {x = 1.0 as f32;}
    for i32 i = 0; i < 6; i++ {
        x = ((x + v / x) * (0.5 as f32));
    }
    return x;
}

fun hsvToColor(h: f32, s: f32, v: f32, a: f32) >> u32 {
    f32 hh = h;
    for (hh < 0.0 as f32) {hh += 360.0 as f32;}
    for (hh >= 360.0 as f32) {hh -= 360.0 as f32;}
    f32 ss = clampf(s, 0.0, 1.0);
    f32 vv = clampf(v, 0.0, 1.0);

    f32 c = vv * ss;
    f32 hp = hh / (60.0 as f32);
    f32 hp_mod2 = hp;
    for (hp_mod2 >= 2.0 as f32) {hp_mod2 -= 2.0 as f32;}
    for (hp_mod2 < 0.0 as f32) {hp_mod2 += 2.0 as f32;}
    f32 x = c * ((1.0 as f32) - absf(hp_mod2 - (1.0 as f32)));

    f32 r1 = 0.0 as f32;
    f32 g1 = 0.0 as f32;
    f32 b1 = 0.0 as f32;
    if hp < (1.0 as f32) {
        r1 = c;
        g1 = x;
    } else if hp < (2.0 as f32) {
        r1 = x;
        g1 = c;
    } else if hp < (3.0 as f32) {
        g1 = c;
        b1 = x;
    } else if hp < (4.0 as f32) {
        g1 = x;
        b1 = c;
    } else if hp < (5.0 as f32) {
        r1 = x;
        b1 = c;
    } else {
        r1 = c;
        b1 = x;
    }

    f32 m = vv - c;
    i32 ri = ((r1 + m) * (255.0 as f32) + (0.5 as f32)) as i32;
    i32 gi = ((g1 + m) * (255.0 as f32) + (0.5 as f32)) as i32;
    i32 bi = ((b1 + m) * (255.0 as f32) + (0.5 as f32)) as i32;
    if ri < 0 {ri = 0;} else if ri > 255 {ri = 255;}
    if gi < 0 {gi = 0;} else if gi > 255 {gi = 255;}
    if bi < 0 {bi = 0;} else if bi > 255 {bi = 255;}

    i32 ai = (clampf(a, 0.0, 1.0) * (255.0 as f32) + (0.5 as f32)) as i32;
    if ai < 0 {ai = 0;} else if ai > 255 {ai = 255;}
    return themeRgba(ri, gi, bi, ai);
}

fun colorToHsv(color: u32, out_h: ptr<f32>, out_s: ptr<f32>, out_v: ptr<f32>) >> void {
    f32 r = colorRf(color);
    f32 g = colorGf(color);
    f32 b = colorBf(color);

    f32 maxc = maxf(r, maxf(g, b));
    f32 minc = minf(r, minf(g, b));
    f32 delta = maxc - minc;

    f32 h = 0.0 as f32;
    if delta > (0.00001 as f32) {
        if maxc >= g && maxc >= b {
            h = ((g - b) / delta) * (60.0 as f32);
        } else if g >= r && g >= b {
            h = (((b - r) / delta) + (2.0 as f32)) * (60.0 as f32);
        } else {
            h = (((r - g) / delta) + (4.0 as f32)) * (60.0 as f32);
        }
    }
    if h < 0.0 as f32 {h += 360.0 as f32;}

    f32 s = 0.0 as f32;
    if maxc > (0.00001 as f32) {s = delta / maxc;}
    out_h[0] = h;
    out_s[0] = clampf(s, 0.0, 1.0);
    out_v[0] = clampf(maxc, 0.0, 1.0);
}

fun themeMgrNameLen() >> i32 {
    i32 len = 0;
    for (len < CUSTOM_THEME_NAME_MAX - 1 && g_settings.theme_mgr_name[len] != 0) {len += 1;}
    return len;
}

fun themeMgrClampNameCursor() >> void {
    i32 len = themeMgrNameLen();
    if g_settings.theme_mgr_name_cursor < 0 {g_settings.theme_mgr_name_cursor = 0;}
    if g_settings.theme_mgr_name_cursor > len {g_settings.theme_mgr_name_cursor = len;}
    if g_settings.theme_mgr_name_cursor > 0 && g_settings.theme_mgr_name_cursor < len {
        for ((g_settings.theme_mgr_name[g_settings.theme_mgr_name_cursor] & 0xC0) == 0x80) {
            g_settings.theme_mgr_name_cursor -= 1;
            if g_settings.theme_mgr_name_cursor <= 0 {break;}
        }
    }
}

fun themeMgrLoadNameBuffer() >> void {
    copyFixed(&g_settings.theme_mgr_name[0], customThemeName(g_settings.theme_mgr_selected), CUSTOM_THEME_NAME_MAX);
    g_settings.theme_mgr_name_cursor = themeMgrNameLen();
}

fun themeMgrCommitNameBuffer() >> void {
    customThemeSetName(g_settings.theme_mgr_selected, &g_settings.theme_mgr_name[0]);
    themeMgrClampNameCursor();
}

fun themeMgrPrevCharStart(index: i32) >> i32 {
    i32 i = index;
    if i <= 0 {return 0;}
    i -= 1;
    for (i > 0 && (g_settings.theme_mgr_name[i] & 0xC0) == 0x80) {i -= 1;}
    return i;
}

fun themeMgrNextCharStart(index: i32) >> i32 {
    i32 len = themeMgrNameLen();
    i32 i = index;
    if i >= len {return len;}
    i += 1;
    for (i < len && (g_settings.theme_mgr_name[i] & 0xC0) == 0x80) {i += 1;}
    return i;
}

fun themeMgrDeleteAtCursor(backspace: bool) >> void {
    i32 len = themeMgrNameLen();
    themeMgrClampNameCursor();

    i32 from = g_settings.theme_mgr_name_cursor;
    i32 to = g_settings.theme_mgr_name_cursor;
    if backspace {
        if from <= 0 {return;}
        from = themeMgrPrevCharStart(from);
    } else {
        if from >= len {return;}
        to = themeMgrNextCharStart(from);
    }

    if backspace {to = g_settings.theme_mgr_name_cursor;}

    i32 shift = to - from;
    if shift <= 0 {return;}

    for i32 i = from; i <= len - shift; i++ {
        g_settings.theme_mgr_name[i] = g_settings.theme_mgr_name[i + shift];
    }
    g_settings.theme_mgr_name_cursor = from;
    themeMgrCommitNameBuffer();
}

fun themeMgrInsertChar(ch: i32) >> void {
    if ch < 32 || ch == 127 {return;}

    arr<u8, 4> bytes = {0};
    i32 n = 0;
    if ch <= 0xFF {
        bytes[0] = ch as u8;
        n = 1;
    } else if ch <= 0x7FF {
        bytes[0] = (0xC0 | ((ch >> 6) & 0x1F)) as u8;
        bytes[1] = (0x80 | (ch & 0x3F)) as u8;
        n = 2;
    } else if ch <= 0xFFFF {
        bytes[0] = (0xE0 | ((ch >> 12) & 0x0F)) as u8;
        bytes[1] = (0x80 | ((ch >> 6) & 0x3F)) as u8;
        bytes[2] = (0x80 | (ch & 0x3F)) as u8;
        n = 3;
    } else if ch <= 0x10FFFF {
        bytes[0] = (0xF0 | ((ch >> 18) & 0x07)) as u8;
        bytes[1] = (0x80 | ((ch >> 12) & 0x3F)) as u8;
        bytes[2] = (0x80 | ((ch >> 6) & 0x3F)) as u8;
        bytes[3] = (0x80 | (ch & 0x3F)) as u8;
        n = 4;
    } else {
        return;
    }

    i32 len = themeMgrNameLen();
    themeMgrClampNameCursor();
    if len + n >= CUSTOM_THEME_NAME_MAX {return;}

    i32 i = len;
    for (i >= g_settings.theme_mgr_name_cursor) {
        g_settings.theme_mgr_name[i + n] = g_settings.theme_mgr_name[i];
        if i == g_settings.theme_mgr_name_cursor {break;}
        i -= 1;
    }

    for i32 b = 0; b < n; b++ {
        g_settings.theme_mgr_name[g_settings.theme_mgr_name_cursor + b] = bytes[b];
    }
    g_settings.theme_mgr_name_cursor += n;
    themeMgrCommitNameBuffer();
}

fun themeMgrCursorOffset(font: Font, size: i64) >> i64 {
    themeMgrClampNameCursor();
    i32 idx = g_settings.theme_mgr_name_cursor;
    u8 saved = g_settings.theme_mgr_name[idx];
    g_settings.theme_mgr_name[idx] = 0;
    i64 w = measureTextWidthBase(font, &g_settings.theme_mgr_name[0], size);
    g_settings.theme_mgr_name[idx] = saved;
    return w;
}

fun themeMgrCursorOffsetAt(font: Font, size: i64, idx: i32) >> i64 {
    i32 len = themeMgrNameLen();
    i32 at = idx;
    if at < 0 {at = 0;}
    if at > len {at = len;}
    u8 saved = g_settings.theme_mgr_name[at];
    g_settings.theme_mgr_name[at] = 0;
    i64 w = measureTextWidthBase(font, &g_settings.theme_mgr_name[0], size);
    g_settings.theme_mgr_name[at] = saved;
    return w;
}

fun themeMgrSetCursorFromMouse(font: Font, size: i64, text_x: i64, mouse_x: f32) >> void {
    i32 len = themeMgrNameLen();
    i32 best_idx = 0;
    f32 best_dist = absf(mouse_x - (uiX(text_x) as f32));

    i32 idx = 0;
    for (idx <= len) {
        i64 w = themeMgrCursorOffsetAt(font, size, idx);
        f32 px = uiX(text_x + w) as f32;
        f32 d = absf(mouse_x - px);
        if d < best_dist {
            best_dist = d;
            best_idx = idx;
        }
        if idx >= len {break;}
        idx = themeMgrNextCharStart(idx);
        if idx <= 0 {idx = len;}
    }

    g_settings.theme_mgr_name_cursor = best_idx;
    themeMgrClampNameCursor();
}

fun themeMgrSyncWheelFromThemeColor() >> void {
    i32 field = g_settings.theme_mgr_field;
    if field < 0 {field = 0;}
    if field >= customThemeFieldCount() {field = customThemeFieldCount() - 1;}
    g_settings.theme_mgr_field = field;

    u32 color = customThemeGetColor(g_settings.theme_mgr_selected, field);
    colorToHsv(color, &g_settings.theme_mgr_hue, &g_settings.theme_mgr_saturation, &g_settings.theme_mgr_brightness);
}

fun themeMgrApplyWheelColor() >> void {
    u32 old = customThemeGetColor(g_settings.theme_mgr_selected, g_settings.theme_mgr_field);
    u32 c = hsvToColor(g_settings.theme_mgr_hue, g_settings.theme_mgr_saturation, g_settings.theme_mgr_brightness, colorAf(old));
    customThemeSetColor(g_settings.theme_mgr_selected, g_settings.theme_mgr_field, c);
}

fun themeMgrSelectTheme(index: i32) >> void {
    customThemeSetSelected(index);
    g_settings.theme_mgr_selected = customThemeSelected();
    themeMgrLoadNameBuffer();
    themeMgrSyncWheelFromThemeColor();
}

fun openThemeManager(theme_index: ptr<i32>) >> void {
    theme_index[0] = themeCustomSlotIndex();
    g_settings.theme_custom_active = true;
    g_settings.theme_mgr_open = true;
    g_settings.theme_mgr_focus = THEME_MGR_FOCUS_LIST;
    g_settings.theme_mgr_scroll = 0.0 as f32;
    g_settings.theme_mgr_field = 0;
    g_settings.theme_mgr_button = THEME_MGR_BUTTON_NEW;
    g_settings.theme_mgr_name_edit = false;
    g_settings.theme_mgr_selected = customThemeSelected();
    themeMgrLoadNameBuffer();
    themeMgrSyncWheelFromThemeColor();
}

fun closeThemeManager() >> void {
    g_settings.theme_mgr_open = false;
    g_settings.theme_mgr_name_edit = false;
}

fun themeMgrFocusNext() >> void {
    g_settings.theme_mgr_focus += 1;
    if g_settings.theme_mgr_focus > THEME_MGR_FOCUS_BUTTONS {g_settings.theme_mgr_focus = THEME_MGR_FOCUS_LIST;}
}

fun visibleBaseTop() >> i64 {
    f32 scale = uiScale();
    i32 oy = uiOffsetY(scale);
    return (((0 - oy) as f32) / scale) as i64;
}

fun visibleBaseBottom() >> i64 {
    f32 scale = uiScale();
    i32 oy = uiOffsetY(scale);
    return (((GetScreenHeight() - oy) as f32) / scale) as i64;
}

fun themeManagerLayout(out_left_x: ptr<i64>, out_left_y: ptr<i64>, out_left_w: ptr<i64>, out_left_h: ptr<i64>, out_right_x: ptr<i64>, out_right_y: ptr<i64>, out_right_w: ptr<i64>, out_right_h: ptr<i64>) >> void {
    i64 left_w = 472;
    i64 left_h = 700;
    i64 right_w = 548;
    i64 right_h = 860;

    i64 vis_left = visibleBaseLeft();
    i64 vis_right = visibleBaseRight();
    i64 vis_top = visibleBaseTop();
    i64 vis_bottom = visibleBaseBottom();
    i64 avail_w = vis_right - vis_left;
    i64 avail_h = vis_bottom - vis_top;

    i64 min_gap = 18;
    i64 max_gap = 96;
    i64 gap = min_gap;
    i64 base_total = left_w + right_w + min_gap;
    if avail_w > base_total {
        gap += (avail_w - base_total) / 4;
        if gap > max_gap {gap = max_gap;}
    }

    i64 group_w = left_w + right_w + gap;
    i64 group_h = left_h;
    if right_h > group_h {group_h = right_h;}

    i64 group_x = vis_left + (avail_w - group_w) / 2;
    i64 group_y = vis_top + (avail_h - group_h) / 2;

    out_left_x[0] = group_x;
    out_left_y[0] = group_y + (group_h - left_h) / 2;
    out_left_w[0] = left_w;
    out_left_h[0] = left_h;

    out_right_x[0] = out_left_x[0] + left_w + gap;
    out_right_y[0] = group_y + (group_h - right_h) / 2;
    out_right_w[0] = right_w;
    out_right_h[0] = right_h;
}

fun themeManagerPanelRect(out_x: ptr<i64>, out_y: ptr<i64>, out_w: ptr<i64>, out_h: ptr<i64>) >> void {
    i64 right_x = 0;
    i64 right_y = 0;
    i64 right_w = 0;
    i64 right_h = 0;
    themeManagerLayout(out_x, out_y, out_w, out_h, &right_x, &right_y, &right_w, &right_h);
}

fun themeManagerPreviewRect(out_x: ptr<i64>, out_y: ptr<i64>, out_w: ptr<i64>, out_h: ptr<i64>) >> void {
    i64 left_x = 0;
    i64 left_y = 0;
    i64 left_w = 0;
    i64 left_h = 0;
    themeManagerLayout(&left_x, &left_y, &left_w, &left_h, out_x, out_y, out_w, out_h);
}

fun themeMgrListVisible() >> i32 {return 6;}

fun themeMgrSyncListScroll() >> void {
    i32 count = customThemeCount();
    i32 visible = themeMgrListVisible();
    i32 max_scroll = count - visible;
    if max_scroll < 0 {max_scroll = 0;}
    if g_settings.theme_mgr_selected < (g_settings.theme_mgr_scroll as i32) {g_settings.theme_mgr_scroll = g_settings.theme_mgr_selected as f32;}
    if g_settings.theme_mgr_selected >= (g_settings.theme_mgr_scroll as i32) + visible {g_settings.theme_mgr_scroll = (g_settings.theme_mgr_selected - visible + 1) as f32;}
    if g_settings.theme_mgr_scroll < 0.0 as f32 {g_settings.theme_mgr_scroll = 0.0 as f32;}
    if g_settings.theme_mgr_scroll > max_scroll as f32 {g_settings.theme_mgr_scroll = max_scroll as f32;}
}

fun themeMgrWheelHit(mouse: Vector2, cx: i64, cy: i64, radius: i64) >> bool {
    if !pointInBaseRect(mouse.x, mouse.y, cx - radius, cy - radius, radius * 2, radius * 2) {return false;}
    f32 dx = (mouse.x - uiX(cx) as f32) / (uiS(radius) as f32);
    f32 dy = (mouse.y - uiY(cy) as f32) / (uiS(radius) as f32);
    f32 r = sqrtApprox(dx * dx + dy * dy);
    return r <= (1.0 as f32);
}

fun themeMgrWheelSetFromMouse(mouse: Vector2, cx: i64, cy: i64, radius: i64) >> void {
    f32 dx = (mouse.x - uiX(cx) as f32) / (uiS(radius) as f32);
    f32 dy = (mouse.y - uiY(cy) as f32) / (uiS(radius) as f32);
    f32 rr = dx * dx + dy * dy;
    if rr <= (0.000001 as f32) {
        g_settings.theme_mgr_saturation = 0.0 as f32;
        themeMgrApplyWheelColor();
        return;
    }

    f32 r = sqrtApprox(rr);
    if r > (1.0 as f32) {
        dx = dx / r;
        dy = dy / r;
        r = 1.0 as f32;
    }

    f64 ang = atan2((-dy) as f64, dx as f64);
    f32 hue = (ang as f32) * (57.2957795 as f32);
    if hue < 0.0 as f32 {hue += 360.0 as f32;}
    g_settings.theme_mgr_hue = hue;
    g_settings.theme_mgr_saturation = clampf(r, 0.0, 1.0);
    themeMgrApplyWheelColor();
}

fun themeMgrHandleNameEdit() >> void {
    themeMgrClampNameCursor();

    if IsKeyPressed(KEY_LEFT) || IsKeyPressedRepeat(KEY_LEFT) {
        g_settings.theme_mgr_name_cursor = themeMgrPrevCharStart(g_settings.theme_mgr_name_cursor);
        themeMgrClampNameCursor();
    }
    if IsKeyPressed(KEY_RIGHT) || IsKeyPressedRepeat(KEY_RIGHT) {
        g_settings.theme_mgr_name_cursor = themeMgrNextCharStart(g_settings.theme_mgr_name_cursor);
        themeMgrClampNameCursor();
    }

    if IsKeyPressed(KEY_BACKSPACE) {themeMgrDeleteAtCursor(true);}
    if IsKeyPressed(KEY_DELETE) {themeMgrDeleteAtCursor(false);}

    for (true) {
        i32 ch = GetCharPressed();
        if ch == 0 {break;}
        themeMgrInsertChar(ch);
    }

    if IsKeyPressed(KEY_ENTER) || IsKeyPressed(KEY_ESCAPE) {
        g_settings.theme_mgr_name_edit = false;
        themeMgrCommitNameBuffer();
    }
}

fun drawThemeManager(font: Font, theme: Theme) >> void {
    i64 panel_x = 0;
    i64 panel_y = 0;
    i64 panel_w = 0;
    i64 panel_h = 0;
    themeManagerPanelRect(&panel_x, &panel_y, &panel_w, &panel_h);

    fillRect(panel_x, panel_y, panel_w, panel_h, alphaColor(theme.panel_bg, 0.96 as f32));
    strokeRect(panel_x, panel_y, panel_w, panel_h, alphaColor(theme.panel_stroke, 0.90 as f32));

    drawTextColor(font, "MANAGE CUSTOM THEMES", panel_x + 24, panel_y + 24, 17, theme.text_main);
    drawTextColor(font, "TAB focus, ENTER action, ESC close", panel_x + 24, panel_y + 48, 11, alphaColor(theme.text_muted, 0.84 as f32));
    drawTextColor(font, "Live game preview is on the right", panel_x + 24, panel_y + 64, 11, alphaColor(theme.text_muted, 0.72 as f32));

    i64 list_x = panel_x + 24;
    i64 list_y = panel_y + 82;
    i64 list_w = 188;
    i64 row_h = 54;
    i64 list_h = row_h * (themeMgrListVisible() as i64);

    fillRect(list_x, list_y, list_w, list_h, alphaColor(theme.board_bg, 0.75 as f32));
    strokeRect(list_x, list_y, list_w, list_h, alphaColor(theme.text_muted, 0.48 as f32));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_LIST {strokeRect(list_x - 2, list_y - 2, list_w + 4, list_h + 4, alphaColor(theme.panel_stroke, 0.86 as f32));}

    i32 count = customThemeCount();
    themeMgrSyncListScroll();
    if count == 0 {
        drawTextColor(font, "No custom themes yet", list_x + 16, list_y + 20, 11, alphaColor(theme.text_muted, 0.84 as f32));
        drawTextColor(font, "Press NEW", list_x + 16, list_y + 40, 11, alphaColor(theme.text_muted, 0.84 as f32));
    }
    for i32 i = 0; i < count; i++ {
        i64 y = list_y + ((i as f32 - g_settings.theme_mgr_scroll) * (row_h as f32)) as i64;
        if y < list_y || y + row_h > list_y + list_h {continue;}
        bool sel = i == g_settings.theme_mgr_selected;
        if sel {
            fillRect(list_x + 6, y + 5, list_w - 12, row_h - 10, alphaColor(theme.panel_stroke, 0.22 as f32));
            strokeRect(list_x + 6, y + 5, list_w - 12, row_h - 10, alphaColor(theme.panel_stroke, 0.78 as f32));
        }
        drawTextColor(font, customThemeName(i), list_x + 14, y + 18, 12, alphaColor(theme.text_main, 0.96 as f32));
    }

    i64 right_x = panel_x + 226;
    i64 right_w = panel_w - (right_x - panel_x) - 24;

    i64 name_y = panel_y + 86;
    fillRect(right_x, name_y, right_w, 54, alphaColor(theme.board_bg, 0.74 as f32));
    strokeRect(right_x, name_y, right_w, 54, alphaColor(theme.text_muted, 0.52 as f32));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_NAME {strokeRect(right_x - 2, name_y - 2, right_w + 4, 58, alphaColor(theme.panel_stroke, 0.86 as f32));}
    drawTextColor(font, "Name", right_x + 12, name_y + 8, 11, alphaColor(theme.text_muted, 0.80 as f32));
    drawTextColor(font, &g_settings.theme_mgr_name[0], right_x + 12, name_y + 28, 13, theme.text_main);
    if g_settings.theme_mgr_name_edit {
        i64 cursor_x = right_x + 12 + themeMgrCursorOffset(font, 13) + 4;
        fillRect(cursor_x, name_y + 28, 2, 16, alphaColor(theme.panel_stroke, 0.92 as f32));
    }

    i64 field_y = panel_y + 150;
    fillRect(right_x, field_y, right_w, 54, alphaColor(theme.board_bg, 0.74 as f32));
    strokeRect(right_x, field_y, right_w, 54, alphaColor(theme.text_muted, 0.52 as f32));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_FIELD {strokeRect(right_x - 2, field_y - 2, right_w + 4, 58, alphaColor(theme.panel_stroke, 0.86 as f32));}
    drawTextColor(font, "<", right_x + 10, field_y + 20, 15, theme.text_main);
    drawTextColor(font, customThemeFieldName(g_settings.theme_mgr_field), right_x + 28, field_y + 20, 12, theme.text_main);
    drawTextColor(font, ">", right_x + right_w - 20, field_y + 20, 15, theme.text_main);

    i64 wheel_cx = right_x + right_w / 2;
    i64 wheel_cy = panel_y + 372;
    i64 wheel_r = 114;

    i32 center_px_x = uiX(wheel_cx);
    i32 center_px_y = uiY(wheel_cy);
    i32 radius_px = uiS(wheel_r);
    for i32 py = -radius_px; py <= radius_px; py++ {
        for i32 px = -radius_px; px <= radius_px; px++ {
            f32 nx = (px as f32) / (radius_px as f32);
            f32 ny = (py as f32) / (radius_px as f32);
            f32 rr = nx * nx + ny * ny;
            if rr > 1.0 as f32 {continue;}

            f32 sat = clampf(sqrtApprox(rr), 0.0, 1.0);
            f64 ang2 = atan2((-ny) as f64, nx as f64);
            f32 hue2 = (ang2 as f32) * (57.2957795 as f32);
            if hue2 < 0.0 as f32 {hue2 += 360.0 as f32;}
            DrawPixel(center_px_x + px, center_px_y + py, toColor(hsvToColor(hue2, sat, g_settings.theme_mgr_brightness, 1.0 as f32)));
        }
    }
    DrawCircleLines(uiX(wheel_cx), uiY(wheel_cy), uiS(wheel_r) as f32, toColor(alphaColor(theme.text_main, 0.82 as f32)));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_WHEEL {
        DrawCircleLines(uiX(wheel_cx), uiY(wheel_cy), uiS(wheel_r + 3) as f32, toColor(alphaColor(theme.panel_stroke, 0.84 as f32)));
    }

    f64 ang = (g_settings.theme_mgr_hue as f64) * (3.14159265 as f64) / (180.0 as f64);
    f32 ux = cos(ang) as f32;
    f32 uy = -(sin(ang) as f32);
    i64 px = wheel_cx + (ux * (wheel_r as f32) * g_settings.theme_mgr_saturation) as i64;
    i64 py = wheel_cy + (uy * (wheel_r as f32) * g_settings.theme_mgr_saturation) as i64;
    DrawCircle(uiX(px), uiY(py), uiS(6) as f32, toColor(alphaColor(theme.text_main, 0.95 as f32)));
    DrawCircleLines(uiX(px), uiY(py), uiS(8) as f32, toColor(alphaColor(theme.bg_outer, 0.92 as f32)));

    i64 br_x = right_x;
    i64 br_y = panel_y + 506;
    i64 br_w = right_w;
    i64 br_h = 22;
    for i32 i = 0; i < br_w; i += 6 {
        f32 t = (i as f32) / (br_w as f32);
        u32 c = hsvToColor(g_settings.theme_mgr_hue, g_settings.theme_mgr_saturation, t, 1.0 as f32);
        fillRect(br_x + i, br_y, 6, br_h, c);
    }
    strokeRect(br_x, br_y, br_w, br_h, alphaColor(theme.text_muted, 0.76 as f32));
    i64 knob_x = br_x + (g_settings.theme_mgr_brightness * (br_w as f32)) as i64;
    fillRect(knob_x - 2, br_y - 3, 4, br_h + 6, alphaColor(theme.text_main, 0.96 as f32));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BRIGHTNESS {strokeRect(br_x - 2, br_y - 2, br_w + 4, br_h + 4, alphaColor(theme.panel_stroke, 0.84 as f32));}

    u32 preview = customThemeGetColor(g_settings.theme_mgr_selected, g_settings.theme_mgr_field);
    fillRect(right_x, panel_y + 538, right_w, 56, alphaColor(theme.board_bg, 0.74 as f32));
    strokeRect(right_x, panel_y + 538, right_w, 56, alphaColor(theme.text_muted, 0.52 as f32));
    fillRect(right_x + 12, panel_y + 550, 34, 32, preview);
    strokeRect(right_x + 12, panel_y + 550, 34, 32, alphaColor(theme.text_main, 0.60 as f32));
    drawTextColor(font, TextFormat("0x%08X", preview), right_x + 56, panel_y + 560, 12, theme.text_main);

    i64 btn_y = panel_y + 620;
    i64 btn_w = 140;
    i64 btn_h = 52;
    arr<ptr<u8>, 3> labels = {"NEW", "DELETE", "CLOSE"};
    for i32 b = 0; b < 3; b++ {
        i64 bx = panel_x + 24 + (b as i64) * (btn_w + 12);
        fillRect(bx, btn_y, btn_w, btn_h, alphaColor(theme.board_bg, 0.78 as f32));
        u32 st = alphaColor(theme.text_muted, 0.54 as f32);
        if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BUTTONS && g_settings.theme_mgr_button == b {st = alphaColor(theme.panel_stroke, 0.90 as f32);}
        strokeRect(bx, btn_y, btn_w, btn_h, st);
        drawTextCenteredInRect(font, labels[b], bx, btn_y + 2, btn_w, btn_h - 4, 13, alphaColor(theme.text_main, 0.96 as f32));
    }
}

fun updateThemeManager(theme_index: ptr<i32>) >> bool {
    if !g_settings.theme_mgr_open {return false;}

    theme_index[0] = themeCustomSlotIndex();
    g_settings.theme_custom_active = true;

    i32 count = customThemeCount();
    if count <= 0 {
        g_settings.theme_mgr_selected = 0;
        g_settings.theme_mgr_name[0] = 0;
        g_settings.theme_mgr_name_cursor = 0;
        g_settings.theme_mgr_name_edit = false;
    } else {
        if g_settings.theme_mgr_selected < 0 {g_settings.theme_mgr_selected = 0;}
        if g_settings.theme_mgr_selected >= count {g_settings.theme_mgr_selected = count - 1;}
    }
    customThemeSetSelected(g_settings.theme_mgr_selected);
    g_settings.theme_mgr_selected = customThemeSelected();
    themeMgrSyncListScroll();

    Vector2 mouse = GetMousePosition();
    i64 panel_x = 0;
    i64 panel_y = 0;
    i64 panel_w_tmp = 0;
    i64 panel_h_tmp = 0;
    themeManagerPanelRect(&panel_x, &panel_y, &panel_w_tmp, &panel_h_tmp);
    i64 list_x = panel_x + 24;
    i64 list_y = panel_y + 82;
    i64 list_w = 188;
    i64 list_row_h = 54;
    i64 list_h = list_row_h * (themeMgrListVisible() as i64);

    i64 right_x = panel_x + 226;
    i64 right_w = panel_w_tmp - (right_x - panel_x) - 24;
    i64 name_y = panel_y + 86;
    i64 field_y = panel_y + 150;
    i64 wheel_cx = right_x + right_w / 2;
    i64 wheel_cy = panel_y + 372;
    i64 wheel_r = 114;
    i64 br_x = right_x;
    i64 br_y = panel_y + 506;
    i64 br_w = right_w;
    i64 br_h = 22;
    i64 btn_y = panel_y + 620;
    i64 btn_w = 140;
    i64 btn_h = 52;

    if IsKeyPressed(KEY_ESCAPE) {
        if g_settings.theme_mgr_name_edit {
            g_settings.theme_mgr_name_edit = false;
            themeMgrLoadNameBuffer();
        } else {
            closeThemeManager();
        }
        return true;
    }

    if g_settings.theme_mgr_name_edit {
        themeMgrHandleNameEdit();
        return true;
    }

    if IsKeyPressed(KEY_TAB) {
        themeMgrFocusNext();
        g_settings.keyboard_nav_lock = true;
    }

    if IsKeyPressed(KEY_N) {
        Theme base = setTheme(theme_index[0]);
        i32 next = customThemeCreateFromTheme(base);
        themeMgrSelectTheme(next);
        count = customThemeCount();
    }
    if count > 0 && IsKeyPressed(KEY_DELETE) {
        customThemeDelete(g_settings.theme_mgr_selected);
        themeMgrSelectTheme(customThemeSelected());
        count = customThemeCount();
    }

    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_LIST {
        if IsKeyPressed(KEY_UP) {themeMgrSelectTheme(g_settings.theme_mgr_selected - 1);}
        if IsKeyPressed(KEY_DOWN) {themeMgrSelectTheme(g_settings.theme_mgr_selected + 1);}
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_FIELD {
        if IsKeyPressed(KEY_LEFT) {
            g_settings.theme_mgr_field -= 1;
            if g_settings.theme_mgr_field < 0 {g_settings.theme_mgr_field = customThemeFieldCount() - 1;}
            themeMgrSyncWheelFromThemeColor();
        }
        if IsKeyPressed(KEY_RIGHT) {
            g_settings.theme_mgr_field += 1;
            if g_settings.theme_mgr_field >= customThemeFieldCount() {g_settings.theme_mgr_field = 0;}
            themeMgrSyncWheelFromThemeColor();
        }
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_WHEEL {
        if IsKeyPressed(KEY_LEFT) || IsKeyPressedRepeat(KEY_LEFT) {
            g_settings.theme_mgr_hue -= 2.0 as f32;
            themeMgrApplyWheelColor();
        }
        if IsKeyPressed(KEY_RIGHT) || IsKeyPressedRepeat(KEY_RIGHT) {
            g_settings.theme_mgr_hue += 2.0 as f32;
            themeMgrApplyWheelColor();
        }
        if IsKeyPressed(KEY_UP) || IsKeyPressedRepeat(KEY_UP) {
            g_settings.theme_mgr_saturation += 0.02 as f32;
            if g_settings.theme_mgr_saturation > 1.0 as f32 {g_settings.theme_mgr_saturation = 1.0 as f32;}
            themeMgrApplyWheelColor();
        }
        if IsKeyPressed(KEY_DOWN) || IsKeyPressedRepeat(KEY_DOWN) {
            g_settings.theme_mgr_saturation -= 0.02 as f32;
            if g_settings.theme_mgr_saturation < 0.0 as f32 {g_settings.theme_mgr_saturation = 0.0 as f32;}
            themeMgrApplyWheelColor();
        }
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BRIGHTNESS {
        if IsKeyPressed(KEY_LEFT) || IsKeyPressedRepeat(KEY_LEFT) {
            g_settings.theme_mgr_brightness -= 0.02 as f32;
            if g_settings.theme_mgr_brightness < 0.0 as f32 {g_settings.theme_mgr_brightness = 0.0 as f32;}
            themeMgrApplyWheelColor();
        }
        if IsKeyPressed(KEY_RIGHT) || IsKeyPressedRepeat(KEY_RIGHT) {
            g_settings.theme_mgr_brightness += 0.02 as f32;
            if g_settings.theme_mgr_brightness > 1.0 as f32 {g_settings.theme_mgr_brightness = 1.0 as f32;}
            themeMgrApplyWheelColor();
        }
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BUTTONS {
        if IsKeyPressed(KEY_LEFT) {
            g_settings.theme_mgr_button -= 1;
            if g_settings.theme_mgr_button < THEME_MGR_BUTTON_NEW {g_settings.theme_mgr_button = THEME_MGR_BUTTON_CLOSE;}
        }
        if IsKeyPressed(KEY_RIGHT) {
            g_settings.theme_mgr_button += 1;
            if g_settings.theme_mgr_button > THEME_MGR_BUTTON_CLOSE {g_settings.theme_mgr_button = THEME_MGR_BUTTON_NEW;}
        }
    }

    bool do_enter = IsKeyPressed(KEY_ENTER);
    if do_enter {
        if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_NAME && count > 0 {
            g_settings.theme_mgr_name_edit = true;
            g_settings.theme_mgr_name_cursor = themeMgrNameLen();
        } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BUTTONS {
            if g_settings.theme_mgr_button == THEME_MGR_BUTTON_NEW {
                Theme base = setTheme(theme_index[0]);
                i32 next = customThemeCreateFromTheme(base);
                themeMgrSelectTheme(next);
                count = customThemeCount();
            } else if g_settings.theme_mgr_button == THEME_MGR_BUTTON_DELETE {
                if count > 0 {
                    customThemeDelete(g_settings.theme_mgr_selected);
                    themeMgrSelectTheme(customThemeSelected());
                    count = customThemeCount();
                }
            } else {
                closeThemeManager();
            }
        }
    }

    f32 wheel = GetMouseWheelMove();
    if pointInBaseRect(mouse.x, mouse.y, list_x, list_y, list_w, list_h) {
        if wheel > 0.0 as f32 {g_settings.theme_mgr_scroll -= 1.0 as f32;}
        if wheel < 0.0 as f32 {g_settings.theme_mgr_scroll += 1.0 as f32;}
        themeMgrSyncListScroll();
    }

    if IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {
        g_settings.keyboard_nav_lock = false;

        if pointInBaseRect(mouse.x, mouse.y, list_x, list_y, list_w, list_h) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_LIST;
            i32 idx = (((mouse.y - uiY(list_y) as f32) / (uiS(list_row_h) as f32)) + g_settings.theme_mgr_scroll) as i32;
            if idx >= 0 && idx < customThemeCount() {themeMgrSelectTheme(idx);}
        } else if pointInBaseRect(mouse.x, mouse.y, right_x, name_y, right_w, 54) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_NAME;
            if count > 0 {
                g_settings.theme_mgr_name_edit = true;
                g_settings.theme_mgr_name_cursor = themeMgrNameLen();
            }
        } else if pointInBaseRect(mouse.x, mouse.y, right_x, field_y, right_w, 54) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_FIELD;
            if mouse.x < uiX(right_x + right_w / 2) as f32 {
                g_settings.theme_mgr_field -= 1;
                if g_settings.theme_mgr_field < 0 {g_settings.theme_mgr_field = customThemeFieldCount() - 1;}
            } else {
                g_settings.theme_mgr_field += 1;
                if g_settings.theme_mgr_field >= customThemeFieldCount() {g_settings.theme_mgr_field = 0;}
            }
            themeMgrSyncWheelFromThemeColor();
        } else if themeMgrWheelHit(mouse, wheel_cx, wheel_cy, wheel_r) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_WHEEL;
            themeMgrWheelSetFromMouse(mouse, wheel_cx, wheel_cy, wheel_r);
        } else if pointInBaseRect(mouse.x, mouse.y, br_x, br_y, br_w, br_h) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_BRIGHTNESS;
            g_settings.theme_mgr_brightness = clampf((mouse.x - uiX(br_x) as f32) / (uiS(br_w) as f32), 0.0, 1.0);
            themeMgrApplyWheelColor();
        } else {
            for i32 b = 0; b < 3; b++ {
                i64 bx = panel_x + 24 + (b as i64) * (btn_w + 12);
                if pointInBaseRect(mouse.x, mouse.y, bx, btn_y, btn_w, btn_h) {
                    g_settings.theme_mgr_focus = THEME_MGR_FOCUS_BUTTONS;
                    g_settings.theme_mgr_button = b;
                    if b == THEME_MGR_BUTTON_NEW {
                        Theme base = setTheme(theme_index[0]);
                        i32 next = customThemeCreateFromTheme(base);
                        themeMgrSelectTheme(next);
                        count = customThemeCount();
                    } else if b == THEME_MGR_BUTTON_DELETE {
                        if count > 0 {
                            customThemeDelete(g_settings.theme_mgr_selected);
                            themeMgrSelectTheme(customThemeSelected());
                            count = customThemeCount();
                        }
                    } else {
                        closeThemeManager();
                    }
                    break;
                }
            }
        }
    }

    if IsMouseButtonDown(MOUSE_BUTTON_LEFT) {
        if themeMgrWheelHit(mouse, wheel_cx, wheel_cy, wheel_r) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_WHEEL;
            themeMgrWheelSetFromMouse(mouse, wheel_cx, wheel_cy, wheel_r);
        }
        if pointInBaseRect(mouse.x, mouse.y, br_x, br_y, br_w, br_h) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_BRIGHTNESS;
            g_settings.theme_mgr_brightness = clampf((mouse.x - uiX(br_x) as f32) / (uiS(br_w) as f32), 0.0, 1.0);
            themeMgrApplyWheelColor();
        }
    }

    return true;
}

fun settingsThemeManagerOpen() >> bool {
    return g_settings.theme_mgr_open;
}

fun drawThemeManagerStandalone(font: Font, theme: Theme) >> void {
    drawThemeManager(font, theme);
}

fun sectionAnimForRow(row: i32) >> f32 {
    if row >= SETTINGS_ROW_ARR && row <= SETTINGS_ROW_INSTANT_RESTART {return g_settings.controls_anim;}
    if row >= SETTINGS_ROW_THEME && row <= SETTINGS_ROW_FULLSCREEN_MODE {return g_settings.video_anim;}
    if row >= SETTINGS_ROW_MUSIC_VOLUME && row <= SETTINGS_ROW_MUSIC_SHUFFLE {return g_settings.audio_anim;}
    return 1.0 as f32;
}

fun rowIsSectionHeader(row: i32) >> bool {
    return row == SETTINGS_ROW_SECTION_CONTROLS || row == SETTINGS_ROW_SECTION_VIDEO || row == SETTINGS_ROW_SECTION_AUDIO;
}

fun rowVisible(row: i32, bg_stars_mode: i32, shader_mode: i32) >> bool {
    if row == SETTINGS_ROW_BACK {return true;}
    if row == SETTINGS_ROW_SECTION_CONTROLS || row == SETTINGS_ROW_SECTION_VIDEO || row == SETTINGS_ROW_SECTION_AUDIO {return true;}

    if row >= SETTINGS_ROW_ARR && row <= SETTINGS_ROW_INSTANT_RESTART {return g_settings.controls_expanded;}

    if row >= SETTINGS_ROW_THEME && row <= SETTINGS_ROW_FULLSCREEN_MODE {
        if !g_settings.video_expanded {return false;}
        if row == SETTINGS_ROW_MANAGE_THEMES {return g_settings.theme_custom_active;}
        if row == SETTINGS_ROW_CRT_CURVATURE || row == SETTINGS_ROW_CRT_BRIGHTNESS {return shader_mode == SHADER_MODE_CRT;}
        if row == SETTINGS_ROW_VHS_WAVES || row == SETTINGS_ROW_VHS_DAMAGE {return shader_mode == SHADER_MODE_VHS;}
        if row == SETTINGS_ROW_CHOOSE_SHADER {return shader_mode == SHADER_MODE_CUSTOM;}
        if row == SETTINGS_ROW_STAR_PEAK_TARGET || row == SETTINGS_ROW_STAR_INTENSITY {return bg_stars_mode == STAR_MODE_DROPS;}
        if row == SETTINGS_ROW_MUSIC_STYLE || row == SETTINGS_ROW_MUSIC_INTENSITY {return bg_stars_mode == STAR_MODE_MUSIC;}
        return true;
    }

    if row >= SETTINGS_ROW_MUSIC_VOLUME && row <= SETTINGS_ROW_MUSIC_SHUFFLE {
        if !g_settings.audio_expanded {return false;}
        if row == SETTINGS_ROW_SELECT_SONGS {return g_music_mode == MUSIC_MODE_CUSTOM;}
        return true;
    }

    return false;
}

fun visibleRowCount(bg_stars_mode: i32, shader_mode: i32) >> i32 {
    i32 count = 0;
    for i32 row = 0; row < SETTINGS_ROW_COUNT; row++ {
        if rowVisible(row, bg_stars_mode, shader_mode) {count += 1;}
    }
    return count;
}

fun rowOrder(row: i32, bg_stars_mode: i32, shader_mode: i32) >> i32 {
    if !rowVisible(row, bg_stars_mode, shader_mode) {return -1;}
    i32 order = 0;
    for i32 it = 0; it < row; it++ {
        if rowVisible(it, bg_stars_mode, shader_mode) {order += 1;}
    }
    return order;
}

fun rowFromOrder(order: i32, bg_stars_mode: i32, shader_mode: i32) >> i32 {
    i32 seen = 0;
    for i32 row = 0; row < SETTINGS_ROW_COUNT; row++ {
        if !rowVisible(row, bg_stars_mode, shader_mode) {continue;}
        if seen == order {return row;}
        seen += 1;
    }
    return SETTINGS_ROW_BACK;
}

fun itemYDraw(row: i32, bg_stars_mode: i32, shader_mode: i32) >> i64 {
    i32 order = rowOrder(row, bg_stars_mode, shader_mode);
    if order < 0 {return -10000;}
    return 246 + (order as i64) * 78 - (g_settings.scroll * 78.0 as f32) as i64;
}

fun rowSelected(row: i32) >> bool {
    return g_settings.selected_row == row;
}

fun drawSelectionGlow(theme: Theme, y: i64, alpha: f32) >> void {
    fillRect(114, y - 4, 420, 70, alphaColor(theme.panel_stroke, (0.10 as f32) + alpha * (0.14 as f32)));
    strokeRect(115, y - 3, 418, 68, alphaColor(theme.panel_stroke, (0.46 as f32) + alpha * (0.40 as f32)));
}

fun bgStarsModeLabel(mode: i32) >> ptr<u8> {
    if mode == STAR_MODE_DROPS {return "Drops";}
    if mode == STAR_MODE_MUSIC {return "Music";}
    return "None";
}

fun musicStyleLabel(style: i32) >> ptr<u8> {
    if style == STAR_MUSIC_STYLE_WAVE {return "Wave";}
    if style == STAR_MUSIC_STYLE_AGGRO {return "Aggro";}
    return "Pulse";
}

fun shaderModeLabel(mode: i32) >> ptr<u8> {
    if mode == SHADER_MODE_LIGHT_CRT {return "Light CRT";}
    if mode == SHADER_MODE_CRT {return "CRT";}
    if mode == SHADER_MODE_VHS {return "VHS";}
    if mode == SHADER_MODE_CUSTOM {return "Custom";}
    return "None";
}

fun sliderPercent(value: f32, min_v: f32, max_v: f32) >> f32 {
    return clampf((value - min_v) / (max_v - min_v), 0.0, 1.0);
}

fun sliderValueFromMouse(px: f32, x: i64, w: i64, min_v: f32, max_v: f32) >> f32 {
    f32 left = uiX(x) as f32;
    f32 width = uiS(w) as f32;
    f32 t = (px - left) / width;
    t = clampf(t, 0.0, 1.0);
    return min_v + (max_v - min_v) * t;
}

fun sliderTrackHit(mouse: Vector2, row: i32, bg_stars_mode: i32, shader_mode: i32) >> bool {
    if !rowVisible(row, bg_stars_mode, shader_mode) {return false;}
    return pointInBaseRect(mouse.x, mouse.y, 136, itemYDraw(row, bg_stars_mode, shader_mode) + 40, 372, 10);
}

fun dragSliderF32(mouse: Vector2, row: i32, bg_stars_mode: i32, shader_mode: i32, target: ptr<f32>, min_v: f32, max_v: f32) >> void {
    if !sliderTrackHit(mouse, row, bg_stars_mode, shader_mode) {return;}
    target[0] = sliderValueFromMouse(mouse.x, 136, 372, min_v, max_v);
}

fun dragSliderI32(mouse: Vector2, row: i32, bg_stars_mode: i32, shader_mode: i32, target: ptr<i32>, min_v: f32, max_v: f32) >> void {
    if !sliderTrackHit(mouse, row, bg_stars_mode, shader_mode) {return;}
    target[0] = sliderValueFromMouse(mouse.x, 136, 372, min_v, max_v) as i32;
}

fun rowBodyHit(mouse: Vector2, row: i32, bg_stars_mode: i32, shader_mode: i32) >> bool {
    if !rowVisible(row, bg_stars_mode, shader_mode) {return false;}
    return pointInBaseRect(mouse.x, mouse.y, 118, itemYDraw(row, bg_stars_mode, shader_mode), 412, 62);
}

fun selectorDirectionFromMouse(mouse_x: f32) >> i32 {
    if mouse_x < uiX(336) as f32 {return -1;}
    return 1;
}

fun rowUsesSelectorMouseNudge(row: i32) >> bool {
    return row == SETTINGS_ROW_SHADER || row == SETTINGS_ROW_BG_STARS_MODE || row == SETTINGS_ROW_MUSIC_STYLE || row == SETTINGS_ROW_MUSIC_MODE;
}

fun rowUsesToggleMouseNudge(row: i32) >> bool {
    return row == SETTINGS_ROW_DOUBLE_ROW || row == SETTINGS_ROW_INSTANT_RESTART || row == SETTINGS_ROW_HARD_DROP_RING || row == SETTINGS_ROW_HIGH_CONTRAST_BLOCKS || row == SETTINGS_ROW_BIG_FIRST_BAG_PREVIEW || row == SETTINGS_ROW_FULLSCREEN_MODE || row == SETTINGS_ROW_MUSIC_SHUFFLE;
}

fun measureTextWidthBase(font: Font, text: ptr<u8>, size: i64) >> i64 {
    Vector2 m = MeasureTextExSize(font, text, uiS(size) as f32, 0.0);
    return (m.x / uiScale()) as i64;
}

fun sectionHeaderLabel(row: i32) >> ptr<u8> {
    if row == SETTINGS_ROW_SECTION_CONTROLS {return "CONTROLS";}
    if row == SETTINGS_ROW_SECTION_VIDEO {return "VIDEO";}
    return "AUDIO";
}

fun sectionExpanded(row: i32) >> bool {
    if row == SETTINGS_ROW_SECTION_CONTROLS {return g_settings.controls_expanded;}
    if row == SETTINGS_ROW_SECTION_VIDEO {return g_settings.video_expanded;}
    return g_settings.audio_expanded;
}

fun setSectionExpanded(row: i32, open: bool) >> void {
    if row == SETTINGS_ROW_SECTION_CONTROLS {
        g_settings.controls_expanded = open;
        g_settings_controls_expanded = open;
        return;
    }
    if row == SETTINGS_ROW_SECTION_VIDEO {
        g_settings.video_expanded = open;
        g_settings_video_expanded = open;
        return;
    }
    g_settings.audio_expanded = open;
    g_settings_audio_expanded = open;
}

fun toggleSection(row: i32) >> void {
    if !rowIsSectionHeader(row) {return;}
    setSectionExpanded(row, !sectionExpanded(row));
}

fun updateSectionAnimations(dt: f32) >> void {
    f32 speed = 10.0 as f32;
    f32 tgt_controls = 0.0 as f32;
    if g_settings.controls_expanded {tgt_controls = 1.0 as f32;}
    g_settings.controls_anim += (tgt_controls - g_settings.controls_anim) * clampf(dt * speed, 0.0, 1.0);

    f32 tgt_video = 0.0 as f32;
    if g_settings.video_expanded {tgt_video = 1.0 as f32;}
    g_settings.video_anim += (tgt_video - g_settings.video_anim) * clampf(dt * speed, 0.0, 1.0);

    f32 tgt_audio = 0.0 as f32;
    if g_settings.audio_expanded {tgt_audio = 1.0 as f32;}
    g_settings.audio_anim += (tgt_audio - g_settings.audio_anim) * clampf(dt * speed, 0.0, 1.0);
}

fun drawSectionHeaderRow(font: Font, theme: Theme, row: i32, bg_stars_mode: i32, shader_mode: i32) >> void {
    i64 y = itemYDraw(row, bg_stars_mode, shader_mode);
    f32 pulse = 0.0 as f32;
    if rowSelected(row) {pulse = triWave01((GetTime() as f32) * (1.8 as f32));}
    u32 stroke = alphaColor(theme.panel_stroke, (0.44 as f32) + pulse * (0.28 as f32));

    fillRect(118, y, 412, 62, alphaColor(theme.board_bg, 0.74 as f32));
    strokeRect(118, y, 412, 62, stroke);
    if rowSelected(row) {drawSelectionGlow(theme, y, (0.62 as f32) + pulse * (0.38 as f32));}

    ptr<u8> caret = ">";
    if sectionExpanded(row) {caret = "v";}
    drawTextColor(font, sectionHeaderLabel(row), 160, y + 20, 16, alphaColor(theme.text_main, 0.96 as f32));
    drawTextColor(font, caret, 136, y + 20, 16, alphaColor(theme.panel_stroke, 0.96 as f32));
}

fun drawSelectorRow(font: Font, theme: Theme, row: i32, bg_stars_mode: i32, shader_mode: i32, label: ptr<u8>, value: ptr<u8>) >> void {
    i64 y = itemYDraw(row, bg_stars_mode, shader_mode);
    f32 alpha = sectionAnimForRow(row);
    if alpha < 0.01 as f32 {return;}
    i64 row_x = 118;
    i64 row_w = 412;
    i64 right_padding = 18;
    i64 text_gap = 12;
    i64 arrow_gap = 14;

    i64 right_arrow_w = measureTextWidthBase(font, ">", 15);
    i64 left_arrow_w = measureTextWidthBase(font, "<", 15);
    i64 value_w = measureTextWidthBase(font, value, 15);

    i64 right_edge = row_x + row_w - right_padding;
    i64 right_arrow_x = right_edge - right_arrow_w;
    i64 value_x = right_arrow_x - text_gap - value_w;
    i64 left_arrow_x = value_x - arrow_gap - left_arrow_w;

    u32 stroke = alphaColor(theme.text_muted, (0.22 as f32) + alpha * (0.30 as f32));
    if rowSelected(row) {
        drawSelectionGlow(theme, y, alpha);
        stroke = alphaColor(theme.panel_stroke, 0.86 as f32);
    }
    fillRect(row_x, y, row_w, 62, alphaColor(theme.panel_bg, (0.30 as f32) + alpha * (0.62 as f32)));
    strokeRect(row_x, y, row_w, 62, stroke);
    drawTextColor(font, label, 136, y + 20, 15, alphaColor(theme.text_main, (0.36 as f32) + alpha * (0.64 as f32)));
    drawTextColor(font, "<", left_arrow_x, y + 20, 15, alphaColor(theme.text_main, (0.30 as f32) + alpha * (0.70 as f32)));
    drawTextColor(font, value, value_x, y + 20, 15, alphaColor(theme.panel_stroke, (0.42 as f32) + alpha * (0.58 as f32)));
    drawTextColor(font, ">", right_arrow_x, y + 20, 15, alphaColor(theme.text_main, (0.30 as f32) + alpha * (0.70 as f32)));
}

fun drawSliderRow(font: Font, theme: Theme, row: i32, bg_stars_mode: i32, shader_mode: i32, label: ptr<u8>, value_text: ptr<u8>, value: f32, min_v: f32, max_v: f32) >> void {
    i64 y = itemYDraw(row, bg_stars_mode, shader_mode);
    f32 alpha = sectionAnimForRow(row);
    if alpha < 0.01 as f32 {return;}

    u32 stroke = alphaColor(theme.text_muted, (0.22 as f32) + alpha * (0.30 as f32));
    if rowSelected(row) {
        drawSelectionGlow(theme, y, alpha);
        stroke = alphaColor(theme.panel_stroke, 0.86 as f32);
    }
    fillRect(118, y, 412, 62, alphaColor(theme.panel_bg, (0.30 as f32) + alpha * (0.62 as f32)));
    strokeRect(118, y, 412, 62, stroke);

    drawTextColor(font, label, 136, y + 14, 15, alphaColor(theme.text_main, (0.36 as f32) + alpha * (0.64 as f32)));
    drawTextColor(font, value_text, 430, y + 14, 14, alphaColor(theme.panel_stroke, (0.42 as f32) + alpha * (0.58 as f32)));

    i64 sx = 136;
    i64 sy = y + 40;
    i64 sw = 372;
    i64 sh = 10;
    fillRect(sx, sy, sw, sh, alphaColor(theme.board_bg, (0.40 as f32) + alpha * (0.55 as f32)));
    strokeRect(sx, sy, sw, sh, alphaColor(theme.text_muted, (0.18 as f32) + alpha * (0.30 as f32)));
    i64 fill_w = ((sw as f32) * sliderPercent(value, min_v, max_v)) as i64;
    fillRect(sx, sy, fill_w, sh, alphaColor(theme.panel_stroke, (0.40 as f32) + alpha * (0.45 as f32)));
    fillRect(sx + fill_w - 3, sy - 3, 6, sh + 6, alphaColor(theme.text_main, (0.52 as f32) + alpha * (0.48 as f32)));
}

fun drawToggleRow(font: Font, theme: Theme, row: i32, bg_stars_mode: i32, shader_mode: i32, label: ptr<u8>, enabled: bool) >> void {
    i64 y = itemYDraw(row, bg_stars_mode, shader_mode);
    f32 alpha = sectionAnimForRow(row);
    if alpha < 0.01 as f32 {return;}

    u32 stroke = alphaColor(theme.text_muted, (0.22 as f32) + alpha * (0.30 as f32));
    if rowSelected(row) {
        drawSelectionGlow(theme, y, alpha);
        stroke = alphaColor(theme.panel_stroke, 0.86 as f32);
    }
    fillRect(118, y, 412, 62, alphaColor(theme.panel_bg, (0.30 as f32) + alpha * (0.62 as f32)));
    strokeRect(118, y, 412, 62, stroke);
    drawTextColor(font, label, 136, y + 20, 15, alphaColor(theme.text_main, (0.36 as f32) + alpha * (0.64 as f32)));
    ptr<u8> mark = "[ ]";
    if enabled {mark = "[X]";}
    drawTextColor(font, mark, 470, y + 20, 15, alphaColor(theme.panel_stroke, (0.42 as f32) + alpha * (0.58 as f32)));
}

fun drawButtonRow(font: Font, theme: Theme, row: i32, bg_stars_mode: i32, shader_mode: i32, label: ptr<u8>) >> void {
    i64 y = itemYDraw(row, bg_stars_mode, shader_mode);
    f32 alpha = sectionAnimForRow(row);
    if alpha < 0.01 as f32 {return;}

    u32 stroke = alphaColor(theme.text_muted, (0.22 as f32) + alpha * (0.30 as f32));
    if rowSelected(row) {
        drawSelectionGlow(theme, y, alpha);
        stroke = alphaColor(theme.panel_stroke, 0.86 as f32);
    }
    fillRect(118, y, 412, 62, alphaColor(theme.panel_bg, (0.30 as f32) + alpha * (0.62 as f32)));
    strokeRect(118, y, 412, 62, stroke);
    drawTextCenteredInRect(font, label, 118, y + 2, 412, 58, 15, alphaColor(theme.text_main, (0.36 as f32) + alpha * (0.64 as f32)));
}

fun drawBackRow(font: Font, theme: Theme, row: i32, bg_stars_mode: i32, shader_mode: i32) >> void {
    i64 y = itemYDraw(row, bg_stars_mode, shader_mode);
    u32 stroke = alphaColor(theme.text_muted, 0.45 as f32);
    if rowSelected(row) {
        drawSelectionGlow(theme, y, 1.0 as f32);
        stroke = theme.panel_stroke;
    }
    fillRect(118, y, 412, 62, alphaColor(theme.panel_bg, 0.92 as f32));
    strokeRect(118, y, 412, 62, stroke);
    drawTextColor(font, "Back", 136, y + 20, 15, theme.text_main);
    drawTextColor(font, "ENTER", 436, y + 20, 12, theme.text_muted);
}

fun settingsEnsureSelectedVisible(bg_stars_mode: i32, shader_mode: i32) >> void {
    if rowVisible(g_settings.selected_row, bg_stars_mode, shader_mode) {return;}
    if g_settings.selected_row >= SETTINGS_ROW_ARR && g_settings.selected_row <= SETTINGS_ROW_INSTANT_RESTART {
        g_settings.selected_row = SETTINGS_ROW_SECTION_CONTROLS;
        return;
    }
    if g_settings.selected_row >= SETTINGS_ROW_THEME && g_settings.selected_row <= SETTINGS_ROW_FULLSCREEN_MODE {
        g_settings.selected_row = SETTINGS_ROW_SECTION_VIDEO;
        return;
    }
    if g_settings.selected_row >= SETTINGS_ROW_MUSIC_VOLUME && g_settings.selected_row <= SETTINGS_ROW_MUSIC_SHUFFLE {
        g_settings.selected_row = SETTINGS_ROW_SECTION_AUDIO;
        return;
    }
    g_settings.selected_row = SETTINGS_ROW_THEME;
}

fun drawSettings(font: Font, theme: Theme, theme_index: i32, shader_mode: i32, crt_curvature: f32, crt_brightness: f32, vhs_waves: f32, vhs_damage: f32, arr: f32, das: f32, dcd: f32, sdf: f32, music_volume: f32, board_bounciness: i32, bg_stars_amount: i32, bg_stars_mode: i32, star_peak_target_dps: f32, star_intensity: f32, star_music_intensity: f32, star_music_style: i32, double_row_ui: bool, instant_restart: bool, hard_drop_ring: bool, high_contrast_blocks: bool, big_first_bag_preview: bool, fullscreen_mode: bool, custom_shader_name: ptr<u8>, music_mode: i32, music_shuffle: bool) >> void {
    g_settings.theme_custom_active = theme_index == themeCustomSlotIndex();

    if g_settings.theme_mgr_open {
        drawThemeManager(font, theme);
        return;
    }

    settingsEnsureSelectedVisible(bg_stars_mode, shader_mode);

    DrawRectangleGradientV(0, 0, GetScreenWidth(), GetScreenHeight(), toColor(theme.bg_inner), toColor(theme.bg_outer));
    drawImpulseGridBackground(font, theme);

    fillRect(84, 48, 480, 860, alphaColor(theme.bg_outer, 0.90 as f32));
    strokeRect(84, 48, 480, 860, alphaColor(theme.panel_stroke, 0.90 as f32));

    drawTextColor(font, "SETTINGS", 130, 118, 30, theme.text_main);
    drawTextColor(font, "Sections: ENTER toggle", 130, 162, 14, theme.text_muted);
    drawTextColor(font, "Arrow keys or mouse", 130, 182, 14, theme.text_muted);

    if g_settings.song_picker_open {
        i32 song_count = g_star_music_track_count;
        i32 song_visible = 7;
        i32 song_max_scroll = song_count - song_visible;
        if song_max_scroll < 0 {song_max_scroll = 0;}
        if g_settings.song_picker_scroll < 0.0 as f32 {g_settings.song_picker_scroll = 0.0 as f32;}
        if g_settings.song_picker_scroll > song_max_scroll as f32 {g_settings.song_picker_scroll = song_max_scroll as f32;}

        fillRect(112, 232, 424, 646, alphaColor(theme.panel_bg, 0.94 as f32));
        strokeRect(112, 232, 424, 646, alphaColor(theme.panel_stroke, 0.86 as f32));
        drawTextColor(font, "SELECT SONGS", 136, 258, 18, theme.text_main);
        drawTextColor(font, "click to toggle", 136, 278, 11, alphaColor(theme.text_muted, 0.70 as f32));

        i64 row_h = 68;
        i64 row_inner_h = 56;
        i64 row_inner_off = (row_h - row_inner_h) / 2;
        i64 start_y = 298;

        if song_count == 0 {
            drawTextColor(font, "No songs in assets/songs/", 148, 340, 12, alphaColor(theme.text_muted, 0.70 as f32));
        }

        for i32 i = 0; i < song_count; i++ {
            i64 y = start_y + ((i as f32 - g_settings.song_picker_scroll) * (row_h as f32)) as i64;
            if y < 290 || y > 770 {continue;}
            i64 iy = y + row_inner_off;

            bool enabled = !g_star_music_track_disabled[i];
            bool sel = i == g_settings.song_picker_selected;
            u32 stroke = alphaColor(theme.text_muted, 0.38 as f32);
            if sel {
                stroke = theme.panel_stroke;
                drawSelectionGlow(theme, iy - 3, 1.0 as f32);
            }
            fillRect(130, iy, 388, row_inner_h, alphaColor(theme.board_bg, 0.74 as f32));
            strokeRect(130, iy, 388, row_inner_h, stroke);
            ptr<u8> mark = "[ ]";
            if enabled {mark = "[X]";}
            u32 mark_col = alphaColor(theme.text_muted, 0.60 as f32);
            if enabled {mark_col = alphaColor(theme.panel_stroke, 0.90 as f32);}
            drawTextColor(font, mark, 148, iy + 20, 13, mark_col);
            drawTextColor(font, musicTrackBasename(i), 222, iy + 20, 13, alphaColor(theme.text_main, 0.92 as f32));
        }

        i64 by = 806;
        bool back_sel = g_settings.song_picker_selected == song_count;
        fillRect(130, by, 388, 56, alphaColor(theme.board_bg, 0.86 as f32));
        strokeRect(130, by, 388, 56, alphaColor(theme.panel_stroke, 0.82 as f32));
        if back_sel {drawSelectionGlow(theme, by + 3, 1.0 as f32);}
        drawTextColor(font, "Close", 148, by + 18, 15, theme.text_main);
        drawTextColor(font, "ESC", 470, by + 18, 12, theme.text_muted);

        return;
    }

    if g_settings.picker_open {
        fillRect(112, 232, 424, 646, alphaColor(theme.panel_bg, 0.94 as f32));
        strokeRect(112, 232, 424, 646, alphaColor(theme.panel_stroke, 0.86 as f32));
        drawTextColor(font, "CHOOSE SHADER", 136, 258, 18, theme.text_main);

        i32 visible = 7;
        i32 max_scroll = g_settings.picker_count - visible;
        if max_scroll < 0 {max_scroll = 0;}
        if g_settings.picker_scroll < 0.0 as f32 {g_settings.picker_scroll = 0.0 as f32;}
        if g_settings.picker_scroll > max_scroll as f32 {g_settings.picker_scroll = max_scroll as f32;}

        i64 row_h = 68;
        i64 row_inner_h = 56;
        i64 row_inner_off = (row_h - row_inner_h) / 2;
        i64 start_y = 298;
        for i32 i = 0; i < g_settings.picker_count; i++ {
            i64 y = start_y + ((i as f32 - g_settings.picker_scroll) * (row_h as f32)) as i64;
            if y < 290 || y > 770 {continue;}
            i64 iy = y + row_inner_off;

            bool sel = i == g_settings.picker_selected;
            u32 stroke = alphaColor(theme.text_muted, 0.38 as f32);
            if sel {
                stroke = theme.panel_stroke;
                drawSelectionGlow(theme, iy - 3, 1.0 as f32);
            }
            fillRect(130, iy, 388, row_inner_h, alphaColor(theme.board_bg, 0.74 as f32));
            strokeRect(130, iy, 388, row_inner_h, stroke);
            drawTextColor(font, pickerNamePtr(i), 148, iy + 20, 14, theme.text_main);
        }

        i64 by = 806;
        bool back_sel = g_settings.picker_selected == g_settings.picker_count;
        fillRect(130, by, 388, 56, alphaColor(theme.board_bg, 0.86 as f32));
        strokeRect(130, by, 388, 56, alphaColor(theme.panel_stroke, 0.82 as f32));
        if back_sel {drawSelectionGlow(theme, by + 3, 1.0 as f32);}
        drawTextColor(font, "Back", 148, by + 18, 15, theme.text_main);
        drawTextColor(font, "ESC", 470, by + 18, 12, theme.text_muted);

        return;
    }

    i32 visible_rows = visibleRowCount(bg_stars_mode, shader_mode);
    if visible_rows > SETTINGS_VISIBLE_ROWS {visible_rows = SETTINGS_VISIBLE_ROWS;}
    i64 list_h_base = 18 + (visible_rows as i64) * 78;
    i32 list_x = uiX(112);
    i32 list_y = uiY(232);
    i32 list_w = uiS(424);
    i32 list_h = uiS(list_h_base);
    BeginScissorMode(list_x, list_y, list_w, list_h);

    drawSectionHeaderRow(font, theme, SETTINGS_ROW_SECTION_CONTROLS, bg_stars_mode, shader_mode);
    if rowVisible(SETTINGS_ROW_ARR, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_ARR, bg_stars_mode, shader_mode, "ARR", TextFormat("%.1fF", arr), arr, 0.0, 8.0);}
    if rowVisible(SETTINGS_ROW_DAS, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_DAS, bg_stars_mode, shader_mode, "DAS", TextFormat("%.1fF", das), das, 0.0, 20.0);}
    if rowVisible(SETTINGS_ROW_DCD, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_DCD, bg_stars_mode, shader_mode, "DCD", TextFormat("%.1fF", dcd), dcd, 0.0, 10.0);}
    if rowVisible(SETTINGS_ROW_SDF, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_SDF, bg_stars_mode, shader_mode, "SDF", TextFormat("%.1fX", sdf), sdf, 1.0, 40.0);}
    if rowVisible(SETTINGS_ROW_INSTANT_RESTART, bg_stars_mode, shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_INSTANT_RESTART, bg_stars_mode, shader_mode, "Instant restart", instant_restart);}

    drawSectionHeaderRow(font, theme, SETTINGS_ROW_SECTION_VIDEO, bg_stars_mode, shader_mode);
    if rowVisible(SETTINGS_ROW_THEME, bg_stars_mode, shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_THEME, bg_stars_mode, shader_mode, "Theme", themeName(theme_index));}
    if rowVisible(SETTINGS_ROW_MANAGE_THEMES, bg_stars_mode, shader_mode) {drawButtonRow(font, theme, SETTINGS_ROW_MANAGE_THEMES, bg_stars_mode, shader_mode, "MANAGE THEMES");}
    if rowVisible(SETTINGS_ROW_SHADER, bg_stars_mode, shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_SHADER, bg_stars_mode, shader_mode, "Shader", shaderModeLabel(shader_mode));}
    if rowVisible(SETTINGS_ROW_CHOOSE_SHADER, bg_stars_mode, shader_mode) {
        drawButtonRow(font, theme, SETTINGS_ROW_CHOOSE_SHADER, bg_stars_mode, shader_mode, "CHOOSE CUSTOM SHADER");
    }
    if rowVisible(SETTINGS_ROW_BOARD_BOUNCINESS, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BOARD_BOUNCINESS, bg_stars_mode, shader_mode, "Board bounciness", TextFormat("%i%%", board_bounciness), board_bounciness as f32, 0.0, 100.0);}
    if rowVisible(SETTINGS_ROW_CRT_CURVATURE, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_CRT_CURVATURE, bg_stars_mode, shader_mode, "CRT curvature", TextFormat("%i%%", (crt_curvature * 100.0 as f32) as i32), crt_curvature, 0.2, 1.4);}
    if rowVisible(SETTINGS_ROW_CRT_BRIGHTNESS, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_CRT_BRIGHTNESS, bg_stars_mode, shader_mode, "CRT brightness", TextFormat("%i%%", (crt_brightness * 100.0 as f32) as i32), crt_brightness, 0.6, 1.8);}
    if rowVisible(SETTINGS_ROW_VHS_WAVES, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_VHS_WAVES, bg_stars_mode, shader_mode, "VHS waves", TextFormat("%i%%", (vhs_waves * 100.0 as f32) as i32), vhs_waves, 0.0, 1.4);}
    if rowVisible(SETTINGS_ROW_VHS_DAMAGE, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_VHS_DAMAGE, bg_stars_mode, shader_mode, "VHS damage", TextFormat("%i%%", (vhs_damage * 100.0 as f32) as i32), vhs_damage, 0.0, 1.5);}
    if rowVisible(SETTINGS_ROW_BG_STARS_AMOUNT, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BG_STARS_AMOUNT, bg_stars_mode, shader_mode, "BG stars amount", TextFormat("%i", bg_stars_amount), bg_stars_amount as f32, 0.0, 150.0);}
    if rowVisible(SETTINGS_ROW_BG_STARS_MODE, bg_stars_mode, shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_BG_STARS_MODE, bg_stars_mode, shader_mode, "BG stars react", bgStarsModeLabel(bg_stars_mode));}
    if rowVisible(SETTINGS_ROW_STAR_PEAK_TARGET, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_STAR_PEAK_TARGET, bg_stars_mode, shader_mode, "Star peak target", TextFormat("%.1f dps", star_peak_target_dps), star_peak_target_dps, 0.5, 3.5);}
    if rowVisible(SETTINGS_ROW_STAR_INTENSITY, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_STAR_INTENSITY, bg_stars_mode, shader_mode, "Star intensity", TextFormat("%.1f", star_intensity), star_intensity, 0.1, 1.0);}
    if rowVisible(SETTINGS_ROW_MUSIC_STYLE, bg_stars_mode, shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_MUSIC_STYLE, bg_stars_mode, shader_mode, "Music style", musicStyleLabel(star_music_style));}
    if rowVisible(SETTINGS_ROW_MUSIC_INTENSITY, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_MUSIC_INTENSITY, bg_stars_mode, shader_mode, "Music intensity", TextFormat("%.1f", star_music_intensity), star_music_intensity, 0.1, 1.0);}
    if rowVisible(SETTINGS_ROW_DOUBLE_ROW, bg_stars_mode, shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_DOUBLE_ROW, bg_stars_mode, shader_mode, "Double-row UI", double_row_ui);}
    if rowVisible(SETTINGS_ROW_HARD_DROP_RING, bg_stars_mode, shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_HARD_DROP_RING, bg_stars_mode, shader_mode, "Hard drop ring", hard_drop_ring);}
    if rowVisible(SETTINGS_ROW_HIGH_CONTRAST_BLOCKS, bg_stars_mode, shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_HIGH_CONTRAST_BLOCKS, bg_stars_mode, shader_mode, "Higher contrast blocks", high_contrast_blocks);}
    if rowVisible(SETTINGS_ROW_BIG_FIRST_BAG_PREVIEW, bg_stars_mode, shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_BIG_FIRST_BAG_PREVIEW, bg_stars_mode, shader_mode, "Big first NEXT", big_first_bag_preview);}
    if rowVisible(SETTINGS_ROW_FULLSCREEN_MODE, bg_stars_mode, shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_FULLSCREEN_MODE, bg_stars_mode, shader_mode, "Fullscreen mode", fullscreen_mode);}

    drawSectionHeaderRow(font, theme, SETTINGS_ROW_SECTION_AUDIO, bg_stars_mode, shader_mode);
    if rowVisible(SETTINGS_ROW_MUSIC_VOLUME, bg_stars_mode, shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_MUSIC_VOLUME, bg_stars_mode, shader_mode, "Music volume", TextFormat("%i%%", (music_volume * 100.0 as f32) as i32), music_volume, 0.0, 1.0);}
    if rowVisible(SETTINGS_ROW_MUSIC_MODE, bg_stars_mode, shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_MUSIC_MODE, bg_stars_mode, shader_mode, "Music", musicModeLabel(music_mode));}
    if rowVisible(SETTINGS_ROW_SELECT_SONGS, bg_stars_mode, shader_mode) {drawButtonRow(font, theme, SETTINGS_ROW_SELECT_SONGS, bg_stars_mode, shader_mode, "SELECT SONGS");}
    if rowVisible(SETTINGS_ROW_MUSIC_SHUFFLE, bg_stars_mode, shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_MUSIC_SHUFFLE, bg_stars_mode, shader_mode, "Shuffle songs", music_shuffle);}

    drawBackRow(font, theme, SETTINGS_ROW_BACK, bg_stars_mode, shader_mode);

    EndScissorMode();

    fillRect(112, 232, 424, 18, alphaColor(theme.bg_outer, 0.75 as f32));
    fillRect(112, 232 + list_h_base - 18, 424, 18, alphaColor(theme.bg_outer, 0.75 as f32));
}

fun settingsNudgeRow(row: i32, dir: i32, theme_index: ptr<i32>, shader_mode: ptr<i32>, crt_curvature: ptr<f32>, crt_brightness: ptr<f32>, vhs_waves: ptr<f32>, vhs_damage: ptr<f32>, arr: ptr<f32>, das: ptr<f32>, dcd: ptr<f32>, sdf: ptr<f32>, music_volume: ptr<f32>, board_bounciness: ptr<i32>, bg_stars_amount: ptr<i32>, bg_stars_mode: ptr<i32>, star_peak_target_dps: ptr<f32>, star_intensity: ptr<f32>, star_music_intensity: ptr<f32>, star_music_style: ptr<i32>, double_row_ui: ptr<bool>, instant_restart: ptr<bool>, hard_drop_ring: ptr<bool>, high_contrast_blocks: ptr<bool>, big_first_bag_preview: ptr<bool>, fullscreen_mode: ptr<bool>, music_mode: ptr<i32>, music_shuffle: ptr<bool>) >> i32 {
    if rowIsSectionHeader(row) {
        if dir < 0 {setSectionExpanded(row, false);} else {setSectionExpanded(row, true);}
        return SETTINGS_ACTION_NONE;
    }

    if row == SETTINGS_ROW_THEME {theme_index[0] = switchTheme(theme_index[0], dir); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MANAGE_THEMES {return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_SHADER {
        shader_mode[0] += dir;
        if shader_mode[0] < SHADER_MODE_NONE {shader_mode[0] = SHADER_MODE_CUSTOM;}
        if shader_mode[0] > SHADER_MODE_CUSTOM {shader_mode[0] = SHADER_MODE_NONE;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_CHOOSE_SHADER {return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_CRT_CURVATURE {crt_curvature[0] = clampf(crt_curvature[0] + (dir as f32) * (0.05 as f32), 0.2, 1.4); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_CRT_BRIGHTNESS {crt_brightness[0] = clampf(crt_brightness[0] + (dir as f32) * (0.05 as f32), 0.6, 1.8); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_VHS_WAVES {vhs_waves[0] = clampf(vhs_waves[0] + (dir as f32) * (0.05 as f32), 0.0, 1.4); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_VHS_DAMAGE {vhs_damage[0] = clampf(vhs_damage[0] + (dir as f32) * (0.05 as f32), 0.0, 1.5); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_ARR {arr[0] = clampf(arr[0] + (dir as f32) * (0.1 as f32), 0.0, 8.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_DAS {das[0] = clampf(das[0] + (dir as f32) * (0.1 as f32), 0.0, 20.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_DCD {dcd[0] = clampf(dcd[0] + (dir as f32) * (0.1 as f32), 0.0, 10.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_SDF {sdf[0] = clampf(sdf[0] + (dir as f32) * (0.5 as f32), 1.0, 40.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MUSIC_VOLUME {music_volume[0] = clampf(music_volume[0] + (dir as f32) * (0.05 as f32), 0.0, 1.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BOARD_BOUNCINESS {
        board_bounciness[0] += dir;
        if board_bounciness[0] < 0 {board_bounciness[0] = 0;}
        if board_bounciness[0] > 100 {board_bounciness[0] = 100;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_BG_STARS_AMOUNT {
        bg_stars_amount[0] += dir;
        if bg_stars_amount[0] < 0 {bg_stars_amount[0] = 0;}
        if bg_stars_amount[0] > 150 {bg_stars_amount[0] = 150;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_BG_STARS_MODE {
        bg_stars_mode[0] += dir;
        if bg_stars_mode[0] < STAR_MODE_NONE {bg_stars_mode[0] = STAR_MODE_MUSIC;}
        if bg_stars_mode[0] > STAR_MODE_MUSIC {bg_stars_mode[0] = STAR_MODE_NONE;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_STAR_PEAK_TARGET {star_peak_target_dps[0] = clampf(star_peak_target_dps[0] + (dir as f32) * (0.1 as f32), 0.5, 3.5); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_STAR_INTENSITY {star_intensity[0] = clampf(star_intensity[0] + (dir as f32) * (0.1 as f32), 0.1, 1.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MUSIC_STYLE {
        star_music_style[0] += dir;
        if star_music_style[0] < STAR_MUSIC_STYLE_PULSE {star_music_style[0] = STAR_MUSIC_STYLE_AGGRO;}
        if star_music_style[0] > STAR_MUSIC_STYLE_AGGRO {star_music_style[0] = STAR_MUSIC_STYLE_PULSE;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_MUSIC_INTENSITY {star_music_intensity[0] = clampf(star_music_intensity[0] + (dir as f32) * (0.1 as f32), 0.1, 1.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_DOUBLE_ROW {double_row_ui[0] = !double_row_ui[0]; return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_INSTANT_RESTART {instant_restart[0] = !instant_restart[0]; return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_HARD_DROP_RING {hard_drop_ring[0] = !hard_drop_ring[0]; return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_HIGH_CONTRAST_BLOCKS {high_contrast_blocks[0] = !high_contrast_blocks[0]; return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BIG_FIRST_BAG_PREVIEW {big_first_bag_preview[0] = !big_first_bag_preview[0]; return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_FULLSCREEN_MODE {fullscreen_mode[0] = !fullscreen_mode[0]; return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MUSIC_MODE {
        music_mode[0] += dir;
        if music_mode[0] < MUSIC_MODE_BUILTIN {music_mode[0] = MUSIC_MODE_CUSTOM;}
        if music_mode[0] > MUSIC_MODE_CUSTOM {music_mode[0] = MUSIC_MODE_BUILTIN;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_SELECT_SONGS {return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MUSIC_SHUFFLE {music_shuffle[0] = !music_shuffle[0]; return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BACK {return SETTINGS_ACTION_BACK;}
    return SETTINGS_ACTION_NONE;
}

fun settingsUpdate(theme_index: ptr<i32>, shader_mode: ptr<i32>, crt_curvature: ptr<f32>, crt_brightness: ptr<f32>, vhs_waves: ptr<f32>, vhs_damage: ptr<f32>, arr: ptr<f32>, das: ptr<f32>, dcd: ptr<f32>, sdf: ptr<f32>, music_volume: ptr<f32>, board_bounciness: ptr<i32>, bg_stars_amount: ptr<i32>, bg_stars_mode: ptr<i32>, star_peak_target_dps: ptr<f32>, star_intensity: ptr<f32>, star_music_intensity: ptr<f32>, star_music_style: ptr<i32>, double_row_ui: ptr<bool>, instant_restart: ptr<bool>, hard_drop_ring: ptr<bool>, high_contrast_blocks: ptr<bool>, big_first_bag_preview: ptr<bool>, fullscreen_mode: ptr<bool>, custom_shader_name: ptr<u8>, music_mode: ptr<i32>, music_shuffle: ptr<bool>) >> i32 {

    g_settings.theme_custom_active = theme_index[0] == themeCustomSlotIndex();
    if !g_settings.theme_custom_active && g_settings.theme_mgr_open {closeThemeManager();}

    updateSectionAnimations(GetFrameTime());

    Vector2 mouse = GetMousePosition();
    bool mouse_moved = absf(mouse.x - g_settings.mouse_last_x) > (0.5 as f32) || absf(mouse.y - g_settings.mouse_last_y) > (0.5 as f32);
    if mouse_moved {g_settings.keyboard_nav_lock = false;}
    g_settings.mouse_last_x = mouse.x;
    g_settings.mouse_last_y = mouse.y;

    if g_settings.song_picker_open {
        if IsKeyPressed(KEY_ESCAPE) {closeSongPicker(); return SETTINGS_ACTION_NONE;}

        i32 song_count = g_star_music_track_count;
        i32 song_max_sel = song_count;

        if IsKeyPressed(KEY_UP) {
            g_settings.song_picker_selected -= 1;
            if g_settings.song_picker_selected < 0 {g_settings.song_picker_selected = song_max_sel;}
            g_settings.keyboard_nav_lock = true;
        }
        if IsKeyPressed(KEY_DOWN) {
            g_settings.song_picker_selected += 1;
            if g_settings.song_picker_selected > song_max_sel {g_settings.song_picker_selected = 0;}
            g_settings.keyboard_nav_lock = true;
        }

        i32 song_visible = 7;
        i32 song_max_scroll = song_count - song_visible;
        if song_max_scroll < 0 {song_max_scroll = 0;}
        f32 song_wheel = GetMouseWheelMove();
        if song_wheel > 0.0 as f32 {g_settings.song_picker_scroll -= 1.0 as f32;}
        if song_wheel < 0.0 as f32 {g_settings.song_picker_scroll += 1.0 as f32;}
        if g_settings.song_picker_selected < (g_settings.song_picker_scroll as i32) {g_settings.song_picker_scroll = g_settings.song_picker_selected as f32;}
        if g_settings.song_picker_selected >= (g_settings.song_picker_scroll as i32) + song_visible {g_settings.song_picker_scroll = (g_settings.song_picker_selected - song_visible + 1) as f32;}
        if g_settings.song_picker_scroll < 0.0 as f32 {g_settings.song_picker_scroll = 0.0 as f32;}
        if g_settings.song_picker_scroll > song_max_scroll as f32 {g_settings.song_picker_scroll = song_max_scroll as f32;}

        if !g_settings.keyboard_nav_lock && pointInBaseRect(mouse.x, mouse.y, 130, 298, 388, 68 * song_visible) {
            i32 sidx = (((mouse.y - uiY(298) as f32) / (uiS(68) as f32)) + g_settings.song_picker_scroll) as i32;
            if sidx >= 0 && sidx < song_count {g_settings.song_picker_selected = sidx;}
        }
        if !g_settings.keyboard_nav_lock && pointInBaseRect(mouse.x, mouse.y, 130, 806, 388, 56) {g_settings.song_picker_selected = song_count;}

        bool song_choose = IsKeyPressed(KEY_ENTER) || IsMouseButtonPressed(MOUSE_BUTTON_LEFT);
        if song_choose {
            g_settings.keyboard_nav_lock = false;
            if g_settings.song_picker_selected == song_count {
                closeSongPicker();
                return SETTINGS_ACTION_NONE;
            }
            if g_settings.song_picker_selected >= 0 && g_settings.song_picker_selected < song_count {
                g_star_music_track_disabled[g_settings.song_picker_selected] = !g_star_music_track_disabled[g_settings.song_picker_selected];
                if countEnabledTracks() <= 0 {
                    g_star_music_track_disabled[g_settings.song_picker_selected] = false;
                }
                g_songs_modified = true;
            }
        }
        return SETTINGS_ACTION_NONE;
    }

    if g_settings.picker_open {
        if IsKeyPressed(KEY_ESCAPE) {closeShaderPicker(); return SETTINGS_ACTION_NONE;}

        i32 max_sel = g_settings.picker_count;
        if IsKeyPressed(KEY_UP) {
            g_settings.picker_selected -= 1;
            if g_settings.picker_selected < 0 {g_settings.picker_selected = max_sel;}
            g_settings.keyboard_nav_lock = true;
        }
        if IsKeyPressed(KEY_DOWN) {
            g_settings.picker_selected += 1;
            if g_settings.picker_selected > max_sel {g_settings.picker_selected = 0;}
            g_settings.keyboard_nav_lock = true;
        }

        i32 visible = 7;
        i32 max_scroll = g_settings.picker_count - visible;
        if max_scroll < 0 {max_scroll = 0;}
        f32 wheel = GetMouseWheelMove();
        if wheel > 0.0 as f32 {g_settings.picker_scroll -= 1.0 as f32;}
        if wheel < 0.0 as f32 {g_settings.picker_scroll += 1.0 as f32;}
        if g_settings.picker_selected < (g_settings.picker_scroll as i32) {g_settings.picker_scroll = g_settings.picker_selected as f32;}
        if g_settings.picker_selected >= (g_settings.picker_scroll as i32) + visible {g_settings.picker_scroll = (g_settings.picker_selected - visible + 1) as f32;}
        if g_settings.picker_scroll < 0.0 as f32 {g_settings.picker_scroll = 0.0 as f32;}
        if g_settings.picker_scroll > max_scroll as f32 {g_settings.picker_scroll = max_scroll as f32;}

        if !g_settings.keyboard_nav_lock && pointInBaseRect(mouse.x, mouse.y, 130, 298, 388, 68 * visible) {
            i32 idx = (((mouse.y - uiY(298) as f32) / (uiS(68) as f32)) + g_settings.picker_scroll) as i32;
            if idx >= 0 && idx < g_settings.picker_count {g_settings.picker_selected = idx;}
        }
        if !g_settings.keyboard_nav_lock && pointInBaseRect(mouse.x, mouse.y, 130, 806, 388, 56) {g_settings.picker_selected = g_settings.picker_count;}

        bool choose = IsKeyPressed(KEY_ENTER) || IsMouseButtonPressed(MOUSE_BUTTON_LEFT);
        if choose {
            g_settings.keyboard_nav_lock = false;
            if g_settings.picker_selected == g_settings.picker_count {
                closeShaderPicker();
                return SETTINGS_ACTION_NONE;
            }
            if g_settings.picker_selected >= 0 && g_settings.picker_selected < g_settings.picker_count {
                copyFixed(custom_shader_name, pickerNamePtr(g_settings.picker_selected), CUSTOM_SHADER_NAME_MAX);
                return SETTINGS_ACTION_NONE;
            }
        }
        return SETTINGS_ACTION_NONE;
    }

    if updateThemeManager(theme_index) {return SETTINGS_ACTION_NONE;}

    if IsKeyPressed(KEY_ESCAPE) {return SETTINGS_ACTION_BACK;}

    settingsEnsureSelectedVisible(bg_stars_mode[0], shader_mode[0]);

    i32 item_count = visibleRowCount(bg_stars_mode[0], shader_mode[0]);
    i32 max_scroll = item_count - (SETTINGS_VISIBLE_ROWS as i32);
    if max_scroll < 0 {max_scroll = 0;}

    f32 wheel = GetMouseWheelMove();
    if (wheel > 0.0) {g_settings.scroll -= 1.0;} else if (wheel < 0.0) {g_settings.scroll += 1.0;}
    if g_settings.scroll < 0.0 {g_settings.scroll = 0.0;}
    if g_settings.scroll > (max_scroll as f32) {g_settings.scroll = max_scroll as f32;}

    if IsKeyPressed(KEY_UP) {
        i32 order = rowOrder(g_settings.selected_row, bg_stars_mode[0], shader_mode[0]);
        if order < 0 {order = 0;}
        order -= 1;
        if order < 0 {order = item_count - 1;}
        g_settings.selected_row = rowFromOrder(order, bg_stars_mode[0], shader_mode[0]);
        g_settings.keyboard_nav_lock = true;
    }
    if IsKeyPressed(KEY_DOWN) {
        i32 order = rowOrder(g_settings.selected_row, bg_stars_mode[0], shader_mode[0]);
        if order < 0 {order = 0;}
        order += 1;
        if order >= item_count {order = 0;}
        g_settings.selected_row = rowFromOrder(order, bg_stars_mode[0], shader_mode[0]);
        g_settings.keyboard_nav_lock = true;
    }

    i32 sel_order = rowOrder(g_settings.selected_row, bg_stars_mode[0], shader_mode[0]);
    if sel_order < 0 {sel_order = 0;}
    if (sel_order as f32) < g_settings.scroll {g_settings.scroll = sel_order as f32;}
    if sel_order >= (g_settings.scroll as i32) + (SETTINGS_VISIBLE_ROWS as i32) {g_settings.scroll = (sel_order - ((SETTINGS_VISIBLE_ROWS as i32) - 1)) as f32;}
    if g_settings.scroll < 0.0 {g_settings.scroll = 0.0;}
    if g_settings.scroll > (max_scroll as f32) {g_settings.scroll = max_scroll as f32;}

    if IsKeyPressed(KEY_LEFT) {
        g_settings.keyboard_nav_lock = true;
        i32 act = settingsNudgeRow(g_settings.selected_row, -1, theme_index, shader_mode, crt_curvature, crt_brightness, vhs_waves, vhs_damage, arr, das, dcd, sdf, music_volume, board_bounciness, bg_stars_amount, bg_stars_mode, star_peak_target_dps, star_intensity, star_music_intensity, star_music_style, double_row_ui, instant_restart, hard_drop_ring, high_contrast_blocks, big_first_bag_preview, fullscreen_mode, music_mode, music_shuffle);
        settingsEnsureSelectedVisible(bg_stars_mode[0], shader_mode[0]);
        if act != SETTINGS_ACTION_NONE {return act;}
    }
    if IsKeyPressed(KEY_RIGHT) {
        g_settings.keyboard_nav_lock = true;
        i32 act = settingsNudgeRow(g_settings.selected_row, 1, theme_index, shader_mode, crt_curvature, crt_brightness, vhs_waves, vhs_damage, arr, das, dcd, sdf, music_volume, board_bounciness, bg_stars_amount, bg_stars_mode, star_peak_target_dps, star_intensity, star_music_intensity, star_music_style, double_row_ui, instant_restart, hard_drop_ring, high_contrast_blocks, big_first_bag_preview, fullscreen_mode, music_mode, music_shuffle);
        settingsEnsureSelectedVisible(bg_stars_mode[0], shader_mode[0]);
        if act != SETTINGS_ACTION_NONE {return act;}
    }
    if IsKeyPressed(KEY_ENTER) {
        g_settings.keyboard_nav_lock = true;
        if rowIsSectionHeader(g_settings.selected_row) {
            toggleSection(g_settings.selected_row);
            settingsEnsureSelectedVisible(bg_stars_mode[0], shader_mode[0]);
        } else if g_settings.selected_row == SETTINGS_ROW_MANAGE_THEMES {
            openThemeManager(theme_index);
        } else if g_settings.selected_row == SETTINGS_ROW_CHOOSE_SHADER {
            openShaderPicker(custom_shader_name);
        } else if g_settings.selected_row == SETTINGS_ROW_SELECT_SONGS {
            if g_star_music_track_count > 0 {openSongPicker();}
        } else {
            i32 act = settingsNudgeRow(g_settings.selected_row, 1, theme_index, shader_mode, crt_curvature, crt_brightness, vhs_waves, vhs_damage, arr, das, dcd, sdf, music_volume, board_bounciness, bg_stars_amount, bg_stars_mode, star_peak_target_dps, star_intensity, star_music_intensity, star_music_style, double_row_ui, instant_restart, hard_drop_ring, high_contrast_blocks, big_first_bag_preview, fullscreen_mode, music_mode, music_shuffle);
            settingsEnsureSelectedVisible(bg_stars_mode[0], shader_mode[0]);
            if act != SETTINGS_ACTION_NONE {return act;}
        }
    }

    i32 visible_rows = item_count;
    if visible_rows > SETTINGS_VISIBLE_ROWS {visible_rows = SETTINGS_VISIBLE_ROWS;}
    i64 list_h_base = 18 + (visible_rows as i64) * 78;
    if !g_settings.keyboard_nav_lock && pointInBaseRect(mouse.x, mouse.y, 112, 232, 424, list_h_base) {
        f32 row_h = uiS(78) as f32;
        f32 local = (mouse.y - (uiY(246) as f32)) / row_h;
        i32 hovered_order = (local + g_settings.scroll) as i32;
        if hovered_order < 0 {hovered_order = 0;}
        if hovered_order >= item_count {hovered_order = item_count - 1;}
        g_settings.selected_row = rowFromOrder(hovered_order, bg_stars_mode[0], shader_mode[0]);
    }

    if IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {
        g_settings.keyboard_nav_lock = false;
        if rowIsSectionHeader(g_settings.selected_row) && rowBodyHit(mouse, g_settings.selected_row, bg_stars_mode[0], shader_mode[0]) {
            toggleSection(g_settings.selected_row);
            settingsEnsureSelectedVisible(bg_stars_mode[0], shader_mode[0]);
        } else {
            i32 act = SETTINGS_ACTION_NONE;
            if g_settings.selected_row == SETTINGS_ROW_THEME && rowBodyHit(mouse, SETTINGS_ROW_THEME, bg_stars_mode[0], shader_mode[0]) {
                act = settingsNudgeRow(SETTINGS_ROW_THEME, selectorDirectionFromMouse(mouse.x), theme_index, shader_mode, crt_curvature, crt_brightness, vhs_waves, vhs_damage, arr, das, dcd, sdf, music_volume, board_bounciness, bg_stars_amount, bg_stars_mode, star_peak_target_dps, star_intensity, star_music_intensity, star_music_style, double_row_ui, instant_restart, hard_drop_ring, high_contrast_blocks, big_first_bag_preview, fullscreen_mode, music_mode, music_shuffle);
            } else if rowUsesSelectorMouseNudge(g_settings.selected_row) && rowBodyHit(mouse, g_settings.selected_row, bg_stars_mode[0], shader_mode[0]) {
                act = settingsNudgeRow(g_settings.selected_row, selectorDirectionFromMouse(mouse.x), theme_index, shader_mode, crt_curvature, crt_brightness, vhs_waves, vhs_damage, arr, das, dcd, sdf, music_volume, board_bounciness, bg_stars_amount, bg_stars_mode, star_peak_target_dps, star_intensity, star_music_intensity, star_music_style, double_row_ui, instant_restart, hard_drop_ring, high_contrast_blocks, big_first_bag_preview, fullscreen_mode, music_mode, music_shuffle);
            } else if g_settings.selected_row == SETTINGS_ROW_CHOOSE_SHADER && rowBodyHit(mouse, SETTINGS_ROW_CHOOSE_SHADER, bg_stars_mode[0], shader_mode[0]) {
                openShaderPicker(custom_shader_name);
            } else if g_settings.selected_row == SETTINGS_ROW_MANAGE_THEMES && rowBodyHit(mouse, SETTINGS_ROW_MANAGE_THEMES, bg_stars_mode[0], shader_mode[0]) {
                openThemeManager(theme_index);
            } else if g_settings.selected_row == SETTINGS_ROW_SELECT_SONGS && rowBodyHit(mouse, SETTINGS_ROW_SELECT_SONGS, bg_stars_mode[0], shader_mode[0]) {
                if g_star_music_track_count > 0 {openSongPicker();}
            } else if rowUsesToggleMouseNudge(g_settings.selected_row) && rowBodyHit(mouse, g_settings.selected_row, bg_stars_mode[0], shader_mode[0]) {
                act = settingsNudgeRow(g_settings.selected_row, 1, theme_index, shader_mode, crt_curvature, crt_brightness, vhs_waves, vhs_damage, arr, das, dcd, sdf, music_volume, board_bounciness, bg_stars_amount, bg_stars_mode, star_peak_target_dps, star_intensity, star_music_intensity, star_music_style, double_row_ui, instant_restart, hard_drop_ring, high_contrast_blocks, big_first_bag_preview, fullscreen_mode, music_mode, music_shuffle);
            } else if g_settings.selected_row == SETTINGS_ROW_BACK && rowBodyHit(mouse, SETTINGS_ROW_BACK, bg_stars_mode[0], shader_mode[0]) {
                return SETTINGS_ACTION_BACK;
            }
            if act != SETTINGS_ACTION_NONE {return act;}
        }
    }

    if IsMouseButtonDown(MOUSE_BUTTON_LEFT) {
        dragSliderF32(mouse, SETTINGS_ROW_CRT_CURVATURE, bg_stars_mode[0], shader_mode[0], crt_curvature, 0.2, 1.4);
        dragSliderF32(mouse, SETTINGS_ROW_CRT_BRIGHTNESS, bg_stars_mode[0], shader_mode[0], crt_brightness, 0.6, 1.8);
        dragSliderF32(mouse, SETTINGS_ROW_VHS_WAVES, bg_stars_mode[0], shader_mode[0], vhs_waves, 0.0, 1.4);
        dragSliderF32(mouse, SETTINGS_ROW_VHS_DAMAGE, bg_stars_mode[0], shader_mode[0], vhs_damage, 0.0, 1.5);
        dragSliderF32(mouse, SETTINGS_ROW_ARR, bg_stars_mode[0], shader_mode[0], arr, 0.0, 8.0);
        dragSliderF32(mouse, SETTINGS_ROW_DAS, bg_stars_mode[0], shader_mode[0], das, 0.0, 20.0);
        dragSliderF32(mouse, SETTINGS_ROW_DCD, bg_stars_mode[0], shader_mode[0], dcd, 0.0, 10.0);
        dragSliderF32(mouse, SETTINGS_ROW_SDF, bg_stars_mode[0], shader_mode[0], sdf, 1.0, 40.0);
        dragSliderF32(mouse, SETTINGS_ROW_MUSIC_VOLUME, bg_stars_mode[0], shader_mode[0], music_volume, 0.0, 1.0);
        dragSliderI32(mouse, SETTINGS_ROW_BOARD_BOUNCINESS, bg_stars_mode[0], shader_mode[0], board_bounciness, 0.0, 100.0);
        dragSliderI32(mouse, SETTINGS_ROW_BG_STARS_AMOUNT, bg_stars_mode[0], shader_mode[0], bg_stars_amount, 0.0, 150.0);
        dragSliderF32(mouse, SETTINGS_ROW_STAR_PEAK_TARGET, bg_stars_mode[0], shader_mode[0], star_peak_target_dps, 0.5, 3.5);
        dragSliderF32(mouse, SETTINGS_ROW_STAR_INTENSITY, bg_stars_mode[0], shader_mode[0], star_intensity, 0.1, 1.0);
        dragSliderF32(mouse, SETTINGS_ROW_MUSIC_INTENSITY, bg_stars_mode[0], shader_mode[0], star_music_intensity, 0.1, 1.0);
    }

    settingsEnsureSelectedVisible(bg_stars_mode[0], shader_mode[0]);
    return SETTINGS_ACTION_NONE;
}
