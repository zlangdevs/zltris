#define SETTINGS_ROW_SECTION_AUDIO 27
#define SETTINGS_ROW_MUSIC_VOLUME 28
#define SETTINGS_ROW_MUSIC_MODE 29
#define SETTINGS_ROW_SELECT_SONGS 30
#define SETTINGS_ROW_MUSIC_SHUFFLE 31

#define SETTINGS_ROW_BACK 32
#define SETTINGS_ROW_COUNT 33
#define SETTINGS_VISIBLE_ROWS 8

#define STAR_MODE_NONE 0
#define STAR_MODE_DROPS 1
#define STAR_MODE_MUSIC 2
#define SHADER_MODE_NONE 0
#define SHADER_MODE_LIGHT_CRT 1
#define SHADER_MODE_CRT 2
