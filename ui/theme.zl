module zltris.theme;

#define BUILTIN_THEME_COUNT 6
#define THEME_SLOT_CUSTOM BUILTIN_THEME_COUNT
#define CUSTOM_THEME_MAX 12
#define CUSTOM_THEME_NAME_MAX 48
#define CUSTOM_THEME_NAME_STORAGE 576

#define THEME_FIELD_BG_OUTER 0
#define THEME_FIELD_BG_INNER 1
#define THEME_FIELD_PANEL_BG 2
#define THEME_FIELD_PANEL_STROKE 3
#define THEME_FIELD_BOARD_BG 4
#define THEME_FIELD_BOARD_GRID 5
#define THEME_FIELD_TEXT_MAIN 6
#define THEME_FIELD_TEXT_MUTED 7
#define THEME_FIELD_PIECE_I 8
#define THEME_FIELD_PIECE_O 9
#define THEME_FIELD_PIECE_T 10
#define THEME_FIELD_PIECE_J 11
#define THEME_FIELD_PIECE_L 12
#define THEME_FIELD_PIECE_S 13
#define THEME_FIELD_PIECE_Z 14
#define THEME_FIELD_COUNT 15

struct Theme {
    name ptr<u8>,
    bg_outer u32,
    bg_inner u32,
    panel_bg u32,
    panel_stroke u32,
    board_bg u32,
    board_grid u32,
    text_main u32,
    text_muted u32,
    piece_i u32,
    piece_o u32,
    piece_t u32,
    piece_j u32,
    piece_l u32,
    piece_s u32,
    piece_z u32,
}

fun themeRgba(r: i32, g: i32, b: i32, a: i32) >> u32 {
    return (r as u32) |
           ((g as u32) << 8) |
           ((b as u32) << 16) |
           ((a as u32) << 24);
}

