fun init(self: SettingsState) >> SettingsState {
    SettingsState next = self;
    next.selected_row = SETTINGS_ROW_THEME;
    next.scroll = 0.0;
    next.controls_expanded = g_settings_controls_expanded;
    next.controls_anim = 0.0;
    if next.controls_expanded {next.controls_anim = 1.0;}
    next.video_expanded = g_settings_video_expanded;
    next.video_anim = 0.0;
    if next.video_expanded {next.video_anim = 1.0;}
    next.audio_expanded = g_settings_audio_expanded;
    next.audio_anim = 0.0;
    if next.audio_expanded {next.audio_anim = 1.0;}
    next.picker_open = false;
    next.picker_scroll = 0.0;
    next.picker_selected = 0;
    next.picker_count = 0;
    next.mouse_last_x = 0.0;
    next.mouse_last_y = 0.0;
    next.keyboard_nav_lock = false;
    next.song_picker_open = false;
    next.song_picker_scroll = 0.0;
    next.song_picker_selected = 0;
    next.theme_custom_active = false;
    next.theme_mgr_open = false;
    next.theme_mgr_focus = THEME_MGR_FOCUS_LIST;
    next.theme_mgr_selected = 0;
    next.theme_mgr_scroll = 0.0;
    next.theme_mgr_field = 0;
    next.theme_mgr_name_edit = false;
    next.theme_mgr_name[0] = 0;
    next.theme_mgr_name_cursor = 0;
    next.theme_mgr_brightness = 1.0;
    next.theme_mgr_hue = 0.0;
    next.theme_mgr_saturation = 0.0;
    next.theme_mgr_button = THEME_MGR_BUTTON_NEW;
    next.theme_mgr_left_repeat = 0.0;
    next.theme_mgr_right_repeat = 0.0;
    next.theme_mgr_backspace_repeat = 0.0;
    next.theme_mgr_delete_repeat = 0.0;
    return next;
}

SettingsState g_settings = {0};

#define SETTINGS_BG_GRID 18
#define SETTINGS_BG_PHASES 16

fun settingsInit() >> void {
    g_settings = g_settings.init();
}

fun settingsActionNone() >> i32 { return SETTINGS_ACTION_NONE; }
fun settingsActionBack() >> i32 { return SETTINGS_ACTION_BACK; }

fun absi(v: i32) >> i32 {
    if v < 0 {return -v;}
    return v;
}

fun maxi(a: i32, b: i32) >> i32 {
    if a > b {return a;}
    return b;
}

fun maxf(a: f32, b: f32) >> f32 {
    if a > b {return a;}
    return b;
}

fun minf(a: f32, b: f32) >> f32 {
    if a < b {return a;}
    return b;
}

fun posMod(v: i32, m: i32) >> i32 {
    if m <= 0 {return 0;}
    i32 r = v % m;
    if r < 0 {r += m;}
    return r;
}

fun hash32(v: i32) >> i32 {
    i32 x = v * 1664525 + 1013904223;
    x = x ^ (x >> 16);
    if x < 0 {x = -x;}
    return x;
}

fun triWave01(v: f32) >> f32 {
    f32 t = fractf(v);
    if t < 0.5 {return t * 2.0;}
    return (1.0 - t) * 2.0;
}

fun pulseBand(distance: f32, width: f32) >> f32 {
    if width <= 0.0 {return 0.0;}
    return clamp01(1.0 - distance / width);
}

fun zltrisGlyphFilled(letter: i32, col: i32, row: i32) >> bool {
    if col < 0 || col >= 5 || row < 0 || row >= 7 {return false;}

    if (letter == 0) {
        if row == 0 || row == 6 {return true;}
        if row == 1 {return col == 3;}
        if row == 2 {return col == 2;}
        if row == 3 {return col == 2;}
        if row == 4 {return col == 1;}
        return col == 0;
    }

    if letter == 1 {return col == 0 || row == 6;}

    if letter == 2 {return row == 0 || col == 2;}

    if (letter == 3) {
        if col == 0 {return true;}
        if row == 0 || row == 3 {return col <= 3;}
        if col == 3 && row < 3 {return true;}
        if row >= 3 && col == row - 2 {return true;}
        return false;
    }

    if letter == 4 {return row == 0 || row == 6 || col == 2;}

    if row == 0 || row == 3 || row == 6 {return true;}
    if row < 3 {return col == 0;}
    return col == 4;
}

fun chevronGlyphFilled(right_dir: bool, col: i32, row: i32) >> bool {
    if col < 0 || col >= 5 || row < 0 || row >= 7 {return false;}

    i32 band = row;
    if band > 3 {band = 6 - row;}

    if right_dir {return col == band || col == (band + 1);}
    return col == (4 - band) || col == (3 - band);
}

fun drawImpulseGridBackground(font: Font, theme: Theme) >> void {
    i64 left = visibleBaseLeft();
    i64 right = visibleBaseRight();
    i64 top = 0;
    i64 bottom = 920;
    i64 step = SETTINGS_BG_GRID;

    f32 t = GetTime() as f32;
    f32 span_x = (right - left) as f32;
    f32 span_y = (bottom - top) as f32;
    if span_x < 1.0 {span_x = 1.0;}
    if span_y < 1.0 {span_y = 1.0;}

    f32 cx = ((left + right) as f32) * 0.5;
    f32 cy = ((top + bottom) as f32) * 0.5;

    f32 impulse_time = 1.5;
    f32 pause_time = 1.0;
    f32 cycle_time = impulse_time + pause_time;
    i32 cycle_idx = (t / cycle_time) as i32;
    f32 cycle_local = t - (cycle_idx as f32) * cycle_time;
    bool in_pause = cycle_local >= impulse_time;
    f32 p = cycle_local / impulse_time;
    p = clamp01(p);
    f32 envelope = 0.34 + triWave01(p) * 0.66;

    i32 block_idx = cycle_idx / SETTINGS_BG_PHASES;
    i32 pos_in_block = posMod(cycle_idx, SETTINGS_BG_PHASES);
    i32 step_pick = posMod(hash32(block_idx + 311), 4);
    i32 phase_step = 1;
    if (step_pick == 1) {phase_step = 5;} else if (step_pick == 2) {
        phase_step = 9;
    } else if (step_pick == 3) {
        phase_step = 13;
    }
    i32 shift = posMod(hash32(block_idx + 911), SETTINGS_BG_PHASES);
    i32 phase = posMod(shift + pos_in_block * phase_step, SETTINGS_BG_PHASES);
    i32 color_pick = posMod(hash32(cycle_idx + 97), 7);
    i32 corner_pick = posMod(hash32(cycle_idx + 555), 4);
    i32 block_size = 2;
    if posMod(hash32(cycle_idx + 777), 2) == 1 {block_size = 3;}
    i32 corner_pick2 = posMod(hash32(cycle_idx + 1333), 4);
    i32 lane_span = 3 + posMod(hash32(cycle_idx + 1666), 4);

    i32 text_chars = 6;
    i32 glyph_w = 5;
    i32 glyph_h = 7;
    i32 glyph_gap = 1;
    i32 text_grid_w = text_chars * glyph_w + (text_chars - 1) * glyph_gap;
    i32 text_grid_h = glyph_h;
    f32 text_w_base = (text_grid_w as f32) * (step as f32);
    f32 text_h_base = (text_grid_h as f32) * (step as f32);
    f32 start_x = (left as f32) - text_w_base - 1.0 * (step as f32);
    f32 end_x = (right as f32) + 1.0 * (step as f32);
    f32 travel_p = p;
    if travel_p > 1.0 {travel_p = 1.0;}
    f32 text_x = start_x + (end_x - start_x) * travel_p;
    f32 text_y = cy - text_h_base * 0.5;

    f32 lr_pos = (left as f32) - 120.0 + p * (span_x + 240.0);
    f32 rl_pos = (right as f32) + 120.0 - p * (span_x + 240.0);
    f32 tb_pos = (top as f32) - 120.0 + p * (span_y + 240.0);
    f32 bt_pos = (bottom as f32) + 120.0 - p * (span_y + 240.0);

    f32 diag_min = ((left + top) as f32) - 140.0;
    f32 diag_span = span_x + span_y + 280.0;
    f32 d1_pos = diag_min + p * diag_span;

    f32 anti_min = ((left - bottom) as f32) - 140.0;
    f32 anti_span = span_x + span_y + 280.0;
    f32 d2_pos = anti_min + p * anti_span;

    f32 x_radius = p * (maxf(span_x, span_y) * 0.7 + 160.0);
    f32 center_travel = p * (span_y * 0.62 + 180.0);

    i32 grid_w = ((span_x / (step as f32)) as i32) + 2;
    i32 grid_h = ((span_y / (step as f32)) as i32) + 2;
    i32 center_ix = grid_w / 2;
    i32 center_iy = grid_h / 2;
    i32 max_ring = maxi(center_ix, center_iy) + 3;

    for i64 y = top - step; y < bottom + step; y += step {
        for i64 x = left - step; x < right + step; x += step {
            f32 gx = x as f32;
            f32 gy = y as f32;

            f32 e = 0.0;
            u32 impulse_color = theme.panel_stroke;
            u32 accent_color = theme.text_main;

            if (color_pick == 0) {
                impulse_color = theme.panel_stroke;
                accent_color = theme.text_main;
            } else if (color_pick == 1) {
                impulse_color = theme.text_muted;
                accent_color = theme.piece_o;
            } else if (color_pick == 2) {
                impulse_color = theme.piece_i;
                accent_color = theme.text_main;
            } else if (color_pick == 3) {
                impulse_color = theme.piece_t;
                accent_color = theme.text_muted;
            } else if (color_pick == 4) {
                impulse_color = theme.piece_o;
                accent_color = theme.piece_s;
            } else if (color_pick == 5) {
                impulse_color = theme.piece_s;
                accent_color = theme.piece_z;
            } else {
                impulse_color = theme.piece_z;
                accent_color = theme.text_main;
            }

            if (!in_pause) {
                if (phase == 0) {e = pulseBand(absf(gx - lr_pos), 54.0);} else if (phase == 1) {
                    e = pulseBand(absf(gx - rl_pos), 54.0);
                } else if (phase == 2) {
                    e = pulseBand(absf(gy - tb_pos), 48.0);
                } else if (phase == 3) {
                    e = pulseBand(absf(gy - bt_pos), 48.0);
                } else if (phase == 4) {
                    e = pulseBand(absf((gx + gy) - d1_pos), 54.0);
                } else if (phase == 5) {
                    e = pulseBand(absf((gx - gy) - d2_pos), 54.0);
                } else if (phase == 6) {
                    f32 arm = x_radius;

                    f32 tip_rx = cx + arm;
                    f32 back_rx = tip_rx - gx;
                    f32 e_right = 0.0;
                    if (back_rx >= 0.0) {
                        f32 d_right = absf(absf(gy - cy) - back_rx);
                        e_right = pulseBand(d_right, 18.0);
                    }

                    f32 tip_lx = cx - arm;
                    f32 back_lx = gx - tip_lx;
                    f32 e_left = 0.0;
                    if (back_lx >= 0.0) {
                        f32 d_left = absf(absf(gy - cy) - back_lx);
                        e_left = pulseBand(d_left, 18.0);
                    }

                    f32 tip_ty = cy - arm;
                    f32 back_ty = gy - tip_ty;
                    f32 e_up = 0.0;
                    if (back_ty >= 0.0) {
                        f32 d_up = absf(absf(gx - cx) - back_ty);
                        e_up = pulseBand(d_up, 18.0);
                    }

                    f32 tip_by = cy + arm;
                    f32 back_by = tip_by - gy;
                    f32 e_down = 0.0;
                    if (back_by >= 0.0) {
                        f32 d_down = absf(absf(gx - cx) - back_by);
                        e_down = pulseBand(d_down, 18.0);
                    }

                    e = maxf(maxf(e_left, e_right), maxf(e_up, e_down));
                } else {
                    if (phase == 7) {
                        f32 ex = (gx - cx) / 90.0 + p * 2.2;
                        f32 w_shape = (triWave01(ex) - 0.5) * 78.0;
                        f32 w_up = cy - center_travel + w_shape;
                        f32 w_dn = cy + center_travel - w_shape;
                        e = maxf(pulseBand(absf(gy - w_up), 20.0), pulseBand(absf(gy - w_dn), 20.0));
                    } else if (phase == 8) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 ix = gx_i;
                        i32 iy = gy_i;
                        if (corner_pick == 1) {ix = grid_w - gx_i;} else if (corner_pick == 2) {
                            iy = grid_h - gy_i;
                        } else if (corner_pick == 3) {
                            ix = grid_w - gx_i;
                            iy = grid_h - gy_i;
                        }

                        i32 bx = (gx_i + 4096) / block_size;
                        i32 by = (gy_i + 4096) / block_size;
                        bool checker = posMod(bx + by, 2) == 0;

                        f32 total_d = (grid_w + grid_h) as f32;
                        f32 d = (ix + iy) as f32;
                        f32 fill_front = p * 2.0 * total_d;
                        if fill_front > total_d {fill_front = total_d;}
                        f32 clear_front = 0.0;
                        if p > 0.5 {clear_front = (p - 0.5) * 2.0 * total_d;}

                        if checker && d <= fill_front && d >= clear_front {e = 0.42 + pulseBand(absf(d - fill_front), 16.0) * 0.58;}

                        impulse_color = theme.text_main;
                        accent_color = theme.piece_o;
                    } else if (phase == 9) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 dx_i = absi(gx_i - center_ix);
                        i32 dy_i = absi(gy_i - center_iy);
                        i32 ring = maxi(dx_i, dy_i);
                        f32 ring_wave = p * (max_ring as f32);
                        f32 ring_band = pulseBand(absf((ring as f32) - ring_wave), 2.2);

                        i32 lane = posMod(gx_i + gy_i + cycle_idx, 3);
                        if (lane == 0) {e = ring_band;} else if (lane == 1) {
                            e = ring_band * 0.74;
                        } else {
                            e = ring_band * 0.46;
                        }

                        impulse_color = theme.piece_i;
                        accent_color = theme.piece_z;
                    } else if (phase == 10) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 bx = (gx_i + 4096) / block_size;
                        i32 by = (gy_i + 4096) / block_size;
                        i32 lane = posMod(bx - by + cycle_idx, lane_span);
                        f32 lane_target = p * (lane_span as f32);
                        f32 lane_e = pulseBand(absf((lane as f32) - lane_target), 1.1);
                        f32 beat = triWave01((bx + by) as f32 * 0.17 + p * 2.0);
                        e = lane_e * (0.35 + beat * 0.65);
                        impulse_color = theme.piece_t;
                        accent_color = theme.text_main;
                    } else if (phase == 11) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 dx_i = absi(gx_i - center_ix);
                        i32 gate = posMod(dx_i + cycle_idx, lane_span + 2);
                        f32 gate_target = p * ((lane_span + 2) as f32);
                        f32 gate_e = pulseBand(absf((gate as f32) - gate_target), 1.2);
                        f32 row_blink = triWave01((gy_i as f32) * 0.15 + p * 3.0);
                        e = gate_e * (0.30 + row_blink * 0.70);
                        impulse_color = theme.text_muted;
                        accent_color = theme.piece_o;
                    } else if (phase == 12) {
                        f32 dx = absf(gx - cx);
                        f32 dy = absf(gy - cy);

                        f32 plus_mask = maxf(pulseBand(dx, 24.0), pulseBand(dy, 24.0));
                        f32 flash_env = pulseBand(p, 0.24);
                        f32 plus_flash = plus_mask * (0.52 + flash_env * 0.90);

                        f32 diag_line = pulseBand(absf(dx - dy), 18.0);
                        f32 diag_dist = (dx + dy) * 0.5;
                        f32 diag_wave = pulseBand(absf(diag_dist - x_radius), 44.0);
                        f32 corner_impulse = diag_line * diag_wave;

                        f32 center_burst = pulseBand(dx + dy, 20.0) * flash_env;
                        e = maxf(maxf(plus_flash, corner_impulse), center_burst);
                        impulse_color = theme.text_main;
                        accent_color = theme.piece_i;
                    } else if (phase == 13) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 ix = gx_i;
                        i32 iy = gy_i;
                        if (corner_pick2 == 1) {ix = grid_w - gx_i;} else if (corner_pick2 == 2) {
                            iy = grid_h - gy_i;
                        } else if (corner_pick2 == 3) {
                            ix = grid_w - gx_i;
                            iy = grid_h - gy_i;
                        }
                        i32 ring = maxi(ix, iy);
                        f32 ring_front = p * (maxi(grid_w, grid_h) as f32);
                        f32 ring_e = pulseBand(absf((ring as f32) - ring_front), 1.8);
                        i32 hash_gate = posMod(hash32(ix * 73 + iy * 131 + cycle_idx * 17), 5);
                        if (hash_gate == 0 || hash_gate == 2) {e = ring_e;} else {
                            e = ring_e * 0.42;
                        }
                        impulse_color = theme.piece_s;
                        accent_color = theme.piece_z;
                    } else if (phase == 14) {
                        i32 gx_i = ((x - left) / step) as i32;
                        i32 gy_i = ((y - top) / step) as i32;
                        i32 r3 = posMod(gx_i + cycle_idx, 3);
                        i32 c3 = posMod(gy_i + cycle_idx, 3);
                        bool cluster = (r3 == 0 && c3 == 0) || (r3 == 1 && c3 == 1) || (r3 == 2 && c3 == 2);
                        f32 travel = p * (span_x + span_y + 260.0);
                        f32 sweep = pulseBand(absf((gx + gy) - ((left + top) as f32 + travel)), 70.0);
                        if cluster {e = sweep;} else {
                            e = sweep * 0.36;
                        }
                        impulse_color = theme.piece_o;
                        accent_color = theme.text_main;
                    } else {
                        f32 rx = gx - text_x;
                        f32 ry = gy - text_y;
                        i32 ix = (rx / (step as f32)) as i32;
                        i32 iy = (ry / (step as f32)) as i32;

                        bool inside = rx >= 0.0 && ry >= 0.0 && rx < text_w_base && ry < text_h_base;
                        if inside {
                            i32 char_span = glyph_w + glyph_gap;
                            i32 letter = ix / char_span;
                            i32 col = ix % char_span;
                            if (letter >= 0 && letter < text_chars && col < glyph_w) {
                                if zltrisGlyphFilled(letter, col, iy) {e = 1.0;}
                            }
                        }

                        impulse_color = theme.text_main;
                        accent_color = theme.piece_t;
                    }
                }
            }

            f32 idle_breathe = triWave01(t * 0.26 + ((x + y) as f32) / 430.0);
            fillRect(x, y, step - 2, step - 2, alphaColor(theme.board_grid, 0.11 + idle_breathe * 0.04));

            if (e > 0.0) {
                f32 ea = e * envelope;
                i64 center_x = x + step / 2;
                i64 center_y = y + step / 2;
                f32 glow_r = uiS(step) as f32 * (0.9 + ea * 1.2);

                DrawCircleGradient(
                    uiX(center_x),
                    uiY(center_y),
                    glow_r,
                    toColor(alphaColor(impulse_color, 0.20 + ea * 0.62)),
                    toColor(alphaColor(theme.bg_outer, 0.0))
                );

                DrawCircleGradient(
                    uiX(center_x),
                    uiY(center_y),
                    glow_r * 0.52,
                    toColor(alphaColor(accent_color, 0.18 + ea * 0.52)),
                    toColor(alphaColor(theme.bg_outer, 0.0))
                );

                fillRect(x + 1, y + 1, step - 4, step - 4, alphaColor(impulse_color, 0.20 + ea * 0.68));
                fillRect(x + 3, y + 3, step - 8, step - 8, alphaColor(accent_color, 0.12 + ea * 0.40));
            }
        }
    }

    font;
}

fun clampf(v: f32, min_v: f32, max_v: f32) >> f32 {
    if v < min_v {return min_v;}
    if v > max_v {return max_v;}
    return v;
}

fun loadI32(p: ptr<i32>) >> i32 {return p[0];}
fun storeI32(p: ptr<i32>, v: i32) >> void {p[0] = v;}
fun loadF32(p: ptr<f32>) >> f32 {return p[0];}
fun storeF32(p: ptr<f32>, v: f32) >> void {p[0] = v;}
fun loadBool(p: ptr<bool>) >> bool {return p[0];}
fun storeBool(p: ptr<bool>, v: bool) >> void {p[0] = v;}

fun colorRf(color: u32) >> f32 {return (color & 255) as f32 / 255.0;}
fun colorGf(color: u32) >> f32 {return ((color >> 8) & 255) as f32 / 255.0;}
fun colorBf(color: u32) >> f32 {return ((color >> 16) & 255) as f32 / 255.0;}
fun colorAf(color: u32) >> f32 {return ((color >> 24) & 255) as f32 / 255.0;}
fun colorOpaque(color: u32) >> u32 {return (color & 0x00FFFFFF) | 0xFF000000;}

fun sqrtApprox(v: f32) >> f32 {
    if v <= 0.0 {return 0.0;}
    f32 x = v;
    if x < 1.0 {x = 1.0;}
    for i32 i = 0; i < 6; i++ {
        x = ((x + v / x) * 0.5);
    }
    return x;
}

fun hsvToColor(h: f32, s: f32, v: f32, a: f32) >> u32 {
    f32 hh = h;
    for (hh < 0.0) {hh += 360.0;}
    for (hh >= 360.0) {hh -= 360.0;}
    f32 ss = clampf(s, 0.0, 1.0);
    f32 vv = clampf(v, 0.0, 1.0);

    f32 c = vv * ss;
    f32 hp = hh / 60.0;
    f32 hp_mod2 = hp;
    for (hp_mod2 >= 2.0) {hp_mod2 -= 2.0;}
    for (hp_mod2 < 0.0) {hp_mod2 += 2.0;}
    f32 x = c * (1.0 - absf(hp_mod2 - 1.0));

    f32 r1 = 0.0;
    f32 g1 = 0.0;
    f32 b1 = 0.0;
    if hp < 1.0 {
        r1 = c;
        g1 = x;
    } else if hp < 2.0 {
        r1 = x;
        g1 = c;
    } else if hp < 3.0 {
        g1 = c;
        b1 = x;
    } else if hp < 4.0 {
        g1 = x;
        b1 = c;
    } else if hp < 5.0 {
        r1 = x;
        b1 = c;
    } else {
        r1 = c;
        b1 = x;
    }

    f32 m = vv - c;
    i32 ri = ((r1 + m) * 255.0 + 0.5) as i32;
    i32 gi = ((g1 + m) * 255.0 + 0.5) as i32;
    i32 bi = ((b1 + m) * 255.0 + 0.5) as i32;
    if ri < 0 {ri = 0;} else if ri > 255 {ri = 255;}
    if gi < 0 {gi = 0;} else if gi > 255 {gi = 255;}
    if bi < 0 {bi = 0;} else if bi > 255 {bi = 255;}

    i32 ai = (clampf(a, 0.0, 1.0) * 255.0 + 0.5) as i32;
    if ai < 0 {ai = 0;} else if ai > 255 {ai = 255;}
    return themeRgba(ri, gi, bi, ai);
}

fun colorToHsv(color: u32, out_h: ptr<f32>, out_s: ptr<f32>, out_v: ptr<f32>) >> void {
    i32 ri = (color & 255) as i32;
    i32 gi = ((color >> 8) & 255) as i32;
    i32 bi = ((color >> 16) & 255) as i32;

    i32 maxc = ri;
    if gi > maxc {maxc = gi;}
    if bi > maxc {maxc = bi;}
    i32 minc = ri;
    if gi < minc {minc = gi;}
    if bi < minc {minc = bi;}
    i32 delta = maxc - minc;

    f32 h = 0.0;
    if delta > 0 {
        if maxc == ri {
            h = (((gi - bi) as f32) / (delta as f32)) * 60.0;
        } else if maxc == gi {
            h = ((((bi - ri) as f32) / (delta as f32)) + 2.0) * 60.0;
        } else {
            h = ((((ri - gi) as f32) / (delta as f32)) + 4.0) * 60.0;
        }
        if h < 0.0 {h += 360.0;}
    }

    f32 v = (maxc as f32) / 255.0;
    f32 s = 0.0;
    if maxc > 0 {s = (delta as f32) / (maxc as f32);}
    out_h[0] = h;
    out_s[0] = clampf(s, 0.0, 1.0);
    out_v[0] = clampf(v, 0.0, 1.0);
}

fun themeMgrNameLen() >> i32 {
    i32 len = 0;
    for (len < CUSTOM_THEME_NAME_MAX - 1 && g_settings.theme_mgr_name[len] != 0) {len += 1;}
    return len;
}

fun themeMgrClampNameCursor() >> void {
    i32 len = themeMgrNameLen();
    if g_settings.theme_mgr_name_cursor < 0 {g_settings.theme_mgr_name_cursor = 0;}
    if g_settings.theme_mgr_name_cursor > len {g_settings.theme_mgr_name_cursor = len;}
    if g_settings.theme_mgr_name_cursor > 0 && g_settings.theme_mgr_name_cursor < len {
        for ((g_settings.theme_mgr_name[g_settings.theme_mgr_name_cursor] & 0xC0) == 0x80) {
            g_settings.theme_mgr_name_cursor -= 1;
            if g_settings.theme_mgr_name_cursor <= 0 {break;}
        }
    }
}

fun themeMgrLoadNameBuffer() >> void {
    copyFixed(&g_settings.theme_mgr_name[0], customThemeName(g_settings.theme_mgr_selected), CUSTOM_THEME_NAME_MAX);
    g_settings.theme_mgr_name_cursor = themeMgrNameLen();
}

fun themeMgrCommitNameBuffer() >> void {
    customThemeSetName(g_settings.theme_mgr_selected, &g_settings.theme_mgr_name[0]);
    themeMgrClampNameCursor();
}

fun themeMgrPrevCharStart(index: i32) >> i32 {
    i32 i = index;
    if i <= 0 {return 0;}
    i -= 1;
    for (i > 0 && (g_settings.theme_mgr_name[i] & 0xC0) == 0x80) {i -= 1;}
    return i;
}

fun themeMgrNextCharStart(index: i32) >> i32 {
    i32 len = themeMgrNameLen();
    i32 i = index;
    if i >= len {return len;}
    i += 1;
    for (i < len && (g_settings.theme_mgr_name[i] & 0xC0) == 0x80) {i += 1;}
    return i;
}

fun themeMgrDeleteAtCursor(backspace: bool) >> void {
    i32 len = themeMgrNameLen();
    themeMgrClampNameCursor();

    i32 from = g_settings.theme_mgr_name_cursor;
    i32 to = g_settings.theme_mgr_name_cursor;
    if backspace {
        if from <= 0 {return;}
        from = themeMgrPrevCharStart(from);
    } else {
        if from >= len {return;}
        to = themeMgrNextCharStart(from);
    }

    if backspace {to = g_settings.theme_mgr_name_cursor;}

    i32 shift = to - from;
    if shift <= 0 {return;}

    for i32 i = from; i <= len - shift; i++ {
        g_settings.theme_mgr_name[i] = g_settings.theme_mgr_name[i + shift];
    }
    g_settings.theme_mgr_name_cursor = from;
    themeMgrCommitNameBuffer();
}

fun themeMgrInsertChar(ch: i32) >> void {
    if ch < 32 || ch == 127 {return;}

    arr<u8, 4> bytes = {0};
    i32 n = 0;
    if ch <= 0xFF {
        bytes[0] = ch as u8;
        n = 1;
    } else if ch <= 0x7FF {
        bytes[0] = (0xC0 | ((ch >> 6) & 0x1F)) as u8;
        bytes[1] = (0x80 | (ch & 0x3F)) as u8;
        n = 2;
    } else if ch <= 0xFFFF {
        bytes[0] = (0xE0 | ((ch >> 12) & 0x0F)) as u8;
        bytes[1] = (0x80 | ((ch >> 6) & 0x3F)) as u8;
        bytes[2] = (0x80 | (ch & 0x3F)) as u8;
        n = 3;
    } else if ch <= 0x10FFFF {
        bytes[0] = (0xF0 | ((ch >> 18) & 0x07)) as u8;
        bytes[1] = (0x80 | ((ch >> 12) & 0x3F)) as u8;
        bytes[2] = (0x80 | ((ch >> 6) & 0x3F)) as u8;
        bytes[3] = (0x80 | (ch & 0x3F)) as u8;
        n = 4;
    } else {
        return;
    }

    i32 len = themeMgrNameLen();
    themeMgrClampNameCursor();
    if len + n >= CUSTOM_THEME_NAME_MAX {return;}

    i32 i = len;
    for (i >= g_settings.theme_mgr_name_cursor) {
        g_settings.theme_mgr_name[i + n] = g_settings.theme_mgr_name[i];
        if i == g_settings.theme_mgr_name_cursor {break;}
        i -= 1;
    }

    for i32 b = 0; b < n; b++ {
        g_settings.theme_mgr_name[g_settings.theme_mgr_name_cursor + b] = bytes[b];
    }
    g_settings.theme_mgr_name_cursor += n;
    themeMgrCommitNameBuffer();
}

fun themeMgrInsertUtf8Text(text: ptr<u8>) >> void {
    if text == (0 as ptr<u8>) {return;}

    i32 add = 0;
    i32 i = 0;
    for (text[i] != 0) {
        u8 ch = text[i];
        if ch != ('\n' as u8) && ch != ('\r' as u8) && ch != ('\t' as u8) {
            add += 1;
        }
        i += 1;
    }
    if add <= 0 {return;}

    i32 len = themeMgrNameLen();
    themeMgrClampNameCursor();
    i32 free = (CUSTOM_THEME_NAME_MAX - 1) - len;
    if free <= 0 {return;}
    if add > free {add = free;}

    i32 at = g_settings.theme_mgr_name_cursor;
    for i32 p = len; p >= at; p-- {
        g_settings.theme_mgr_name[p + add] = g_settings.theme_mgr_name[p];
    }

    i32 wrote = 0;
    i = 0;
    for (text[i] != 0 && wrote < add) {
        u8 ch = text[i];
        if ch != ('\n' as u8) && ch != ('\r' as u8) && ch != ('\t' as u8) {
            g_settings.theme_mgr_name[at + wrote] = ch;
            wrote += 1;
        }
        i += 1;
    }

    g_settings.theme_mgr_name_cursor = at + wrote;
    themeMgrClampNameCursor();
    themeMgrCommitNameBuffer();
}

fun themeMgrRangeWidth(font: Font, size: i64, start_idx: i32, end_idx: i32) >> i64 {
    return uiTextRangeWidth(font, &g_settings.theme_mgr_name[0], size, start_idx, end_idx);
}

fun themeMgrCursorOffset(font: Font, size: i64) >> i64 {
    themeMgrClampNameCursor();
    return themeMgrRangeWidth(font, size, 0, g_settings.theme_mgr_name_cursor);
}

fun themeMgrCursorOffsetAt(font: Font, size: i64, idx: i32) >> i64 {
    i32 len = themeMgrNameLen();
    i32 at = idx;
    if at < 0 {at = 0;}
    if at > len {at = len;}
    return themeMgrRangeWidth(font, size, 0, at);
}

fun themeMgrVisibleStart(font: Font, size: i64, max_w: i64) >> i32 {
    return uiTextVisibleStartForCursor(font, &g_settings.theme_mgr_name[0], size, g_settings.theme_mgr_name_cursor, max_w);
}

fun themeMgrSetCursorFromMouse(font: Font, size: i64, text_x: i64, mouse_x: f32, start_idx: i32) >> void {
    uiTextSetCursorFromMouse(font, &g_settings.theme_mgr_name[0], size, text_x, mouse_x, start_idx, &g_settings.theme_mgr_name_cursor);
    themeMgrClampNameCursor();
}

fun themeMgrSyncWheelFromThemeColor() >> void {
    i32 field = g_settings.theme_mgr_field;
    if field < 0 {field = 0;}
    if field >= customThemeFieldCount() {field = customThemeFieldCount() - 1;}
    g_settings.theme_mgr_field = field;

    u32 color = customThemeGetColor(g_settings.theme_mgr_selected, field);
    colorToHsv(color, &g_settings.theme_mgr_hue, &g_settings.theme_mgr_saturation, &g_settings.theme_mgr_brightness);
}

fun themeMgrApplyWheelColor() >> void {
    u32 old = customThemeGetColor(g_settings.theme_mgr_selected, g_settings.theme_mgr_field);
    u32 c = hsvToColor(g_settings.theme_mgr_hue, g_settings.theme_mgr_saturation, g_settings.theme_mgr_brightness, colorAf(old));
    customThemeSetColor(g_settings.theme_mgr_selected, g_settings.theme_mgr_field, c);
}

fun themeMgrSelectTheme(index: i32) >> void {
    customThemeSetSelected(index);
    g_settings.theme_mgr_selected = customThemeSelected();
    themeMgrLoadNameBuffer();
    themeMgrSyncWheelFromThemeColor();
}

fun openThemeManager(theme_index: ptr<i32>) >> void {
    theme_index[0] = themeCustomSlotIndex();
    if customThemeCount() <= 0 {
        Theme base = setTheme(0);
        customThemeCreateFromTheme(base);
    }
    g_settings.theme_custom_active = true;
    g_settings.theme_mgr_open = true;
    g_settings.theme_mgr_focus = THEME_MGR_FOCUS_LIST;
    g_settings.theme_mgr_scroll = 0.0;
    g_settings.theme_mgr_field = 0;
    g_settings.theme_mgr_button = THEME_MGR_BUTTON_NEW;
    g_settings.theme_mgr_name_edit = false;
    g_settings.theme_mgr_selected = customThemeSelected();
    themeMgrLoadNameBuffer();
    themeMgrSyncWheelFromThemeColor();
}

fun closeThemeManager() >> void {
    g_settings.theme_mgr_open = false;
    g_settings.theme_mgr_name_edit = false;
}

fun themeMgrFocusNext() >> void {
    g_settings.theme_mgr_focus += 1;
    if g_settings.theme_mgr_focus > THEME_MGR_FOCUS_BUTTONS {g_settings.theme_mgr_focus = THEME_MGR_FOCUS_LIST;}
}

fun visibleBaseTop() >> i64 {
    f32 scale = uiScale();
    i32 oy = uiOffsetY(scale);
    return (((0 - oy) as f32) / scale) as i64;
}

fun visibleBaseBottom() >> i64 {
    f32 scale = uiScale();
    i32 oy = uiOffsetY(scale);
    return (((GetScreenHeight() - oy) as f32) / scale) as i64;
}

fun themeManagerLayout(out_left_x: ptr<i64>, out_left_y: ptr<i64>, out_left_w: ptr<i64>, out_left_h: ptr<i64>, out_right_x: ptr<i64>, out_right_y: ptr<i64>, out_right_w: ptr<i64>, out_right_h: ptr<i64>) >> void {
    i64 left_w = 472;
    i64 left_h = 700;
    i64 right_w = 548;
    i64 right_h = 860;

    i64 vis_left = visibleBaseLeft();
    i64 vis_right = visibleBaseRight();
    i64 vis_top = visibleBaseTop();
    i64 vis_bottom = visibleBaseBottom();
    i64 avail_w = vis_right - vis_left;
    i64 avail_h = vis_bottom - vis_top;

    i64 min_gap = 18;
    i64 max_gap = 96;
    i64 gap = min_gap;
    i64 base_total = left_w + right_w + min_gap;
    if avail_w > base_total {
        gap += (avail_w - base_total) / 4;
        if gap > max_gap {gap = max_gap;}
    }

    i64 group_w = left_w + right_w + gap;
    i64 group_h = left_h;
    if right_h > group_h {group_h = right_h;}

    i64 group_x = vis_left + (avail_w - group_w) / 2;
    i64 group_y = vis_top + (avail_h - group_h) / 2;

    out_left_x[0] = group_x;
    out_left_y[0] = group_y + (group_h - left_h) / 2;
    out_left_w[0] = left_w;
    out_left_h[0] = left_h;

    out_right_x[0] = out_left_x[0] + left_w + gap;
    out_right_y[0] = group_y + (group_h - right_h) / 2;
    out_right_w[0] = right_w;
    out_right_h[0] = right_h;
}

fun themeManagerPanelRect(out_x: ptr<i64>, out_y: ptr<i64>, out_w: ptr<i64>, out_h: ptr<i64>) >> void {
    i64 right_x = 0;
    i64 right_y = 0;
    i64 right_w = 0;
    i64 right_h = 0;
    themeManagerLayout(out_x, out_y, out_w, out_h, &right_x, &right_y, &right_w, &right_h);
}

fun themeManagerPreviewRect(out_x: ptr<i64>, out_y: ptr<i64>, out_w: ptr<i64>, out_h: ptr<i64>) >> void {
    i64 left_x = 0;
    i64 left_y = 0;
    i64 left_w = 0;
    i64 left_h = 0;
    themeManagerLayout(&left_x, &left_y, &left_w, &left_h, out_x, out_y, out_w, out_h);
}

fun themeMgrListVisible() >> i32 {return 6;}

fun themeMgrSyncListScroll() >> void {
    i32 count = customThemeCount();
    i32 visible = themeMgrListVisible();
    i32 max_scroll = count - visible;
    if max_scroll < 0 {max_scroll = 0;}
    if g_settings.theme_mgr_selected < (g_settings.theme_mgr_scroll as i32) {g_settings.theme_mgr_scroll = g_settings.theme_mgr_selected as f32;}
    if g_settings.theme_mgr_selected >= (g_settings.theme_mgr_scroll as i32) + visible {g_settings.theme_mgr_scroll = (g_settings.theme_mgr_selected - visible + 1) as f32;}
    if g_settings.theme_mgr_scroll < 0.0 {g_settings.theme_mgr_scroll = 0.0;}
    if g_settings.theme_mgr_scroll > max_scroll as f32 {g_settings.theme_mgr_scroll = max_scroll as f32;}
}

fun themeMgrWheelHit(mouse: Vector2, cx: i64, cy: i64, radius: i64) >> bool {
    if !pointInBaseRect(mouse.x, mouse.y, cx - radius, cy - radius, radius * 2, radius * 2) {return false;}
    f32 dx = (mouse.x - uiX(cx) as f32) / (uiS(radius) as f32);
    f32 dy = (mouse.y - uiY(cy) as f32) / (uiS(radius) as f32);
    f32 r = sqrtApprox(dx * dx + dy * dy);
    return r <= 1.0;
}

fun themeMgrWheelSetFromMouse(mouse: Vector2, cx: i64, cy: i64, radius: i64) >> void {
    f32 dx = (mouse.x - uiX(cx) as f32) / (uiS(radius) as f32);
    f32 dy = (mouse.y - uiY(cy) as f32) / (uiS(radius) as f32);
    f32 rr = dx * dx + dy * dy;
    if rr <= 0.000001 {
        g_settings.theme_mgr_saturation = 0.0;
        themeMgrApplyWheelColor();
        return;
    }

    f32 r = sqrtApprox(rr);
    if r > 1.0 {
        dx = dx / r;
        dy = dy / r;
        r = 1.0;
    }

    f64 ang = atan2((-dy) as f64, dx as f64);
    f32 hue = (ang as f32) * 57.2957795;
    if hue < 0.0 {hue += 360.0;}
    g_settings.theme_mgr_hue = hue;
    g_settings.theme_mgr_saturation = clampf(r, 0.0, 1.0);
    themeMgrApplyWheelColor();
}

fun keyRepeatPulse(key: i32, timer: ptr<f32>, initial_delay: f32, repeat_delay: f32) >> bool {
    return uiKeyRepeatPulse(key, timer, initial_delay, repeat_delay);
}

fun themeMgrHandleNameEdit() >> void {
    themeMgrClampNameCursor();

    bool ctrl = IsKeyDown(KEY_LEFT_CONTROL) || IsKeyDown(KEY_RIGHT_CONTROL);

    if IsKeyPressed(KEY_HOME) {
        g_settings.theme_mgr_name_cursor = 0;
        themeMgrClampNameCursor();
    }
    if IsKeyPressed(KEY_END) {
        g_settings.theme_mgr_name_cursor = themeMgrNameLen();
        themeMgrClampNameCursor();
    }

    if keyRepeatPulse(KEY_LEFT, &g_settings.theme_mgr_left_repeat, 0.28, 0.04) {
        g_settings.theme_mgr_name_cursor = themeMgrPrevCharStart(g_settings.theme_mgr_name_cursor);
        themeMgrClampNameCursor();
    }
    if keyRepeatPulse(KEY_RIGHT, &g_settings.theme_mgr_right_repeat, 0.28, 0.04) {
        g_settings.theme_mgr_name_cursor = themeMgrNextCharStart(g_settings.theme_mgr_name_cursor);
        themeMgrClampNameCursor();
    }

    if (ctrl && IsKeyPressed(KEY_V)) || IsKeyPressed(KEY_INSERT) {
        if ctrl || IsKeyDown(KEY_LEFT_SHIFT) || IsKeyDown(KEY_RIGHT_SHIFT) {themeMgrInsertUtf8Text(GetClipboardText());}
    }
    if ctrl && (IsKeyPressed(KEY_C) || IsKeyPressed(KEY_INSERT)) {SetClipboardText(&g_settings.theme_mgr_name[0]);}
    if ctrl && IsKeyPressed(KEY_X) {
        SetClipboardText(&g_settings.theme_mgr_name[0]);
        g_settings.theme_mgr_name[0] = 0;
        g_settings.theme_mgr_name_cursor = 0;
        themeMgrCommitNameBuffer();
    }

    if keyRepeatPulse(KEY_BACKSPACE, &g_settings.theme_mgr_backspace_repeat, 0.32, 0.035) {themeMgrDeleteAtCursor(true);}
    if keyRepeatPulse(KEY_DELETE, &g_settings.theme_mgr_delete_repeat, 0.32, 0.035) {themeMgrDeleteAtCursor(false);}

    if !ctrl {
        for true {
            i32 ch = GetCharPressed();
            if ch == 0 {break;}
            themeMgrInsertChar(ch);
        }
    }

    if IsKeyPressed(KEY_ENTER) || IsKeyPressed(KEY_ESCAPE) {
        g_settings.theme_mgr_name_edit = false;
        themeMgrCommitNameBuffer();
    }
}

fun drawThemeManager(font: Font, theme: Theme) >> void {
    i64 panel_x = 0;
    i64 panel_y = 0;
    i64 panel_w = 0;
    i64 panel_h = 0;
    themeManagerPanelRect(&panel_x, &panel_y, &panel_w, &panel_h);

    fillRect(panel_x, panel_y, panel_w, panel_h, alphaColor(theme.panel_bg, 0.96));
    strokeRect(panel_x, panel_y, panel_w, panel_h, alphaColor(theme.panel_stroke, 0.90));

    drawTextColor(font, "MANAGE CUSTOM THEMES", panel_x + 24, panel_y + 24, 17, theme.text_main);
    drawTextColor(font, "TAB focus, ENTER action, ESC close", panel_x + 24, panel_y + 48, 11, alphaColor(theme.text_muted, 0.84));
    drawTextColor(font, "Live game preview is on the right", panel_x + 24, panel_y + 64, 11, alphaColor(theme.text_muted, 0.72));

    i64 list_x = panel_x + 24;
    i64 list_y = panel_y + 82;
    i64 list_w = 188;
    i64 row_h = 54;
    i64 list_h = row_h * (themeMgrListVisible() as i64);

    fillRect(list_x, list_y, list_w, list_h, alphaColor(theme.board_bg, 0.75));
    strokeRect(list_x, list_y, list_w, list_h, alphaColor(theme.text_muted, 0.48));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_LIST {strokeRect(list_x - 2, list_y - 2, list_w + 4, list_h + 4, alphaColor(theme.panel_stroke, 0.86));}

    i32 count = customThemeCount();
    themeMgrSyncListScroll();
    if count == 0 {
        drawTextColor(font, "No custom themes yet", list_x + 16, list_y + 20, 11, alphaColor(theme.text_muted, 0.84));
        drawTextColor(font, "Press NEW", list_x + 16, list_y + 40, 11, alphaColor(theme.text_muted, 0.84));
    }
    for i32 i = 0; i < count; i++ {
        i64 y = list_y + ((i as f32 - g_settings.theme_mgr_scroll) * (row_h as f32)) as i64;
        if y < list_y || y + row_h > list_y + list_h {continue;}
        bool sel = i == g_settings.theme_mgr_selected;
        if sel {
            fillRect(list_x + 6, y + 5, list_w - 12, row_h - 10, alphaColor(theme.panel_stroke, 0.22));
            strokeRect(list_x + 6, y + 5, list_w - 12, row_h - 10, alphaColor(theme.panel_stroke, 0.78));
        }
        drawTextColor(font, customThemeName(i), list_x + 14, y + 18, 12, alphaColor(theme.text_main, 0.96));
    }

    i64 right_x = panel_x + 226;
    i64 right_w = panel_w - (right_x - panel_x) - 24;

    i64 name_y = panel_y + 86;
    fillRect(right_x, name_y, right_w, 54, alphaColor(theme.board_bg, 0.74));
    strokeRect(right_x, name_y, right_w, 54, alphaColor(theme.text_muted, 0.52));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_NAME {strokeRect(right_x - 2, name_y - 2, right_w + 4, 58, alphaColor(theme.panel_stroke, 0.86));}
    drawTextColor(font, "Name", right_x + 12, name_y + 8, 11, alphaColor(theme.text_muted, 0.80));

    i64 name_text_x = right_x + 12;
    i64 name_text_y = name_y + 28;
    i64 name_text_w = right_w - 24;
    i64 name_visible_w = name_text_w - 2;
    if name_visible_w < 1 {name_visible_w = 1;}
    i32 name_start = themeMgrVisibleStart(font, 13, name_visible_w);

    BeginScissorMode(uiX(name_text_x), uiY(name_text_y), uiS(name_text_w), uiS(18));
    drawTextColor(font, &g_settings.theme_mgr_name[name_start], name_text_x, name_text_y, 13, theme.text_main);
    EndScissorMode();

    if g_settings.theme_mgr_name_edit {
        i64 cursor_dx = themeMgrRangeWidth(font, 13, name_start, g_settings.theme_mgr_name_cursor);
        i64 cursor_x = name_text_x + cursor_dx;
        fillRect(cursor_x, name_text_y, 2, 16, alphaColor(theme.panel_stroke, 0.92));
    }

    i64 field_y = panel_y + 150;
    fillRect(right_x, field_y, right_w, 54, alphaColor(theme.board_bg, 0.74));
    strokeRect(right_x, field_y, right_w, 54, alphaColor(theme.text_muted, 0.52));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_FIELD {strokeRect(right_x - 2, field_y - 2, right_w + 4, 58, alphaColor(theme.panel_stroke, 0.86));}
    drawTextColor(font, "<", right_x + 10, field_y + 20, 15, theme.text_main);
    drawTextColor(font, customThemeFieldName(g_settings.theme_mgr_field), right_x + 28, field_y + 20, 12, theme.text_main);
    drawTextColor(font, ">", right_x + right_w - 20, field_y + 20, 15, theme.text_main);

    i64 wheel_cx = right_x + right_w / 2;
    i64 wheel_cy = panel_y + 372;
    i64 wheel_r = 114;

    fillRect(wheel_cx - wheel_r - 2, wheel_cy - wheel_r - 2, wheel_r * 2 + 4, wheel_r * 2 + 4, colorOpaque(theme.board_bg));

    i32 center_px_x = uiX(wheel_cx);
    i32 center_px_y = uiY(wheel_cy);
    i32 radius_px = uiS(wheel_r);
    for i32 py = -radius_px; py <= radius_px; py++ {
        for i32 px = -radius_px; px <= radius_px; px++ {
            f32 nx = (px as f32) / (radius_px as f32);
            f32 ny = (py as f32) / (radius_px as f32);
            f32 rr = nx * nx + ny * ny;
            if rr > 1.0 {continue;}

            f32 sat = clampf(sqrtApprox(rr), 0.0, 1.0);
            f64 ang2 = atan2((-ny) as f64, nx as f64);
            f32 hue2 = (ang2 as f32) * 57.2957795;
            if hue2 < 0.0 {hue2 += 360.0;}
            DrawPixel(center_px_x + px, center_px_y + py, toColor(hsvToColor(hue2, sat, g_settings.theme_mgr_brightness, 1.0)));
        }
    }
    DrawCircleLines(uiX(wheel_cx), uiY(wheel_cy), uiS(wheel_r) as f32, toColor(alphaColor(theme.text_main, 0.82)));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_WHEEL {
        DrawCircleLines(uiX(wheel_cx), uiY(wheel_cy), uiS(wheel_r + 3) as f32, toColor(alphaColor(theme.panel_stroke, 0.84)));
    }

    f64 ang = (g_settings.theme_mgr_hue as f64) * (3.14159265 as f64) / (180.0 as f64);
    f32 ux = cos(ang) as f32;
    f32 uy = -(sin(ang) as f32);
    i64 px = wheel_cx + (ux * (wheel_r as f32) * g_settings.theme_mgr_saturation) as i64;
    i64 py = wheel_cy + (uy * (wheel_r as f32) * g_settings.theme_mgr_saturation) as i64;
    DrawCircle(uiX(px), uiY(py), uiS(6) as f32, toColor(alphaColor(theme.text_main, 0.95)));
    DrawCircleLines(uiX(px), uiY(py), uiS(8) as f32, toColor(alphaColor(theme.bg_outer, 0.92)));

    i64 br_x = right_x;
    i64 br_y = panel_y + 506;
    i64 br_w = right_w;
    i64 br_h = 22;
    fillRect(br_x, br_y, br_w, br_h, colorOpaque(theme.board_bg));
    i32 br_px_x = uiX(br_x);
    i32 br_px_y = uiY(br_y);
    i32 br_px_w = uiS(br_w);
    i32 br_px_h = uiS(br_h);
    if br_px_w < 1 {br_px_w = 1;}
    if br_px_h < 1 {br_px_h = 1;}
    i32 br_px_den = br_px_w - 1;
    if br_px_den < 1 {br_px_den = 1;}
    for i32 i = 0; i < br_px_w; i++ {
        f32 t = (i as f32) / (br_px_den as f32);
        u32 c = hsvToColor(g_settings.theme_mgr_hue, g_settings.theme_mgr_saturation, t, 1.0);
        DrawLine(br_px_x + i, br_px_y, br_px_x + i, br_px_y + br_px_h - 1, toColor(c));
    }
    strokeRect(br_x, br_y, br_w, br_h, alphaColor(theme.text_muted, 0.76));
    i64 knob_x = br_x + (g_settings.theme_mgr_brightness * (br_w as f32)) as i64;
    fillRect(knob_x - 2, br_y - 3, 4, br_h + 6, alphaColor(theme.text_main, 0.96));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BRIGHTNESS {strokeRect(br_x - 2, br_y - 2, br_w + 4, br_h + 4, alphaColor(theme.panel_stroke, 0.84));}

    i64 ang_x = right_x;
    i64 ang_y = panel_y + 540;
    i64 ang_w = right_w;
    i64 ang_h = 22;
    f32 bg_angle = customThemeGradientAngle(g_settings.theme_mgr_selected);
    fillRect(ang_x, ang_y, ang_w, ang_h, alphaColor(theme.board_bg, 0.82));
    strokeRect(ang_x, ang_y, ang_w, ang_h, alphaColor(theme.text_muted, 0.76));
    i64 ang_fill = ((ang_w as f32) * (bg_angle / 360.0)) as i64;
    fillRect(ang_x, ang_y, ang_fill, ang_h, alphaColor(theme.panel_stroke, 0.70));
    i64 ang_knob = ang_x + ang_fill;
    fillRect(ang_knob - 2, ang_y - 3, 4, ang_h + 6, alphaColor(theme.text_main, 0.96));
    drawTextColor(font, "BG angle", ang_x + 6, ang_y + ang_h + 8, 10, alphaColor(theme.text_muted, 0.82));
    drawTextColor(font, TextFormat("%.0f deg", bg_angle), ang_x + ang_w - 72, ang_y + ang_h + 8, 10, alphaColor(theme.text_main, 0.88));
    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BG_ANGLE {strokeRect(ang_x - 2, ang_y - 2, ang_w + 4, ang_h + 4, alphaColor(theme.panel_stroke, 0.84));}

    u32 preview = customThemeGetColor(g_settings.theme_mgr_selected, g_settings.theme_mgr_field);
    i64 hex_x = list_x;
    i64 hex_y = list_y + list_h + 14;
    i64 hex_w = list_w;
    i64 hex_h = 86;
    fillRect(hex_x, hex_y, hex_w, hex_h, alphaColor(theme.board_bg, 0.74));
    strokeRect(hex_x, hex_y, hex_w, hex_h, alphaColor(theme.text_muted, 0.52));
    drawTextColor(font, "Selected color", hex_x + 10, hex_y + 10, 10, alphaColor(theme.text_muted, 0.84));
    fillRect(hex_x + 10, hex_y + 32, 34, 32, colorOpaque(preview));
    strokeRect(hex_x + 10, hex_y + 32, 34, 32, alphaColor(theme.text_main, 0.60));
    drawTextColor(font, TextFormat("0x%08X", preview), hex_x + 52, hex_y + 42, 12, theme.text_main);

    i64 btn_w = 140;
    i64 btn_h = 52;
    i64 btn_y = panel_y + panel_h - btn_h - 24;
    i64 btn_gap = 12;
    i64 btn_total_w = btn_w * 3 + btn_gap * 2;
    i64 btn_start_x = panel_x + (panel_w - btn_total_w) / 2;
    arr<ptr<u8>, 3> labels = {"NEW", "DELETE", "CLOSE"};
    for i32 b = 0; b < 3; b++ {
        i64 bx = btn_start_x + b * (btn_w + btn_gap);
        fillRect(bx, btn_y, btn_w, btn_h, alphaColor(theme.board_bg, 0.78));
        u32 st = alphaColor(theme.text_muted, 0.54);
        if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BUTTONS && g_settings.theme_mgr_button == b {st = alphaColor(theme.panel_stroke, 0.90);}
        strokeRect(bx, btn_y, btn_w, btn_h, st);
        drawTextCenteredInRect(font, labels[b], bx, btn_y + 2, btn_w, btn_h - 4, 13, alphaColor(theme.text_main, 0.96));
    }
}

fun updateThemeManager(theme_index: ptr<i32>) >> bool {
    if !g_settings.theme_mgr_open {return false;}

    theme_index[0] = themeCustomSlotIndex();
    g_settings.theme_custom_active = true;

    i32 count = customThemeCount();
    if count <= 0 {
        g_settings.theme_mgr_selected = 0;
        g_settings.theme_mgr_name[0] = 0;
        g_settings.theme_mgr_name_cursor = 0;
        g_settings.theme_mgr_name_edit = false;
    } else {
        if g_settings.theme_mgr_selected < 0 {g_settings.theme_mgr_selected = 0;}
        if g_settings.theme_mgr_selected >= count {g_settings.theme_mgr_selected = count - 1;}
    }
    customThemeSetSelected(g_settings.theme_mgr_selected);
    g_settings.theme_mgr_selected = customThemeSelected();
    themeMgrSyncListScroll();

    Vector2 mouse = GetMousePosition();
    i64 panel_x = 0;
    i64 panel_y = 0;
    i64 panel_w_tmp = 0;
    i64 panel_h_tmp = 0;
    themeManagerPanelRect(&panel_x, &panel_y, &panel_w_tmp, &panel_h_tmp);
    i64 list_x = panel_x + 24;
    i64 list_y = panel_y + 82;
    i64 list_w = 188;
    i64 list_row_h = 54;
    i64 list_h = list_row_h * (themeMgrListVisible() as i64);

    i64 right_x = panel_x + 226;
    i64 right_w = panel_w_tmp - (right_x - panel_x) - 24;
    i64 name_y = panel_y + 86;
    i64 field_y = panel_y + 150;
    i64 wheel_cx = right_x + right_w / 2;
    i64 wheel_cy = panel_y + 372;
    i64 wheel_r = 114;
    i64 br_x = right_x;
    i64 br_y = panel_y + 506;
    i64 br_w = right_w;
    i64 br_h = 22;
    i64 ang_x = right_x;
    i64 ang_y = panel_y + 540;
    i64 ang_w = right_w;
    i64 ang_h = 22;
    i64 btn_w = 140;
    i64 btn_h = 52;
    i64 btn_y = panel_y + panel_h_tmp - btn_h - 24;
    i64 btn_gap = 12;
    i64 btn_total_w = btn_w * 3 + btn_gap * 2;
    i64 btn_start_x = panel_x + (panel_w_tmp - btn_total_w) / 2;

    if IsKeyPressed(KEY_ESCAPE) {
        if g_settings.theme_mgr_name_edit {
            g_settings.theme_mgr_name_edit = false;
            themeMgrLoadNameBuffer();
        } else {
            closeThemeManager();
        }
        return true;
    }

    if g_settings.theme_mgr_name_edit {
        themeMgrHandleNameEdit();
        return true;
    }

    if IsKeyPressed(KEY_TAB) {
        themeMgrFocusNext();
        g_settings.keyboard_nav_lock = true;
    }

    if IsKeyPressed(KEY_N) {
        Theme base = setTheme(theme_index[0]);
        i32 next = customThemeCreateFromTheme(base);
        themeMgrSelectTheme(next);
        count = customThemeCount();
    }
    if count > 0 && IsKeyPressed(KEY_DELETE) {
        customThemeDelete(g_settings.theme_mgr_selected);
        themeMgrSelectTheme(customThemeSelected());
        count = customThemeCount();
    }

    if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_LIST {
        if IsKeyPressed(KEY_UP) {themeMgrSelectTheme(g_settings.theme_mgr_selected - 1);}
        if IsKeyPressed(KEY_DOWN) {themeMgrSelectTheme(g_settings.theme_mgr_selected + 1);}
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_FIELD {
        if IsKeyPressed(KEY_LEFT) {
            g_settings.theme_mgr_field -= 1;
            if g_settings.theme_mgr_field < 0 {g_settings.theme_mgr_field = customThemeFieldCount() - 1;}
            themeMgrSyncWheelFromThemeColor();
        }
        if IsKeyPressed(KEY_RIGHT) {
            g_settings.theme_mgr_field += 1;
            if g_settings.theme_mgr_field >= customThemeFieldCount() {g_settings.theme_mgr_field = 0;}
            themeMgrSyncWheelFromThemeColor();
        }
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_WHEEL {
        if IsKeyPressed(KEY_LEFT) || IsKeyPressedRepeat(KEY_LEFT) {
            g_settings.theme_mgr_hue -= 2.0;
            themeMgrApplyWheelColor();
        }
        if IsKeyPressed(KEY_RIGHT) || IsKeyPressedRepeat(KEY_RIGHT) {
            g_settings.theme_mgr_hue += 2.0;
            themeMgrApplyWheelColor();
        }
        if IsKeyPressed(KEY_UP) || IsKeyPressedRepeat(KEY_UP) {
            g_settings.theme_mgr_saturation += 0.02;
            if g_settings.theme_mgr_saturation > 1.0 {g_settings.theme_mgr_saturation = 1.0;}
            themeMgrApplyWheelColor();
        }
        if IsKeyPressed(KEY_DOWN) || IsKeyPressedRepeat(KEY_DOWN) {
            g_settings.theme_mgr_saturation -= 0.02;
            if g_settings.theme_mgr_saturation < 0.0 {g_settings.theme_mgr_saturation = 0.0;}
            themeMgrApplyWheelColor();
        }
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BRIGHTNESS {
        if IsKeyPressed(KEY_LEFT) || IsKeyPressedRepeat(KEY_LEFT) {
            g_settings.theme_mgr_brightness -= 0.02;
            if g_settings.theme_mgr_brightness < 0.0 {g_settings.theme_mgr_brightness = 0.0;}
            themeMgrApplyWheelColor();
        }
        if IsKeyPressed(KEY_RIGHT) || IsKeyPressedRepeat(KEY_RIGHT) {
            g_settings.theme_mgr_brightness += 0.02;
            if g_settings.theme_mgr_brightness > 1.0 {g_settings.theme_mgr_brightness = 1.0;}
            themeMgrApplyWheelColor();
        }
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BG_ANGLE {
        if IsKeyPressed(KEY_LEFT) || IsKeyPressedRepeat(KEY_LEFT) {
            customThemeSetGradientAngle(g_settings.theme_mgr_selected, customThemeGradientAngle(g_settings.theme_mgr_selected) - 2.0);
        }
        if IsKeyPressed(KEY_RIGHT) || IsKeyPressedRepeat(KEY_RIGHT) {
            customThemeSetGradientAngle(g_settings.theme_mgr_selected, customThemeGradientAngle(g_settings.theme_mgr_selected) + 2.0);
        }
    } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BUTTONS {
        if IsKeyPressed(KEY_LEFT) {
            g_settings.theme_mgr_button -= 1;
            if g_settings.theme_mgr_button < THEME_MGR_BUTTON_NEW {g_settings.theme_mgr_button = THEME_MGR_BUTTON_CLOSE;}
        }
        if IsKeyPressed(KEY_RIGHT) {
            g_settings.theme_mgr_button += 1;
            if g_settings.theme_mgr_button > THEME_MGR_BUTTON_CLOSE {g_settings.theme_mgr_button = THEME_MGR_BUTTON_NEW;}
        }
    }

    bool do_enter = IsKeyPressed(KEY_ENTER);
    if do_enter {
        if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_NAME && count > 0 {
            g_settings.theme_mgr_name_edit = true;
            g_settings.theme_mgr_name_cursor = themeMgrNameLen();
            g_settings.theme_mgr_left_repeat = 0.0;
            g_settings.theme_mgr_right_repeat = 0.0;
            g_settings.theme_mgr_backspace_repeat = 0.0;
            g_settings.theme_mgr_delete_repeat = 0.0;
        } else if g_settings.theme_mgr_focus == THEME_MGR_FOCUS_BUTTONS {
            if g_settings.theme_mgr_button == THEME_MGR_BUTTON_NEW {
                Theme base = setTheme(theme_index[0]);
                i32 next = customThemeCreateFromTheme(base);
                themeMgrSelectTheme(next);
                count = customThemeCount();
            } else if g_settings.theme_mgr_button == THEME_MGR_BUTTON_DELETE {
                if count > 0 {
                    customThemeDelete(g_settings.theme_mgr_selected);
                    themeMgrSelectTheme(customThemeSelected());
                    count = customThemeCount();
                }
            } else {
                closeThemeManager();
            }
        }
    }

    f32 wheel = GetMouseWheelMove();
    if pointInBaseRect(mouse.x, mouse.y, list_x, list_y, list_w, list_h) {
        if wheel > 0.0 {g_settings.theme_mgr_scroll -= 1.0;}
        if wheel < 0.0 {g_settings.theme_mgr_scroll += 1.0;}
        themeMgrSyncListScroll();
    }

    if IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {
        g_settings.keyboard_nav_lock = false;

        if pointInBaseRect(mouse.x, mouse.y, list_x, list_y, list_w, list_h) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_LIST;
            i32 idx = 0;
            if uiScrollListHoverIndex(mouse, list_x, list_y, list_w, list_row_h, themeMgrListVisible(), g_settings.theme_mgr_scroll, customThemeCount(), &idx) {
                themeMgrSelectTheme(idx);
            }
        } else if pointInBaseRect(mouse.x, mouse.y, right_x, name_y, right_w, 54) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_NAME;
            if count > 0 {
                g_settings.theme_mgr_name_edit = true;
                g_settings.theme_mgr_name_cursor = themeMgrNameLen();
                g_settings.theme_mgr_left_repeat = 0.0;
                g_settings.theme_mgr_right_repeat = 0.0;
                g_settings.theme_mgr_backspace_repeat = 0.0;
                g_settings.theme_mgr_delete_repeat = 0.0;
            }
        } else if pointInBaseRect(mouse.x, mouse.y, right_x, field_y, right_w, 54) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_FIELD;
            if mouse.x < uiX(right_x + right_w / 2) as f32 {
                g_settings.theme_mgr_field -= 1;
                if g_settings.theme_mgr_field < 0 {g_settings.theme_mgr_field = customThemeFieldCount() - 1;}
            } else {
                g_settings.theme_mgr_field += 1;
                if g_settings.theme_mgr_field >= customThemeFieldCount() {g_settings.theme_mgr_field = 0;}
            }
            themeMgrSyncWheelFromThemeColor();
        } else if themeMgrWheelHit(mouse, wheel_cx, wheel_cy, wheel_r) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_WHEEL;
            themeMgrWheelSetFromMouse(mouse, wheel_cx, wheel_cy, wheel_r);
        } else if pointInBaseRect(mouse.x, mouse.y, br_x, br_y, br_w, br_h) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_BRIGHTNESS;
            g_settings.theme_mgr_brightness = clampf((mouse.x - uiX(br_x) as f32) / (uiS(br_w) as f32), 0.0, 1.0);
            themeMgrApplyWheelColor();
        } else if pointInBaseRect(mouse.x, mouse.y, ang_x, ang_y - 4, ang_w, ang_h + 12) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_BG_ANGLE;
            f32 t = clampf((mouse.x - uiX(ang_x) as f32) / (uiS(ang_w) as f32), 0.0, 1.0);
            customThemeSetGradientAngle(g_settings.theme_mgr_selected, t * 360.0);
        } else {
            for i32 b = 0; b < 3; b++ {
                i64 bx = btn_start_x + b * (btn_w + btn_gap);
                if pointInBaseRect(mouse.x, mouse.y, bx, btn_y, btn_w, btn_h) {
                    g_settings.theme_mgr_focus = THEME_MGR_FOCUS_BUTTONS;
                    g_settings.theme_mgr_button = b;
                    if b == THEME_MGR_BUTTON_NEW {
                        Theme base = setTheme(theme_index[0]);
                        i32 next = customThemeCreateFromTheme(base);
                        themeMgrSelectTheme(next);
                        count = customThemeCount();
                    } else if b == THEME_MGR_BUTTON_DELETE {
                        if count > 0 {
                            customThemeDelete(g_settings.theme_mgr_selected);
                            themeMgrSelectTheme(customThemeSelected());
                            count = customThemeCount();
                        }
                    } else {
                        closeThemeManager();
                    }
                    break;
                }
            }
        }
    }

    if IsMouseButtonDown(MOUSE_BUTTON_LEFT) {
        if themeMgrWheelHit(mouse, wheel_cx, wheel_cy, wheel_r) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_WHEEL;
            themeMgrWheelSetFromMouse(mouse, wheel_cx, wheel_cy, wheel_r);
        }
        if pointInBaseRect(mouse.x, mouse.y, br_x, br_y, br_w, br_h) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_BRIGHTNESS;
            g_settings.theme_mgr_brightness = clampf((mouse.x - uiX(br_x) as f32) / (uiS(br_w) as f32), 0.0, 1.0);
            themeMgrApplyWheelColor();
        }
        if pointInBaseRect(mouse.x, mouse.y, ang_x, ang_y - 4, ang_w, ang_h + 12) {
            g_settings.theme_mgr_focus = THEME_MGR_FOCUS_BG_ANGLE;
            f32 t = clampf((mouse.x - uiX(ang_x) as f32) / (uiS(ang_w) as f32), 0.0, 1.0);
            customThemeSetGradientAngle(g_settings.theme_mgr_selected, t * 360.0);
        }
    }

    return true;
}

fun settingsThemeManagerOpen() >> bool {
    return g_settings.theme_mgr_open;
}

fun drawThemeManagerStandalone(font: Font, theme: Theme) >> void {
    drawThemeManager(font, theme);
}

fun sectionAnimForRow(row: i32) >> f32 {
    if row >= SETTINGS_ROW_ARR && row <= SETTINGS_ROW_INSTANT_RESTART {return g_settings.controls_anim;}
    if row >= SETTINGS_ROW_THEME && row <= SETTINGS_ROW_FULLSCREEN_MODE {return g_settings.video_anim;}
    if row >= SETTINGS_ROW_MUSIC_VOLUME && row <= SETTINGS_ROW_MUSIC_SHUFFLE {return g_settings.audio_anim;}
    return 1.0;
}

fun rowIsSectionHeader(row: i32) >> bool {
    return row == SETTINGS_ROW_SECTION_CONTROLS || row == SETTINGS_ROW_SECTION_VIDEO || row == SETTINGS_ROW_SECTION_AUDIO;
}

fun rowVisible(row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> bool {
    if row == SETTINGS_ROW_BACK {return true;}
    if row == SETTINGS_ROW_SECTION_CONTROLS || row == SETTINGS_ROW_SECTION_VIDEO || row == SETTINGS_ROW_SECTION_AUDIO {return true;}

    if row >= SETTINGS_ROW_ARR && row <= SETTINGS_ROW_INSTANT_RESTART {return g_settings.controls_expanded;}

    if row >= SETTINGS_ROW_THEME && row <= SETTINGS_ROW_FULLSCREEN_MODE {
        if !g_settings.video_expanded {return false;}
        if row == SETTINGS_ROW_MANAGE_THEMES {return g_settings.theme_custom_active;}
        if row == SETTINGS_ROW_CRT_CURVATURE || row == SETTINGS_ROW_CRT_BRIGHTNESS {return shader_mode == SHADER_MODE_CRT;}
        if row == SETTINGS_ROW_VHS_WAVES || row == SETTINGS_ROW_VHS_DAMAGE {return shader_mode == SHADER_MODE_VHS;}
        if row == SETTINGS_ROW_CHOOSE_SHADER {return shader_mode == SHADER_MODE_CUSTOM;}
        if row == SETTINGS_ROW_BG_STARS_AMOUNT || row == SETTINGS_ROW_BG_STARS_MODE || row == SETTINGS_ROW_STAR_PEAK_TARGET || row == SETTINGS_ROW_STAR_INTENSITY || row == SETTINGS_ROW_MUSIC_STYLE || row == SETTINGS_ROW_MUSIC_INTENSITY {
            if bg_visual_mode != BG_VISUAL_STARS {return false;}
            if row == SETTINGS_ROW_STAR_PEAK_TARGET || row == SETTINGS_ROW_STAR_INTENSITY {return bg_stars_mode == STAR_MODE_DROPS;}
            if row == SETTINGS_ROW_MUSIC_STYLE || row == SETTINGS_ROW_MUSIC_INTENSITY {return bg_stars_mode == STAR_MODE_MUSIC;}
            return true;
        }
        if row == SETTINGS_ROW_BG_BARS_AMOUNT ||
           row == SETTINGS_ROW_BG_BARS_INTENSITY ||
           row == SETTINGS_ROW_BG_BARS_HEIGHT_LIMIT ||
           row == SETTINGS_ROW_BG_BARS_OPACITY ||
           row == SETTINGS_ROW_BG_BARS_GLOW ||
           row == SETTINGS_ROW_BG_BARS_LAYOUT {
            return bg_visual_mode == BG_VISUAL_BARS;
        }
        return true;
    }

    if row >= SETTINGS_ROW_MUSIC_VOLUME && row <= SETTINGS_ROW_MUSIC_SHUFFLE {
        if !g_settings.audio_expanded {return false;}
        if row == SETTINGS_ROW_SELECT_SONGS {return g_music_mode == MUSIC_MODE_CUSTOM;}
        return true;
    }

    return false;
}

fun visibleRowCount(bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> i32 {
    i32 count = 0;
    for i32 row = 0; row < SETTINGS_ROW_COUNT; row++ {
        if rowVisible(row, bg_visual_mode, bg_stars_mode, shader_mode) {count += 1;}
    }
    return count;
}

fun rowOrder(row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> i32 {
    if !rowVisible(row, bg_visual_mode, bg_stars_mode, shader_mode) {return -1;}
    i32 order = 0;
    for i32 it = 0; it < row; it++ {
        if rowVisible(it, bg_visual_mode, bg_stars_mode, shader_mode) {order += 1;}
    }
    return order;
}

fun rowFromOrder(order: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> i32 {
    i32 seen = 0;
    for i32 row = 0; row < SETTINGS_ROW_COUNT; row++ {
        if !rowVisible(row, bg_visual_mode, bg_stars_mode, shader_mode) {continue;}
        if seen == order {return row;}
        seen += 1;
    }
    return SETTINGS_ROW_BACK;
}

fun itemYDraw(row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> i64 {
    i32 order = rowOrder(row, bg_visual_mode, bg_stars_mode, shader_mode);
    if order < 0 {return -10000;}
    return 246 + order * 78 - (g_settings.scroll * 78.0) as i64;
}

fun rowSelected(row: i32) >> bool {
    return g_settings.selected_row == row;
}

fun drawSelectionGlow(theme: Theme, y: i64, alpha: f32) >> void {
    fillRect(114, y - 4, 420, 70, alphaColor(theme.panel_stroke, 0.10 + alpha * 0.14));
    strokeRect(115, y - 3, 418, 68, alphaColor(theme.panel_stroke, 0.46 + alpha * 0.40));
}

fun bgStarsModeLabel(mode: i32) >> ptr<u8> {
    if mode == STAR_MODE_DROPS {return "Drops";}
    if mode == STAR_MODE_MUSIC {return "Music";}
    return "None";
}

fun bgVisualModeLabel(mode: i32) >> ptr<u8> {
    if mode == BG_VISUAL_BARS {return "Music bars";}
    return "Stars";
}

fun barsLayoutLabel(mode: i32) >> ptr<u8> {
    if mode == BG_BARS_LAYOUT_MIRROR {return "Mirror";}
    return "Classic";
}

fun musicStyleLabel(style: i32) >> ptr<u8> {
    if style == STAR_MUSIC_STYLE_WAVE {return "Wave";}
    if style == STAR_MUSIC_STYLE_AGGRO {return "Aggro";}
    return "Pulse";
}

fun shaderModeLabel(mode: i32) >> ptr<u8> {
    if mode == SHADER_MODE_LIGHT_CRT {return "Light CRT";}
    if mode == SHADER_MODE_CRT {return "CRT";}
    if mode == SHADER_MODE_VHS {return "VHS";}
    if mode == SHADER_MODE_CUSTOM {return "Custom";}
    return "None";
}

fun sliderPercent(value: f32, min_v: f32, max_v: f32) >> f32 {
    return clampf((value - min_v) / (max_v - min_v), 0.0, 1.0);
}

fun sliderValueFromMouse(px: f32, x: i64, w: i64, min_v: f32, max_v: f32) >> f32 {
    f32 left = uiX(x) as f32;
    f32 width = uiS(w) as f32;
    f32 t = (px - left) / width;
    t = clampf(t, 0.0, 1.0);
    return min_v + (max_v - min_v) * t;
}

fun sliderTrackHit(mouse: Vector2, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> bool {
    if !rowVisible(row, bg_visual_mode, bg_stars_mode, shader_mode) {return false;}
    return pointInBaseRect(mouse.x, mouse.y, 136, itemYDraw(row, bg_visual_mode, bg_stars_mode, shader_mode) + 40, 372, 10);
}

fun dragSliderF32(mouse: Vector2, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32, target: ptr<f32>, min_v: f32, max_v: f32) >> void {
    if !sliderTrackHit(mouse, row, bg_visual_mode, bg_stars_mode, shader_mode) {return;}
    target[0] = sliderValueFromMouse(mouse.x, 136, 372, min_v, max_v);
}

fun dragSliderI32(mouse: Vector2, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32, target: ptr<i32>, min_v: f32, max_v: f32) >> void {
    if !sliderTrackHit(mouse, row, bg_visual_mode, bg_stars_mode, shader_mode) {return;}
    target[0] = sliderValueFromMouse(mouse.x, 136, 372, min_v, max_v) as i32;
}

fun rowBodyHit(mouse: Vector2, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> bool {
    if !rowVisible(row, bg_visual_mode, bg_stars_mode, shader_mode) {return false;}

    i32 visible_rows = visibleRowCount(bg_visual_mode, bg_stars_mode, shader_mode);
    if visible_rows > SETTINGS_VISIBLE_ROWS {visible_rows = SETTINGS_VISIBLE_ROWS;}
    if visible_rows < 0 {visible_rows = 0;}
    if !pointInBaseRect(mouse.x, mouse.y, 112, 246, 424, visible_rows * 78) {return false;}

    return pointInBaseRect(mouse.x, mouse.y, 118, itemYDraw(row, bg_visual_mode, bg_stars_mode, shader_mode), 412, 62);
}

fun selectorDirectionFromMouse(mouse_x: f32) >> i32 {
    if mouse_x < uiX(336) as f32 {return -1;}
    return 1;
}

fun rowUsesSelectorMouseNudge(row: i32) >> bool {
    return row == SETTINGS_ROW_SHADER || row == SETTINGS_ROW_BG_VISUAL_MODE || row == SETTINGS_ROW_BG_STARS_MODE || row == SETTINGS_ROW_BG_BARS_LAYOUT || row == SETTINGS_ROW_MUSIC_STYLE || row == SETTINGS_ROW_MUSIC_MODE;
}

fun rowUsesToggleMouseNudge(row: i32) >> bool {
    return row == SETTINGS_ROW_DOUBLE_ROW || row == SETTINGS_ROW_INSTANT_RESTART || row == SETTINGS_ROW_HARD_DROP_RING || row == SETTINGS_ROW_HIGH_CONTRAST_BLOCKS || row == SETTINGS_ROW_BIG_FIRST_BAG_PREVIEW || row == SETTINGS_ROW_FULLSCREEN_MODE || row == SETTINGS_ROW_MUSIC_SHUFFLE;
}

fun measureTextWidthBase(font: Font, text: ptr<u8>, size: i64) >> i64 {
    Vector2 m = MeasureTextExSize(font, text, uiS(size) as f32, 0.0);
    return (m.x / uiScale()) as i64;
}

fun sectionHeaderLabel(row: i32) >> ptr<u8> {
    if row == SETTINGS_ROW_SECTION_CONTROLS {return "CONTROLS";}
    if row == SETTINGS_ROW_SECTION_VIDEO {return "VIDEO";}
    return "AUDIO";
}

fun sectionExpanded(row: i32) >> bool {
    if row == SETTINGS_ROW_SECTION_CONTROLS {return g_settings.controls_expanded;}
    if row == SETTINGS_ROW_SECTION_VIDEO {return g_settings.video_expanded;}
    return g_settings.audio_expanded;
}

fun setSectionExpanded(row: i32, open: bool) >> void {
    if row == SETTINGS_ROW_SECTION_CONTROLS {
        g_settings.controls_expanded = open;
        g_settings_controls_expanded = open;
        return;
    }
    if row == SETTINGS_ROW_SECTION_VIDEO {
        g_settings.video_expanded = open;
        g_settings_video_expanded = open;
        return;
    }
    g_settings.audio_expanded = open;
    g_settings_audio_expanded = open;
}

fun toggleSection(row: i32) >> void {
    if !rowIsSectionHeader(row) {return;}
    setSectionExpanded(row, !sectionExpanded(row));
}

fun updateSectionAnimations(dt: f32) >> void {
    f32 speed = 10.0;
    f32 tgt_controls = 0.0;
    if g_settings.controls_expanded {tgt_controls = 1.0;}
    g_settings.controls_anim += (tgt_controls - g_settings.controls_anim) * clampf(dt * speed, 0.0, 1.0);

    f32 tgt_video = 0.0;
    if g_settings.video_expanded {tgt_video = 1.0;}
    g_settings.video_anim += (tgt_video - g_settings.video_anim) * clampf(dt * speed, 0.0, 1.0);

    f32 tgt_audio = 0.0;
    if g_settings.audio_expanded {tgt_audio = 1.0;}
    g_settings.audio_anim += (tgt_audio - g_settings.audio_anim) * clampf(dt * speed, 0.0, 1.0);
}

fun drawSectionHeaderRow(font: Font, theme: Theme, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> void {
    i64 y = itemYDraw(row, bg_visual_mode, bg_stars_mode, shader_mode);
    f32 pulse = 0.0;
    if rowSelected(row) {pulse = triWave01((GetTime() as f32) * 1.8);}
    u32 stroke = alphaColor(theme.panel_stroke, 0.44 + pulse * 0.28);

    fillRect(118, y, 412, 62, alphaColor(theme.board_bg, 0.74));
    strokeRect(118, y, 412, 62, stroke);
    if rowSelected(row) {drawSelectionGlow(theme, y, 0.62 + pulse * 0.38);}

    ptr<u8> caret = ">";
    if sectionExpanded(row) {caret = "v";}
    drawTextColor(font, sectionHeaderLabel(row), 160, y + 20, 16, alphaColor(theme.text_main, 0.96));
    drawTextColor(font, caret, 136, y + 20, 16, alphaColor(theme.panel_stroke, 0.96));
}

fun drawSelectorRow(font: Font, theme: Theme, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32, label: ptr<u8>, value: ptr<u8>) >> void {
    i64 y = itemYDraw(row, bg_visual_mode, bg_stars_mode, shader_mode);
    f32 alpha = sectionAnimForRow(row);
    if alpha < 0.01 {return;}
    i64 row_x = 118;
    i64 row_w = 412;
    i64 right_padding = 18;
    i64 text_gap = 12;
    i64 arrow_gap = 14;

    i64 right_arrow_w = measureTextWidthBase(font, ">", 15);
    i64 left_arrow_w = measureTextWidthBase(font, "<", 15);
    i64 value_w = measureTextWidthBase(font, value, 15);

    i64 right_edge = row_x + row_w - right_padding;
    i64 right_arrow_x = right_edge - right_arrow_w;
    i64 value_x = right_arrow_x - text_gap - value_w;
    i64 left_arrow_x = value_x - arrow_gap - left_arrow_w;

    u32 stroke = alphaColor(theme.text_muted, 0.22 + alpha * 0.30);
    if rowSelected(row) {
        drawSelectionGlow(theme, y, alpha);
        stroke = alphaColor(theme.panel_stroke, 0.86);
    }
    fillRect(row_x, y, row_w, 62, alphaColor(theme.panel_bg, 0.30 + alpha * 0.62));
    strokeRect(row_x, y, row_w, 62, stroke);
    drawTextColor(font, label, 136, y + 20, 15, alphaColor(theme.text_main, 0.36 + alpha * 0.64));
    drawTextColor(font, "<", left_arrow_x, y + 20, 15, alphaColor(theme.text_main, 0.30 + alpha * 0.70));
    drawTextColor(font, value, value_x, y + 20, 15, alphaColor(theme.panel_stroke, 0.42 + alpha * 0.58));
    drawTextColor(font, ">", right_arrow_x, y + 20, 15, alphaColor(theme.text_main, 0.30 + alpha * 0.70));
}

fun drawSliderRow(font: Font, theme: Theme, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32, label: ptr<u8>, value_text: ptr<u8>, value: f32, min_v: f32, max_v: f32) >> void {
    i64 y = itemYDraw(row, bg_visual_mode, bg_stars_mode, shader_mode);
    f32 alpha = sectionAnimForRow(row);
    if alpha < 0.01 {return;}

    u32 stroke = alphaColor(theme.text_muted, 0.22 + alpha * 0.30);
    if rowSelected(row) {
        drawSelectionGlow(theme, y, alpha);
        stroke = alphaColor(theme.panel_stroke, 0.86);
    }
    fillRect(118, y, 412, 62, alphaColor(theme.panel_bg, 0.30 + alpha * 0.62));
    strokeRect(118, y, 412, 62, stroke);

    drawTextColor(font, label, 136, y + 14, 15, alphaColor(theme.text_main, 0.36 + alpha * 0.64));
    drawTextColor(font, value_text, 430, y + 14, 14, alphaColor(theme.panel_stroke, 0.42 + alpha * 0.58));

    i64 sx = 136;
    i64 sy = y + 40;
    i64 sw = 372;
    i64 sh = 10;
    fillRect(sx, sy, sw, sh, alphaColor(theme.board_bg, 0.40 + alpha * 0.55));
    strokeRect(sx, sy, sw, sh, alphaColor(theme.text_muted, 0.18 + alpha * 0.30));
    i64 fill_w = ((sw as f32) * sliderPercent(value, min_v, max_v)) as i64;
    fillRect(sx, sy, fill_w, sh, alphaColor(theme.panel_stroke, 0.40 + alpha * 0.45));
    fillRect(sx + fill_w - 3, sy - 3, 6, sh + 6, alphaColor(theme.text_main, 0.52 + alpha * 0.48));
}

fun drawToggleRow(font: Font, theme: Theme, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32, label: ptr<u8>, enabled: bool) >> void {
    i64 y = itemYDraw(row, bg_visual_mode, bg_stars_mode, shader_mode);
    f32 alpha = sectionAnimForRow(row);
    if alpha < 0.01 {return;}

    u32 stroke = alphaColor(theme.text_muted, 0.22 + alpha * 0.30);
    if rowSelected(row) {
        drawSelectionGlow(theme, y, alpha);
        stroke = alphaColor(theme.panel_stroke, 0.86);
    }
    fillRect(118, y, 412, 62, alphaColor(theme.panel_bg, 0.30 + alpha * 0.62));
    strokeRect(118, y, 412, 62, stroke);
    drawTextColor(font, label, 136, y + 20, 15, alphaColor(theme.text_main, 0.36 + alpha * 0.64));
    drawCheckboxText(font, enabled, 470, y + 20, 15, alphaColor(theme.panel_stroke, 0.42 + alpha * 0.58));
}

fun drawButtonRow(font: Font, theme: Theme, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32, label: ptr<u8>) >> void {
    i64 y = itemYDraw(row, bg_visual_mode, bg_stars_mode, shader_mode);
    f32 alpha = sectionAnimForRow(row);
    if alpha < 0.01 {return;}

    u32 stroke = alphaColor(theme.text_muted, 0.22 + alpha * 0.30);
    if rowSelected(row) {
        drawSelectionGlow(theme, y, alpha);
        stroke = alphaColor(theme.panel_stroke, 0.86);
    }
    fillRect(118, y, 412, 62, alphaColor(theme.panel_bg, 0.30 + alpha * 0.62));
    strokeRect(118, y, 412, 62, stroke);
    drawTextCenteredInRect(font, label, 118, y + 2, 412, 58, 15, alphaColor(theme.text_main, 0.36 + alpha * 0.64));
}

fun drawBackRow(font: Font, theme: Theme, row: i32, bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> void {
    i64 y = itemYDraw(row, bg_visual_mode, bg_stars_mode, shader_mode);
    u32 stroke = alphaColor(theme.text_muted, 0.45);
    if rowSelected(row) {
        drawSelectionGlow(theme, y, 1.0);
        stroke = theme.panel_stroke;
    }
    fillRect(118, y, 412, 62, alphaColor(theme.panel_bg, 0.92));
    strokeRect(118, y, 412, 62, stroke);
    drawTextColor(font, "Back", 136, y + 20, 15, theme.text_main);
    drawTextColor(font, "ENTER", 436, y + 20, 12, theme.text_muted);
}

fun settingsEnsureSelectedVisible(bg_visual_mode: i32, bg_stars_mode: i32, shader_mode: i32) >> void {
    if rowVisible(g_settings.selected_row, bg_visual_mode, bg_stars_mode, shader_mode) {return;}
    if g_settings.selected_row >= SETTINGS_ROW_ARR && g_settings.selected_row <= SETTINGS_ROW_INSTANT_RESTART {
        g_settings.selected_row = SETTINGS_ROW_SECTION_CONTROLS;
        return;
    }
    if g_settings.selected_row >= SETTINGS_ROW_THEME && g_settings.selected_row <= SETTINGS_ROW_FULLSCREEN_MODE {
        g_settings.selected_row = SETTINGS_ROW_SECTION_VIDEO;
        return;
    }
    if g_settings.selected_row >= SETTINGS_ROW_MUSIC_VOLUME && g_settings.selected_row <= SETTINGS_ROW_MUSIC_SHUFFLE {
        g_settings.selected_row = SETTINGS_ROW_SECTION_AUDIO;
        return;
    }
    g_settings.selected_row = SETTINGS_ROW_THEME;
}

fun drawSettings(font: Font, theme: Theme, params: SettingsDrawParams) >> void {
    g_settings.theme_custom_active = params.theme_index == themeCustomSlotIndex();

    if g_settings.theme_mgr_open {
        drawThemeManager(font, theme);
        return;
    }

    settingsEnsureSelectedVisible(params.bg_visual_mode, params.bg_stars_mode, params.shader_mode);

    drawScreenThemeGradient(theme.bg_inner, theme.bg_outer, theme.bg_gradient_angle);
    drawImpulseGridBackground(font, theme);

    fillRect(84, 48, 480, 860, alphaColor(theme.bg_outer, 0.90));
    strokeRect(84, 48, 480, 860, alphaColor(theme.panel_stroke, 0.90));

    drawTextColor(font, "SETTINGS", 130, 118, 30, theme.text_main);
    drawTextColor(font, "Sections: ENTER toggle", 130, 162, 14, theme.text_muted);
    drawTextColor(font, "Arrow keys or mouse", 130, 182, 14, theme.text_muted);

    if g_settings.song_picker_open {
        i32 song_count = g_star_music_track_count;
        i32 song_visible = 7;
        i32 song_max_scroll = song_count - song_visible;
        if song_max_scroll < 0 {song_max_scroll = 0;}
        if g_settings.song_picker_scroll < 0.0 {g_settings.song_picker_scroll = 0.0;}
        if g_settings.song_picker_scroll > song_max_scroll as f32 {g_settings.song_picker_scroll = song_max_scroll as f32;}

        fillRect(112, 232, 424, 646, alphaColor(theme.panel_bg, 0.94));
        strokeRect(112, 232, 424, 646, alphaColor(theme.panel_stroke, 0.86));
        drawTextColor(font, "SELECT SONGS", 136, 258, 18, theme.text_main);
        drawTextColor(font, "click to toggle", 136, 278, 11, alphaColor(theme.text_muted, 0.70));

        i64 row_h = 68;
        i64 row_inner_h = 56;
        i64 row_inner_off = (row_h - row_inner_h) / 2;
        i64 start_y = 298;

        if song_count == 0 {
            drawTextColor(font, "No songs in assets/songs/", 148, 340, 12, alphaColor(theme.text_muted, 0.70));
        }

        for i32 i = 0; i < song_count; i++ {
            i64 y = start_y + ((i as f32 - g_settings.song_picker_scroll) * (row_h as f32)) as i64;
            if y < 290 || y > 770 {continue;}
            i64 iy = y + row_inner_off;

            bool enabled = !g_star_music_track_disabled[i];
            bool sel = i == g_settings.song_picker_selected;
            u32 stroke = alphaColor(theme.text_muted, 0.38);
            if sel {
                stroke = theme.panel_stroke;
                drawSelectionGlow(theme, iy - 3, 1.0);
            }
            fillRect(130, iy, 388, row_inner_h, alphaColor(theme.board_bg, 0.74));
            strokeRect(130, iy, 388, row_inner_h, stroke);
            u32 mark_col = alphaColor(theme.text_muted, 0.60);
            if enabled {mark_col = alphaColor(theme.panel_stroke, 0.90);}
            drawCheckboxText(font, enabled, 148, iy + 20, 13, mark_col);
            drawTextColor(font, musicTrackBasename(i), 222, iy + 20, 13, alphaColor(theme.text_main, 0.92));
        }

        i64 by = 806;
        bool back_sel = g_settings.song_picker_selected == song_count;
        fillRect(130, by, 388, 56, alphaColor(theme.board_bg, 0.86));
        strokeRect(130, by, 388, 56, alphaColor(theme.panel_stroke, 0.82));
        if back_sel {drawSelectionGlow(theme, by + 3, 1.0);}
        drawTextColor(font, "Close", 148, by + 18, 15, theme.text_main);
        drawTextColor(font, "ESC", 470, by + 18, 12, theme.text_muted);

        return;
    }

    if g_settings.picker_open {
        fillRect(112, 232, 424, 646, alphaColor(theme.panel_bg, 0.94));
        strokeRect(112, 232, 424, 646, alphaColor(theme.panel_stroke, 0.86));
        drawTextColor(font, "CHOOSE SHADER", 136, 258, 18, theme.text_main);

        i32 visible = 7;
        i32 max_scroll = g_settings.picker_count - visible;
        if max_scroll < 0 {max_scroll = 0;}
        if g_settings.picker_scroll < 0.0 {g_settings.picker_scroll = 0.0;}
        if g_settings.picker_scroll > max_scroll as f32 {g_settings.picker_scroll = max_scroll as f32;}

        i64 row_h = 68;
        i64 row_inner_h = 56;
        i64 row_inner_off = (row_h - row_inner_h) / 2;
        i64 start_y = 298;
        for i32 i = 0; i < g_settings.picker_count; i++ {
            i64 y = start_y + ((i as f32 - g_settings.picker_scroll) * (row_h as f32)) as i64;
            if y < 290 || y > 770 {continue;}
            i64 iy = y + row_inner_off;

            bool sel = i == g_settings.picker_selected;
            u32 stroke = alphaColor(theme.text_muted, 0.38);
            if sel {
                stroke = theme.panel_stroke;
                drawSelectionGlow(theme, iy - 3, 1.0);
            }
            fillRect(130, iy, 388, row_inner_h, alphaColor(theme.board_bg, 0.74));
            strokeRect(130, iy, 388, row_inner_h, stroke);
            drawTextColor(font, pickerNamePtr(i), 148, iy + 20, 14, theme.text_main);
        }

        i64 by = 806;
        bool back_sel = g_settings.picker_selected == g_settings.picker_count;
        fillRect(130, by, 388, 56, alphaColor(theme.board_bg, 0.86));
        strokeRect(130, by, 388, 56, alphaColor(theme.panel_stroke, 0.82));
        if back_sel {drawSelectionGlow(theme, by + 3, 1.0);}
        drawTextColor(font, "Back", 148, by + 18, 15, theme.text_main);
        drawTextColor(font, "ESC", 470, by + 18, 12, theme.text_muted);

        return;
    }

    i32 visible_rows = visibleRowCount(params.bg_visual_mode, params.bg_stars_mode, params.shader_mode);
    if visible_rows > SETTINGS_VISIBLE_ROWS {visible_rows = SETTINGS_VISIBLE_ROWS;}
    i64 list_h_base = 18 + visible_rows * 78;
    i32 list_x = uiX(112);
    i32 list_y = uiY(232);
    i32 list_w = uiS(424);
    i32 list_h = uiS(list_h_base);
    BeginScissorMode(list_x, list_y, list_w, list_h);

    drawSectionHeaderRow(font, theme, SETTINGS_ROW_SECTION_CONTROLS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode);
    if rowVisible(SETTINGS_ROW_ARR, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_ARR, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "ARR", TextFormat("%.1fF", params.arr), params.arr, 0.0, 8.0);}
    if rowVisible(SETTINGS_ROW_DAS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_DAS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "DAS", TextFormat("%.1fF", params.das), params.das, 0.0, 20.0);}
    if rowVisible(SETTINGS_ROW_DCD, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_DCD, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "DCD", TextFormat("%.1fF", params.dcd), params.dcd, 0.0, 10.0);}
    if rowVisible(SETTINGS_ROW_SDF, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_SDF, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "SDF", TextFormat("%.1fX", params.sdf), params.sdf, 1.0, 40.0);}
    if rowVisible(SETTINGS_ROW_INSTANT_RESTART, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_INSTANT_RESTART, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Instant restart", params.instant_restart);}

    drawSectionHeaderRow(font, theme, SETTINGS_ROW_SECTION_VIDEO, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode);
    if rowVisible(SETTINGS_ROW_THEME, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_THEME, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Theme", themeName(params.theme_index));}
    if rowVisible(SETTINGS_ROW_MANAGE_THEMES, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawButtonRow(font, theme, SETTINGS_ROW_MANAGE_THEMES, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "MANAGE THEMES");}
    if rowVisible(SETTINGS_ROW_SHADER, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_SHADER, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Shader", shaderModeLabel(params.shader_mode));}
    if rowVisible(SETTINGS_ROW_CHOOSE_SHADER, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {
        drawButtonRow(font, theme, SETTINGS_ROW_CHOOSE_SHADER, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "CHOOSE CUSTOM SHADER");
    }
    if rowVisible(SETTINGS_ROW_BOARD_BOUNCINESS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BOARD_BOUNCINESS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Board bounciness", TextFormat("%i%%", params.board_bounciness), params.board_bounciness as f32, 0.0, 100.0);}
    if rowVisible(SETTINGS_ROW_CRT_CURVATURE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_CRT_CURVATURE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "CRT curvature", TextFormat("%i%%", (params.crt_curvature * 100.0) as i32), params.crt_curvature, 0.2, 1.4);}
    if rowVisible(SETTINGS_ROW_CRT_BRIGHTNESS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_CRT_BRIGHTNESS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "CRT brightness", TextFormat("%i%%", (params.crt_brightness * 100.0) as i32), params.crt_brightness, 0.6, 1.8);}
    if rowVisible(SETTINGS_ROW_VHS_WAVES, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_VHS_WAVES, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "VHS waves", TextFormat("%i%%", (params.vhs_waves * 100.0) as i32), params.vhs_waves, 0.0, 1.4);}
    if rowVisible(SETTINGS_ROW_VHS_DAMAGE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_VHS_DAMAGE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "VHS damage", TextFormat("%i%%", (params.vhs_damage * 100.0) as i32), params.vhs_damage, 0.0, 1.5);}
    if rowVisible(SETTINGS_ROW_BG_VISUAL_MODE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_BG_VISUAL_MODE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "BG", bgVisualModeLabel(params.bg_visual_mode));}
    if rowVisible(SETTINGS_ROW_BG_STARS_AMOUNT, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BG_STARS_AMOUNT, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "BG stars amount", TextFormat("%i", params.bg_stars_amount), params.bg_stars_amount as f32, 0.0, 150.0);}
    if rowVisible(SETTINGS_ROW_BG_STARS_MODE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_BG_STARS_MODE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "BG stars react", bgStarsModeLabel(params.bg_stars_mode));}
    if rowVisible(SETTINGS_ROW_STAR_PEAK_TARGET, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_STAR_PEAK_TARGET, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Star peak target", TextFormat("%.1f dps", params.star_peak_target_dps), params.star_peak_target_dps, 0.5, 3.5);}
    if rowVisible(SETTINGS_ROW_STAR_INTENSITY, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_STAR_INTENSITY, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Star intensity", TextFormat("%.1f", params.star_intensity), params.star_intensity, 0.1, 1.0);}
    if rowVisible(SETTINGS_ROW_MUSIC_STYLE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_MUSIC_STYLE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Music style", musicStyleLabel(params.star_music_style));}
    if rowVisible(SETTINGS_ROW_MUSIC_INTENSITY, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_MUSIC_INTENSITY, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Music intensity", TextFormat("%.1f", params.star_music_intensity), params.star_music_intensity, 0.1, 1.0);}
    if rowVisible(SETTINGS_ROW_BG_BARS_AMOUNT, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BG_BARS_AMOUNT, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Bars amount", TextFormat("%i", params.bg_bars_amount), params.bg_bars_amount as f32, 8.0, 96.0);}
    if rowVisible(SETTINGS_ROW_BG_BARS_INTENSITY, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BG_BARS_INTENSITY, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Bars intensity", TextFormat("%.2f", params.bg_bars_intensity), params.bg_bars_intensity, 0.2, 2.0);}
    if rowVisible(SETTINGS_ROW_BG_BARS_HEIGHT_LIMIT, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BG_BARS_HEIGHT_LIMIT, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Bars height limit", TextFormat("%i%%", (params.bg_bars_height_limit * 100.0) as i32), params.bg_bars_height_limit, 0.35, 0.95);}
    if rowVisible(SETTINGS_ROW_BG_BARS_OPACITY, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BG_BARS_OPACITY, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Bars opacity", TextFormat("%i%%", (params.bg_bars_opacity * 100.0) as i32), params.bg_bars_opacity, 0.2, 1.0);}
    if rowVisible(SETTINGS_ROW_BG_BARS_GLOW, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_BG_BARS_GLOW, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Bars glow", TextFormat("%i%%", (params.bg_bars_glow * 100.0) as i32), params.bg_bars_glow, 0.0, 2.0);}
    if rowVisible(SETTINGS_ROW_BG_BARS_LAYOUT, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_BG_BARS_LAYOUT, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Bars layout", barsLayoutLabel(params.bg_bars_layout));}
    if rowVisible(SETTINGS_ROW_DOUBLE_ROW, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_DOUBLE_ROW, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Double-row UI", params.double_row_ui);}
    if rowVisible(SETTINGS_ROW_HARD_DROP_RING, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_HARD_DROP_RING, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Hard drop ring", params.hard_drop_ring);}
    if rowVisible(SETTINGS_ROW_HIGH_CONTRAST_BLOCKS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_HIGH_CONTRAST_BLOCKS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Higher contrast blocks", params.high_contrast_blocks);}
    if rowVisible(SETTINGS_ROW_BIG_FIRST_BAG_PREVIEW, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_BIG_FIRST_BAG_PREVIEW, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Big first NEXT", params.big_first_bag_preview);}
    if rowVisible(SETTINGS_ROW_FULLSCREEN_MODE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_FULLSCREEN_MODE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Fullscreen mode", params.fullscreen_mode);}

    drawSectionHeaderRow(font, theme, SETTINGS_ROW_SECTION_AUDIO, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode);
    if rowVisible(SETTINGS_ROW_MUSIC_VOLUME, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSliderRow(font, theme, SETTINGS_ROW_MUSIC_VOLUME, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Music volume", TextFormat("%i%%", (params.music_volume * 100.0) as i32), params.music_volume, 0.0, 1.0);}
    if rowVisible(SETTINGS_ROW_MUSIC_MODE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawSelectorRow(font, theme, SETTINGS_ROW_MUSIC_MODE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Music", musicModeLabel(params.music_mode));}
    if rowVisible(SETTINGS_ROW_SELECT_SONGS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawButtonRow(font, theme, SETTINGS_ROW_SELECT_SONGS, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "SELECT SONGS");}
    if rowVisible(SETTINGS_ROW_MUSIC_SHUFFLE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode) {drawToggleRow(font, theme, SETTINGS_ROW_MUSIC_SHUFFLE, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode, "Shuffle songs", params.music_shuffle);}

    drawBackRow(font, theme, SETTINGS_ROW_BACK, params.bg_visual_mode, params.bg_stars_mode, params.shader_mode);

    EndScissorMode();

    fillRect(112, 232, 424, 18, alphaColor(theme.bg_outer, 0.75));
    fillRect(112, 232 + list_h_base - 18, 424, 18, alphaColor(theme.bg_outer, 0.75));
}

fun settingsNudgeRow(row: i32, dir: i32, params: SettingsUpdateParams) >> i32 {
    if rowIsSectionHeader(row) {
        if dir < 0 {setSectionExpanded(row, false);} else {setSectionExpanded(row, true);}
        return SETTINGS_ACTION_NONE;
    }

    if row == SETTINGS_ROW_THEME {params.theme_index[0] = switchTheme(params.theme_index[0], dir); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MANAGE_THEMES {return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_SHADER {
        params.shader_mode[0] += dir;
        if params.shader_mode[0] < SHADER_MODE_NONE {params.shader_mode[0] = SHADER_MODE_CUSTOM;}
        if params.shader_mode[0] > SHADER_MODE_CUSTOM {params.shader_mode[0] = SHADER_MODE_NONE;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_CHOOSE_SHADER {return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_CRT_CURVATURE {params.crt_curvature[0] = clampf(params.crt_curvature[0] + (dir as f32) * 0.05, 0.2, 1.4); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_CRT_BRIGHTNESS {params.crt_brightness[0] = clampf(params.crt_brightness[0] + (dir as f32) * 0.05, 0.6, 1.8); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_VHS_WAVES {params.vhs_waves[0] = clampf(params.vhs_waves[0] + (dir as f32) * 0.05, 0.0, 1.4); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_VHS_DAMAGE {params.vhs_damage[0] = clampf(params.vhs_damage[0] + (dir as f32) * 0.05, 0.0, 1.5); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_ARR {params.arr[0] = clampf(params.arr[0] + (dir as f32) * 0.1, 0.0, 8.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_DAS {params.das[0] = clampf(params.das[0] + (dir as f32) * 0.1, 0.0, 20.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_DCD {params.dcd[0] = clampf(params.dcd[0] + (dir as f32) * 0.1, 0.0, 10.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_SDF {params.sdf[0] = clampf(params.sdf[0] + (dir as f32) * 0.5, 1.0, 40.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MUSIC_VOLUME {params.music_volume[0] = clampf(params.music_volume[0] + (dir as f32) * 0.05, 0.0, 1.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BOARD_BOUNCINESS {
        params.board_bounciness[0] += dir;
        if params.board_bounciness[0] < 0 {params.board_bounciness[0] = 0;}
        if params.board_bounciness[0] > 100 {params.board_bounciness[0] = 100;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_BG_VISUAL_MODE {
        params.bg_visual_mode[0] += dir;
        if params.bg_visual_mode[0] < BG_VISUAL_STARS {params.bg_visual_mode[0] = BG_VISUAL_BARS;}
        if params.bg_visual_mode[0] > BG_VISUAL_BARS {params.bg_visual_mode[0] = BG_VISUAL_STARS;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_BG_STARS_AMOUNT {
        params.bg_stars_amount[0] += dir;
        if params.bg_stars_amount[0] < 0 {params.bg_stars_amount[0] = 0;}
        if params.bg_stars_amount[0] > 150 {params.bg_stars_amount[0] = 150;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_BG_STARS_MODE {
        params.bg_stars_mode[0] += dir;
        if params.bg_stars_mode[0] < STAR_MODE_NONE {params.bg_stars_mode[0] = STAR_MODE_MUSIC;}
        if params.bg_stars_mode[0] > STAR_MODE_MUSIC {params.bg_stars_mode[0] = STAR_MODE_NONE;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_STAR_PEAK_TARGET {params.star_peak_target_dps[0] = clampf(params.star_peak_target_dps[0] + (dir as f32) * 0.1, 0.5, 3.5); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_STAR_INTENSITY {params.star_intensity[0] = clampf(params.star_intensity[0] + (dir as f32) * 0.1, 0.1, 1.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MUSIC_STYLE {
        params.star_music_style[0] += dir;
        if params.star_music_style[0] < STAR_MUSIC_STYLE_PULSE {params.star_music_style[0] = STAR_MUSIC_STYLE_AGGRO;}
        if params.star_music_style[0] > STAR_MUSIC_STYLE_AGGRO {params.star_music_style[0] = STAR_MUSIC_STYLE_PULSE;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_MUSIC_INTENSITY {params.star_music_intensity[0] = clampf(params.star_music_intensity[0] + (dir as f32) * 0.1, 0.1, 1.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BG_BARS_AMOUNT {
        params.bg_bars_amount[0] += dir;
        if params.bg_bars_amount[0] < 8 {params.bg_bars_amount[0] = 8;}
        if params.bg_bars_amount[0] > 96 {params.bg_bars_amount[0] = 96;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_BG_BARS_INTENSITY {params.bg_bars_intensity[0] = clampf(params.bg_bars_intensity[0] + (dir as f32) * 0.05, 0.2, 2.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BG_BARS_HEIGHT_LIMIT {params.bg_bars_height_limit[0] = clampf(params.bg_bars_height_limit[0] + (dir as f32) * 0.02, 0.35, 0.95); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BG_BARS_OPACITY {params.bg_bars_opacity[0] = clampf(params.bg_bars_opacity[0] + (dir as f32) * 0.05, 0.2, 1.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BG_BARS_GLOW {params.bg_bars_glow[0] = clampf(params.bg_bars_glow[0] + (dir as f32) * 0.05, 0.0, 2.0); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BG_BARS_LAYOUT {
        params.bg_bars_layout[0] += dir;
        if params.bg_bars_layout[0] < BG_BARS_LAYOUT_CLASSIC {params.bg_bars_layout[0] = BG_BARS_LAYOUT_MIRROR;}
        if params.bg_bars_layout[0] > BG_BARS_LAYOUT_MIRROR {params.bg_bars_layout[0] = BG_BARS_LAYOUT_CLASSIC;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_DOUBLE_ROW {toggleBoolPtr(params.double_row_ui); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_INSTANT_RESTART {toggleBoolPtr(params.instant_restart); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_HARD_DROP_RING {toggleBoolPtr(params.hard_drop_ring); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_HIGH_CONTRAST_BLOCKS {toggleBoolPtr(params.high_contrast_blocks); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BIG_FIRST_BAG_PREVIEW {toggleBoolPtr(params.big_first_bag_preview); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_FULLSCREEN_MODE {toggleBoolPtr(params.fullscreen_mode); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MUSIC_MODE {
        params.music_mode[0] += dir;
        if params.music_mode[0] < MUSIC_MODE_BUILTIN {params.music_mode[0] = MUSIC_MODE_CUSTOM;}
        if params.music_mode[0] > MUSIC_MODE_CUSTOM {params.music_mode[0] = MUSIC_MODE_BUILTIN;}
        return SETTINGS_ACTION_NONE;
    }
    if row == SETTINGS_ROW_SELECT_SONGS {return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_MUSIC_SHUFFLE {toggleBoolPtr(params.music_shuffle); return SETTINGS_ACTION_NONE;}
    if row == SETTINGS_ROW_BACK {return SETTINGS_ACTION_BACK;}
    return SETTINGS_ACTION_NONE;
}

fun settingsUpdate(params: SettingsUpdateParams) >> i32 {
    g_settings.theme_custom_active = params.theme_index[0] == themeCustomSlotIndex();
    if !g_settings.theme_custom_active && g_settings.theme_mgr_open {closeThemeManager();}

    updateSectionAnimations(GetFrameTime());

    Vector2 mouse = GetMousePosition();
    bool mouse_moved = absf(mouse.x - g_settings.mouse_last_x) > 0.5 || absf(mouse.y - g_settings.mouse_last_y) > 0.5;
    if mouse_moved {g_settings.keyboard_nav_lock = false;}
    g_settings.mouse_last_x = mouse.x;
    g_settings.mouse_last_y = mouse.y;

    if g_settings.song_picker_open {
        if IsKeyPressed(KEY_ESCAPE) {closeSongPicker(); return SETTINGS_ACTION_NONE;}

        i32 song_count = g_star_music_track_count;
        i32 song_max_sel = song_count;

        if IsKeyPressed(KEY_UP) {
            g_settings.song_picker_selected -= 1;
            if g_settings.song_picker_selected < 0 {g_settings.song_picker_selected = song_max_sel;}
            g_settings.keyboard_nav_lock = true;
        }
        if IsKeyPressed(KEY_DOWN) {
            g_settings.song_picker_selected += 1;
            if g_settings.song_picker_selected > song_max_sel {g_settings.song_picker_selected = 0;}
            g_settings.keyboard_nav_lock = true;
        }

        i32 song_visible = 7;
        i32 song_max_scroll = song_count - song_visible;
        if song_max_scroll < 0 {song_max_scroll = 0;}
        f32 song_wheel = GetMouseWheelMove();
        if song_wheel > 0.0 {g_settings.song_picker_scroll -= 1.0;}
        if song_wheel < 0.0 {g_settings.song_picker_scroll += 1.0;}
        if g_settings.song_picker_selected < (g_settings.song_picker_scroll as i32) {g_settings.song_picker_scroll = g_settings.song_picker_selected as f32;}
        if g_settings.song_picker_selected >= (g_settings.song_picker_scroll as i32) + song_visible {g_settings.song_picker_scroll = (g_settings.song_picker_selected - song_visible + 1) as f32;}
        if g_settings.song_picker_scroll < 0.0 {g_settings.song_picker_scroll = 0.0;}
        if g_settings.song_picker_scroll > song_max_scroll as f32 {g_settings.song_picker_scroll = song_max_scroll as f32;}

        if !g_settings.keyboard_nav_lock {
            i32 hovered = 0;
            if uiScrollListHoverIndex(mouse, 130, 298, 388, 68, song_visible, g_settings.song_picker_scroll, song_count, &hovered) {
                g_settings.song_picker_selected = hovered;
            }
        }
        if !g_settings.keyboard_nav_lock && pointInBaseRect(mouse.x, mouse.y, 130, 806, 388, 56) {g_settings.song_picker_selected = song_count;}

        bool song_choose = IsKeyPressed(KEY_ENTER) || IsMouseButtonPressed(MOUSE_BUTTON_LEFT);
        if song_choose {
            g_settings.keyboard_nav_lock = false;
            if g_settings.song_picker_selected == song_count {
                closeSongPicker();
                return SETTINGS_ACTION_NONE;
            }
            if g_settings.song_picker_selected >= 0 && g_settings.song_picker_selected < song_count {
                i32 idx = g_settings.song_picker_selected;
                g_star_music_track_disabled[idx] = toggled(g_star_music_track_disabled[idx]);
                if countEnabledTracks() <= 0 {
                    g_star_music_track_disabled[g_settings.song_picker_selected] = false;
                }
                g_songs_modified = true;
            }
        }
        return SETTINGS_ACTION_NONE;
    }

    if g_settings.picker_open {
        if IsKeyPressed(KEY_ESCAPE) {closeShaderPicker(); return SETTINGS_ACTION_NONE;}

        i32 max_sel = g_settings.picker_count;
        if IsKeyPressed(KEY_UP) {
            g_settings.picker_selected -= 1;
            if g_settings.picker_selected < 0 {g_settings.picker_selected = max_sel;}
            g_settings.keyboard_nav_lock = true;
        }
        if IsKeyPressed(KEY_DOWN) {
            g_settings.picker_selected += 1;
            if g_settings.picker_selected > max_sel {g_settings.picker_selected = 0;}
            g_settings.keyboard_nav_lock = true;
        }

        i32 visible = 7;
        i32 max_scroll = g_settings.picker_count - visible;
        if max_scroll < 0 {max_scroll = 0;}
        f32 wheel = GetMouseWheelMove();
        if wheel > 0.0 {g_settings.picker_scroll -= 1.0;}
        if wheel < 0.0 {g_settings.picker_scroll += 1.0;}
        if g_settings.picker_selected < (g_settings.picker_scroll as i32) {g_settings.picker_scroll = g_settings.picker_selected as f32;}
        if g_settings.picker_selected >= (g_settings.picker_scroll as i32) + visible {g_settings.picker_scroll = (g_settings.picker_selected - visible + 1) as f32;}
        if g_settings.picker_scroll < 0.0 {g_settings.picker_scroll = 0.0;}
        if g_settings.picker_scroll > max_scroll as f32 {g_settings.picker_scroll = max_scroll as f32;}

        if !g_settings.keyboard_nav_lock {
            i32 hovered = 0;
            if uiScrollListHoverIndex(mouse, 130, 298, 388, 68, visible, g_settings.picker_scroll, g_settings.picker_count, &hovered) {
                g_settings.picker_selected = hovered;
            }
        }
        if !g_settings.keyboard_nav_lock && pointInBaseRect(mouse.x, mouse.y, 130, 806, 388, 56) {g_settings.picker_selected = g_settings.picker_count;}

        bool choose = IsKeyPressed(KEY_ENTER) || IsMouseButtonPressed(MOUSE_BUTTON_LEFT);
        if choose {
            g_settings.keyboard_nav_lock = false;
            if g_settings.picker_selected == g_settings.picker_count {
                closeShaderPicker();
                return SETTINGS_ACTION_NONE;
            }
            if g_settings.picker_selected >= 0 && g_settings.picker_selected < g_settings.picker_count {
                copyFixed(params.custom_shader_name, pickerNamePtr(g_settings.picker_selected), CUSTOM_SHADER_NAME_MAX);
                return SETTINGS_ACTION_NONE;
            }
        }
        return SETTINGS_ACTION_NONE;
    }

    if updateThemeManager(params.theme_index) {return SETTINGS_ACTION_NONE;}

    if IsKeyPressed(KEY_ESCAPE) {return SETTINGS_ACTION_BACK;}

    settingsEnsureSelectedVisible(params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);

    i32 item_count = visibleRowCount(params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
    i32 max_scroll = item_count - (SETTINGS_VISIBLE_ROWS as i32);
    if max_scroll < 0 {max_scroll = 0;}

    f32 wheel = GetMouseWheelMove();
    if (wheel > 0.0) {g_settings.scroll -= 1.0;} else if (wheel < 0.0) {g_settings.scroll += 1.0;}
    if g_settings.scroll < 0.0 {g_settings.scroll = 0.0;}
    if g_settings.scroll > (max_scroll as f32) {g_settings.scroll = max_scroll as f32;}

    if IsKeyPressed(KEY_UP) {
        i32 order = rowOrder(g_settings.selected_row, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        if order < 0 {order = 0;}
        order -= 1;
        if order < 0 {order = item_count - 1;}
        g_settings.selected_row = rowFromOrder(order, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        g_settings.keyboard_nav_lock = true;
    }
    if IsKeyPressed(KEY_DOWN) {
        i32 order = rowOrder(g_settings.selected_row, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        if order < 0 {order = 0;}
        order += 1;
        if order >= item_count {order = 0;}
        g_settings.selected_row = rowFromOrder(order, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        g_settings.keyboard_nav_lock = true;
    }

    i32 sel_order = rowOrder(g_settings.selected_row, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
    if sel_order < 0 {sel_order = 0;}
    if (sel_order as f32) < g_settings.scroll {g_settings.scroll = sel_order as f32;}
    if sel_order >= (g_settings.scroll as i32) + (SETTINGS_VISIBLE_ROWS as i32) {g_settings.scroll = (sel_order - ((SETTINGS_VISIBLE_ROWS as i32) - 1)) as f32;}
    if g_settings.scroll < 0.0 {g_settings.scroll = 0.0;}
    if g_settings.scroll > (max_scroll as f32) {g_settings.scroll = max_scroll as f32;}

    if IsKeyPressed(KEY_LEFT) {
        g_settings.keyboard_nav_lock = true;
        i32 act = settingsNudgeRow(g_settings.selected_row, -1, params);
        settingsEnsureSelectedVisible(params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        if act != SETTINGS_ACTION_NONE {return act;}
    }
    if IsKeyPressed(KEY_RIGHT) {
        g_settings.keyboard_nav_lock = true;
        i32 act = settingsNudgeRow(g_settings.selected_row, 1, params);
        settingsEnsureSelectedVisible(params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        if act != SETTINGS_ACTION_NONE {return act;}
    }
    if IsKeyPressed(KEY_ENTER) {
        g_settings.keyboard_nav_lock = true;
        if rowIsSectionHeader(g_settings.selected_row) {
            toggleSection(g_settings.selected_row);
            settingsEnsureSelectedVisible(params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        } else if g_settings.selected_row == SETTINGS_ROW_MANAGE_THEMES {
            openThemeManager(params.theme_index);
        } else if g_settings.selected_row == SETTINGS_ROW_CHOOSE_SHADER {
            openShaderPicker(params.custom_shader_name);
        } else if g_settings.selected_row == SETTINGS_ROW_SELECT_SONGS {
            if g_star_music_track_count > 0 {openSongPicker();}
        } else {
            i32 act = settingsNudgeRow(g_settings.selected_row, 1, params);
            settingsEnsureSelectedVisible(params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
            if act != SETTINGS_ACTION_NONE {return act;}
        }
    }

    i32 visible_rows = item_count;
    if visible_rows > SETTINGS_VISIBLE_ROWS {visible_rows = SETTINGS_VISIBLE_ROWS;}

    if !g_settings.keyboard_nav_lock {
        i32 hovered_order = 0;
        if uiScrollListHoverIndex(mouse, 112, 246, 424, 78, visible_rows, g_settings.scroll, item_count, &hovered_order) {
            g_settings.selected_row = rowFromOrder(hovered_order, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        }
    }

    if IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {
        g_settings.keyboard_nav_lock = false;
        if rowIsSectionHeader(g_settings.selected_row) && rowBodyHit(mouse, g_settings.selected_row, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]) {
            toggleSection(g_settings.selected_row);
            settingsEnsureSelectedVisible(params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
        } else {
            i32 act = SETTINGS_ACTION_NONE;
            if g_settings.selected_row == SETTINGS_ROW_THEME && rowBodyHit(mouse, SETTINGS_ROW_THEME, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]) {
                act = settingsNudgeRow(SETTINGS_ROW_THEME, selectorDirectionFromMouse(mouse.x), params);
            } else if rowUsesSelectorMouseNudge(g_settings.selected_row) && rowBodyHit(mouse, g_settings.selected_row, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]) {
                act = settingsNudgeRow(g_settings.selected_row, selectorDirectionFromMouse(mouse.x), params);
            } else if g_settings.selected_row == SETTINGS_ROW_CHOOSE_SHADER && rowBodyHit(mouse, SETTINGS_ROW_CHOOSE_SHADER, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]) {
                openShaderPicker(params.custom_shader_name);
            } else if g_settings.selected_row == SETTINGS_ROW_MANAGE_THEMES && rowBodyHit(mouse, SETTINGS_ROW_MANAGE_THEMES, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]) {
                openThemeManager(params.theme_index);
            } else if g_settings.selected_row == SETTINGS_ROW_SELECT_SONGS && rowBodyHit(mouse, SETTINGS_ROW_SELECT_SONGS, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]) {
                if g_star_music_track_count > 0 {openSongPicker();}
            } else if rowUsesToggleMouseNudge(g_settings.selected_row) && rowBodyHit(mouse, g_settings.selected_row, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]) {
                act = settingsNudgeRow(g_settings.selected_row, 1, params);
            } else if g_settings.selected_row == SETTINGS_ROW_BACK && rowBodyHit(mouse, SETTINGS_ROW_BACK, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]) {
                return SETTINGS_ACTION_BACK;
            }
            if act != SETTINGS_ACTION_NONE {return act;}
        }
    }

    if IsMouseButtonDown(MOUSE_BUTTON_LEFT) {
        dragSliderF32(mouse, SETTINGS_ROW_CRT_CURVATURE, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.crt_curvature, 0.2, 1.4);
        dragSliderF32(mouse, SETTINGS_ROW_CRT_BRIGHTNESS, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.crt_brightness, 0.6, 1.8);
        dragSliderF32(mouse, SETTINGS_ROW_VHS_WAVES, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.vhs_waves, 0.0, 1.4);
        dragSliderF32(mouse, SETTINGS_ROW_VHS_DAMAGE, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.vhs_damage, 0.0, 1.5);
        dragSliderF32(mouse, SETTINGS_ROW_ARR, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.arr, 0.0, 8.0);
        dragSliderF32(mouse, SETTINGS_ROW_DAS, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.das, 0.0, 20.0);
        dragSliderF32(mouse, SETTINGS_ROW_DCD, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.dcd, 0.0, 10.0);
        dragSliderF32(mouse, SETTINGS_ROW_SDF, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.sdf, 1.0, 40.0);
        dragSliderF32(mouse, SETTINGS_ROW_MUSIC_VOLUME, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.music_volume, 0.0, 1.0);
        dragSliderI32(mouse, SETTINGS_ROW_BOARD_BOUNCINESS, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.board_bounciness, 0.0, 100.0);
        dragSliderI32(mouse, SETTINGS_ROW_BG_STARS_AMOUNT, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.bg_stars_amount, 0.0, 150.0);
        dragSliderF32(mouse, SETTINGS_ROW_STAR_PEAK_TARGET, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.star_peak_target_dps, 0.5, 3.5);
        dragSliderF32(mouse, SETTINGS_ROW_STAR_INTENSITY, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.star_intensity, 0.1, 1.0);
        dragSliderF32(mouse, SETTINGS_ROW_MUSIC_INTENSITY, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.star_music_intensity, 0.1, 1.0);
        dragSliderI32(mouse, SETTINGS_ROW_BG_BARS_AMOUNT, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.bg_bars_amount, 8.0, 96.0);
        dragSliderF32(mouse, SETTINGS_ROW_BG_BARS_INTENSITY, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.bg_bars_intensity, 0.2, 2.0);
        dragSliderF32(mouse, SETTINGS_ROW_BG_BARS_HEIGHT_LIMIT, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.bg_bars_height_limit, 0.35, 0.95);
        dragSliderF32(mouse, SETTINGS_ROW_BG_BARS_OPACITY, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.bg_bars_opacity, 0.2, 1.0);
        dragSliderF32(mouse, SETTINGS_ROW_BG_BARS_GLOW, params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0], params.bg_bars_glow, 0.0, 2.0);
    }

    settingsEnsureSelectedVisible(params.bg_visual_mode[0], params.bg_stars_mode[0], params.shader_mode[0]);
    return SETTINGS_ACTION_NONE;
}
