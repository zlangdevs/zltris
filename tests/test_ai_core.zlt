module zltris.test;
use zltris.ai

fun zeroBoard(b: ptr<i32>) >> void {
    for i32 i = 0; i < 220; i++ { b[i] = 0; }
}

fun testMath() >> void {
    checkEqI("pieces_absi(-5)", pieces_absi(-5), 5);
    checkEqI("pieces_absi(7)", pieces_absi(7), 7);
    checkEqI("pieces_minI(3,7)", pieces_minI(3, 7), 3);
    checkEqI("pieces_maxI(3,7)", pieces_maxI(3, 7), 7);
}

fun testBoardIndex() >> void {
    checkEqI("pieces_boardIndex(0,0)", pieces_boardIndex(0, 0), 0);
    checkEqI("pieces_boardIndex(3,5)", pieces_boardIndex(3, 5), 53);
    checkEqI("pieces_boardIndex(9,21)", pieces_boardIndex(9, 21), 219);
}

fun testRotation() >> void {
    checkEqI("pieces_normalizeRotation(0)", pieces_normalizeRotation(0), 0);
    checkEqI("pieces_normalizeRotation(4)", pieces_normalizeRotation(4), 0);
    checkEqI("pieces_normalizeRotation(7)", pieces_normalizeRotation(7), 3);
    checkEqI("pieces_normalizeRotation(-1)", pieces_normalizeRotation(-1), 3);
    checkEqI("rotationCount(O)", rotationCount(1), 1);
    checkEqI("rotationCount(T)", rotationCount(2), 4);
    checkEqI("stepDistance(0->2)", rotationStepDistance(0, 2), 2);
    checkEqI("stepDistance(0->3)", rotationStepDistance(0, 3), 1);
    checkEqI("stepDistance(1->0)", rotationStepDistance(1, 0), 1);
}

fun testBounds() >> void {
    arr<i32, 220> board = {0};
    ptr<i32> b = &board[0];
    zeroBoard(b);
    checkTrue("blocked left wall", boardCellBlocked(b, -1, 5));
    checkTrue("blocked right wall", boardCellBlocked(b, 10, 5));
    checkTrue("blocked below floor", boardCellBlocked(b, 3, 22));
    checkFalse("open above ceiling", boardCellBlocked(b, 3, -1));
    checkFalse("open empty cell", boardCellBlocked(b, 3, 5));
    board[pieces_boardIndex(3, 5)] = 1;
    checkTrue("blocked filled cell", boardCellBlocked(b, 3, 5));
}

fun testPieceFit() >> void {
    arr<i32, 220> board = {0};
    ptr<i32> b = &board[0];
    zeroBoard(b);
    checkTrue("piece fits in empty board", pieces_pieceFits(b, 0, 0, 3, 0));
    checkFalse("piece rejected off left", pieces_pieceFits(b, 0, 0, -5, 0));
    checkFalse("piece rejected off right", pieces_pieceFits(b, 0, 0, 99, 0));
}

fun testLineClear() >> void {
    arr<i32, 220> board = {0};
    ptr<i32> b = &board[0];
    zeroBoard(b);

    checkEqI("no clear on empty board", clearLinesLocal(b), 0);
    checkTrue("empty board is empty", boardIsEmptyLocal(b));

    for i32 x = 0; x < 10; x++ { board[pieces_boardIndex(x, 21)] = 1; }
    board[pieces_boardIndex(0, 20)] = 1;

    checkEqI("clears one full row", clearLinesLocal(b), 1);
    checkTrue("floating block fell to floor", board[pieces_boardIndex(0, 21)] != 0);

    i32 filled = 0;
    for i32 i = 0; i < 220; i++ { if board[i] != 0 { filled += 1; } }
    checkEqI("exactly one cell remains", filled, 1);

    for i32 x = 0; x < 10; x++ {
        board[pieces_boardIndex(x, 20)] = 1;
        board[pieces_boardIndex(x, 21)] = 1;
    }
    checkEqI("clears two full rows", clearLinesLocal(b), 2);
    checkTrue("board empty after double clear", boardIsEmptyLocal(b));
}
