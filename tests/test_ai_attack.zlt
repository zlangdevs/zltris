module zltris.test;
use zltris.ai

fun zeroBoardA(b: ptr<i32>) >> void {
    for i32 i = 0; i < 220; i++ { b[i] = 0; }
}

fun testLineClearAttack() >> void {
    checkEqI("single = 0", aiLockAttack(1, false, false, false, false, 0, false), 0);
    checkEqI("double = 1", aiLockAttack(2, false, false, false, false, 0, false), 1);
    checkEqI("triple = 2", aiLockAttack(3, false, false, false, false, 0, false), 2);
    checkEqI("tetris = 4", aiLockAttack(4, false, false, false, false, 0, false), 4);
    checkEqI("tetris b2b = 6", aiLockAttack(4, false, false, true, true, 0, false), 6);
    checkEqI("double b2b = 2", aiLockAttack(2, false, false, true, true, 0, false), 2);
}

fun testSpinAttack() >> void {
    checkEqI("tss = 2", aiLockAttack(1, true, false, false, false, 0, false), 2);
    checkEqI("tsd = 4", aiLockAttack(2, true, false, false, false, 0, false), 4);
    checkEqI("tst = 6", aiLockAttack(3, true, false, false, false, 0, false), 6);
    checkEqI("tsd mini = 1", aiLockAttack(2, true, true, false, false, 0, false), 1);
    checkEqI("tss mini = 0", aiLockAttack(1, true, true, false, false, 0, false), 0);
}

fun testAttackBonuses() >> void {
    checkEqI("double + combo4 = 3", aiLockAttack(2, false, false, false, false, 4, false), 3);
    checkEqI("tetris + all clear = 14", aiLockAttack(4, false, false, false, false, 0, true), 14);
    checkEqI("no clear, no all-clear bonus", aiLockAttack(0, false, false, false, false, 0, true), 0);
}

fun testEstimateAttack() >> void {
    checkEqI("estimate empty = 0", aiBotEstimateAttack(0, false, false, 0, 0), 0);
    checkEqI("estimate tetris = 4", aiBotEstimateAttack(4, false, false, 0, 0), 4);
}

fun testTSpinDetection() >> void {
    arr<i32, 220> board = {0};
    ptr<i32> b = &board[0];
    zeroBoardA(b);

    checkFalse("non-T piece is never a t-spin", isTSpinPlacement(b, 1, 4, 18));

    board[pieces_boardIndex(4, 18)] = 1;
    board[pieces_boardIndex(6, 18)] = 1;
    checkFalse("two corners is not a t-spin", isTSpinPlacement(b, 2, 4, 18));

    board[pieces_boardIndex(4, 20)] = 1;
    checkTrue("three corners is a t-spin", isTSpinPlacement(b, 2, 4, 18));
}
