    Game next = self;
    next.screen = screen;
    return next;
}

fun with_settings_return_screen(self: Game, screen: i32) >> Game {
    Game next = self;
    next.settings_return_screen = screen;
    return next;
}

fun currentTheme() >> Theme {
    return g_game.current_theme();
}

fun trimLeftSpaces(s: ptr<u8>) >> ptr<u8> {
    ptr<u8> p = s;
    for (p[0] == (' ' as u8) || p[0] == ('\t' as u8)) {
        p = p + 1;
    }
    return p;
}

fun trimRightSpacesInPlace(s: ptr<u8>) >> void {
    i32 len = strlen(s) as i32;
    for (len > 0) {
        u8 c = s[len - 1];
        if (c == (' ' as u8) || c == ('\t' as u8) || c == ('\r' as u8) || c == ('\n' as u8)) {
            s[len - 1] = 0;
            len -= 1;
            continue;
        }
        break;
    }
}

fun parseBoolValue(s: ptr<u8>, fallback: bool) >> bool {
    ptr<u8> v = trimLeftSpaces(s);
    trimRightSpacesInPlace(v);
    if strEq(v, "1") || strEq(v, "true") || strEq(v, "TRUE") || strEq(v, "on") || strEq(v, "ON") {return true;}
    if strEq(v, "0") || strEq(v, "false") || strEq(v, "FALSE") || strEq(v, "off") || strEq(v, "OFF") {return false;}
    return fallback;
}

fun parseFloatValue(s: ptr<u8>, fallback: f32) >> f32 {
    ptr<u8> p = trimLeftSpaces(s);
    i32 sign = 1;
    if (p[0] == ('-' as u8)) {
        sign = -1;
        p = p + 1;
    } else if (p[0] == ('+' as u8)) {
        p = p + 1;
    }

    i32 int_part = 0;
    i32 frac_part = 0;
    i32 frac_div = 1;
    bool seen_digit = false;

    for (p[0] >= ('0' as u8) && p[0] <= ('9' as u8)) {
        int_part = int_part * 10 + ((p[0] as i32) - ('0' as i32));
        p = p + 1;
        seen_digit = true;
    }

    if (p[0] == ('.' as u8)) {
        p = p + 1;
        for (p[0] >= ('0' as u8) && p[0] <= ('9' as u8)) {
            frac_part = frac_part * 10 + ((p[0] as i32) - ('0' as i32));
            frac_div = frac_div * 10;
            p = p + 1;
            seen_digit = true;
        }
    }

    if !seen_digit {return fallback;}

    f32 value = (int_part as f32) + (frac_part as f32) / (frac_div as f32);
    if sign < 0 {value = -value;}
    return value;
}

fun clampSettings() >> void {
    if g_game.theme_index < 0 {g_game.theme_index = 0;}
    if g_game.theme_index >= themeCount() {g_game.theme_index = themeCount() - 1;}
    if g_arr_frames < 0.0 {g_arr_frames = 0.0;}
    if g_arr_frames > 8.0 {g_arr_frames = 8.0;}
    if g_das_frames < 0.0 {g_das_frames = 0.0;}
    if g_das_frames > 20.0 {g_das_frames = 20.0;}
    if g_dcd_frames < 0.0 {g_dcd_frames = 0.0;}
    if g_dcd_frames > 10.0 {g_dcd_frames = 10.0;}
    if g_sdf_multiplier < 1.0 {g_sdf_multiplier = 1.0;}
    if g_sdf_multiplier > 40.0 {g_sdf_multiplier = 40.0;}
    if g_bg_stars_amount < 0 {g_bg_stars_amount = 0;}
    if g_bg_stars_amount > 150 {g_bg_stars_amount = 150;}
    if g_bg_star_react_mode < STAR_MODE_NONE {g_bg_star_react_mode = STAR_MODE_NONE;}
    if g_bg_star_react_mode > STAR_MODE_MUSIC {g_bg_star_react_mode = STAR_MODE_MUSIC;}
    if g_star_peak_target_dps < 0.5 {g_star_peak_target_dps = 0.5;}
    if g_star_peak_target_dps > 3.5 {g_star_peak_target_dps = 3.5;}
    if g_star_intensity < 0.1 {g_star_intensity = 0.1;}
    if g_star_intensity > 1.0 {g_star_intensity = 1.0;}
    if g_board_bounciness < 0 {g_board_bounciness = 0;}
    if g_board_bounciness > 100 {g_board_bounciness = 100;}
}

fun saveSettingsFile() >> void {
    i32 fd = openForWrite(SETTINGS_FILE_PATH);
    if fd < 0 {return;}

    writeLineFd(fd, TextFormat("theme=%i", g_game.theme_index));
    writeLineFd(fd, TextFormat("arr=%.2f", g_arr_frames));
    writeLineFd(fd, TextFormat("das=%.2f", g_das_frames));
    writeLineFd(fd, TextFormat("dcd=%.2f", g_dcd_frames));
    writeLineFd(fd, TextFormat("sdf=%.2f", g_sdf_multiplier));
    i32 double_row_flag = 0;
    if g_double_row_ui {double_row_flag = 1;}
    i32 instant_restart_flag = 0;
    if g_instant_restart {instant_restart_flag = 1;}

    writeLineFd(fd, TextFormat("double_row_ui=%i", double_row_flag));
    writeLineFd(fd, TextFormat("instant_restart=%i", instant_restart_flag));
    writeLineFd(fd, TextFormat("bg_stars_amount=%i", g_bg_stars_amount));
    writeLineFd(fd, TextFormat("bg_star_react_mode=%i", g_bg_star_react_mode));
    writeLineFd(fd, TextFormat("star_peak_target_dps=%.2f", g_star_peak_target_dps));
    writeLineFd(fd, TextFormat("star_intensity=%.2f", g_star_intensity));
    writeLineFd(fd, TextFormat("board_bounciness=%i", g_board_bounciness));

    close(fd);
}

fun loadSettingsFile() >> void {
    i32 fd = openForRead(SETTINGS_FILE_PATH);
    if fd < 0 {return;}

    arr<u8, 262144> data = {0};
    i64 bytes_read = readAll(fd, &data[0], 262143);
    close(fd);
    if bytes_read <= 0 {return;}
    data[bytes_read as i32] = 0;

    ptr<u8> line = &data[0];
    for (line[0] != 0) {
        ptr<u8> next = line;
        for (next[0] != 0 && next[0] != ('\n' as u8)) {
            next = next + 1;
        }
        if (next[0] == ('\n' as u8)) {
            next[0] = 0;
            next = next + 1;
        }

        ptr<u8> raw = trimLeftSpaces(line);
        trimRightSpacesInPlace(raw);
        if (raw[0] != 0 && raw[0] != ('#' as u8) && raw[0] != (';' as u8)) {
            ptr<u8> eq = raw;
            for (eq[0] != 0 && eq[0] != ('=' as u8)) {
                eq = eq + 1;
            }
            if (eq[0] == ('=' as u8)) {
                eq[0] = 0;
                ptr<u8> key = trimLeftSpaces(raw);
                trimRightSpacesInPlace(key);
                ptr<u8> value = trimLeftSpaces(eq + 1);
                trimRightSpacesInPlace(value);

                if (strEq(key, "theme")) {
                    g_game.theme_index = atoi(value);
                } else if (strEq(key, "arr")) {
                    g_arr_frames = parseFloatValue(value, g_arr_frames);
                } else if (strEq(key, "das")) {
                    g_das_frames = parseFloatValue(value, g_das_frames);
                } else if (strEq(key, "dcd")) {
                    g_dcd_frames = parseFloatValue(value, g_dcd_frames);
                } else if (strEq(key, "sdf")) {
                    g_sdf_multiplier = parseFloatValue(value, g_sdf_multiplier);
                } else if (strEq(key, "double_row_ui")) {
                    g_double_row_ui = parseBoolValue(value, g_double_row_ui);
                } else if (strEq(key, "instant_restart")) {
                    g_instant_restart = parseBoolValue(value, g_instant_restart);
                } else if (strEq(key, "bg_stars_amount")) {
                    g_bg_stars_amount = atoi(value);
                } else if (strEq(key, "bg_star_react_mode")) {
                    g_bg_star_react_mode = atoi(value);
                } else if (strEq(key, "star_peak_target_dps")) {
                    g_star_peak_target_dps = parseFloatValue(value, g_star_peak_target_dps);
                } else if (strEq(key, "star_intensity")) {
                    g_star_intensity = parseFloatValue(value, g_star_intensity);
                } else if (strEq(key, "board_bounciness")) {
                    g_board_bounciness = atoi(value);
                }
            }
        }

        line = next;
    }

    clampSettings();
}

fun defaultArenaChampionSetup() >> BotSetupState {
    BotSetupState setup = {0};
    setup.target_apm = BOT_DUELS_FIXED_APM;
    setup.garbage_messiness = 35.0;
    setup.high_stack_tolerance = false;
    setup.panic_burst_enabled = true;
    setup.index = 0;
    return setup;
}

fun clampArenaSetup(setup: BotSetupState) >> BotSetupState {
    BotSetupState next = setup;
    next.target_apm = BOT_DUELS_FIXED_APM;
    next.garbage_messiness = 35.0;
    next.high_stack_tolerance = false;
    next.panic_burst_enabled = true;
    next.index = 0;
    return next;
}

fun copyI32Array(dst: ptr<i32>, src: ptr<i32>, count: i32) >> void {
    for i32 i = 0; i < count; i++ {dst[i] = src[i];}
}

fun loadDefaultArenaTuning() >> void {
    aiFillDefaultTuning(&g_bot_arena_champion_tuning[0]);
    for i32 i = 0; i < AI_TUNE_COUNT; i++ {
        g_bot_arena_champion_tuning[i] = aiClampTuningValue(i, g_bot_arena_champion_tuning[i]);
    }
    normalizeChampionHistory();
}

fun applyAiTuning(values: ptr<i32>) >> void {
    for i32 i = 0; i < AI_TUNE_COUNT; i++ {
        aiSetTuningValue(i, values[i]);
    }
}

fun applyChampionAiTuning() >> void {
    applyAiTuning(&g_bot_arena_champion_tuning[0]);
}

fun applyStockAiTuning() >> void {
    aiResetTuningDefaults();
}

fun applyBotSetupWeights() >> void {
    if g_bot_setup.weights_mode == BOT_WEIGHTS_STOCK {applyStockAiTuning();}
    else {applyChampionAiTuning();}
}

fun arenaRequiredWins(max_rounds: i32, max_losses: i32) >> i32 {
    i32 wins = max_rounds - max_losses;
    if wins < 1 {wins = 1;}
    return wins;
}

fun arenaHistorySlotCount() >> i32 {
    i32 count = BOT_ARENA_SAVED_CHAMPIONS - 1;
    if count < 0 {count = 0;}
    if count > BOT_ARENA_HISTORY_STORAGE {count = BOT_ARENA_HISTORY_STORAGE;}
    return count;
}

fun arenaHistoryTuningPtr(slot: i32) >> ptr<i32> {
    ptr<i32> base = &g_bot_arena_history_tuning[0];
    return base + slot * AI_TUNE_COUNT;
}

fun arenaGauntletChampionCount() >> i32 {
    i32 count = 1 + g_bot_arena.history_size;
    if count > BOT_ARENA_SAVED_CHAMPIONS {count = BOT_ARENA_SAVED_CHAMPIONS;}
    return count;
}

fun arenaTargetSetup(index: i32) >> BotSetupState {
    return g_bot_arena.champion_setup;
}

fun arenaTargetGeneration(index: i32) >> i32 {
    if index == 0 {return g_bot_arena.champion_generation;}
    return g_bot_arena_history_generations[index - 1];
}

fun copyArenaTargetTuning(index: i32, out_values: ptr<i32>) >> void {
    if index == 0 {
        copyI32Array(out_values, &g_bot_arena_champion_tuning[0], AI_TUNE_COUNT);
        return;
    }
    copyI32Array(out_values, arenaHistoryTuningPtr(index - 1), AI_TUNE_COUNT);
}

fun pushChampionToHistory() >> void {
    i32 history_slots = arenaHistorySlotCount();
    if history_slots <= 0 {return;}

    i32 existing = -1;
    for i32 slot = 0; slot < g_bot_arena.history_size; slot++ {
        if g_bot_arena_history_generations[slot] == g_bot_arena.champion_generation {existing = slot;}
    }
    if existing >= 0 {
        for i32 slot = existing; slot < g_bot_arena.history_size - 1; slot++ {
            g_bot_arena_history_generations[slot] = g_bot_arena_history_generations[slot + 1];
            copyI32Array(arenaHistoryTuningPtr(slot), arenaHistoryTuningPtr(slot + 1), AI_TUNE_COUNT);
        }
        if g_bot_arena.history_size > 0 {g_bot_arena.history_size -= 1;}
    }

    for i32 slot = history_slots - 1; slot > 0; slot-- {
        g_bot_arena_history_generations[slot] = g_bot_arena_history_generations[slot - 1];
        copyI32Array(arenaHistoryTuningPtr(slot), arenaHistoryTuningPtr(slot - 1), AI_TUNE_COUNT);
    }
    g_bot_arena_history_generations[0] = g_bot_arena.champion_generation;
    copyI32Array(arenaHistoryTuningPtr(0), &g_bot_arena_champion_tuning[0], AI_TUNE_COUNT);
    g_bot_arena.history_size += 1;
    if g_bot_arena.history_size > history_slots {g_bot_arena.history_size = history_slots;}
}

fun normalizeChampionHistory() >> void {
    i32 history_slots = arenaHistorySlotCount();
    arr<i32, BOT_ARENA_HISTORY_STORAGE> kept_generations = {0};
    arr<i32, BOT_ARENA_HISTORY_TUNING_CELLS> kept_tuning = {0};
    i32 kept = 0;

    for i32 slot = 0; slot < g_bot_arena.history_size; slot++ {
        i32 gen = g_bot_arena_history_generations[slot];
        if gen <= 0 {continue;}
        if gen == g_bot_arena.champion_generation {continue;}

        bool duplicate = false;
        for i32 k = 0; k < kept; k++ {
            if kept_generations[k] == gen {duplicate = true;}
        }
        if duplicate {continue;}
        if kept >= history_slots {continue;}

        kept_generations[kept] = gen;
        ptr<i32> dst = &kept_tuning[kept * AI_TUNE_COUNT];
        copyI32Array(dst, arenaHistoryTuningPtr(slot), AI_TUNE_COUNT);
        kept += 1;
    }

    g_bot_arena.history_size = kept;
    for i32 slot = 0; slot < BOT_ARENA_HISTORY_STORAGE; slot++ {g_bot_arena_history_generations[slot] = 0;}
    for i32 slot = 0; slot < kept; slot++ {
        g_bot_arena_history_generations[slot] = kept_generations[slot];
        copyI32Array(arenaHistoryTuningPtr(slot), &kept_tuning[slot * AI_TUNE_COUNT], AI_TUNE_COUNT);
    }
}

fun parseArenaTuneKey(key: ptr<u8>) >> i32 {
    if key[0] != ('t' as u8) {return -1;}
    if key[1] < ('0' as u8) || key[1] > ('9' as u8) {return -1;}
    return atoi(key + 1);
}

fun planTune(offset: i32) >> i32 {
    return aiGetTuningValue((AI_TUNE_PLAN_BASE as i32) + offset);
}

fun mutateArenaTuning(base: ptr<i32>, generation: i32, out_values: ptr<i32>) >> void {
    i32 changed = 0;
    for i32 i = 0; i < AI_TUNE_COUNT; i++ {
        i32 value = base[i];
        i32 step = aiTuningMutationStep(i);
        if generation >= 24 && step > 1 {step = maxI(1, (step * 3) / 4);}
        if generation >= 64 && step > 1 {step = maxI(1, (step * 2) / 3);}

        if GetRandomValue(0 as i32, 99 as i32) < 78 {
            value += GetRandomValue(0 as i32 - step, step) as i32;
        }
        if GetRandomValue(0 as i32, 99 as i32) < 22 {
            i32 jump = step * 3;
            if jump < 1 {jump = 1;}
            value += GetRandomValue(0 as i32 - jump, jump) as i32;
        }

        out_values[i] = aiClampTuningValue(i, value);
        if out_values[i] != base[i] {changed += 1;}
    }

    if changed == 0 {
        i32 forced = GetRandomValue(0 as i32, (AI_TUNE_COUNT - 1) as i32) as i32;
        i32 step = aiTuningMutationStep(forced);
        if step < 1 {step = 1;}
        if GetRandomValue(0 as i32, 1 as i32) == 0 {out_values[forced] = aiClampTuningValue(forced, base[forced] - step);} else {out_values[forced] = aiClampTuningValue(forced, base[forced] + step);}
    }
}

fun saveBotDuelsFile() >> void {
    if !BOTDEVMODE {return;}
    i32 fd = openForWrite(BOT_DUELS_FILE_PATH);
    if fd < 0 {return;}

    writeLineFd(fd, TextFormat("champion_generation=%i", g_bot_arena.champion_generation));
    writeLineFd(fd, TextFormat("history_size=%i", g_bot_arena.history_size));
    writeLineFd(fd, TextFormat("champion_wins=%i", g_bot_arena.champion_wins));
    writeLineFd(fd, TextFormat("total_matches=%i", g_bot_arena.total_matches));
    writeLineFd(fd, TextFormat("target_apm=%.2f", g_bot_arena.champion_setup.target_apm));
    writeLineFd(fd, TextFormat("garbage_messiness=%.2f", g_bot_arena.champion_setup.garbage_messiness));
    i32 high_stack_flag = 0;
    if g_bot_arena.champion_setup.high_stack_tolerance {high_stack_flag = 1;}
    writeLineFd(fd, TextFormat("high_stack_tolerance=%i", high_stack_flag));
    for i32 i = 0; i < AI_TUNE_COUNT; i++ {
        writeLineFd(fd, TextFormat("t%i=%i", i, g_bot_arena_champion_tuning[i]));
    }
    i32 history_slots = arenaHistorySlotCount();
    for i32 slot = 0; slot < history_slots; slot++ {
        writeLineFd(fd, TextFormat("h%i_generation=%i", slot, g_bot_arena_history_generations[slot]));
        ptr<i32> hist = arenaHistoryTuningPtr(slot);
        for i32 i = 0; i < AI_TUNE_COUNT; i++ {
            writeLineFd(fd, TextFormat("h%i_t%i=%i", slot, i, hist[i]));
        }
    }

    close(fd);
}

fun loadBotDuelsFile() >> void {
    g_bot_arena.champion_setup = defaultArenaChampionSetup();
    g_bot_arena.candidate_setup = g_bot_arena.champion_setup;
    loadDefaultArenaTuning();
    copyI32Array(&g_bot_arena_candidate_tuning[0], &g_bot_arena_champion_tuning[0], AI_TUNE_COUNT);
    g_bot_arena.champion_generation = 0;
    g_bot_arena.candidate_generation = 0;
    g_bot_arena.history_size = 0;
    g_bot_arena.champion_wins = 0;
    g_bot_arena.total_matches = 0;
    g_bot_arena.last_winner_generation = 0;
    g_bot_arena.last_winner_side = 0;
    g_bot_arena.compare_stock = false;
    g_bot_arena.compare_stock_wins = 0;
    g_bot_arena.compare_stock_losses = 0;
    g_bot_arena.generation_round = 0;
    g_bot_arena.generation_left_wins = 0;
    g_bot_arena.generation_right_wins = 0;
    g_bot_arena.generation_stage = BOT_ARENA_STAGE_CHAMPION;
    g_bot_arena.gauntlet_target_index = 0;
    g_bot_arena.stock_round = 0;
    g_bot_arena.stock_left_wins = 0;
    g_bot_arena.stock_right_wins = 0;
    for i32 slot = 0; slot < BOT_ARENA_HISTORY_STORAGE; slot++ {g_bot_arena_history_generations[slot] = 0;}
    for i32 i = 0; i < BOT_ARENA_HISTORY_TUNING_CELLS; i++ {g_bot_arena_history_tuning[i] = 0;}

    if !BOTDEVMODE {
        g_bot_arena.champion_setup = clampArenaSetup(g_bot_arena.champion_setup);
        normalizeChampionHistory();
        return;
    }

    i32 fd = openForRead(BOT_DUELS_FILE_PATH);
    if fd < 0 {
        g_bot_arena.champion_setup = clampArenaSetup(g_bot_arena.champion_setup);
        return;
    }

    arr<u8, 4096> data = {0};
    i64 bytes_read = readAll(fd, &data[0], 4095);
    close(fd);
    if bytes_read <= 0 {
        g_bot_arena.champion_setup = clampArenaSetup(g_bot_arena.champion_setup);
        return;
    }
    data[bytes_read as i32] = 0;

    arr<i32, AI_TUNE_COUNT> champion_tune_seen = {0};
    arr<i32, BOT_ARENA_HISTORY_TUNING_CELLS> history_tune_seen = {0};

    ptr<u8> line = &data[0];
    for (line[0] != 0) {
        ptr<u8> next = line;
        for (next[0] != 0 && next[0] != ('\n' as u8)) {
            next = next + 1;
        }
        if (next[0] == ('\n' as u8)) {
            next[0] = 0;
            next = next + 1;
        }

        ptr<u8> raw = trimLeftSpaces(line);
        trimRightSpacesInPlace(raw);
        if (raw[0] != 0 && raw[0] != ('#' as u8) && raw[0] != (';' as u8)) {
            ptr<u8> eq = raw;
            for (eq[0] != 0 && eq[0] != ('=' as u8)) {
                eq = eq + 1;
            }
            if (eq[0] == ('=' as u8)) {
                eq[0] = 0;

                ptr<u8> key = trimLeftSpaces(raw);
                trimRightSpacesInPlace(key);
                ptr<u8> value = trimLeftSpaces(eq + 1);
                trimRightSpacesInPlace(value);

                if (strEq(key, "champion_generation")) {
                    g_bot_arena.champion_generation = atoi(value);
                } else if (strEq(key, "history_size")) {
                    g_bot_arena.history_size = atoi(value);
                } else if (strEq(key, "champion_wins")) {
                    g_bot_arena.champion_wins = atoi(value);
                } else if (strEq(key, "total_matches")) {
                    g_bot_arena.total_matches = atoi(value);
                } else if (strEq(key, "target_apm")) {
                    g_bot_arena.champion_setup.target_apm = parseFloatValue(value, g_bot_arena.champion_setup.target_apm);
                } else if (strEq(key, "garbage_messiness")) {
                    g_bot_arena.champion_setup.garbage_messiness = parseFloatValue(value, g_bot_arena.champion_setup.garbage_messiness);
                } else if (strEq(key, "high_stack_tolerance")) {
                    g_bot_arena.champion_setup.high_stack_tolerance = parseBoolValue(value, g_bot_arena.champion_setup.high_stack_tolerance);
                } else {
                    if key[0] == ('h' as u8) && key[1] >= ('0' as u8) && key[1] <= ('9' as u8) && key[2] == ('_' as u8) {
                        i32 slot = atoi(key + 1);
                        if slot >= 0 && slot < BOT_ARENA_HISTORY_STORAGE {
                            ptr<u8> hist_key = key + 3;
                            if strEq(hist_key, "generation") {
                                g_bot_arena_history_generations[slot] = atoi(value);
                            } else if hist_key[0] == ('t' as u8) {
                                i32 tune_index = atoi(hist_key + 1);
                                if tune_index >= 0 && tune_index < AI_TUNE_COUNT {
                                    ptr<i32> hist = arenaHistoryTuningPtr(slot);
                                    hist[tune_index] = aiClampTuningValue(tune_index, atoi(value));
                                    history_tune_seen[slot * AI_TUNE_COUNT + tune_index] = 1;
                                }
                            }
                        }
                    }
                    i32 tune_index = parseArenaTuneKey(key);
                    if tune_index >= 0 && tune_index < AI_TUNE_COUNT {
                        g_bot_arena_champion_tuning[tune_index] = aiClampTuningValue(tune_index, atoi(value));
                        champion_tune_seen[tune_index] = 1;
                    }
                }
            }
        }

        line = next;
    }

    g_bot_arena.champion_setup = clampArenaSetup(g_bot_arena.champion_setup);
    if g_bot_arena.champion_generation < 0 {g_bot_arena.champion_generation = 0;}
    if g_bot_arena.candidate_generation < 0 {g_bot_arena.candidate_generation = 0;}
    if g_bot_arena.history_size < 0 {g_bot_arena.history_size = 0;}
    if g_bot_arena.history_size > arenaHistorySlotCount() {g_bot_arena.history_size = arenaHistorySlotCount();}
    if g_bot_arena.champion_wins < 0 {g_bot_arena.champion_wins = 0;}
    if g_bot_arena.total_matches < 0 {g_bot_arena.total_matches = 0;}
    g_bot_arena.compare_stock_wins = 0;
    g_bot_arena.compare_stock_losses = 0;
    g_bot_arena.generation_round = 0;
    g_bot_arena.generation_left_wins = 0;
    g_bot_arena.generation_right_wins = 0;
    g_bot_arena.generation_stage = BOT_ARENA_STAGE_CHAMPION;
    g_bot_arena.gauntlet_target_index = 0;
    g_bot_arena.stock_round = 0;
    g_bot_arena.stock_left_wins = 0;
    g_bot_arena.stock_right_wins = 0;
    arr<i32, AI_TUNE_COUNT> stock_defaults = {0};
    aiFillDefaultTuning(&stock_defaults[0]);
    for i32 i = 0; i < AI_TUNE_COUNT; i++ {
        if champion_tune_seen[i] == 0 {g_bot_arena_champion_tuning[i] = stock_defaults[i];}
        g_bot_arena_champion_tuning[i] = aiClampTuningValue(i, g_bot_arena_champion_tuning[i]);
    }
    i32 history_slots = arenaHistorySlotCount();
    for i32 slot = 0; slot < history_slots; slot++ {
        ptr<i32> hist = arenaHistoryTuningPtr(slot);
        for i32 i = 0; i < AI_TUNE_COUNT; i++ {
            if history_tune_seen[slot * AI_TUNE_COUNT + i] == 0 {hist[i] = stock_defaults[i];}
            hist[i] = aiClampTuningValue(i, hist[i]);
        }
    }
    normalizeChampionHistory();
}

fun mutateArenaSetup(base: BotSetupState, generation: i32) >> BotSetupState {
    BotSetupState next = base;
    next = clampArenaSetup(next);
    return next;
}

fun toColor(color_rgba: u32) >> Color {
    return Color{
        r = (color_rgba & 255) as u8,
        g = ((color_rgba >> 8) & 255) as u8,
        b = ((color_rgba >> 16) & 255) as u8,
        a = ((color_rgba >> 24) & 255) as u8,
    };
}

fun handlingFramesToSeconds(frames: f32) >> f32 {
    return frames / 60.0;
}

fun handlingArrSeconds() >> f32 {
    return handlingFramesToSeconds(g_arr_frames);
}

fun handlingDasSeconds() >> f32 {
    return handlingFramesToSeconds(g_das_frames);
}

fun handlingDcdSeconds() >> f32 {
    return handlingFramesToSeconds(g_dcd_frames);
}

fun canUseDoubleRowLayout() >> bool {
    if !g_double_row_ui {return false;}
    i32 free_px = GetScreenWidth() - uiS(UI_BASE_W);
    return free_px >= uiS(210);
}

fun fractf(v: f32) >> f32 {
    i32 whole = v as i32;
    f32 f = v - (whole as f32);
    if f < 0.0 {f += 1.0;}
    return f;
}

fun clamp01(v: f32) >> f32 {
    if v < 0.0 {return 0.0;}
    if v > 1.0 {return 1.0;}
    return v;
}

fun absf(v: f32) >> f32 {
    if v < 0.0 {return -v;}
    return v;
}

fun starIntensityNorm() >> f32 {
    f32 n = clamp01((g_star_intensity - 0.1) / 0.9);
    return n * (0.35 + 0.65 * n);
}

fun starSpreadMul() >> f32 {
    if g_star_intensity >= 0.4 {return 1.0 + ((g_star_intensity - 0.4) / 0.6) * 0.30;}
    return 1.0 - ((0.4 - g_star_intensity) / 0.3) * 0.15;
}

fun kickBoardShake(base_amp: f32, time_sec: f32) >> void {
    if g_board_bounciness <= 0 {return;}

    f32 mul = (g_board_bounciness as f32) / 70.0;
    f32 impulse = base_amp * mul;
    if impulse <= 0.0 {return;}

    f32 dir_x = 0.34;
    if (g_rt.board_shake_seed & 1) == 1 {dir_x = -0.34;}
    f32 dir_y = -1.0;

    g_rt.board_shake_vel_x += dir_x * impulse * 11.0;
    g_rt.board_shake_vel_y += dir_y * impulse * 14.0;
    g_rt.board_shake_amp += impulse;
    if g_rt.board_shake_amp > 24.0 {g_rt.board_shake_amp = 24.0;}
    if g_rt.board_shake_time < time_sec {g_rt.board_shake_time = time_sec;}
    g_rt.board_shake_seed += 1;
}

fun lineClearShakeAmp(lines_cleared: i32) >> f32 {
    if lines_cleared <= 0 {return 0.0;}
    if lines_cleared == 1 {return 4.4;}
    if lines_cleared == 2 {return 6.2;}
    if lines_cleared == 3 {return 8.4;}
    return 11.2;
}

fun updateBoardShake(dt: f32) >> void {
    f32 step = dt;
    if step > 0.05 {step = 0.05;}
    if step <= 0.0 {return;}

    if g_rt.board_shake_time > 0.0 {
        g_rt.board_shake_time -= step;
        if g_rt.board_shake_time < 0.0 {g_rt.board_shake_time = 0.0;}
    }

    if g_rt.board_shake_amp > 0.0 {
        g_rt.board_shake_amp -= step * (7.4 + g_rt.board_shake_amp * 2.5);
        if g_rt.board_shake_amp < 0.0 {g_rt.board_shake_amp = 0.0;}
    }

    f32 spring_x = 136.0;
    f32 spring_y = 124.0;
    f32 damping = 29.0;

    f32 acc_x = -g_rt.board_shake_render_x * spring_x - g_rt.board_shake_vel_x * damping;
    f32 acc_y = -g_rt.board_shake_render_y * spring_y - g_rt.board_shake_vel_y * damping;
    g_rt.board_shake_vel_x += acc_x * step;
    g_rt.board_shake_vel_y += acc_y * step;
    g_rt.board_shake_render_x += g_rt.board_shake_vel_x * step;
    g_rt.board_shake_render_y += g_rt.board_shake_vel_y * step;

    if g_rt.board_shake_render_x > 21.0 {g_rt.board_shake_render_x = 21.0;}
    if g_rt.board_shake_render_x < -21.0 {g_rt.board_shake_render_x = -21.0;}
    if g_rt.board_shake_render_y > 18.0 {g_rt.board_shake_render_y = 18.0;}
    if g_rt.board_shake_render_y < -18.0 {g_rt.board_shake_render_y = -18.0;}

    if (g_rt.board_shake_time <= 0.0 &&
        g_rt.board_shake_amp <= 0.02 &&
        absf(g_rt.board_shake_render_x) < 0.04 &&
        absf(g_rt.board_shake_render_y) < 0.04 &&
        absf(g_rt.board_shake_vel_x) < 0.6 &&
        absf(g_rt.board_shake_vel_y) < 0.6) {
        g_rt.board_shake_render_x = 0.0;
        g_rt.board_shake_render_y = 0.0;
        g_rt.board_shake_vel_x = 0.0;
        g_rt.board_shake_vel_y = 0.0;
        g_rt.board_shake_px_x = 0;
        g_rt.board_shake_px_y = 0;
        g_rt.board_shake_res_x = 0.0;
        g_rt.board_shake_res_y = 0.0;
        return;
    }

    f32 x_total = g_rt.board_shake_render_x + g_rt.board_shake_res_x;
    i32 x_px = x_total as i32;
    g_rt.board_shake_res_x = x_total - (x_px as f32);
    g_rt.board_shake_px_x = x_px;

    f32 y_total = g_rt.board_shake_render_y + g_rt.board_shake_res_y;
    i32 y_px = y_total as i32;
    g_rt.board_shake_res_y = y_total - (y_px as f32);
    g_rt.board_shake_px_y = y_px;
}

fun boardShakeX() >> i32 {
    return g_rt.board_shake_px_x;
}

fun boardShakeY() >> i32 {
    return g_rt.board_shake_px_y;
}

fun visibleBaseLeft() >> i64 {
    f32 scale = uiScale();
    i32 ox = uiOffsetX(scale);
    return (((0 - ox) as f32) / scale) as i64;
}

fun visibleBaseRight() >> i64 {
    f32 scale = uiScale();
    i32 ox = uiOffsetX(scale);
    return (((GetScreenWidth() - ox) as f32) / scale) as i64;
}

fun vsBotGapBase() >> i64 {
    f32 scale = uiScale();
    if scale <= 0.0001 {return 32;}
    return (((GetScreenWidth() as f32) * 0.025) / scale) as i64;
}

fun vsBotContentWidth() >> i64 {
    return 1180 + vsBotGapBase() * 5;
}

fun vsBotLayoutLeft() >> i64 {
    return (UI_BASE_W - vsBotContentWidth()) / 2;
}

fun vsBotPlayerLeftPanelX() >> i64 { return vsBotLayoutLeft() + vsBotGapBase(); }

fun vsBotPlayerBoardLeft() >> i64 {
    return vsBotPlayerLeftPanelX() + 184 + vsBotGapBase();
}

fun vsBotCenterPanelX() >> i64 {
    return vsBotPlayerBoardLeft() + (BOARD_W as i64) * (CELL as i64) + vsBotGapBase();
}

fun vsBotBotBoardLeft() >> i64 {
    return vsBotCenterPanelX() + 178 + vsBotGapBase();
}

fun vsBotBotPanelX() >> i64 {
    return vsBotBotBoardLeft() + (BOARD_W as i64) * (CELL as i64) + vsBotGapBase();
}

fun currentPlayerBoardLeft() >> i64 {
    if isVsBotMode() {return vsBotPlayerBoardLeft();}
    return BOARD_LEFT;
}

fun duelShowsHighStackArea() >> bool {
    return false;
}

fun currentBoardTop() >> i64 {
    if duelShowsHighStackArea() {return BOARD_TOP + HIGH_STACK_BOARD_SHIFT;}
    return BOARD_TOP;
}

fun currentCenterSidebarX() >> i64 {
    if isVsBotMode() {return vsBotCenterPanelX();}
    return SIDEBAR_X;
}

fun currentBotBoardLeft() >> i64 {
    if isVsBotMode() {return vsBotBotBoardLeft();}
    return BOT_BOARD_LEFT;
}

fun currentBotBoardTop() >> i64 {
    if duelShowsHighStackArea() {return BOT_BOARD_TOP + HIGH_STACK_BOARD_SHIFT;}
    return BOT_BOARD_TOP;
}

fun boardVisibleStartRow() >> i32 {
    if duelShowsHighStackArea() {return 0;}
    return HIDDEN_ROWS;
}

fun boardVisibleRows() >> i32 {
    return BOARD_H - boardVisibleStartRow();
}

fun boardRenderMinRow() >> i32 {
    if duelShowsHighStackArea() {return -HIGH_STACK_SPAWN_ROWS;}
    return HIDDEN_ROWS;
}

fun boardScreenY(board_top: i64, row: i64) >> i64 {
    return board_top + (row - (boardVisibleStartRow() as i64)) * (CELL as i64);
}

fun vsBotLayoutExtraX() >> i32 {
    return 0;
}

fun initBackgroundStars() >> void {
    for i32 i = 0; i < BG_STAR_COUNT; i++ {
        i32 mix_a = (i * 73 + (i * i * 29) + 157);
        i32 mix_b = (i * 181 + (i * i * 47) + 89);
        i32 mix_c = (i * 97 + (i * i * 13) + 271);

        g_star_x[i] = 24 + (mix_a % (UI_BASE_W - 48));
        g_star_y[i] = mix_b % (UI_BASE_H + 220);
        g_star_size[i] = 3 + (mix_c % 7);
        g_star_style[i] = (mix_b / 3) % 4;
        g_star_phase[i] = (mix_a % 1000) as f32 / 1000.0;
        g_star_speed[i] = 0.035 + ((mix_c % 1000) as f32) / 12000.0;
    }
}

fun initAiLogFile() >> void {
    if !LOGMODE {return;}
    i32 fd = openForWrite(AI_LOG_FILE_PATH);
    if fd < 0 {return;}
    writeLineFd(fd, "[zltris] ai log start");
    close(fd);
}

fun aiLog(text: ptr<u8>) >> void {
    if !LOGMODE {return;}
    i32 fd = openForAppend(AI_LOG_FILE_PATH);
    if fd < 0 {return;}
    writeLineFd(fd, text);
    close(fd);
}

fun updateBackgroundStarReaction(dt: f32) >> void {
    if (g_bg_star_react_mode != STAR_MODE_DROPS) {
        g_rt.star_soft_glow = 0.0;
        g_rt.star_hard_burst = 0.0;
        g_rt.star_hard_target = 0.0;
        g_rt.star_pps_meter = 0.0;
        return;
    }

    f32 norm = starIntensityNorm();
    f32 pulse_weight = 0.05 + norm * norm * 0.95;

    if (IsKeyDown(KEY_DOWN)) {
        g_rt.star_soft_glow += dt * (1.10 + norm * 1.90);
        f32 soft_cap = 0.46 + norm * 0.34;
        if g_rt.star_soft_glow > soft_cap {g_rt.star_soft_glow = soft_cap;}
    } else {
        g_rt.star_soft_glow -= dt * (1.40 - norm * 0.20);
        if g_rt.star_soft_glow < 0.0 {g_rt.star_soft_glow = 0.0;}
    }

    g_rt.star_pps_meter -= dt * g_star_peak_target_dps;
    if g_rt.star_pps_meter < 0.0 {g_rt.star_pps_meter = 0.0;}

    g_rt.star_hard_target -= dt * (1.6 + norm * 1.2);
    if g_rt.star_hard_target < 0.0 {g_rt.star_hard_target = 0.0;}

    f32 rise = clamp01(dt * (3.0 + norm * 20.0));
    f32 fall = clamp01(dt * (2.7 + norm * 7.5));
    if (g_rt.star_hard_burst < g_rt.star_hard_target) {
        g_rt.star_hard_burst += (g_rt.star_hard_target - g_rt.star_hard_burst) * rise;
    } else {
        g_rt.star_hard_burst += (g_rt.star_hard_target - g_rt.star_hard_burst) * fall;
    }

    g_rt.star_hard_burst *= (0.995 + pulse_weight * 0.005);
}

fun drawStarArms(cx: i64, cy: i64, size: i64, style: i32, color: u32) >> void {
    if (style == 0) {
        DrawLine(uiX(cx - size), uiY(cy), uiX(cx + size), uiY(cy), toColor(color));
        DrawLine(uiX(cx), uiY(cy - size), uiX(cx), uiY(cy + size), toColor(color));
        return;
    }
    if (style == 1) {
        i64 d = (size * 7) / 10;
        DrawLine(uiX(cx - d), uiY(cy - d), uiX(cx + d), uiY(cy + d), toColor(color));
        DrawLine(uiX(cx - d), uiY(cy + d), uiX(cx + d), uiY(cy - d), toColor(color));
        return;
    }
    if (style == 2) {
        i64 dx = size;
        i64 dy = size / 3;
        DrawLine(uiX(cx - dx), uiY(cy - dy), uiX(cx + dx), uiY(cy + dy), toColor(color));
        DrawLine(uiX(cx - dy), uiY(cy + dx), uiX(cx + dy), uiY(cy - dx), toColor(color));
        return;
    }
    i64 dx = size / 3;
    i64 dy = size;
    DrawLine(uiX(cx - dx), uiY(cy - dy), uiX(cx + dx), uiY(cy + dy), toColor(color));
    DrawLine(uiX(cx - dy), uiY(cy + dx), uiX(cx + dy), uiY(cy - dx), toColor(color));
}

fun drawBackgroundStars(theme: Theme) >> void {
    if g_bg_stars_amount <= 0 {return;}

    f32 t = GetTime() as f32;
    i64 span_y = UI_BASE_H + 160;
    i64 left = visibleBaseLeft();
    i64 right = visibleBaseRight();
    i64 span_x = right - left;
    if span_x < 1 {span_x = 1;}

    i32 count = g_bg_stars_amount;
    if count > BG_STAR_COUNT {count = BG_STAR_COUNT;}

    f32 react_boost = 0.0;
    f32 norm = starIntensityNorm();
    f32 spread_mul = starSpreadMul();
    if (g_bg_star_react_mode == STAR_MODE_DROPS) {
        f32 pps_norm = clamp01(g_rt.star_pps_meter);
        f32 pulse_weight = 0.05 + norm * norm * 0.95;
        f32 base_boost = 0.06 + pps_norm * 0.72 + g_rt.star_soft_glow * 0.50;
        f32 pulse_boost = g_rt.star_hard_burst * (0.25 + norm * 1.35) * pulse_weight;
        react_boost = base_boost + pulse_boost;
        if react_boost > 2.0 {react_boost = 2.0;}
    }

    for i32 i = 0; i < count; i++ {
        f32 speed = g_star_speed[i] * 0.70;
        f32 loop = fractf(g_star_phase[i] + t * speed);
        i64 y = -80 + ((((loop * (span_y as f32)) as i64) + (g_star_y[i] as i64)) % span_y);

        i64 base_x = left + ((span_x as f32) * ((g_star_x[i] as f32) / (UI_BASE_W as f32))) as i64;

        f32 drift_loop = fractf(g_star_phase[i] * 1.7 + t * (0.08 + speed * 0.5));
        f32 drift = drift_loop;
        if drift_loop > 0.5 {drift = 1.0 - drift_loop;}
        i64 x = base_x + (((drift * 2.0) - 0.5) * 18.0) as i64;

        i64 s = g_star_size[i] as i64;
        f32 tw = fractf(t * (0.7 + g_star_speed[i] * 2.0) + g_star_phase[i]);
        if tw > 0.5 {tw = 1.0 - tw;}
        f32 alpha = 0.10 + tw * 0.34;
        if (g_bg_star_react_mode == STAR_MODE_DROPS) {
            alpha += react_boost * (0.55 + norm * 0.55);
            if alpha > 1.00 {alpha = 1.00;}
        }

        i64 glow_radius = ((s * 5) as f32 * spread_mul) as i64;
        if g_bg_star_react_mode == STAR_MODE_DROPS {glow_radius += (react_boost * ((10.0 + norm * 6.0) * spread_mul)) as i64;}

        u32 outer = alphaColor(theme.panel_stroke, alpha * 0.34);
        u32 inner = alphaColor(theme.panel_stroke, alpha * 0.72);
        DrawCircleGradient(uiX(x), uiY(y), uiS(glow_radius) as f32, toColor(outer), toColor(alphaColor(theme.bg_outer, 0.0)));
        DrawCircleGradient(uiX(x), uiY(y), uiS((glow_radius * 2) / 3) as f32, toColor(inner), toColor(alphaColor(theme.bg_outer, 0.0)));
        drawStarArms(x, y, s, g_star_style[i], alphaColor(theme.panel_stroke, alpha));
        fillRect(x - 1, y - 1, 3, 3, alphaColor(theme.text_main, alpha * 0.84 + react_boost * (0.24 + norm * 0.10)));
    }
}

fun isFortyLinesMode() >> bool {
    return g_play.is_mode(MODE_40_LINES);
}

fun isFreePlayMode() >> bool {
    return g_play.is_mode(MODE_FREE_PLAY);
}

fun isBlitzMode() >> bool {
    return g_play.is_mode(MODE_BLITZ);
}

fun isVsBotMode() >> bool {
    return g_play.is_mode(MODE_VS_BOT);
}

fun isBotDuelsMode() >> bool {
    return BOTDEVMODE && g_play.is_mode(MODE_BOT_DUELS);
}

fun modeUsesRoundState() >> bool {
    return isFortyLinesMode() || isBlitzMode();
}

fun blitzTimeLeft() >> f32 {
    f32 left = BLITZ_DURATION_SECONDS - g_rt.mode_timer;
    if left < 0.0 {left = 0.0;}
    return left;
}

fun currentApm() >> f32 {
    if g_rt.run_timer <= 0.001 {return 0.0;}
    return ((g_rt.attack_sent as f32) * 60.0) / g_rt.run_timer;
}

fun botUiPopupText() >> ptr<u8> {
    return "Expand the window horizontally";
}

fun clampBotGarbageMessiness() >> void {
    if g_bot_setup.garbage_messiness < 0.0 {g_bot_setup.garbage_messiness = 0.0;}
    if g_bot_setup.garbage_messiness > 100.0 {g_bot_setup.garbage_messiness = 100.0;}
}

fun nextGarbageHole(board_w: i32, hole_state: ptr<i32>) >> i32 {
    if board_w <= 1 {return 0;}
    if hole_state[0] < 0 || hole_state[0] >= board_w {
        hole_state[0] = GetRandomValue(0 as i32, (board_w - 1) as i32) as i32;
        return hole_state[0];
    }

    i32 roll = GetRandomValue(0 as i32, 99 as i32) as i32;
    if roll < (g_bot_setup.garbage_messiness as i32) {
        i32 jump_roll = GetRandomValue(0 as i32, 99 as i32) as i32;
        if jump_roll < 80 {
            i32 dir = 1;
            if GetRandomValue(0 as i32, 1 as i32) == 0 {dir = -1;}
            i32 next = hole_state[0] + dir;
            if next < 0 {next = 1;}
            if next >= board_w {next = board_w - 2;}
            hole_state[0] = next;
        } else {
            i32 next = hole_state[0];
            for (next == hole_state[0]) {next = GetRandomValue(0 as i32, (board_w - 1) as i32) as i32;}
            hole_state[0] = next;
        }
    }

    return hole_state[0];
}

fun canOpenBotSetupUi() >> bool {
    i32 w = GetScreenWidth();
    i32 h = GetScreenHeight();
    if h <= 0 {return false;}
    i32 fixed_actual = uiS(1180);
    i32 gaps_actual = ((w as f32) * 0.125) as i32;
    return fixed_actual + gaps_actual <= w;
}

fun drawBotWidthPopup(font: Font, theme: Theme, show_back_hint: bool) >> void {
    fillRect(146, 332, 356, 96, alphaColor(theme.board_bg, 0.92));
    strokeRect(146, 332, 356, 96, alphaColor(theme.panel_stroke, 0.88));
    drawTextCenteredInRect(font, botUiPopupText(), 156, 354, 336, 54, 12, theme.text_main);
    if show_back_hint {drawTextColor(font, "ESC back", 176, 642, 12, theme.text_muted);}
}

fun startGameMode(mode: i32) >> void {
    i32 selected_mode = mode;
    if !BOTDEVMODE && selected_mode == MODE_BOT_DUELS {selected_mode = MODE_FREE_PLAY;}
    g_play = g_play.with_mode(selected_mode);
    if selected_mode == MODE_VS_BOT {applyBotSetupWeights();}
    else if selected_mode != MODE_BOT_DUELS {applyChampionAiTuning();}
    g_ai_enabled = false;
    g_ai_armed = false;
    g_duel_running = false;
    g_duel_result = DUEL_RESULT_PLAYING;
    g_player_pending_garbage = 0;
    g_bot_pending_garbage = 0;
    resetGame();
    g_rt.mode_timer = 0.0;
    g_rt.restart_charge = 0.0;
    g_rt.restart_hold_latched = false;
    g_rt.restart_afterglow = 0.0;
    g_rt.hold_action = HOLD_ACTION_NONE;
    g_rt.star_soft_glow = 0.0;
    g_rt.star_hard_burst = 0.0;
    g_rt.star_hard_target = 0.0;
    g_rt.star_pps_meter = 0.0;
    if (modeUsesRoundState()) {
        g_play = g_play.with_round_state(ROUND_COUNTDOWN);
        g_rt.countdown_timer = 4.0;
    } else {
        g_play = g_play.with_round_state(ROUND_RUNNING);
        g_rt.countdown_timer = 0.0;
    }

    if isVsBotMode() {
        initBotMatch();
        g_duel_running = true;
    } else if isBotDuelsMode() {
        initBotArenaRound();
    }
}

fun restartCurrentModeWithShake() >> void {
    startGameMode(g_play.game_mode);
    kickBoardShake(lineClearShakeAmp(4), 0.11);
}

fun restartStripeTopScreen() >> i32 {
    i32 screen_h = GetScreenHeight();
    i32 top_target = uiY(852);
    i32 top = (screen_h as f32 - ((screen_h - top_target) as f32) * g_rt.restart_charge) as i32;
    if top < 0 {top = 0;}
    return top;
}

fun restartAfterglowTopScreen() >> i32 {
    i32 start_top = uiY(852);
    i32 end_top = GetScreenHeight();
    if g_rt.restart_afterglow <= 0.0 {return end_top;}
    f32 p = 1.0 as f32 - (g_rt.restart_afterglow / (0.24 as f32));
    if p < 0.0 {p = 0.0;}
    if p > 1.0 {p = 1.0;}
    return (start_top as f32 + ((end_top - start_top) as f32) * p) as i32;
}

fun restartHintAlpha() >> f32 {
    if g_rt.restart_charge <= 0.0 {return 1.0;}
    f32 stripe_top = restartStripeTopScreen() as f32;
    f32 hint_y = uiY(831) as f32;
    f32 fade_zone = uiS(180) as f32;
    f32 dist = stripe_top - hint_y;
    f32 a = dist / fade_zone;
    if a < 0.0 {a = 0.0;}
    if a > 1.0 {a = 1.0;}
    return a;
}

fun drawRestartCharge(font: Font, theme: Theme) >> void {
    if g_rt.restart_charge <= 0.0 && g_rt.restart_afterglow <= 0.0 {return;}

    i32 top = restartStripeTopScreen();
    f32 alpha_mul = 1.0;
    if (g_rt.restart_charge <= 0.0) {
        top = restartAfterglowTopScreen();
        alpha_mul = g_rt.restart_afterglow / (0.24 as f32);
        if alpha_mul < 0.0 {alpha_mul = 0.0;}
        if alpha_mul > 1.0 {alpha_mul = 1.0;}
    }

    f32 top_alpha = (0.26 + g_rt.restart_charge * 0.44) * alpha_mul;
    if top_alpha > 0.86 {top_alpha = 0.86;}
    u32 top_color = alphaColor(theme.panel_stroke, top_alpha);
    u32 bottom_color = alphaColor(shadeColor(theme.bg_outer, 0.46), 0.92);
    DrawRectangleGradientV(0, top, GetScreenWidth(), GetScreenHeight() - top, toColor(top_color), toColor(bottom_color));
    DrawRectangle(0, top - 2, GetScreenWidth(), 2, toColor(alphaColor(theme.text_main, (0.52 as f32) * alpha_mul)));

    ptr<u8> hint = "Hold for restart";
    if g_rt.hold_action == HOLD_ACTION_MENU {hint = "Hold for menu";}
    f32 hint_size = uiS(12) as f32;
    Vector2 m = MeasureTextExSize(font, hint, hint_size, 0.0 as f32);
    f32 tx = ((GetScreenWidth() as f32) - m.x) * 0.5;
    f32 ty = (top as f32) + uiS(8) as f32;
    f32 hint_alpha = (0.62 as f32 + g_rt.restart_charge * (0.28 as f32)) * alpha_mul;
    DrawTextExXY(font, hint, tx, ty, hint_size, 0.0 as f32, toColor(alphaColor(theme.text_main, hint_alpha)));
}

fun updateRestartAfterglow(dt: f32) >> void {
    if (g_rt.restart_afterglow > 0.0) {
        g_rt.restart_afterglow -= dt;
        if g_rt.restart_afterglow < 0.0 {g_rt.restart_afterglow = 0.0;}
    }
}

fun updateRestartCharge(dt: f32) >> bool {
    bool esc_down = IsKeyDown(KEY_ESCAPE);
    bool r_down = IsKeyDown(KEY_R);
    if g_instant_restart {r_down = false;}

    i32 action = HOLD_ACTION_NONE;
    if esc_down {
        action = HOLD_ACTION_MENU;
    } else if r_down {
        action = HOLD_ACTION_RESTART;
    }

    if action == HOLD_ACTION_NONE {
        g_rt.restart_hold_latched = false;
    } else if action != g_rt.hold_action {
        g_rt.hold_action = action;
        g_rt.restart_hold_latched = false;
        g_rt.restart_charge = 0.0;
    }

    if action != HOLD_ACTION_NONE && g_rt.restart_hold_latched {return false;}

    if action != HOLD_ACTION_NONE {
        f32 hold_seconds = HOLD_RESTART_SECONDS;
        if action == HOLD_ACTION_MENU {hold_seconds = HOLD_MENU_SECONDS;}

        g_rt.restart_charge += dt / hold_seconds;
        if (g_rt.restart_charge >= 1.0) {
            g_rt.restart_charge = 1.0;
            g_rt.restart_hold_latched = true;
            if action == HOLD_ACTION_RESTART {
                restartCurrentModeWithShake();
                g_rt.restart_afterglow = 0.24 as f32;
                return true;
            }

            g_rt.restart_charge = 0.0;
            g_rt.restart_hold_latched = false;
            g_rt.hold_action = HOLD_ACTION_NONE;
            g_rt.restart_afterglow = 0.0;
            g_game = g_game.with_screen(SCREEN_MENU);
            menuInit();
            return true;
        }
        return false;
    }

    if (g_rt.restart_charge > 0.0) {
        g_rt.restart_charge -= dt / 0.64;
        if g_rt.restart_charge < 0.0 {g_rt.restart_charge = 0.0;}
    }
    if g_rt.restart_charge <= 0.0 {g_rt.hold_action = HOLD_ACTION_NONE;}
    return false;
}

fun canShowHoldRestartEffect() >> bool {
    if g_play.game_over {return false;}
    if modeUsesRoundState() && g_play.round_state != ROUND_RUNNING {return false;}
    return true;
}

fun applyDcd() >> void {
    g_rt.dcd_timer = handlingDcdSeconds();
}

fun alphaColor(base: u32, alpha: f32) >> u32 {
    i32 a = ((base >> 24) & 255) as i32;
    i32 scaled = ((a as f32) * alpha) as i32;
    if scaled < 0 {scaled = 0;}
    if scaled > 255 {scaled = 255;}
    return (base & 0x00FFFFFF) | ((scaled as u32) << 24);
}

fun shadeColor(base: u32, factor: f32) >> u32 {
    i32 r = (((base & 255) as i32) as f32 * factor) as i32;
    i32 g = ((((base >> 8) & 255) as i32) as f32 * factor) as i32;
    i32 b = ((((base >> 16) & 255) as i32) as f32 * factor) as i32;
    i32 a = ((base >> 24) & 255) as i32;

    if r < 0 {r = 0;}
    if g < 0 {g = 0;}
    if b < 0 {b = 0;}
    if r > 255 {r = 255;}
    if g > 255 {g = 255;}
    if b > 255 {b = 255;}

    return ((r as u32) & 255) |
           (((g as u32) & 255) << 8) |
           (((b as u32) & 255) << 16) |
           (((a as u32) & 255) << 24);
}

fun colorR(color: u32) >> i32 { return (color & 255) as i32; }
fun colorG(color: u32) >> i32 { return ((color >> 8) & 255) as i32; }
fun colorB(color: u32) >> i32 { return ((color >> 16) & 255) as i32; }

fun printColorDebug(theme: Theme) >> void {
    printf("[zltris] color debug theme=%s index=%d\n", themeName(g_game.theme_index), g_game.theme_index);
    for i32 i = 0; i < 7; i++ {
        u32 c = pieceColor(theme, i);
        printf("[zltris] kind=%d hex=0x%08X rgb=(%d,%d,%d)\n", i, c, colorR(c), colorG(c), colorB(c));
    }
    u32 cur = pieceColor(theme, g_piece_kind);
    printf("[zltris] current kind=%d hex=0x%08X rgb=(%d,%d,%d)\n", g_piece_kind, cur, colorR(cur), colorG(cur), colorB(cur));
}

fun fillRect(x: i64, y: i64, w: i64, h: i64, color_rgba: u32) >> void {
    DrawRectangle(uiX(x), uiY(y), uiS(w), uiS(h), toColor(color_rgba));
}

fun strokeRect(x: i64, y: i64, w: i64, h: i64, color_rgba: u32) >> void {
    DrawRectangleLines(uiX(x), uiY(y), uiS(w), uiS(h), toColor(color_rgba));
}

fun drawGradientRectV(x: i64, y: i64, w: i64, h: i64, top_rgba: u32, bottom_rgba: u32) >> void {
    DrawRectangleGradientV(uiX(x), uiY(y), uiS(w), uiS(h), toColor(top_rgba), toColor(bottom_rgba));
}

fun drawTextColor(font: Font, text: ptr<u8>, x: i64, y: i64, size: i64, color_rgba: u32) >> void {
    DrawTextExXY(font, text, uiX(x) as f32, uiY(y) as f32, uiS(size) as f32, 0.0, toColor(color_rgba));
}

fun drawTextCenteredInRect(font: Font, text: ptr<u8>, x: i64, y: i64, w: i64, h: i64, size: i64, color_rgba: u32) >> void {
    f32 draw_size = uiS(size) as f32;
    Vector2 m = MeasureTextExSize(font, text, draw_size, 0.0);
    i32 rx = uiX(x);
    i32 ry = uiY(y);
    i32 rw = uiS(w);
    i32 rh = uiS(h);
    f32 tx = (rx as f32) + ((rw as f32) - m.x) * 0.5;
    f32 ty = (ry as f32) + ((rh as f32) - m.y) * 0.5;
    DrawTextExXY(font, text, tx, ty, draw_size, 0.0, toColor(color_rgba));
}

fun clearWithColor(color_rgba: u32) >> void {
    ClearBackground(toColor(color_rgba));
}

fun currentPps() >> f32 {
    if g_rt.run_timer <= 0.001 {return 0.0;}
    return (g_rt.pieces_placed as f32) / g_rt.run_timer;
}

fun ghostColor(base: u32) >> u32 { return alphaColor(base, 0.28); }

fun pieceColor(theme: Theme, kind: i32) >> u32 {
    if kind == PIECE_I {return theme.piece_i;}
    if kind == PIECE_O {return theme.piece_o;}
    if kind == PIECE_T {return theme.piece_t;}
    if kind == PIECE_J {return theme.piece_j;}
    if kind == PIECE_L {return theme.piece_l;}
    if kind == PIECE_S {return theme.piece_s;}
    return theme.piece_z;
}

fun normalizeRotation(rotation: i32) >> i32 {
    i32 res = rotation % 4;
    if res < 0 {res += 4;}
    return res;
}

fun boardIndex(x: i32, y: i32) >> i32 {
    return y * BOARD_W + x;
}

fun boardGet(x: i32, y: i32) >> i32 {
    return g_board[boardIndex(x, y)];
}

fun boardSet(x: i32, y: i32, value: i32) >> void {
    g_board[boardIndex(x, y)] = value;
}

fun minoX(kind: i32, rotation: i32, idx: i32) >> i32 {
    i32 rot = normalizeRotation(rotation);

    if (kind == PIECE_I) {
        if rot == 0 {return idx;}
        if rot == 1 {return 2;}
        if rot == 2 {return idx;}
        return 1;
    }

    if (kind == PIECE_O) {
        if idx == 0 || idx == 2 {return 1;}
        return 2;
    }

    if (kind == PIECE_T) {
        if (rot == 0) {
            if idx == 0 {return 1;}
            return idx - 1;
        }
        if (rot == 1) {
            if idx == 2 {return 2;}
            return 1;
        }
        if (rot == 2) {
            if idx == 3 {return 1;}
            return idx;
        }
        if idx == 1 {return 0;}
        return 1;
    }

    if (kind == PIECE_J) {
        if (rot == 0) {
            if idx == 0 {return 0;}
            return idx - 1;
        }
        if (rot == 1) {
            if idx == 0 || idx == 2 || idx == 3 {return 1;}
            return 2;
        }
        if (rot == 2) {
            if idx == 3 {return 2;}
            return idx;
        }
        if idx == 2 {return 0;}
        return 1;
    }

    if (kind == PIECE_L) {
        if (rot == 0) {
            if idx == 0 {return 2;}
            return idx - 1;
        }
        if (rot == 1) {
            if idx == 3 {return 2;}
            return 1;
        }
        if (rot == 2) {
            if idx == 3 {return 0;}
            return idx;
        }
        if idx == 0 {return 0;}
        return 1;
    }

    if (kind == PIECE_S) {
        if (rot == 0) {
            if idx == 0 || idx == 3 {return 1;}
            if idx == 1 {return 2;}
            return 0;
        }
        if (rot == 1) {
            if idx == 0 || idx == 1 {return 1;}
            return 2;
        }
        if (rot == 2) {
            if idx == 0 || idx == 3 {return 1;}
            if idx == 1 {return 2;}
            return 0;
        }
        if idx == 0 || idx == 1 {return 0;}
        return 1;
    }

    if (rot == 0) {
        if idx == 0 {return 0;}
        if idx == 1 || idx == 2 {return 1;}
        return 2;
    }
    if (rot == 1) {
        if idx == 0 || idx == 2 {return 2;}
        return 1;
    }
    if (rot == 2) {
        if idx == 0 {return 0;}
        if idx == 1 || idx == 2 {return 1;}
        return 2;
    }
    if idx == 0 || idx == 2 {return 1;}
    return 0;
}

fun minoY(kind: i32, rotation: i32, idx: i32) >> i32 {
    i32 rot = normalizeRotation(rotation);

    if (kind == PIECE_I) {
        if rot == 0 {return 1;}
        if rot == 1 {return idx;}
        if rot == 2 {return 2;}
        return idx;
    }

    if (kind == PIECE_O) {
        if idx < 2 {return 0;}
        return 1;
    }

    if (kind == PIECE_T) {
        if (rot == 0) {
            if idx == 0 {return 0;}
            return 1;
        }
        if (rot == 1) {
            if idx == 3 {return 2;}
            if idx == 2 {return 1;}
            return idx;
        }
        if (rot == 2) {
            if idx == 3 {return 2;}
            return 1;
        }
        if idx == 0 {return 0;}
        if idx == 3 {return 2;}
        return 1;
    }

    if (kind == PIECE_J) {
        if (rot == 0) {
            if idx == 0 {return 0;}
            return 1;
        }
        if (rot == 1) {
            if idx == 0 || idx == 1 {return 0;}
            if idx == 2 {return 1;}
            return 2;
        }
        if (rot == 2) {
            if idx == 3 {return 2;}
            return 1;
        }
        if idx == 0 {return 0;}
        if idx == 1 {return 1;}
        return 2;
    }

    if (kind == PIECE_L) {
        if (rot == 0) {
            if idx == 0 {return 0;}
            return 1;
        }
        if (rot == 1) {
            if idx == 3 {return 2;}
            return idx;
        }
        if (rot == 2) {
            if idx == 3 {return 2;}
            return 1;
        }
        if idx < 2 {return 0;}
        if idx == 2 {return 1;}
        return 2;
    }

    if (kind == PIECE_S) {
        if (rot == 0) {
            if idx < 2 {return 0;}
            return 1;
        }
        if (rot == 1) {
            if idx == 0 {return 0;}
            if idx == 3 {return 2;}
            return 1;
        }
        if (rot == 2) {
            if idx < 2 {return 1;}
            return 2;
        }
        if idx == 0 {return 0;}
        if idx == 3 {return 2;}
        return 1;
    }

    if (rot == 0) {
        if idx < 2 {return 0;}
        return 1;
    }
    if (rot == 1) {
        if idx == 0 {return 0;}
        if idx == 3 {return 2;}
        return 1;
    }
    if (rot == 2) {
        if idx < 2 {return 1;}
        return 2;
    }
    if idx == 0 {return 0;}
    if idx == 3 {return 2;}
    return 1;
}

fun jlstzKickX(from: i32, to: i32, test: i32) >> i32 {
    if (from == 0 && to == 1) {
        if test == 1 || test == 2 || test == 4 {return -1;}
        return 0;
    }
    if (from == 1 && to == 0) {
        if test == 1 || test == 2 || test == 4 {return 1;}
        return 0;
    }
    if (from == 1 && to == 2) {
        if test == 1 || test == 2 || test == 4 {return 1;}
        return 0;
    }
    if (from == 2 && to == 1) {
        if test == 1 || test == 2 || test == 4 {return -1;}
        return 0;
    }
    if (from == 2 && to == 3) {
        if test == 1 || test == 2 || test == 4 {return 1;}
        return 0;
    }
    if (from == 3 && to == 2) {
        if test == 1 || test == 2 || test == 4 {return -1;}
        return 0;
    }
    if (from == 3 && to == 0) {
        if test == 1 || test == 2 || test == 4 {return -1;}
        return 0;
    }
    if test == 1 || test == 2 || test == 4 {return 1;}
    return 0;
}

fun jlstzKickY(from: i32, to: i32, test: i32) >> i32 {
    if (from == 0 && to == 1) {
        if test == 2 {return 1;}
        if test == 3 {return -2;}
        if test == 4 {return -2;}
        return 0;
    }
    if (from == 1 && to == 0) {
        if test == 2 {return -1;}
        if test == 3 {return 2;}
        if test == 4 {return 2;}
        return 0;
    }
    if (from == 1 && to == 2) {
        if test == 2 {return -1;}
        if test == 3 {return 2;}
        if test == 4 {return 2;}
        return 0;
    }
    if (from == 2 && to == 1) {
        if test == 2 {return 1;}
        if test == 3 {return -2;}
        if test == 4 {return -2;}
        return 0;
    }
    if (from == 2 && to == 3) {
        if test == 2 {return 1;}
        if test == 3 {return -2;}
        if test == 4 {return -2;}
        return 0;
    }
    if (from == 3 && to == 2) {
        if test == 2 {return -1;}
        if test == 3 {return 2;}
        if test == 4 {return 2;}
        return 0;
    }
    if (from == 3 && to == 0) {
        if test == 2 {return -1;}
        if test == 3 {return 2;}
        if test == 4 {return 2;}
        return 0;
    }
    if test == 2 {return 1;}
    if test == 3 {return -2;}
    if test == 4 {return -2;}
    return 0;
}

fun iKickX(from: i32, to: i32, test: i32) >> i32 {
    if (from == 0 && to == 1) {
        if test == 1 || test == 3 {return -2;}
        if test == 2 || test == 4 {return 1;}
        return 0;
    }
    if (from == 1 && to == 0) {
        if test == 1 || test == 3 {return 2;}
        if test == 2 || test == 4 {return -1;}
        return 0;
    }
    if (from == 1 && to == 2) {
        if test == 1 || test == 3 {return -1;}
        if test == 2 || test == 4 {return 2;}
        return 0;
    }
    if (from == 2 && to == 1) {
        if test == 1 || test == 3 {return 1;}
        if test == 2 || test == 4 {return -2;}
        return 0;
    }
    if (from == 2 && to == 3) {
        if test == 1 || test == 3 {return 2;}
        if test == 2 || test == 4 {return -1;}
        return 0;
    }
    if (from == 3 && to == 2) {
        if test == 1 || test == 3 {return -2;}
        if test == 2 || test == 4 {return 1;}
        return 0;
    }
    if (from == 3 && to == 0) {
        if test == 1 || test == 3 {return 1;}
        if test == 2 || test == 4 {return -2;}
        return 0;
    }
    if test == 1 || test == 3 {return -1;}
    if test == 2 || test == 4 {return 2;}
    return 0;
}

fun iKickY(from: i32, to: i32, test: i32) >> i32 {
    if (from == 0 && to == 1) {
        if test == 3 {return -1;}
        if test == 4 {return 2;}
        return 0;
    }
    if (from == 1 && to == 0) {
        if test == 3 {return 1;}
        if test == 4 {return -2;}
        return 0;
    }
    if (from == 1 && to == 2) {
        if test == 3 {return 2;}
        if test == 4 {return -1;}
        return 0;
    }
    if (from == 2 && to == 1) {
        if test == 3 {return -2;}
        if test == 4 {return 1;}
        return 0;
    }
    if (from == 2 && to == 3) {
        if test == 3 {return 1;}
        if test == 4 {return -2;}
        return 0;
    }
    if (from == 3 && to == 2) {
        if test == 3 {return -1;}
        if test == 4 {return 2;}
        return 0;
    }
    if (from == 3 && to == 0) {
        if test == 3 {return -2;}
        if test == 4 {return 1;}
        return 0;
    }
    if test == 3 {return 2;}
    if test == 4 {return -1;}
    return 0;
}

fun kickX(kind: i32, from: i32, to: i32, test: i32) >> i32 {
    if kind == PIECE_I {return iKickX(from, to, test);}
    if kind == PIECE_O {return 0;}
    return jlstzKickX(from, to, test);
}

fun kickY(kind: i32, from: i32, to: i32, test: i32) >> i32 {
    if kind == PIECE_I {return iKickY(from, to, test);}
    if kind == PIECE_O {return 0;}
    return jlstzKickY(from, to, test);
}

fun pieceFits(kind: i32, rotation: i32, base_x: i32, base_y: i32) >> bool {
    for i32 idx = 0; idx < 4; idx++ {
        i32 x = base_x + minoX(kind, rotation, idx);
        i32 y = base_y + minoY(kind, rotation, idx);

        if x < 0 || x >= BOARD_W {return false;}
        if y >= BOARD_H {return false;}
        if y >= 0 && boardGet(x, y) != 0 {return false;}
    }
    return true;
}

fun currentFitsAt(x: i32, y: i32, rotation: i32) >> bool {
    return pieceFits(g_piece_kind, rotation, x, y);
}

fun refillBag() >> void {
    for i32 i = 0; i < BAG_SIZE; i++ {
        g_bag[i] = i;
    }

    for i32 i = 0; i < BAG_SIZE; i++ {
        i32 j = GetRandomValue(i as i32, (BAG_SIZE - 1) as i32) as i32;
        i32 tmp = g_bag[i];
        g_bag[i] = g_bag[j];
        g_bag[j] = tmp;
    }

    g_play.bag_pos = 0;
}

fun enqueueFromBag() >> void {
    if g_play.bag_pos >= BAG_SIZE {refillBag();}
    g_queue[g_play.queue_count] = g_bag[g_play.bag_pos];
    g_play.queue_count += 1;
    g_play.bag_pos += 1;
}

fun ensureQueue() >> void {
    for (g_play.queue_count < QUEUE_CAP) {
        enqueueFromBag();
    }
}

fun popQueue() >> i32 {
    ensureQueue();
    i32 res = g_queue[0];
    for i32 i = 0; i < g_play.queue_count - 1; i++ {
        g_queue[i] = g_queue[i + 1];
    }
    g_play.queue_count -= 1;
    ensureQueue();
    return res;
}

fun playerSpawnY() >> i32 {
    return 0;
}

fun gravityInterval() >> f32 {
    return 0.7;
}

fun spawnNextPiece() >> void {
    g_piece_kind = popQueue();
    g_piece_rotation = 0;
    g_piece_x = 3;
    g_piece_y = playerSpawnY();
    g_rt.gravity_timer = 0.0;
    g_rt.soft_timer = 0.0;
    g_rt.lock_timer = 0.0;
    g_rt.shift_hold_timer = 0.0;
    g_rt.shift_repeat_timer = 0.0;
    g_rt.shift_dir = 0;
    g_rt.last_rotate_success = false;
    g_rt.last_rotate_kick_test = -1;
    g_hold_used = false;
    applyDcd();

    if !currentFitsAt(g_piece_x, g_piece_y, g_piece_rotation) {g_play.game_over = true;}
}

fun resetBoard() >> void {
    for i32 y = 0; y < BOARD_H; y++ {
        for i32 x = 0; x < BOARD_W; x++ {
            boardSet(x, y, 0);
        }
    }
}

fun resetGame() >> void {
    resetBoard();
    g_play.queue_count = 0;
    g_play.bag_pos = BAG_SIZE;
    g_play.score = 0;
    g_play.lines = 0;
    g_rt.run_timer = 0.0;
    g_rt.pieces_placed = 0;
    g_rt.attack_sent = 0;
    g_player_garbage_hole = -1;
    g_bot_garbage_hole = -1;
    g_hold_kind = -1;
    g_hold_used = false;
    g_play.game_over = false;
    g_rt.shift_hold_timer = 0.0;
    g_rt.shift_repeat_timer = 0.0;
    g_rt.shift_dir = 0;
    g_rt.last_horizontal_press = 0;
    g_rt.dcd_timer = 0.0;
    g_rt.board_shake_time = 0.0;
    g_rt.board_shake_amp = 0.0;
    g_rt.board_shake_seed = 0;
    g_rt.board_shake_render_x = 0.0;
    g_rt.board_shake_render_y = 0.0;
    g_rt.board_shake_vel_x = 0.0;
    g_rt.board_shake_vel_y = 0.0;
    g_rt.board_shake_px_x = 0;
    g_rt.board_shake_px_y = 0;
    g_rt.board_shake_res_x = 0.0;
    g_rt.board_shake_res_y = 0.0;
    g_rt.combo = -1;
    g_rt.back_to_back_count = 0;
    g_rt.back_to_back = false;
    g_rt.last_rotate_success = false;
    g_rt.last_rotate_kick_test = -1;
    refillBag();
    ensureQueue();
    spawnNextPiece();
}

fun minI(a: i32, b: i32) >> i32 {
    if a < b {return a;}
    return b;
}

fun maxI(a: i32, b: i32) >> i32 {
    if a > b {return a;}
    return b;
}

fun botBoardGet(x: i32, y: i32) >> i32 {
    return g_bot_board[boardIndex(x, y)];
}

fun botBoardSet(x: i32, y: i32, value: i32) >> void {
    g_bot_board[boardIndex(x, y)] = value;
}

fun botResetBoard() >> void {
    for i32 y = 0; y < BOARD_H; y++ {
        for i32 x = 0; x < BOARD_W; x++ {botBoardSet(x, y, 0);}
    }
}

fun botRefillBag() >> void {
    for i32 i = 0; i < BAG_SIZE; i++ {g_bot_bag[i] = i;}
    for i32 i = 0; i < BAG_SIZE; i++ {
        i32 j = GetRandomValue(i as i32, (BAG_SIZE - 1) as i32) as i32;
        i32 t = g_bot_bag[i];
        g_bot_bag[i] = g_bot_bag[j];
        g_bot_bag[j] = t;
    }
    g_bot.bag_pos = 0;
}

fun botEnqueueFromBag() >> void {
    if g_bot.bag_pos >= BAG_SIZE {botRefillBag();}
    if g_bot.queue_count >= QUEUE_CAP {return;}
    g_bot_queue[g_bot.queue_count] = g_bot_bag[g_bot.bag_pos];
    g_bot.queue_count += 1;
    g_bot.bag_pos += 1;
}

fun botEnsureQueue() >> void {
    for (g_bot.queue_count < QUEUE_CAP) {
        botEnqueueFromBag();
    }
}

fun botPopQueue() >> i32 {
    botEnsureQueue();
    i32 res = g_bot_queue[0];
    for i32 i = 0; i < g_bot.queue_count - 1; i++ {g_bot_queue[i] = g_bot_queue[i + 1];}
    g_bot.queue_count -= 1;
    botEnsureQueue();
    return res;
}

fun botSpawnY() >> i32 {
    return 0;
}

fun botPieceFits(kind: i32, rotation: i32, x: i32, y: i32) >> bool {
    for i32 i = 0; i < 4; i++ {
        i32 mx = x + minoX(kind, rotation, i);
        i32 my = y + minoY(kind, rotation, i);
        if mx < 0 || mx >= BOARD_W || my >= BOARD_H {return false;}
        if my >= 0 && botBoardGet(mx, my) != 0 {return false;}
    }
    return true;
}

fun botSpawnNextPiece() >> void {
    g_bot.piece_kind = botPopQueue();
    g_bot.piece_rotation = 0;
    g_bot.piece_x = 3;
    g_bot.piece_y = botSpawnY();
    g_bot_plan_len = 0;
    g_bot_plan_index = 0;
    g_bot_planned_lines = 0;
    g_bot_planned_spin = false;
    g_bot_planned_all_clear = false;
    g_bot.target_x = g_bot.piece_x;
    g_bot.target_y = g_bot.piece_y;
    g_bot.target_rotation = 0;
    g_bot.last_rotate_success = false;
    g_bot.target_last_rotate = false;
    g_bot.target_valid = false;
    g_bot.target_tspin = false;
    if !botPieceFits(g_bot.piece_kind, g_bot.piece_rotation, g_bot.piece_x, g_bot.piece_y) {g_bot.game_over = true;}
}

fun botBoardIsEmpty() >> bool {
    for i32 y = 0; y < BOARD_H; y++ {
        for i32 x = 0; x < BOARD_W; x++ {
            if botBoardGet(x, y) != 0 {return false;}
        }
    }
    return true;
}

fun botClearLines() >> i32 {
    i32 cleared = 0;
    for i32 y = BOARD_H - 1; y >= 0; y-- {
        bool full = true;
        for i32 x = 0; x < BOARD_W; x++ {
            if botBoardGet(x, y) == 0 {full = false;}
        }
        if (full) {
            cleared += 1;
            for i32 pull = y; pull > 0; pull-- {
                for i32 x = 0; x < BOARD_W; x++ {botBoardSet(x, pull, botBoardGet(x, pull - 1));}
            }
            for i32 x = 0; x < BOARD_W; x++ {botBoardSet(x, 0, 0);}
            y += 1;
        }
    }
    if cleared > 0 {g_bot.lines += cleared;}
    return cleared;
}

fun botBoardCellOccupiedOrBlocked(x: i32, y: i32) >> bool {
    if x < 0 || x >= BOARD_W {return true;}
    if y >= BOARD_H {return true;}
    if y < 0 {return false;}
    return botBoardGet(x, y) != 0;
}

fun botIsTSpin(kind: i32, x: i32, y: i32) >> bool {
    if kind != PIECE_T {return false;}
    if !g_bot.last_rotate_success {return false;}
    i32 cx = x + 1;
    i32 cy = y + 1;
    i32 corners = 0;
    if botBoardCellOccupiedOrBlocked(cx - 1, cy - 1) {corners += 1;}
    if botBoardCellOccupiedOrBlocked(cx + 1, cy - 1) {corners += 1;}
    if botBoardCellOccupiedOrBlocked(cx - 1, cy + 1) {corners += 1;}
    if botBoardCellOccupiedOrBlocked(cx + 1, cy + 1) {corners += 1;}
    return corners >= 3;
}

fun insertGarbageIntoPlayer(amount: i32) >> void {
    if amount <= 0 {return;}
    i32 board_w = BOARD_W as i32;
    i32 board_h = BOARD_H as i32;
    for i32 n = 0; n < amount; n++ {
        bool overflow = false;
        for i32 x = 0; x < board_w; x++ {
            if boardGet(x, 0) != 0 {overflow = true;}
        }
        for i32 y = 0; y < board_h - 1; y++ {
            for i32 x = 0; x < board_w; x++ {boardSet(x, y, boardGet(x, y + 1));}
        }
        i32 hole = nextGarbageHole(board_w, &g_player_garbage_hole);
        for i32 x = 0; x < board_w; x++ {
            if x == hole {boardSet(x, board_h - 1, 0);} else {boardSet(x, board_h - 1, 8);}
        }
        if overflow {g_play.game_over = true;}
    }
}

fun addFreePlayGarbageLine() >> void {
    if !isFreePlayMode() {return;}
    if g_play.game_over {return;}

    insertGarbageIntoPlayer(1);
    if g_play.game_over {
        aiLog("fp garbage+1 -> game over");
        return;
    }

    g_piece_y -= 1;
    i32 lift = 0;
    for (!currentFitsAt(g_piece_x, g_piece_y, g_piece_rotation) && lift < 8) {
        g_piece_y -= 1;
        lift += 1;
    }

    if !currentFitsAt(g_piece_x, g_piece_y, g_piece_rotation) {
        g_play.game_over = true;
        aiLog("fp garbage+1 -> piece blocked");
        return;
    }

    g_rt.lock_timer = 0.0;
    applyDcd();

    i32 max_h = 0;
    i32 holes = 0;
    i32 garbage_rows = 0;
    i32 garbage_cover = 0;
    aiBoardStackStats(&g_board[0], &max_h, &holes, &garbage_rows, &garbage_cover);
    i32 garbage_access = aiBoardGarbageAccessScore(&g_board[0]);
    aiLog(TextFormat("fp garbage+1 max_h=%i holes=%i garbage_rows=%i cover=%i access=%i piece_y=%i", max_h, holes, garbage_rows, garbage_cover, garbage_access, g_piece_y));
}

fun insertGarbageIntoBot(amount: i32) >> void {
    if amount <= 0 {return;}
    aiLog(TextFormat("garbage->bot amount=%i pending_before=%i", amount, g_bot_pending_garbage));
    i32 board_w = BOARD_W as i32;
    i32 board_h = BOARD_H as i32;
    for i32 n = 0; n < amount; n++ {
        bool overflow = false;
        for i32 x = 0; x < board_w; x++ {
            if botBoardGet(x, 0) != 0 {overflow = true;}
        }
        for i32 y = 0; y < board_h - 1; y++ {
            for i32 x = 0; x < board_w; x++ {botBoardSet(x, y, botBoardGet(x, y + 1));}
        }
        i32 hole = nextGarbageHole(board_w, &g_bot_garbage_hole);
        for i32 x = 0; x < board_w; x++ {
            if x == hole {botBoardSet(x, board_h - 1, 0);} else {botBoardSet(x, board_h - 1, 8);}
        }
        if overflow {g_bot.game_over = true;}
    }
}

fun routePlayerAttack(attack: i32) >> void {
    if attack <= 0 {return;}
    i32 cancel = minI(attack, g_player_pending_garbage);
    g_player_pending_garbage -= cancel;
    i32 out = attack - cancel;
    if out > 0 {
        i32 before = g_bot_pending_garbage;
        g_bot_pending_garbage += out;

        if g_duel_running {
            g_bot.target_valid = false;
            g_bot_plan_len = 0;
            g_bot_plan_index = 0;
            aiLog(TextFormat(" replan trigger garbage pending_before=%i pending_after=%i", before, g_bot_pending_garbage));
        }
    }
}

fun routeBotAttack(attack: i32) >> void {
    if attack <= 0 {return;}
    i32 cancel = minI(attack, g_bot_pending_garbage);
    g_bot_pending_garbage -= cancel;
    i32 out = attack - cancel;
    if out > 0 {g_player_pending_garbage += out;}
}

fun initBotMatch() >> void {
    botResetBoard();
    g_bot.queue_count = 0;
    g_bot.bag_pos = BAG_SIZE;
    g_bot_plan_len = 0;
    g_bot_plan_index = 0;
    g_bot_plan_pending_snapshot = 0;
    g_bot_planned_lines = 0;
    g_bot_planned_spin = false;
    g_bot_planned_all_clear = false;
    g_bot.target_x = 3;
    g_bot.target_y = 0;
    g_bot.target_rotation = 0;
    g_bot.combo = -1;
    g_bot.back_to_back_count = 0;
    g_bot.target_last_rotate = false;
    g_bot.target_valid = false;
    g_bot.target_tspin = false;
    g_bot.pending_garbage = 0;
    g_bot.place_meter = 0.0;
    g_bot.rate_smooth = 0.0;
    g_bot.attack_sent = 0;
    g_bot.pieces_placed = 0;
    g_bot.actions_taken = 0;
    g_bot.lines = 0;
    g_bot.score = 0;
    g_bot.game_over = false;
    botRefillBag();
    botEnsureQueue();
    botSpawnNextPiece();
}

fun holdCurrent() >> void {
    if g_hold_used {return;}

    i32 current = g_piece_kind;
    if (g_hold_kind < 0) {
        g_hold_kind = current;
        spawnNextPiece();
        g_hold_used = true;
        return;
    }

    g_piece_kind = g_hold_kind;
    g_hold_kind = current;
    g_piece_rotation = 0;
    g_piece_x = 3;
    g_piece_y = playerSpawnY();
    g_rt.gravity_timer = 0.0;
    g_rt.soft_timer = 0.0;
    g_rt.lock_timer = 0.0;
    g_hold_used = true;
    g_rt.shift_hold_timer = 0.0;
    g_rt.shift_repeat_timer = 0.0;
    g_rt.shift_dir = 0;
    g_rt.last_rotate_success = false;
    g_rt.last_rotate_kick_test = -1;
    applyDcd();

    if !currentFitsAt(g_piece_x, g_piece_y, g_piece_rotation) {g_play.game_over = true;}
}

fun tryMove(dx: i32, dy: i32) >> bool {
    i32 next_x = g_piece_x + dx;
    i32 next_y = g_piece_y + dy;
    if !currentFitsAt(next_x, next_y, g_piece_rotation) {return false;}
    g_piece_x = next_x;
    g_piece_y = next_y;
    g_rt.lock_timer = 0.0;
    return true;
}

fun tryRotate(dir: i32) >> bool {
    i32 from = normalizeRotation(g_piece_rotation);
    i32 to = normalizeRotation(g_piece_rotation + dir);

    if (g_piece_kind == PIECE_O) {
        if (currentFitsAt(g_piece_x, g_piece_y, to)) {
            g_piece_rotation = to;
            g_rt.lock_timer = 0.0;
            g_rt.last_rotate_success = false;
            g_rt.last_rotate_kick_test = -1;
            applyDcd();
            return true;
        }
        return false;
    }

    for i32 test = 0; test < 5; test++ {
        i32 dx = kickX(g_piece_kind, from, to, test);
        i32 dy = kickY(g_piece_kind, from, to, test);
        if (currentFitsAt(g_piece_x + dx, g_piece_y - dy, to)) {
            g_piece_x += dx;
            g_piece_y -= dy;
            g_piece_rotation = to;
            g_rt.lock_timer = 0.0;
            g_rt.last_rotate_success = true;
            g_rt.last_rotate_kick_test = test;
            applyDcd();
            return true;
        }
    }

    return false;
}

fun currentGhostY() >> i32 {
    i32 ghost_y = g_piece_y;
    for (pieceFits(g_piece_kind, g_piece_rotation, g_piece_x, ghost_y + 1)) {
        ghost_y += 1;
    }
    return ghost_y;
}

fun botGhostY() >> i32 {
    i32 ghost_y = g_bot.piece_y;
    for (botPieceFits(g_bot.piece_kind, g_bot.piece_rotation, g_bot.piece_x, ghost_y + 1)) {
        ghost_y += 1;
    }
    return ghost_y;
}

fun botTryMove(dx: i32, dy: i32) >> bool {
    i32 next_x = g_bot.piece_x + dx;
    i32 next_y = g_bot.piece_y + dy;
    if !botPieceFits(g_bot.piece_kind, g_bot.piece_rotation, next_x, next_y) {return false;}
    g_bot.piece_x = next_x;
    g_bot.piece_y = next_y;
    return true;
}

fun botTryRotate(dir: i32) >> bool {
    if g_bot.piece_kind == PIECE_O {
        g_bot.last_rotate_success = false;
        return true;
    }

    i32 from = normalizeRotation(g_bot.piece_rotation);
    i32 to = normalizeRotation(g_bot.piece_rotation + dir);
    if (botPieceFits(g_bot.piece_kind, to, g_bot.piece_x, g_bot.piece_y)) {
        g_bot.piece_rotation = to;
        g_bot.last_rotate_success = true;
        return true;
    }

    for i32 test = 0; test < 5; test++ {
        i32 dx = kickX(g_bot.piece_kind, from, to, test);
        i32 dy = kickY(g_bot.piece_kind, from, to, test);
        if (botPieceFits(g_bot.piece_kind, to, g_bot.piece_x + dx, g_bot.piece_y - dy)) {
            g_bot.piece_x += dx;
            g_bot.piece_y -= dy;
            g_bot.piece_rotation = to;
            g_bot.last_rotate_success = true;
            return true;
        }
    }

    g_bot.last_rotate_success = false;
    return false;
}

fun botProjectDirtyNext(board: ptr<i32>, next_kind: i32, out_rows: ptr<i32>, out_cover: ptr<i32>, out_access: ptr<i32>, out_holes: ptr<i32>, out_max_h: ptr<i32>, out_lines: ptr<i32>, out_score: ptr<i32>) >> void {
    aiBotProjectDirtyNext(board, next_kind, botSpawnY(), out_rows, out_cover, out_access, out_holes, out_max_h, out_lines, out_score);
}

fun botTempPieceFits(board: ptr<i32>, kind: i32, rotation: i32, x: i32, y: i32) >> bool {
    return aiBotTempPieceFits(board, kind, rotation, x, y);
}

fun botTempDropY(board: ptr<i32>, kind: i32, rotation: i32, x: i32, y: i32) >> i32 {
    return aiBotTempDropY(board, kind, rotation, x, y);
}

fun botTempBoardCellBlocked(board: ptr<i32>, x: i32, y: i32) >> bool {
    return aiBotTempBoardCellBlocked(board, x, y);
}

fun botTempIsTSpin(board: ptr<i32>, kind: i32, x: i32, y: i32, last_rotate_success: bool) >> bool {
    return aiBotTempIsTSpin(board, kind, x, y, last_rotate_success);
}

fun clearLinesTemp(board: ptr<i32>) >> i32 {
    return aiClearLinesTemp(board);
}

fun boardIsEmptyTemp(board: ptr<i32>) >> bool {
    return aiBoardIsEmptyTemp(board);
}

fun botApplyRotateState(board: ptr<i32>, kind: i32, x: i32, y: i32, rotation: i32, dir: i32, out_x: ptr<i32>, out_y: ptr<i32>, out_rotation: ptr<i32>, out_kick_test: ptr<i32>) >> bool {
    return aiBotApplyRotateState(board, kind, x, y, rotation, dir, out_x, out_y, out_rotation, out_kick_test);
}

fun botStateTableIndex(x: i32, y: i32, rot: i32, rotate_flag: i32) >> i32 {
    return aiBotStateTableIndex(x, y, rot, rotate_flag);
}

fun botAppendSearchState(count: ptr<i32>, visited: ptr<i32>, xs: ptr<i32>, ys: ptr<i32>, rots: ptr<i32>, rotate_flags: ptr<i32>, parents: ptr<i32>, actions: ptr<i32>, depths: ptr<i32>, x: i32, y: i32, rot: i32, rotate_flag: i32, parent_idx: i32, action: i32) >> void {
    if count[0] >= BOT_SEARCH_MAX {return;}

    i32 slot = botStateTableIndex(x, y, rot, rotate_flag);
    if slot < 0 {return;}
    if visited[slot] != 0 {return;}

    i32 idx = count[0];
    visited[slot] = idx + 1;
    xs[idx] = x;
    ys[idx] = y;
    rots[idx] = normalizeRotation(rot);
    if rotate_flag != 0 {rotate_flags[idx] = 1;} else {rotate_flags[idx] = 0;}
    parents[idx] = parent_idx;
    actions[idx] = action;
    depths[idx] = depths[parent_idx] + 1;
    count[0] += 1;
}

fun botSimulateDropPlacement(board: ptr<i32>, kind: i32, x: i32, y: i32, rot: i32, last_rotate: bool, out_board: ptr<i32>, out_final_y: ptr<i32>, out_lines: ptr<i32>, out_spin: ptr<i32>, out_all_clear: ptr<i32>) >> bool {
    return aiBotSimulateDropPlacement(board, kind, x, y, rot, last_rotate, out_board, out_final_y, out_lines, out_spin, out_all_clear);
}

fun botSimulateActionPlan(board: ptr<i32>, kind: i32, start_x: i32, start_y: i32, start_rot: i32, start_last_rotate: bool, actions: ptr<i32>, action_count: i32, out_board: ptr<i32>, out_final_x: ptr<i32>, out_final_y: ptr<i32>, out_final_rot: ptr<i32>, out_final_last_rotate: ptr<i32>, out_lines: ptr<i32>, out_spin: ptr<i32>, out_all_clear: ptr<i32>) >> bool {
    i32 x = start_x;
    i32 y = start_y;
    i32 rot = start_rot;
    bool last_rotate = start_last_rotate;

    for i32 i = 0; i < action_count; i++ {
        i32 action = actions[i];
        if action == BOT_ACTION_LEFT {
            if !botTempPieceFits(board, kind, rot, x - 1, y) {return false;}
            x -= 1;
        } else if action == BOT_ACTION_RIGHT {
            if !botTempPieceFits(board, kind, rot, x + 1, y) {return false;}
            x += 1;
        } else if action == BOT_ACTION_DOWN {
            if !botTempPieceFits(board, kind, rot, x, y + 1) {return false;}
            y += 1;
        } else if action == BOT_ACTION_CW {
            i32 rx = 0;
            i32 ry = 0;
            i32 rrot = 0;
            i32 rkick = -1;
            if !botApplyRotateState(board, kind, x, y, rot, 1, &rx, &ry, &rrot, &rkick) {return false;}
            x = rx;
            y = ry;
            rot = rrot;
            last_rotate = true;
        } else if action == BOT_ACTION_CCW {
            i32 rx = 0;
            i32 ry = 0;
            i32 rrot = 0;
            i32 rkick = -1;
            if !botApplyRotateState(board, kind, x, y, rot, -1, &rx, &ry, &rrot, &rkick) {return false;}
            x = rx;
            y = ry;
            rot = rrot;
            last_rotate = true;
        } else if action == BOT_ACTION_DROP {
            i32 final_y = 0;
            if !botSimulateDropPlacement(board, kind, x, y, rot, last_rotate, out_board, &final_y, out_lines, out_spin, out_all_clear) {return false;}
            out_final_x[0] = x;
            out_final_y[0] = final_y;
            out_final_rot[0] = rot;
            if last_rotate {out_final_last_rotate[0] = 1;} else {out_final_last_rotate[0] = 0;}
            return true;
        }
    }

    return false;
}

fun botPlanExactPath(lookahead_count: i32, mode: i32) >> bool {
    for i32 i = 0; i < BOT_SEARCH_MAX; i++ {
        g_bot_search_xs[i] = 0;
        g_bot_search_ys[i] = 0;
        g_bot_search_rots[i] = 0;
        g_bot_search_rotate_flags[i] = 0;
        g_bot_search_parents[i] = -1;
        g_bot_search_actions[i] = 0;
        g_bot_search_depths[i] = 0;
    }
    for i32 i = 0; i < BOT_STATE_TABLE_SIZE; i++ {
        g_bot_search_visited[i] = 0;
        g_bot_landing_states[i] = 0;
        g_bot_landing_steps[i] = 0;
    }

    i32 count = 1;
    i32 head = 0;
    g_bot_search_xs[0] = g_bot.piece_x;
    g_bot_search_ys[0] = g_bot.piece_y;
    g_bot_search_rots[0] = g_bot.piece_rotation;
    if g_bot.last_rotate_success {g_bot_search_rotate_flags[0] = 1;} else {g_bot_search_rotate_flags[0] = 0;}
    g_bot_search_parents[0] = -1;
    g_bot_search_actions[0] = 0;
    g_bot_search_depths[0] = 0;
    i32 root_slot = botStateTableIndex(g_bot_search_xs[0], g_bot_search_ys[0], g_bot_search_rots[0], g_bot_search_rotate_flags[0]);
    if root_slot < 0 {return false;}
    g_bot_search_visited[root_slot] = 1;

    for (head < count) {
        i32 next_x = g_bot_search_xs[head] - 1;
        if botTempPieceFits(&g_bot_board[0], g_bot.piece_kind, g_bot_search_rots[head], next_x, g_bot_search_ys[head]) {
            botAppendSearchState(&count, &g_bot_search_visited[0], &g_bot_search_xs[0], &g_bot_search_ys[0], &g_bot_search_rots[0], &g_bot_search_rotate_flags[0], &g_bot_search_parents[0], &g_bot_search_actions[0], &g_bot_search_depths[0], next_x, g_bot_search_ys[head], g_bot_search_rots[head], g_bot_search_rotate_flags[head], head, BOT_ACTION_LEFT);
        }

        next_x = g_bot_search_xs[head] + 1;
        if botTempPieceFits(&g_bot_board[0], g_bot.piece_kind, g_bot_search_rots[head], next_x, g_bot_search_ys[head]) {
            botAppendSearchState(&count, &g_bot_search_visited[0], &g_bot_search_xs[0], &g_bot_search_ys[0], &g_bot_search_rots[0], &g_bot_search_rotate_flags[0], &g_bot_search_parents[0], &g_bot_search_actions[0], &g_bot_search_depths[0], next_x, g_bot_search_ys[head], g_bot_search_rots[head], g_bot_search_rotate_flags[head], head, BOT_ACTION_RIGHT);
        }

        i32 next_y = g_bot_search_ys[head] + 1;
        if botTempPieceFits(&g_bot_board[0], g_bot.piece_kind, g_bot_search_rots[head], g_bot_search_xs[head], next_y) {
            botAppendSearchState(&count, &g_bot_search_visited[0], &g_bot_search_xs[0], &g_bot_search_ys[0], &g_bot_search_rots[0], &g_bot_search_rotate_flags[0], &g_bot_search_parents[0], &g_bot_search_actions[0], &g_bot_search_depths[0], g_bot_search_xs[head], next_y, g_bot_search_rots[head], g_bot_search_rotate_flags[head], head, BOT_ACTION_DOWN);
        }

        i32 rx = 0;
        i32 ry = 0;
        i32 rrot = 0;
        i32 rkick = -1;
        if botApplyRotateState(&g_bot_board[0], g_bot.piece_kind, g_bot_search_xs[head], g_bot_search_ys[head], g_bot_search_rots[head], 1, &rx, &ry, &rrot, &rkick) {
            botAppendSearchState(&count, &g_bot_search_visited[0], &g_bot_search_xs[0], &g_bot_search_ys[0], &g_bot_search_rots[0], &g_bot_search_rotate_flags[0], &g_bot_search_parents[0], &g_bot_search_actions[0], &g_bot_search_depths[0], rx, ry, rrot, 1, head, BOT_ACTION_CW);
        }

        if botApplyRotateState(&g_bot_board[0], g_bot.piece_kind, g_bot_search_xs[head], g_bot_search_ys[head], g_bot_search_rots[head], -1, &rx, &ry, &rrot, &rkick) {
            botAppendSearchState(&count, &g_bot_search_visited[0], &g_bot_search_xs[0], &g_bot_search_ys[0], &g_bot_search_rots[0], &g_bot_search_rotate_flags[0], &g_bot_search_parents[0], &g_bot_search_actions[0], &g_bot_search_depths[0], rx, ry, rrot, 1, head, BOT_ACTION_CCW);
        }

        head += 1;
    }

    i32 landing_count = 0;
    for i32 state_idx = 0; state_idx < count; state_idx++ {
        if g_bot_search_depths[state_idx] >= BOT_PLAN_MAX - 1 {continue;}

        i32 final_y = botTempDropY(&g_bot_board[0], g_bot.piece_kind, g_bot_search_rots[state_idx], g_bot_search_xs[state_idx], g_bot_search_ys[state_idx]);
        if final_y < -1000 {continue;}

        i32 slot = botStateTableIndex(g_bot_search_xs[state_idx], final_y, g_bot_search_rots[state_idx], g_bot_search_rotate_flags[state_idx]);
        if slot < 0 {continue;}

        i32 step_count = g_bot_search_depths[state_idx] + 1;
        if g_bot_landing_states[slot] == 0 {
            g_bot_landing_states[slot] = state_idx + 1;
            g_bot_landing_steps[slot] = step_count;
            landing_count += 1;
        } else if step_count < g_bot_landing_steps[slot] {
            g_bot_landing_states[slot] = state_idx + 1;
            g_bot_landing_steps[slot] = step_count;
        }
    }

    i32 cur_max_h = 0;
    i32 cur_holes = 0;
    i32 cur_garbage_rows = 0;
    i32 cur_garbage_cover = 0;
    aiBoardStackStats(&g_bot_board[0], &cur_max_h, &cur_holes, &cur_garbage_rows, &cur_garbage_cover);
    i32 cur_garbage_access = aiBoardGarbageAccessScore(&g_bot_board[0]);
    i32 cur_hole_depth = 0;
    boardHoleStats(&g_bot_board[0], &cur_holes, &cur_hole_depth, &cur_max_h);
    i32 before_score = evaluateBoardStructural(&g_bot_board[0]);

    f32 apm_current = botCurrentApm();
    f32 apm_delta_f = g_bot_setup.target_apm - apm_current;
    i32 apm_delta = apm_delta_f as i32;

    i32 speed_tier = 0;
    if g_bot_setup.target_apm >= (planTune(0) as f32) {speed_tier = 1;}
    if g_bot_setup.target_apm >= (planTune(1) as f32) {speed_tier = 2;}
    if g_bot_setup.target_apm >= (planTune(2) as f32) {speed_tier = 3;}
    bool unrestricted_speed = g_bot_setup.target_apm >= (planTune(3) as f32);

    i32 action_budget = 12;
    if g_bot_setup.target_apm <= 40.0 {
        action_budget = 7;
    } else if g_bot_setup.target_apm <= 70.0 {
        action_budget = 8;
    } else if g_bot_setup.target_apm <= 110.0 {
        action_budget = 10;
    } else {
        action_budget = 12;
    }
    if speed_tier == 1 {action_budget += planTune(4);}
    if speed_tier == 2 {action_budget += planTune(5);}
    if speed_tier == 3 {action_budget += planTune(6);}
    if mode == BOT_MODE_DIG {action_budget += 1;}
    if mode == BOT_MODE_SURVIVE {action_budget += 2;}
    if cur_max_h >= 16 {action_budget -= 1;}
    if cur_max_h >= 19 {action_budget -= 1;}
    if apm_delta < -15 {action_budget -= 1;}
    if apm_delta > 12 {action_budget += 1;}
    if apm_delta > planTune(7) {action_budget += planTune(9);}
    if apm_delta > planTune(8) {action_budget += planTune(10);}
    if unrestricted_speed {
        action_budget = BOT_PLAN_MAX - 1;
    }
    if cur_max_h >= 13 && action_budget < 8 {action_budget = 8;}
    if action_budget < 7 {action_budget = 7;}
    if action_budget > BOT_PLAN_MAX - 1 {action_budget = BOT_PLAN_MAX - 1;}

    i32 best_state = -1;
    i32 best_final_y = g_bot.piece_y;
    i32 best_score = -2147483647;
    i32 best_lines = 0;
    i32 best_spin = 0;
    i32 best_action_count = 0;
    i32 best_target_x = g_bot.piece_x;
    i32 best_target_rotation = g_bot.piece_rotation;
    bool best_target_last_rotate = false;
    bool best_all_clear = false;
    i32 best_next_holes = cur_holes;
    i32 best_next_max_h = cur_max_h;
    arr<i32, BOARD_CELLS> best_board = {0};

    i32 clean_state = -1;
    i32 clean_final_y = g_bot.piece_y;
    i32 clean_lines = 0;
    i32 clean_spin = 0;
    i32 clean_action_count = 0;
    i32 clean_target_x = g_bot.piece_x;
    i32 clean_target_rotation = g_bot.piece_rotation;
    bool clean_target_last_rotate = false;
    bool clean_all_clear = false;
    i32 clean_score = -2147483647;
    i32 clean_next_holes = 99999;
    i32 clean_next_max_h = 99999;
    arr<i32, BOARD_CELLS> clean_board = {0};

    for i32 slot = 0; slot < BOT_STATE_TABLE_SIZE; slot++ {
        if g_bot_landing_states[slot] == 0 {continue;}

        i32 state_idx = g_bot_landing_states[slot] - 1;
        bool last_rotate = false;
        if g_bot_search_rotate_flags[state_idx] != 0 {last_rotate = true;}

        i32 final_y = 0;
        i32 lines = 0;
        i32 spin = 0;
        i32 all_clear = 0;
        arr<i32, BOARD_CELLS> temp_board = {0};
        if !botSimulateDropPlacement(&g_bot_board[0], g_bot.piece_kind, g_bot_search_xs[state_idx], g_bot_search_ys[state_idx], g_bot_search_rots[state_idx], last_rotate, &temp_board[0], &final_y, &lines, &spin, &all_clear) {continue;}
        i32 action_count = g_bot_landing_steps[slot];

        if !unrestricted_speed && mode == BOT_MODE_CLEAN && cur_garbage_rows == 0 && g_bot_pending_garbage == 0 && action_count > action_budget + 5 {
            continue;
        }

        i32 next_max_h = 0;
        i32 next_holes = 0;
        i32 next_garbage_rows = 0;
        i32 next_garbage_cover = 0;
        aiBoardStackStats(&temp_board[0], &next_max_h, &next_holes, &next_garbage_rows, &next_garbage_cover);
        i32 next_garbage_access = aiBoardGarbageAccessScore(&temp_board[0]);

        i32 rows_delta = cur_garbage_rows - next_garbage_rows;
        i32 cover_delta = cur_garbage_cover - next_garbage_cover;
        i32 access_delta = cur_garbage_access - next_garbage_access;
        i32 holes_delta = cur_holes - next_holes;
        i32 max_h_delta = cur_max_h - next_max_h;

        bool no_immediate_progress = rows_delta <= 0 && cover_delta <= 0 && access_delta <= 0;
        bool immediate_worse = next_garbage_rows > cur_garbage_rows || next_garbage_cover > cur_garbage_cover || next_garbage_access > cur_garbage_access;

        i32 projected_rows = next_garbage_rows;
        i32 projected_cover = next_garbage_cover;
        i32 projected_access = next_garbage_access;
        i32 projected_holes = next_holes;
        i32 projected_max_h = next_max_h;
        i32 projected_lines = lines;
        i32 projected_score = 0;

        i32 base_score = evaluateExactLockedState(&g_bot_board[0], &temp_board[0], before_score, cur_garbage_rows, cur_garbage_cover, cur_garbage_access, cur_holes, cur_hole_depth, cur_max_h, lines, spin != 0, all_clear != 0, &g_bot_queue[0], lookahead_count, botSpawnY(), g_bot.combo, g_bot.back_to_back_count > 0, botLevel(), mode, g_bot_pending_garbage);
        if unrestricted_speed {base_score -= action_count * planTune(30);} else {base_score -= action_count * planTune(29);}

        if mode != BOT_MODE_CLEAN {
            projected_score = base_score;
            if g_bot.queue_count > 0 {
                botProjectDirtyNext(&temp_board[0], g_bot_queue[0], &projected_rows, &projected_cover, &projected_access, &projected_holes, &projected_max_h, &projected_lines, &projected_score);
            }
        }

        i32 projected_rows_delta = cur_garbage_rows - projected_rows;
        i32 projected_cover_delta = cur_garbage_cover - projected_cover;
        i32 projected_access_delta = cur_garbage_access - projected_access;
        i32 projected_holes_delta = cur_holes - projected_holes;
        i32 projected_max_h_delta = cur_max_h - projected_max_h;
        bool no_projected_progress = projected_rows_delta <= 0 && projected_cover_delta <= 0 && projected_access_delta <= 0;

        i32 attack = aiBotEstimateAttack(lines, spin != 0, all_clear != 0, g_bot.combo, g_bot.back_to_back_count);
        i32 spawn_penalty = 0;
        if g_bot.queue_count > 0 {
            if !botTempPieceFits(&temp_board[0], g_bot_queue[0], 0, 3, botSpawnY()) {spawn_penalty = 600000;}
        }

        i32 score = base_score;
        i32 over_budget = action_count - action_budget;
        if over_budget < 0 {over_budget = 0;}
        i32 action_step_penalty = planTune(11);
        i32 over_budget_penalty = planTune(16);
        if speed_tier == 1 {
            action_step_penalty = planTune(12);
            over_budget_penalty = planTune(17);
        }
        if speed_tier == 2 {
            action_step_penalty = planTune(13);
            over_budget_penalty = planTune(18);
        }
        if speed_tier == 3 {
            action_step_penalty = planTune(14);
            over_budget_penalty = planTune(19);
        }
        if unrestricted_speed {
            action_step_penalty = planTune(15);
            over_budget_penalty = planTune(20);
        }
        score -= action_count * action_step_penalty;
        score -= over_budget * over_budget_penalty;
        score -= spawn_penalty;
        if mode == BOT_MODE_SURVIVE {score -= spawn_penalty * 2;}
        if mode == BOT_MODE_DIG {score += projected_score / 6;}
        if mode == BOT_MODE_SURVIVE {score += projected_score / 8;}
        if attack > 0 && apm_delta > 0 {
            i32 attack_bonus = planTune(21);
            if speed_tier == 1 {attack_bonus = planTune(22);}
            if speed_tier == 2 {attack_bonus = planTune(23);}
            if speed_tier == 3 {attack_bonus = planTune(24);}
            if apm_delta > planTune(7) {attack_bonus += planTune(25);}
            if apm_delta > planTune(8) {attack_bonus += planTune(26);}
            score += attack * attack_bonus;
        }
        if unrestricted_speed && attack > 0 {
            score += attack * planTune(27);
            if spin != 0 {score += planTune(28);}
        }
        if lines == 0 && mode != BOT_MODE_CLEAN && no_immediate_progress {score -= aiBotPanicPenalty(cur_garbage_access, mode);}
        if lines == 0 && mode == BOT_MODE_CLEAN && next_holes > cur_holes {score -= (next_holes - cur_holes) * 180000;}
        if lines == 0 && mode == BOT_MODE_CLEAN && next_max_h > cur_max_h {score -= (next_max_h - cur_max_h) * 50000;}

        bool prefer_simple_plan = false;
        if BOT_SIMPLE_PLAN && mode == BOT_MODE_CLEAN && cur_garbage_rows == 0 && cur_holes == 0 && cur_max_h <= 10 && g_bot_setup.target_apm <= 45.0 {
            prefer_simple_plan = true;
        }

        if prefer_simple_plan {
            if spin != 0 {score -= 280000;}
            if lines == 3 {score -= 90000;}
            if lines >= 4 {score -= 180000;}

            if g_bot_search_rotate_flags[state_idx] != 0 {score -= 28000;}

            if action_count > action_budget {
                i32 over = action_count - action_budget;
                score -= over * 120000;
            }
        }

        if mode == BOT_MODE_CLEAN {
            bool clean_better = false;
            if clean_state < 0 {
                clean_better = true;
            } else {
                clean_better = aiBotCleanCandidateBetter(cur_holes, cur_max_h, next_holes, next_max_h, lines, action_count, score, clean_next_holes, clean_next_max_h, clean_lines, clean_action_count, clean_score);
            }

            if clean_better {
                clean_state = state_idx;
                clean_final_y = final_y;
                clean_lines = lines;
                clean_spin = spin;
                clean_action_count = action_count;
                clean_target_x = g_bot_search_xs[state_idx];
                clean_target_rotation = g_bot_search_rots[state_idx];
                clean_target_last_rotate = last_rotate;
                clean_all_clear = all_clear != 0;
                clean_score = score;
                clean_next_holes = next_holes;
                clean_next_max_h = next_max_h;
                for i32 i = 0; i < BOARD_CELLS; i++ {clean_board[i] = temp_board[i];}
            }
        }

        if best_state < 0 || score > best_score || (score == best_score && action_count < best_action_count) {
            best_state = state_idx;
            best_final_y = final_y;
            best_score = score;
            best_lines = lines;
            best_spin = spin;
            best_action_count = action_count;
            best_target_x = g_bot_search_xs[state_idx];
            best_target_rotation = g_bot_search_rots[state_idx];
            best_target_last_rotate = last_rotate;
            best_all_clear = all_clear != 0;
            best_next_holes = next_holes;
            best_next_max_h = next_max_h;
            for i32 i = 0; i < BOARD_CELLS; i++ {best_board[i] = temp_board[i];}
        }
    }

    if best_state < 0 {return false;}

    bool clean_forced = false;
    if mode == BOT_MODE_CLEAN && clean_state >= 0 {
        bool should_force_clean = false;
        if best_next_holes > cur_holes && clean_next_holes <= cur_holes {should_force_clean = true;}
        if best_next_holes > clean_next_holes + 1 {should_force_clean = true;}
        if best_next_max_h > clean_next_max_h + 2 && clean_next_holes <= best_next_holes {should_force_clean = true;}
        if best_lines == 0 && clean_next_holes < best_next_holes && clean_score >= best_score - 240000 {should_force_clean = true;}
        if cur_max_h >= 14 && clean_next_max_h < best_next_max_h {should_force_clean = true;}
        if g_bot_pending_garbage > 0 && clean_next_holes <= best_next_holes && clean_next_max_h <= best_next_max_h {should_force_clean = true;}
        if cur_max_h >= 12 && clean_next_max_h <= cur_max_h && best_next_max_h > cur_max_h {should_force_clean = true;}
        if cur_holes > 0 && clean_next_holes < best_next_holes && clean_score >= best_score - 400000 {should_force_clean = true;}

        if should_force_clean {
            clean_forced = true;
            best_state = clean_state;
            best_final_y = clean_final_y;
            best_lines = clean_lines;
            best_spin = clean_spin;
            best_action_count = clean_action_count;
            best_target_x = clean_target_x;
            best_target_rotation = clean_target_rotation;
            best_target_last_rotate = clean_target_last_rotate;
            best_all_clear = clean_all_clear;
            best_score = clean_score;
            best_next_holes = clean_next_holes;
            best_next_max_h = clean_next_max_h;
            for i32 i = 0; i < BOARD_CELLS; i++ {best_board[i] = clean_board[i];}
        }
    }

    for i32 i = 0; i < BOARD_CELLS; i++ {g_bot_planned_board[i] = best_board[i];}
    g_bot_planned_lines = best_lines;
    g_bot_planned_spin = best_spin != 0;
    g_bot_planned_all_clear = best_all_clear;
    g_bot.target_x = best_target_x;
    g_bot.target_y = best_final_y;
    g_bot.target_rotation = best_target_rotation;
    g_bot.target_last_rotate = best_target_last_rotate;

    arr<i32, BOT_PLAN_MAX> reverse_actions = {0};
    i32 reverse_count = 0;
    i32 idx = best_state;
    for (idx > 0 && reverse_count < BOT_PLAN_MAX - 1) {
        reverse_actions[reverse_count] = g_bot_search_actions[idx];
        reverse_count += 1;
        idx = g_bot_search_parents[idx];
    }

    g_bot_plan_len = best_action_count;
    g_bot_plan_index = 0;
    i32 plan_write = 0;
    for i32 i = reverse_count - 1; i >= 0; i-- {
        g_bot_plan_actions[plan_write] = reverse_actions[i];
        plan_write += 1;
    }
    g_bot_plan_actions[plan_write] = BOT_ACTION_DROP;
    g_bot.target_valid = true;
    g_bot.target_tspin = best_spin != 0;
    g_bot_plan_pending_snapshot = g_bot_pending_garbage;
    aiLog(TextFormat(" exact plan x=%i rot=%i y=%i steps=%i lines=%i score=%i spin=%i states=%i landings=%i mode=%i budget=%i clean_forced=%i nh=%i", g_bot.target_x, g_bot.target_rotation, best_final_y, g_bot_plan_len, best_lines, best_score, best_spin, count, landing_count, mode, action_budget, clean_forced as i32, best_next_holes));
    return true;
}

fun botPlanMove() >> bool {
    if g_bot_pending_garbage > 0 {
        insertGarbageIntoBot(g_bot_pending_garbage);
        if g_bot.game_over {return false;}
        g_bot_pending_garbage = 0;
    }

    i32 max_h = 0;
    i32 holes = 0;
    i32 garbage_rows = 0;
    i32 garbage_cover = 0;
    aiBoardStackStats(&g_bot_board[0], &max_h, &holes, &garbage_rows, &garbage_cover);
    i32 garbage_access = aiBoardGarbageAccessScore(&g_bot_board[0]);

    i32 mode = aiBotChooseMode(max_h, holes, garbage_rows, garbage_cover, garbage_access, 0);

    i32 lookahead_count = g_bot.queue_count;
    if lookahead_count < 0 {lookahead_count = 0;}

    if mode == BOT_MODE_CLEAN {
        if lookahead_count > 6 {lookahead_count = 6;}
        if lookahead_count < 2 {lookahead_count = 2;}
        if max_h >= 14 {lookahead_count = minI(lookahead_count, 4);}
    } else if mode == BOT_MODE_DIG {
        if lookahead_count > 4 {lookahead_count = 4;}
        if lookahead_count < 2 {lookahead_count = 2;}
        if max_h >= 18 || holes >= 11 {lookahead_count = 1;}
    } else {
        if lookahead_count > 2 {lookahead_count = 2;}
        if lookahead_count < 1 {lookahead_count = 1;}
    }

    if max_h >= 22 && holes >= 15 {lookahead_count = 1;}

    aiLog(TextFormat("plan kind=%i max_h=%i holes=%i garbage_rows=%i cover=%i access=%i mode=%i lookahead=%i", g_bot.piece_kind, max_h, holes, garbage_rows, garbage_cover, garbage_access, mode, lookahead_count));

    return botPlanExactPath(lookahead_count, mode);
}

fun botRotationDelta(target: i32) >> i32 {
    i32 current = normalizeRotation(g_bot.piece_rotation);
    i32 want = normalizeRotation(target);
    i32 diff = normalizeRotation(want - current);
    if diff == 0 {return 0;}
    if diff == 3 {return -1;}
    return 1;
}

fun botPerformPlannedAction() >> bool {
    if g_bot.target_valid && g_bot_plan_index < g_bot_plan_len && g_bot_plan_pending_snapshot != g_bot_pending_garbage {
        aiLog(TextFormat(" replan trigger pending changed old=%i new=%i", g_bot_plan_pending_snapshot, g_bot_pending_garbage));
        g_bot.target_valid = false;
        g_bot_plan_len = 0;
        g_bot_plan_index = 0;
    }

    if !g_bot.target_valid || g_bot_plan_index >= g_bot_plan_len {
        if !botPlanMove() {return false;}
    }

    i32 action = g_bot_plan_actions[g_bot_plan_index];
    g_bot_plan_index += 1;

    if action == BOT_ACTION_LEFT {
        if botTryMove(-1, 0) {return true;}
    } else if action == BOT_ACTION_RIGHT {
        if botTryMove(1, 0) {return true;}
    } else if action == BOT_ACTION_CW {
        if botTryRotate(1) {return true;}
    } else if action == BOT_ACTION_CCW {
        if botTryRotate(-1) {return true;}
    } else if action == BOT_ACTION_DOWN {
        if botTryMove(0, 1) {return true;}
    } else if action == BOT_ACTION_DROP {
        g_bot.piece_x = g_bot.target_x;
        g_bot.piece_y = g_bot.target_y;
        g_bot.piece_rotation = g_bot.target_rotation;
        g_bot.last_rotate_success = g_bot.target_last_rotate;
        botApplyPlannedLock();
        return true;
    }

    aiLog(TextFormat(" plan desync action=%i x=%i y=%i rot=%i", action, g_bot.piece_x, g_bot.piece_y, g_bot.piece_rotation));
    g_bot.target_valid = false;
    g_bot_plan_len = 0;
    g_bot_plan_index = 0;
    return true;
}

fun lockCurrentPiece() >> void {
    for i32 idx = 0; idx < 4; idx++ {
        i32 x = g_piece_x + minoX(g_piece_kind, g_piece_rotation, idx);
        i32 y = g_piece_y + minoY(g_piece_kind, g_piece_rotation, idx);
        if y >= 0 && y < BOARD_H && x >= 0 && x < BOARD_W {boardSet(x, y, g_piece_kind + 1);}
    }
}

fun awardLineClear(lines_cleared: i32) >> void {
    g_play.lines += lines_cleared;
}

fun clearLines() >> i32 {
    i32 cleared = 0;
    for i32 y = BOARD_H - 1; y >= 0; y-- {
        bool full = true;
        for i32 x = 0; x < BOARD_W; x++ {
            if boardGet(x, y) == 0 {full = false;}
        }

        if (full) {
            cleared += 1;
            for i32 pull = y; pull > 0; pull-- {
                for i32 x = 0; x < BOARD_W; x++ {
                    boardSet(x, pull, boardGet(x, pull - 1));
                }
            }
            for i32 x = 0; x < BOARD_W; x++ {
                boardSet(x, 0, 0);
            }
            y += 1;
        }
    }

    if cleared > 0 {awardLineClear(cleared);}
    return cleared;
}

fun boardIsEmpty() >> bool {
    for i32 y = 0; y < BOARD_H; y++ {
        for i32 x = 0; x < BOARD_W; x++ {
            if boardGet(x, y) != 0 {return false;}
        }
    }
    return true;
}

fun boardCellOccupiedOrBlocked(x: i32, y: i32) >> bool {
    if x < 0 || x >= BOARD_W {return true;}
    if y >= BOARD_H {return true;}
    if y < 0 {return false;}
    return boardGet(x, y) != 0;
}

fun isTSpin(kind: i32, x: i32, y: i32) >> bool {
    if kind != PIECE_T {return false;}
    if !g_rt.last_rotate_success {return false;}

    i32 cx = x + 1;
    i32 cy = y + 1;
    i32 occupied_corners = 0;
    if boardCellOccupiedOrBlocked(cx - 1, cy - 1) {occupied_corners += 1;}
    if boardCellOccupiedOrBlocked(cx + 1, cy - 1) {occupied_corners += 1;}
    if boardCellOccupiedOrBlocked(cx - 1, cy + 1) {occupied_corners += 1;}
    if boardCellOccupiedOrBlocked(cx + 1, cy + 1) {occupied_corners += 1;}
    return occupied_corners >= 3;
}

fun lineBasePoints(lines_cleared: i32) >> i32 {
    if lines_cleared <= 0 {return 0;}
    if lines_cleared == 1 {return 100;}
    if lines_cleared == 2 {return 300;}
    if lines_cleared == 3 {return 500;}
    return 800;
}

fun spinBasePoints(lines_cleared: i32) >> i32 {
    if lines_cleared <= 0 {return 400;}
    if lines_cleared == 1 {return 800;}
    if lines_cleared == 2 {return 1200;}
    if lines_cleared == 3 {return 1600;}
    return 2600;
}

fun miniSpinBasePoints(lines_cleared: i32) >> i32 {
    if lines_cleared <= 0 {return 100;}
    if lines_cleared == 1 {return 200;}
    if lines_cleared == 2 {return 400;}
    if lines_cleared == 3 {return 800;}
    return 1600;
}

fun lockAttack(lines_cleared: i32, spin: bool, mini: bool, difficult: bool, b2b_chain: bool, combo_value: i32, all_clear: bool) >> i32 {
    i32 attack = 0;

    if spin {
        if mini {
            if lines_cleared == 1 {attack = 0;}
            if lines_cleared == 2 {attack = 1;}
        } else {
            if lines_cleared == 1 {attack = 2;}
            if lines_cleared == 2 {attack = 4;}
            if lines_cleared >= 3 {attack = 6;}
        }
    } else {
        if lines_cleared == 2 {attack = 1;}
        if lines_cleared == 3 {attack = 2;}
        if lines_cleared >= 4 {attack = 4;}
    }

    if difficult && b2b_chain {
        if spin {
            if mini {
                attack += 1;
            } else if lines_cleared == 1 {
                attack += 1;
            } else if lines_cleared == 2 {
                attack += 2;
            } else {
                attack += 3;
            }
        } else if lines_cleared >= 4 {
            attack += 2;
        } else {
            attack += 1;
        }
    }
    if lines_cleared > 0 && combo_value >= 1 {attack += combo_value / 2;}
    if all_clear && lines_cleared > 0 {attack += 10;}
    return attack;
}

fun scoreLevel() >> i32 {
    i32 level = (g_play.lines / 10) + 1;
    if level < 1 {level = 1;}
    return level;
}

fun applyLockScore(lines_cleared: i32, spin: bool, mini: bool, all_clear: bool) >> void {
    i32 level = scoreLevel();

    i32 base = 0;
    if spin {
        if mini {
            base = miniSpinBasePoints(lines_cleared);
        } else {
            base = spinBasePoints(lines_cleared);
        }
    } else {
        base = lineBasePoints(lines_cleared);
    }

    bool difficult = false;
    if lines_cleared == 4 {difficult = true;}
    if spin && lines_cleared > 0 {difficult = true;}
    bool b2b_chain = g_rt.back_to_back_count > 0;

    i32 clear_points = base;
    if difficult && b2b_chain {clear_points = (clear_points * 3) / 2;}

    i32 combo_points = 0;
    i32 all_clear_points = 0;

    if lines_cleared > 0 {
        g_rt.combo += 1;
        combo_points = g_rt.combo * 50;
    } else {
        g_rt.combo = -1;
    }

    if all_clear {all_clear_points = 3500;}
    g_play.score += (clear_points + combo_points + all_clear_points) * level;

    i32 attack = lockAttack(lines_cleared, spin, mini, difficult, b2b_chain, g_rt.combo, all_clear);
    g_rt.attack_sent += attack;
    if isVsBotMode() {routePlayerAttack(attack);}

    if difficult {
        g_rt.back_to_back_count += 1;
        g_rt.back_to_back = true;
    } else if lines_cleared > 0 {
        g_rt.back_to_back_count = 0;
        g_rt.back_to_back = false;
    }

    g_rt.last_rotate_success = false;
    g_rt.last_rotate_kick_test = -1;
}

fun stepLock() >> void {
    lockCurrentPiece();
    kickBoardShake(3.0, 0.08);
    g_rt.pieces_placed += 1;
    bool spin = isTSpin(g_piece_kind, g_piece_x, g_piece_y);
    i32 lines_cleared = clearLines();
    bool mini = false;
    if spin && lines_cleared <= 1 && g_rt.last_rotate_kick_test == 0 {mini = true;}
    bool all_clear = lines_cleared > 0 && boardIsEmpty();
    if isFreePlayMode() {
        i32 max_h = 0;
        i32 holes = 0;
        i32 garbage_rows = 0;
        i32 garbage_cover = 0;
        aiBoardStackStats(&g_board[0], &max_h, &holes, &garbage_rows, &garbage_cover);
        i32 garbage_access = aiBoardGarbageAccessScore(&g_board[0]);
        aiLog(TextFormat("fp lock kind=%i x=%i rot=%i lines=%i spin=%i all_clear=%i total_lines=%i max_h=%i holes=%i garbage_rows=%i cover=%i access=%i", g_piece_kind, g_piece_x, g_piece_rotation, lines_cleared, spin as i32, all_clear as i32, g_play.lines, max_h, holes, garbage_rows, garbage_cover, garbage_access));
    }
    if lines_cleared > 0 {kickBoardShake(lineClearShakeAmp(lines_cleared), 0.11);}
    applyLockScore(lines_cleared, spin, mini, all_clear);
    if (isFortyLinesMode() && g_play.round_state == ROUND_RUNNING && g_play.lines >= 40) {
        g_play = g_play.with_round_state(ROUND_FINISHED);
        return;
    }

    if isVsBotMode() && g_player_pending_garbage > 0 {
        insertGarbageIntoPlayer(g_player_pending_garbage);
        g_player_pending_garbage = 0;
        if g_play.game_over {return;}
    }

    spawnNextPiece();
}

fun hardDrop() >> void {
    i32 distance = 0;
    for (tryMove(0, 1)) {
        distance += 1;
    }
    g_play.score += distance * 2;
    if (g_bg_star_react_mode == STAR_MODE_DROPS) {
        f32 norm = starIntensityNorm();
        g_rt.star_pps_meter += 1.0;
        if g_rt.star_pps_meter > 3.0 {g_rt.star_pps_meter = 3.0;}
        g_rt.star_hard_target += 0.06 + norm * 0.64;
        if g_rt.star_hard_target > 1.0 {g_rt.star_hard_target = 1.0;}
    }
    stepLock();
}

fun drawCell(screen_x: i64, screen_y: i64, color: u32) >> void {
    u32 hi = shadeColor(color, 1.24);
    u32 lo = shadeColor(color, 0.56);
    fillRect(screen_x, screen_y, CELL, CELL, color);
    fillRect(screen_x + 2, screen_y + 2, CELL - 4, 5, alphaColor(hi, 0.62));
    fillRect(screen_x + 2, screen_y + 9, 4, CELL - 16, alphaColor(hi, 0.34));
    fillRect(screen_x + CELL - 6, screen_y + 9, 4, CELL - 16, alphaColor(lo, 0.36));
    fillRect(screen_x + 2, screen_y + CELL - 8, CELL - 4, 6, alphaColor(lo, 0.48));
    strokeRect(screen_x + 1, screen_y + 1, CELL - 2, CELL - 2, alphaColor(hi, 0.34));
    strokeRect(screen_x, screen_y, CELL, CELL, alphaColor(lo, 0.70));
}

fun drawMiniCell(screen_x: i64, screen_y: i64, size: i64, color: u32) >> void {
    u32 hi = shadeColor(color, 1.20);
    u32 lo = shadeColor(color, 0.60);
    fillRect(screen_x, screen_y, size, size, color);
    fillRect(screen_x + 1, screen_y + 1, size - 2, 3, alphaColor(hi, 0.62));
    fillRect(screen_x + 1, screen_y + size - 4, size - 2, 3, alphaColor(lo, 0.56));
    strokeRect(screen_x, screen_y, size, size, alphaColor(lo, 0.72));
}

fun garbageCellColor(theme: Theme) >> u32 {
    return shadeColor(theme.panel_stroke, 0.72);
}

fun drawHighStackSpawnZone(theme: Theme, board_left: i64, board_top: i64) >> void {
    if !duelShowsHighStackArea() {return;}

    i64 zone_top = board_top - (HIGH_STACK_SPAWN_ROWS as i64) * (CELL as i64);
    i64 zone_h = (HIGH_STACK_SPAWN_ROWS as i64) * (CELL as i64);
    i64 spawn_x = board_left + 3 * (CELL as i64);
    i64 spawn_w = 4 * (CELL as i64);
    fillRect(spawn_x - 6, zone_top - 8, spawn_w + 12, zone_h + 8, alphaColor(theme.panel_stroke, 0.09));
    strokeRect(spawn_x - 6, zone_top - 8, spawn_w + 12, zone_h + 8, alphaColor(theme.panel_stroke, 0.22));

    for i32 y = -HIGH_STACK_SPAWN_ROWS; y < 0; y++ {
        for i32 x = 3; x < 7; x++ {
            i64 sx = board_left + (x as i64) * (CELL as i64);
            i64 sy = boardScreenY(board_top, y as i64);
            fillRect(sx + 1, sy + 1, CELL - 2, CELL - 2, alphaColor(theme.panel_stroke, 0.06));
            strokeRect(sx, sy, CELL, CELL, alphaColor(theme.panel_stroke, 0.18));
        }
    }

    fillRect(board_left, board_top - 4, (BOARD_W * CELL) as i64, 4, alphaColor(theme.text_main, 0.26));
    strokeRect(board_left - 1, board_top - 1, (BOARD_W * CELL + 2) as i64, 2, alphaColor(theme.text_main, 0.44));
}

fun drawPieceAtBoard(kind: i32, rotation: i32, base_x: i64, base_y: i64, board_left: i64, board_top: i64, color: u32) >> void {
    for i32 idx = 0; idx < 4; idx++ {
        i64 x = base_x + (minoX(kind, rotation, idx) as i64);
        i64 y = base_y + (minoY(kind, rotation, idx) as i64);
        if y >= (boardRenderMinRow() as i64) {drawCell(board_left + x * (CELL as i64), boardScreenY(board_top, y), color);}
    }
}

fun drawPieceAt(kind: i32, rotation: i32, base_x: i64, base_y: i64, color: u32) >> void {
    drawPieceAtBoard(kind, rotation, base_x, base_y, currentPlayerBoardLeft(), currentBoardTop(), color);
}

fun drawMiniPiece(theme: Theme, kind: i32, panel_x: i64, panel_y: i64, size: i64) >> void {
    for i32 idx = 0; idx < 4; idx++ {
        i64 px = panel_x + (minoX(kind, 0, idx) as i64) * size;
        i64 py = panel_y + (minoY(kind, 0, idx) as i64) * size;
        drawMiniCell(px, py, size, pieceColor(theme, kind));
    }
}

fun drawMiniPieceCentered(theme: Theme, kind: i32, panel_x: i64, panel_y: i64, panel_w: i64, panel_h: i64, size: i64) >> void {
    i32 min_x = 99;
    i32 max_x = -99;
    i32 min_y = 99;
    i32 max_y = -99;

    for i32 idx = 0; idx < 4; idx++ {
        i32 mx = minoX(kind, 0, idx);
        i32 my = minoY(kind, 0, idx);
        if mx < min_x {min_x = mx;}
        if mx > max_x {max_x = mx;}
        if my < min_y {min_y = my;}
        if my > max_y {max_y = my;}
    }

    i32 piece_w = max_x - min_x + 1;
    i32 piece_h = max_y - min_y + 1;

    i64 origin_x = panel_x + (panel_w - (piece_w as i64) * size) / 2 - (min_x as i64) * size;
    i64 origin_y = panel_y + (panel_h - (piece_h as i64) * size) / 2 - (min_y as i64) * size;

    drawMiniPiece(theme, kind, origin_x, origin_y, size);
}

fun drawBoard(theme: Theme) >> void {
    i64 board_left = currentPlayerBoardLeft();
    i64 board_top = currentBoardTop();
    i64 board_h = (boardVisibleRows() as i64) * (CELL as i64);
    drawHighStackSpawnZone(theme, board_left, board_top);
    fillRect(board_left - 8, board_top - 8, (BOARD_W * CELL + 16) as i64, board_h + 16, theme.board_bg);
    strokeRect(board_left - 8, board_top - 8, (BOARD_W * CELL + 16) as i64, board_h + 16, theme.panel_stroke);

    for i32 y = boardVisibleStartRow(); y < BOARD_H; y++ {
        for i32 x = 0; x < BOARD_W; x++ {
            i32 sx = (board_left as i32) + x * (CELL as i32);
            i32 sy = boardScreenY(board_top, y as i64) as i32;
            strokeRect(sx, sy, CELL, CELL, theme.board_grid);
            i32 cell = boardGet(x, y);
            if cell == 8 {
                drawCell(sx, sy, garbageCellColor(theme));
            } else if cell != 0 {
                drawCell(sx, sy, pieceColor(theme, cell - 1));
            }
        }
    }

    if (!g_play.game_over) {
        drawPieceAt(g_piece_kind, g_piece_rotation, g_piece_x, currentGhostY(), ghostColor(pieceColor(theme, g_piece_kind)));
        drawPieceAt(g_piece_kind, g_piece_rotation, g_piece_x, g_piece_y, pieceColor(theme, g_piece_kind));
    }
}

fun drawBotBoard(theme: Theme, font: Font) >> void {
    i64 board_x = currentBotBoardLeft();
    i64 board_y = currentBotBoardTop();
    i64 board_w = (BOARD_W as i64) * (CELL as i64);
    i64 board_h = (boardVisibleRows() as i64) * (CELL as i64);

    drawHighStackSpawnZone(theme, board_x, board_y);
    fillRect(board_x - 8, board_y - 8, board_w + 16, board_h + 16, theme.board_bg);
    strokeRect(board_x - 8, board_y - 8, board_w + 16, board_h + 16, theme.panel_stroke);
    drawTextColor(font, "BOT", board_x + 120, board_y - 42, 16, theme.text_main);

    for i32 y = boardVisibleStartRow(); y < BOARD_H; y++ {
        for i32 x = 0; x < BOARD_W; x++ {
            i64 sx = board_x + (x as i64) * (CELL as i64);
            i64 sy = boardScreenY(board_y, y as i64);
            strokeRect(sx, sy, CELL, CELL, theme.board_grid);

            i32 cell = botBoardGet(x, y);
            if cell == 8 {
                drawCell(sx, sy, garbageCellColor(theme));
            } else if cell != 0 {
                drawCell(sx, sy, pieceColor(theme, cell - 1));
            }
        }
    }

    if !g_bot.game_over {
        drawPieceAtBoard(g_bot.piece_kind, g_bot.piece_rotation, g_bot.piece_x as i64, botGhostY() as i64, board_x, board_y, ghostColor(pieceColor(theme, g_bot.piece_kind)));
        drawPieceAtBoard(g_bot.piece_kind, g_bot.piece_rotation, g_bot.piece_x as i64, g_bot.piece_y as i64, board_x, board_y, pieceColor(theme, g_bot.piece_kind));
    }

    f32 bot_apm = 0.0;
    if g_rt.run_timer > 0.001 {bot_apm = ((g_bot.attack_sent as f32) * 60.0) / g_rt.run_timer;}
    drawTextColor(font, TextFormat("APM %.1f / %.1f", bot_apm, g_bot_setup.target_apm), board_x + 30, board_y + board_h + 14, 10, theme.panel_stroke);
    drawTextColor(font, TextFormat("LINES %i", g_bot.lines), board_x + 102, board_y + board_h + 34, 10, theme.text_muted);
}

fun arenaBoardPtr(side: i32) >> ptr<i32> {
    if side == BOT_ARENA_LEFT {return &g_bot_arena_left_board[0];}
    return &g_bot_arena_right_board[0];
}

fun arenaQueuePtr(side: i32) >> ptr<i32> {
    if side == BOT_ARENA_LEFT {return &g_bot_arena_left_queue[0];}
    return &g_bot_arena_right_queue[0];
}

fun arenaBagPtr(side: i32) >> ptr<i32> {
    if side == BOT_ARENA_LEFT {return &g_bot_arena_left_bag[0];}
    return &g_bot_arena_right_bag[0];
}

fun arenaPlanActionsPtr(side: i32) >> ptr<i32> {
    if side == BOT_ARENA_LEFT {return &g_bot_arena_left_plan_actions[0];}
    return &g_bot_arena_right_plan_actions[0];
}

fun arenaPlannedBoardPtr(side: i32) >> ptr<i32> {
    if side == BOT_ARENA_LEFT {return &g_bot_arena_left_planned_board[0];}
    return &g_bot_arena_right_planned_board[0];
}

fun arenaTuningPtr(side: i32) >> ptr<i32> {
    if side == BOT_ARENA_LEFT {return &g_bot_arena_left_tuning[0];}
    return &g_bot_arena_right_tuning[0];
}

fun arenaBoardCell(side: i32, x: i32, y: i32) >> i32 {
    ptr<i32> board = arenaBoardPtr(side);
    return board[boardIndex(x, y)];
}

fun arenaSideApm(side: i32) >> f32 {
    if g_rt.run_timer <= 0.001 {return 0.0;}
    if side == BOT_ARENA_LEFT {return ((g_bot_arena_left.runtime.attack_sent as f32) * 60.0) / g_rt.run_timer;}
    return ((g_bot_arena_right.runtime.attack_sent as f32) * 60.0) / g_rt.run_timer;
}

fun drawArenaSideBoard(theme: Theme, font: Font, side: i32, board_x: i64, board_y: i64, label: ptr<u8>, champion: bool) >> void {
    BotArenaSide state = g_bot_arena_left;
    if side == BOT_ARENA_RIGHT {state = g_bot_arena_right;}
    i64 board_w = (BOARD_W as i64) * (CELL as i64);
    i64 board_h = (boardVisibleRows() as i64) * (CELL as i64);

    drawHighStackSpawnZone(theme, board_x, board_y);
    fillRect(board_x - 8, board_y - 8, board_w + 16, board_h + 16, theme.board_bg);
    if champion {strokeRect(board_x - 8, board_y - 8, board_w + 16, board_h + 16, pieceColor(theme, PIECE_I));}
    else {strokeRect(board_x - 8, board_y - 8, board_w + 16, board_h + 16, theme.panel_stroke);}
    drawTextColor(font, label, board_x + 72, board_y - 42, 16, theme.text_main);
    drawTextColor(font, TextFormat("GEN %i", state.generation), board_x + 90, board_y - 22, 10, theme.text_muted);

    for i32 y = boardVisibleStartRow(); y < BOARD_H; y++ {
        for i32 x = 0; x < BOARD_W; x++ {
            i64 sx = board_x + (x as i64) * (CELL as i64);
            i64 sy = boardScreenY(board_y, y as i64);
            strokeRect(sx, sy, CELL, CELL, theme.board_grid);

            i32 cell = arenaBoardCell(side, x, y);
            if cell == 8 {
                drawCell(sx, sy, garbageCellColor(theme));
            } else if cell != 0 {
                drawCell(sx, sy, pieceColor(theme, cell - 1));
            }
        }
    }

    if !state.runtime.game_over {
        drawPieceAtBoard(state.runtime.piece_kind, state.runtime.piece_rotation, state.runtime.piece_x as i64, state.runtime.piece_y as i64, board_x, board_y, pieceColor(theme, state.runtime.piece_kind));
    }

    drawTextColor(font, TextFormat("APM %.1f / %.1f", arenaSideApm(side), state.setup.target_apm), board_x + 26, board_y + board_h + 14, 10, theme.panel_stroke);
    drawTextColor(font, TextFormat("LINES %i", state.runtime.lines), board_x + 102, board_y + board_h + 34, 10, theme.text_muted);
    drawTextColor(font, TextFormat("MESS %.0f%%", state.setup.garbage_messiness), board_x + 20, board_y + board_h + 34, 10, theme.text_muted);
}

fun drawBotDuelsFrame(font: Font) >> void {
    if !BOTDEVMODE {return;}
    Theme theme = currentTheme();
    DrawRectangleGradientV(0, 0, GetScreenWidth(), GetScreenHeight(), toColor(theme.bg_inner), toColor(theme.bg_outer));
    drawBackgroundStars(theme);

    if !canOpenBotSetupUi() {
        drawBotWidthPopup(font, theme, true);
        if g_debug_colors {drawColorDebugOverlay(font, theme);}
        return;
    }

    i64 board_y = BOT_BOARD_TOP;
    if duelShowsHighStackArea() {board_y += HIGH_STACK_BOARD_SHIFT;}

    if !g_bot_arena.compare_stock && g_bot_arena.generation_stage == BOT_ARENA_STAGE_STOCK {
        drawArenaSideBoard(theme, font, BOT_ARENA_LEFT, vsBotPlayerBoardLeft(), board_y, "CANDIDATE", true);
        drawArenaSideBoard(theme, font, BOT_ARENA_RIGHT, vsBotBotBoardLeft(), board_y, "STOCK", false);
    } else {
        drawArenaSideBoard(theme, font, BOT_ARENA_LEFT, vsBotPlayerBoardLeft(), board_y, "CHAMPION", true);
        if g_bot_arena.compare_stock {drawArenaSideBoard(theme, font, BOT_ARENA_RIGHT, vsBotBotBoardLeft(), board_y, "STOCK", false);} else {drawArenaSideBoard(theme, font, BOT_ARENA_RIGHT, vsBotBotBoardLeft(), board_y, "CHALLENGER", false);}
    }

    i64 panel_x = vsBotCenterPanelX();
    fillRect(panel_x, 120, 178, 510, theme.panel_bg);
    strokeRect(panel_x, 120, 178, 510, theme.panel_stroke);
    drawTextColor(font, "BOT DUELS", panel_x + 20, 150, 14, theme.text_main);
    if g_bot_arena.compare_stock {
        drawTextColor(font, "MODE CHAMP VS STOCK", panel_x + 20, 184, 12, theme.panel_stroke);
    } else if g_bot_arena.generation_stage == BOT_ARENA_STAGE_STOCK {
        drawTextColor(font, TextFormat("GEN %i STOCK GATE", g_bot_arena.total_matches + 1), panel_x + 20, 184, 12, theme.panel_stroke);
    } else {
        drawTextColor(font, TextFormat("GEN %i CHALLENGER", g_bot_arena.total_matches + 1), panel_x + 20, 184, 12, theme.panel_stroke);
    }
    drawTextColor(font, TextFormat("CHAMP GEN %i", g_bot_arena.champion_generation), panel_x + 20, 216, 11, theme.text_main);
    drawTextColor(font, TextFormat("STREAK %i", g_bot_arena.champion_wins), panel_x + 20, 238, 11, theme.text_main);
    drawTextColor(font, "APM FIXED 300", panel_x + 20, 272, 11, theme.text_muted);
    drawTextColor(font, "MUTATING AI WEIGHTS", panel_x + 20, 294, 11, theme.text_muted);
    drawTextColor(font, TextFormat("GENES %i", AI_TUNE_COUNT), panel_x + 20, 316, 11, theme.text_muted);

    if g_bot_arena.compare_stock {
        i32 stock_total = g_bot_arena.compare_stock_wins + g_bot_arena.compare_stock_losses;
        f32 stock_wr = 0.0;
        if stock_total > 0 {stock_wr = ((g_bot_arena.compare_stock_wins as f32) * 100.0) / (stock_total as f32);}
        drawTextColor(font, TextFormat("WR %.1f%%", stock_wr), panel_x + 20, 360, 11, theme.text_main);
        drawTextColor(font, TextFormat("W %i  L %i", g_bot_arena.compare_stock_wins, g_bot_arena.compare_stock_losses), panel_x + 20, 382, 11, theme.panel_stroke);
    } else {
        if g_bot_arena.generation_stage == BOT_ARENA_STAGE_CHAMPION {
            if g_bot_arena.champion_generation < 5 {
                drawTextColor(font, TextFormat("CHAMP %i/%i", g_bot_arena.generation_round + 1, BOT_ARENA_EARLY_MAX_ROUNDS), panel_x + 20, 360, 11, theme.text_main);
                drawTextColor(font, TextFormat("TOTAL %i-%i", g_bot_arena.generation_right_wins, g_bot_arena.generation_left_wins), panel_x + 20, 382, 11, theme.panel_stroke);
            } else {
                drawTextColor(font, TextFormat("GAUNTLET %i/%i", g_bot_arena.gauntlet_target_index + 1, arenaGauntletChampionCount()), panel_x + 20, 360, 11, theme.text_main);
                drawTextColor(font, TextFormat("CH %i  CL %i", g_bot_arena.generation_left_wins, g_bot_arena.generation_right_wins), panel_x + 20, 382, 11, theme.panel_stroke);
            }
        } else {
            drawTextColor(font, TextFormat("STOCK %i/%i", g_bot_arena.stock_round + 1, BOT_ARENA_STOCK_MAX_ROUNDS), panel_x + 20, 360, 11, theme.text_main);
            drawTextColor(font, TextFormat("CAND %i  STOCK %i", g_bot_arena.stock_left_wins, g_bot_arena.stock_right_wins), panel_x + 20, 382, 11, theme.panel_stroke);
        }
    }
    drawTextColor(font, TextFormat("LAST WIN %i", g_bot_arena.last_winner_generation), panel_x + 20, 414, 11, theme.text_main);
    if g_bot_arena.last_winner_side == 1 {drawTextColor(font, "SIDE CHAMPION", panel_x + 20, 436, 11, theme.panel_stroke);}
    else if g_bot_arena.last_winner_side == 2 {
        if g_bot_arena.compare_stock {drawTextColor(font, "SIDE STOCK", panel_x + 20, 436, 11, theme.panel_stroke);} else {drawTextColor(font, "SIDE CLONE", panel_x + 20, 436, 11, theme.panel_stroke);}
    }

    drawTextColor(font, TextFormat("SIM x%i", BOT_DUELS_SIM_STEPS), panel_x + 20, 474, 11, theme.text_main);
    drawTextColor(font, "Saved to bot_duels.cfg", panel_x + 20, 504, 10, theme.text_muted);
    drawTextColor(font, "1 toggle stock test", panel_x + 20, 526, 10, theme.text_muted);
    drawTextColor(font, "ESC menu", panel_x + 20, 580, 11, theme.text_muted);

    if g_debug_colors {drawColorDebugOverlay(font, theme);}
}

fun botSetupPanelHeight() >> i64 {
    if BOTDEVMODE {return 636;}
    return 560;
}

fun botSetupRowCount() >> i32 {
    if BOTDEVMODE {return 6;}
    return 5;
}

fun botSetupPanicRow() >> i32 {
    return 2;
}

fun botSetupWeightsRow() >> i32 {
    if BOTDEVMODE {return 3;}
    return -1;
}

fun botSetupStartRow() >> i32 {
    if BOTDEVMODE {return 4;}
    return 3;
}

fun botSetupBackRow() >> i32 {
    if BOTDEVMODE {return 5;}
    return 4;
}

fun drawBotSetupScreen(font: Font, theme: Theme) >> void {
    DrawRectangleGradientV(0, 0, GetScreenWidth(), GetScreenHeight(), toColor(theme.bg_inner), toColor(theme.bg_outer));

    i64 panel_h = botSetupPanelHeight();
    fillRect(126, 128, 396, panel_h, alphaColor(theme.bg_outer, 0.90));
    strokeRect(126, 128, 396, panel_h, alphaColor(theme.panel_stroke, 0.88));
    drawTextColor(font, "AGAINST BOT", 176, 164, 28, theme.text_main);
    drawTextColor(font, "Duel setup", 176, 202, 12, theme.text_muted);

    if !canOpenBotSetupUi() {
        drawBotWidthPopup(font, theme, true);
        return;
    }

    i64 slider_x = 176;
    i64 slider_y = 309;
    i64 slider_w = 296;
    f32 apm_norm = (g_bot_setup.target_apm - (BOT_APM_MIN as f32)) / ((BOT_APM_MAX - BOT_APM_MIN) as f32);
    if apm_norm < 0.0 {apm_norm = 0.0;}
    if apm_norm > 1.0 {apm_norm = 1.0;}

    i64 row_y0 = 270;
    i64 row_h = 76;
    i32 row_count = botSetupRowCount();
    for i32 i = 0; i < row_count; i++ {
        i64 y = row_y0 + (i as i64) * row_h;
        u32 bg = alphaColor(theme.panel_bg, 0.88);
        u32 st = alphaColor(theme.panel_stroke, 0.55);
        if i == g_bot_setup.index {
            bg = alphaColor(theme.board_bg, 0.98);
            st = theme.panel_stroke;
        }
        fillRect(156, y, 336, 58, bg);
        strokeRect(156, y, 336, 58, st);
    }

    drawTextColor(font, "Target APM", 176, 286, 13, theme.text_main);
    drawTextColor(font, TextFormat("%.1f", g_bot_setup.target_apm), 426, 286, 13, theme.panel_stroke);
    fillRect(slider_x, slider_y, slider_w, 8, alphaColor(theme.board_bg, 0.94));
    strokeRect(slider_x, slider_y, slider_w, 8, alphaColor(theme.panel_stroke, 0.76));
    i64 knob_x = slider_x + (((slider_w - 14) as f32) * apm_norm) as i64;
    fillRect(knob_x, slider_y - 4, 14, 16, alphaColor(theme.panel_stroke, 0.95));
    strokeRect(knob_x, slider_y - 4, 14, 16, alphaColor(theme.text_main, 0.85));
    f32 messiness_norm = g_bot_setup.garbage_messiness / 100.0;
    if messiness_norm < 0.0 {messiness_norm = 0.0;}
    if messiness_norm > 1.0 {messiness_norm = 1.0;}
    drawTextColor(font, "Garbage messiness", 176, 362, 13, theme.text_main);
    drawTextColor(font, TextFormat("%.0f%%", g_bot_setup.garbage_messiness), 420, 362, 13, theme.panel_stroke);
    fillRect(slider_x, slider_y + row_h, slider_w, 8, alphaColor(theme.board_bg, 0.94));
    strokeRect(slider_x, slider_y + row_h, slider_w, 8, alphaColor(theme.panel_stroke, 0.76));
    i64 messiness_knob_x = slider_x + (((slider_w - 14) as f32) * messiness_norm) as i64;
    fillRect(messiness_knob_x, slider_y + row_h - 4, 14, 16, alphaColor(theme.panel_stroke, 0.95));
    strokeRect(messiness_knob_x, slider_y + row_h - 4, 14, 16, alphaColor(theme.text_main, 0.85));
    ... Hidden temporarily.
    drawTextColor(font, "High stack tolerance", 176, 438, 13, theme.text_main);
    drawTextColor(font, "DISABLED", 384, 438, 13, theme.text_muted);
    ...
    drawTextColor(font, "Panic burst", 176, 438, 13, theme.text_main);
    if g_bot_setup.panic_burst_enabled {drawTextColor(font, "ON", 434, 438, 13, theme.panel_stroke);} else {drawTextColor(font, "OFF", 418, 438, 13, theme.text_muted);}
    if BOTDEVMODE {
        drawTextColor(font, "Weights", 176, 514, 13, theme.text_main);
        if g_bot_setup.weights_mode == BOT_WEIGHTS_STOCK {drawTextColor(font, "STOCK", 408, 514, 13, theme.panel_stroke);} else {drawTextColor(font, "CHAMPION", 368, 514, 13, theme.panel_stroke);}
        drawTextColor(font, "START DUEL", 176, 590, 13, theme.text_main);
        drawTextColor(font, "BACK", 176, 666, 13, theme.text_muted);
        drawTextColor(font, "UP/DOWN select  LEFT/RIGHT or mouse  ENTER confirm", 156, 710, 10, theme.text_muted);
    } else {
        drawTextColor(font, "START DUEL", 176, 514, 13, theme.text_main);
        drawTextColor(font, "BACK", 176, 590, 13, theme.text_muted);
        drawTextColor(font, "UP/DOWN select  LEFT/RIGHT or mouse  ENTER confirm", 156, 634, 10, theme.text_muted);
    }
}

fun clampBotTargetApm() >> void {
    if g_bot_setup.target_apm < BOT_APM_MIN {g_bot_setup.target_apm = BOT_APM_MIN as f32;}
    if g_bot_setup.target_apm > BOT_APM_MAX {g_bot_setup.target_apm = BOT_APM_MAX as f32;}
}

fun setBotTargetApmNorm(norm: f32) >> void {
    f32 n = norm;
    if n < 0.0 {n = 0.0;}
    if n > 1.0 {n = 1.0;}
    g_bot_setup.target_apm = (BOT_APM_MIN as f32) + ((BOT_APM_MAX - BOT_APM_MIN) as f32) * n;
    clampBotTargetApm();
}

fun mouseBaseX() >> f32 {
    Vector2 mouse = GetMousePosition();
    f32 scale = uiScale();
    if scale <= 0.0001 {return 0.0;}
    i32 ox = uiOffsetX(scale);
    return (mouse.x - (ox as f32)) / scale;
}

fun mouseBaseY() >> f32 {
    Vector2 mouse = GetMousePosition();
    f32 scale = uiScale();
    if scale <= 0.0001 {return 0.0;}
    i32 oy = uiOffsetY(scale);
    return (mouse.y - (oy as f32)) / scale;
}

fun pointInBaseRectLocal(px: f32, py: f32, x: i64, y: i64, w: i64, h: i64) >> bool {
    if px < (x as f32) {return false;}
    if py < (y as f32) {return false;}
    if px > ((x + w) as f32) {return false;}
    if py > ((y + h) as f32) {return false;}
    return true;
}

fun initBotSetupDefaults() >> void {
    if g_bot_setup.target_apm < 1.0 {g_bot_setup.target_apm = 65.0;}
    if g_bot_setup.garbage_messiness < 0.5 {g_bot_setup.garbage_messiness = 35.0;}
    g_bot_setup.high_stack_tolerance = false;
    g_bot_setup.panic_burst_enabled = false;
    g_bot_setup.weights_mode = BOT_WEIGHTS_CHAMPION;
    clampBotTargetApm();
    clampBotGarbageMessiness();
    g_bot_setup.index = 0;
}

fun startBotDuel() >> void {
    g_game = g_game.with_screen(SCREEN_GAME);
    startGameMode(MODE_VS_BOT);
}

fun initBotArenaSide(side: i32, setup: BotSetupState, generation: i32) >> void {
    ptr<i32> board = arenaBoardPtr(side);
    ptr<i32> queue = arenaQueuePtr(side);
    ptr<i32> bag = arenaBagPtr(side);
    ptr<i32> plan_actions = arenaPlanActionsPtr(side);
    ptr<i32> planned_board = arenaPlannedBoardPtr(side);
    g_bot_setup = setup;
    initBotMatch();

    if side == BOT_ARENA_LEFT {
        g_bot_arena_left.setup = setup;
        g_bot_arena_left.generation = generation;
        g_bot_arena_left.runtime = g_bot;
        g_bot_arena_left.runtime.pending_garbage = g_bot_pending_garbage;
        g_bot_arena_left.plan_len = g_bot_plan_len;
        g_bot_arena_left.plan_index = g_bot_plan_index;
        g_bot_arena_left.plan_pending_snapshot = g_bot_plan_pending_snapshot;
        g_bot_arena_left.planned_lines = g_bot_planned_lines;
        g_bot_arena_left.planned_spin = g_bot_planned_spin;
        g_bot_arena_left.planned_all_clear = g_bot_planned_all_clear;
        g_bot_arena_left.garbage_hole = g_bot_garbage_hole;
    } else {
        g_bot_arena_right.setup = setup;
        g_bot_arena_right.generation = generation;
        g_bot_arena_right.runtime = g_bot;
        g_bot_arena_right.runtime.pending_garbage = g_bot_pending_garbage;
        g_bot_arena_right.plan_len = g_bot_plan_len;
        g_bot_arena_right.plan_index = g_bot_plan_index;
        g_bot_arena_right.plan_pending_snapshot = g_bot_plan_pending_snapshot;
        g_bot_arena_right.planned_lines = g_bot_planned_lines;
        g_bot_arena_right.planned_spin = g_bot_planned_spin;
        g_bot_arena_right.planned_all_clear = g_bot_planned_all_clear;
        g_bot_arena_right.garbage_hole = g_bot_garbage_hole;
    }

    for i32 i = 0; i < BOARD_CELLS; i++ {
        board[i] = g_bot_board[i];
        planned_board[i] = g_bot_planned_board[i];
    }
    for i32 i = 0; i < QUEUE_CAP; i++ {queue[i] = g_bot_queue[i];}
    for i32 i = 0; i < BAG_SIZE; i++ {bag[i] = g_bot_bag[i];}
    for i32 i = 0; i < BOT_PLAN_MAX; i++ {plan_actions[i] = g_bot_plan_actions[i];}
}

fun loadBotArenaSideIntoScratch(side: i32, opponent_pending: i32) >> void {
    ptr<i32> board = arenaBoardPtr(side);
    ptr<i32> queue = arenaQueuePtr(side);
    ptr<i32> bag = arenaBagPtr(side);
    ptr<i32> plan_actions = arenaPlanActionsPtr(side);
    ptr<i32> planned_board = arenaPlannedBoardPtr(side);
    if side == BOT_ARENA_LEFT {
        g_bot_setup = g_bot_arena_left.setup;
        g_bot = g_bot_arena_left.runtime;
        g_bot.pending_garbage = g_bot_arena_left.runtime.pending_garbage;
        g_bot_pending_garbage = g_bot_arena_left.runtime.pending_garbage;
        g_bot_plan_len = g_bot_arena_left.plan_len;
        g_bot_plan_index = g_bot_arena_left.plan_index;
        g_bot_plan_pending_snapshot = g_bot_arena_left.plan_pending_snapshot;
        g_bot_planned_lines = g_bot_arena_left.planned_lines;
        g_bot_planned_spin = g_bot_arena_left.planned_spin;
        g_bot_planned_all_clear = g_bot_arena_left.planned_all_clear;
        g_bot_garbage_hole = g_bot_arena_left.garbage_hole;
    } else {
        g_bot_setup = g_bot_arena_right.setup;
        g_bot = g_bot_arena_right.runtime;
        g_bot.pending_garbage = g_bot_arena_right.runtime.pending_garbage;
        g_bot_pending_garbage = g_bot_arena_right.runtime.pending_garbage;
        g_bot_plan_len = g_bot_arena_right.plan_len;
        g_bot_plan_index = g_bot_arena_right.plan_index;
        g_bot_plan_pending_snapshot = g_bot_arena_right.plan_pending_snapshot;
        g_bot_planned_lines = g_bot_arena_right.planned_lines;
        g_bot_planned_spin = g_bot_arena_right.planned_spin;
        g_bot_planned_all_clear = g_bot_arena_right.planned_all_clear;
        g_bot_garbage_hole = g_bot_arena_right.garbage_hole;
    }
    g_player_pending_garbage = opponent_pending;

    for i32 i = 0; i < BOARD_CELLS; i++ {
        g_bot_board[i] = board[i];
        g_bot_planned_board[i] = planned_board[i];
    }
    for i32 i = 0; i < QUEUE_CAP; i++ {g_bot_queue[i] = queue[i];}
    for i32 i = 0; i < BAG_SIZE; i++ {g_bot_bag[i] = bag[i];}
    for i32 i = 0; i < BOT_PLAN_MAX; i++ {g_bot_plan_actions[i] = plan_actions[i];}
}

fun saveScratchIntoBotArenaSide(side: i32) >> i32 {
    ptr<i32> board = arenaBoardPtr(side);
    ptr<i32> queue = arenaQueuePtr(side);
    ptr<i32> bag = arenaBagPtr(side);
    ptr<i32> plan_actions = arenaPlanActionsPtr(side);
    ptr<i32> planned_board = arenaPlannedBoardPtr(side);
    if side == BOT_ARENA_LEFT {
        g_bot_arena_left.setup = g_bot_setup;
        g_bot_arena_left.runtime = g_bot;
        g_bot_arena_left.runtime.pending_garbage = g_bot_pending_garbage;
        g_bot_arena_left.plan_len = g_bot_plan_len;
        g_bot_arena_left.plan_index = g_bot_plan_index;
        g_bot_arena_left.plan_pending_snapshot = g_bot_plan_pending_snapshot;
        g_bot_arena_left.planned_lines = g_bot_planned_lines;
        g_bot_arena_left.planned_spin = g_bot_planned_spin;
        g_bot_arena_left.planned_all_clear = g_bot_planned_all_clear;
        g_bot_arena_left.garbage_hole = g_bot_garbage_hole;
    } else {
        g_bot_arena_right.setup = g_bot_setup;
        g_bot_arena_right.runtime = g_bot;
        g_bot_arena_right.runtime.pending_garbage = g_bot_pending_garbage;
        g_bot_arena_right.plan_len = g_bot_plan_len;
        g_bot_arena_right.plan_index = g_bot_plan_index;
        g_bot_arena_right.plan_pending_snapshot = g_bot_plan_pending_snapshot;
        g_bot_arena_right.planned_lines = g_bot_planned_lines;
        g_bot_arena_right.planned_spin = g_bot_planned_spin;
        g_bot_arena_right.planned_all_clear = g_bot_planned_all_clear;
        g_bot_arena_right.garbage_hole = g_bot_garbage_hole;
    }

    for i32 i = 0; i < BOARD_CELLS; i++ {
        board[i] = g_bot_board[i];
        planned_board[i] = g_bot_planned_board[i];
    }
    for i32 i = 0; i < QUEUE_CAP; i++ {queue[i] = g_bot_queue[i];}
    for i32 i = 0; i < BAG_SIZE; i++ {bag[i] = g_bot_bag[i];}
    for i32 i = 0; i < BOT_PLAN_MAX; i++ {plan_actions[i] = g_bot_plan_actions[i];}

    return g_player_pending_garbage;
}

fun syncBotArenaOpeningSequence(dst: i32, src: i32) >> void {
    ptr<i32> dst_queue = arenaQueuePtr(dst);
    ptr<i32> src_queue = arenaQueuePtr(src);
    ptr<i32> dst_bag = arenaBagPtr(dst);
    ptr<i32> src_bag = arenaBagPtr(src);
    i32 src_queue_count = g_bot_arena_left.runtime.queue_count;
    i32 src_bag_pos = g_bot_arena_left.runtime.bag_pos;
    i32 src_piece_kind = g_bot_arena_left.runtime.piece_kind;
    if src == BOT_ARENA_RIGHT {
        src_queue_count = g_bot_arena_right.runtime.queue_count;
        src_bag_pos = g_bot_arena_right.runtime.bag_pos;
        src_piece_kind = g_bot_arena_right.runtime.piece_kind;
    }

    if dst == BOT_ARENA_LEFT {
        g_bot_arena_left.runtime.queue_count = src_queue_count;
        g_bot_arena_left.runtime.bag_pos = src_bag_pos;
        g_bot_arena_left.runtime.piece_kind = src_piece_kind;
        g_bot_arena_left.runtime.piece_rotation = 0;
        g_bot_arena_left.runtime.piece_x = 3;
        g_bot_arena_left.runtime.piece_y = 0;
        g_bot_arena_left.runtime.target_x = 3;
        g_bot_arena_left.runtime.target_y = 0;
        g_bot_arena_left.runtime.target_rotation = 0;
        g_bot_arena_left.runtime.target_valid = false;
        g_bot_arena_left.runtime.target_last_rotate = false;
        g_bot_arena_left.runtime.target_tspin = false;
        g_bot_arena_left.plan_len = 0;
        g_bot_arena_left.plan_index = 0;
        g_bot_arena_left.plan_pending_snapshot = 0;
    } else {
        g_bot_arena_right.runtime.queue_count = src_queue_count;
        g_bot_arena_right.runtime.bag_pos = src_bag_pos;
        g_bot_arena_right.runtime.piece_kind = src_piece_kind;
        g_bot_arena_right.runtime.piece_rotation = 0;
        g_bot_arena_right.runtime.piece_x = 3;
        g_bot_arena_right.runtime.piece_y = 0;
        g_bot_arena_right.runtime.target_x = 3;
        g_bot_arena_right.runtime.target_y = 0;
        g_bot_arena_right.runtime.target_rotation = 0;
        g_bot_arena_right.runtime.target_valid = false;
        g_bot_arena_right.runtime.target_last_rotate = false;
        g_bot_arena_right.runtime.target_tspin = false;
        g_bot_arena_right.plan_len = 0;
        g_bot_arena_right.plan_index = 0;
        g_bot_arena_right.plan_pending_snapshot = 0;
    }

    for i32 i = 0; i < QUEUE_CAP; i++ {dst_queue[i] = src_queue[i];}
    for i32 i = 0; i < BAG_SIZE; i++ {dst_bag[i] = src_bag[i];}
}

fun initBotArenaRound() >> void {
    if !BOTDEVMODE {
        g_duel_running = false;
        return;
    }
    g_bot_arena.champion_setup = clampArenaSetup(g_bot_arena.champion_setup);

    bool fresh_generation = false;
    if g_bot_arena.compare_stock {fresh_generation = true;}
    else if g_bot_arena.generation_stage == BOT_ARENA_STAGE_CHAMPION && g_bot_arena.generation_round == 0 && g_bot_arena.gauntlet_target_index == 0 {fresh_generation = true;}
    BotSetupState challenger_setup = g_bot_arena_right.setup;
    i32 challenger_generation = g_bot_arena_right.generation;

    if fresh_generation {
        challenger_setup = mutateArenaSetup(g_bot_arena.champion_setup, g_bot_arena.total_matches);
        challenger_generation = g_bot_arena.total_matches + 1;
        if challenger_generation <= g_bot_arena.champion_generation {challenger_generation = g_bot_arena.champion_generation + 1;}

        copyI32Array(&g_bot_arena_left_tuning[0], &g_bot_arena_champion_tuning[0], AI_TUNE_COUNT);
        if g_bot_arena.compare_stock {
            aiFillDefaultTuning(&g_bot_arena_right_tuning[0]);
            challenger_setup = defaultArenaChampionSetup();
            challenger_generation = 0;
        } else {
            mutateArenaTuning(&g_bot_arena_champion_tuning[0], g_bot_arena.total_matches, &g_bot_arena_right_tuning[0]);
        }

        if !g_bot_arena.compare_stock && g_bot_arena.generation_stage == BOT_ARENA_STAGE_CHAMPION {
            g_bot_arena.candidate_setup = challenger_setup;
            g_bot_arena.candidate_generation = challenger_generation;
            copyI32Array(&g_bot_arena_candidate_tuning[0], &g_bot_arena_right_tuning[0], AI_TUNE_COUNT);
        }
    }

    BotSetupState left_setup = arenaTargetSetup(g_bot_arena.gauntlet_target_index);
    i32 left_generation = arenaTargetGeneration(g_bot_arena.gauntlet_target_index);
    ptr<i32> left_tuning = &g_bot_arena_left_tuning[0];
    BotSetupState right_setup = challenger_setup;
    i32 right_generation = challenger_generation;
    ptr<i32> right_tuning = &g_bot_arena_right_tuning[0];

    copyArenaTargetTuning(g_bot_arena.gauntlet_target_index, left_tuning);

    if !g_bot_arena.compare_stock && g_bot_arena.generation_stage == BOT_ARENA_STAGE_STOCK {
        left_setup = g_bot_arena.candidate_setup;
        left_generation = g_bot_arena.candidate_generation;
        copyI32Array(left_tuning, &g_bot_arena_candidate_tuning[0], AI_TUNE_COUNT);
        right_setup = defaultArenaChampionSetup();
        right_generation = 0;
        right_tuning = &g_bot_arena_right_tuning[0];
        aiFillDefaultTuning(right_tuning);
    }

    copyI32Array(&g_bot_arena_right_tuning[0], right_tuning, AI_TUNE_COUNT);

    initBotArenaSide(BOT_ARENA_LEFT, left_setup, left_generation);
    initBotArenaSide(BOT_ARENA_RIGHT, right_setup, right_generation);
    syncBotArenaOpeningSequence(BOT_ARENA_RIGHT, BOT_ARENA_LEFT);

    g_rt.run_timer = 0.0;
    g_duel_running = true;
    g_duel_result = DUEL_RESULT_PLAYING;
}

fun resolveBotArenaMatch(winner_side: i32) >> void {
    if !BOTDEVMODE {return;}
    if g_bot_arena.compare_stock {
        g_bot_arena.last_winner_side = winner_side;
        if winner_side == 1 {g_bot_arena.last_winner_generation = g_bot_arena_left.generation;}
        else {g_bot_arena.last_winner_generation = 0;}
        if winner_side == 1 {g_bot_arena.compare_stock_wins += 1;} else {g_bot_arena.compare_stock_losses += 1;}
        g_bot_arena.generation_round = 0;
        g_bot_arena.generation_left_wins = 0;
        g_bot_arena.generation_right_wins = 0;
        initBotArenaRound();
        return;
    }

    g_bot_arena.generation_round += 1;
    if winner_side == 1 {g_bot_arena.generation_left_wins += 1;} else {g_bot_arena.generation_right_wins += 1;}

    if g_bot_arena.generation_stage == BOT_ARENA_STAGE_CHAMPION {
        bool champion_stage_done = false;
        if g_bot_arena.generation_right_wins >= arenaRequiredWins(BOT_ARENA_CHAMP_MAX_ROUNDS, BOT_ARENA_CHAMP_MAX_LOSSES) {champion_stage_done = true;}
        if g_bot_arena.generation_left_wins >= (BOT_ARENA_CHAMP_MAX_LOSSES + 1) {champion_stage_done = true;}
        if g_bot_arena.generation_round >= BOT_ARENA_CHAMP_MAX_ROUNDS {champion_stage_done = true;}

        if !champion_stage_done {
            initBotArenaRound();
            return;
        }

        bool challenger_passed_champion_gate = g_bot_arena.generation_right_wins >= arenaRequiredWins(BOT_ARENA_CHAMP_MAX_ROUNDS, BOT_ARENA_CHAMP_MAX_LOSSES);

        if challenger_passed_champion_gate {
            g_bot_arena.gauntlet_target_index += 1;
            if g_bot_arena.gauntlet_target_index >= arenaGauntletChampionCount() {
                g_bot_arena.generation_stage = BOT_ARENA_STAGE_STOCK;
                g_bot_arena.stock_round = 0;
                g_bot_arena.stock_left_wins = 0;
                g_bot_arena.stock_right_wins = 0;
            }
            g_bot_arena.generation_round = 0;
            g_bot_arena.generation_left_wins = 0;
            g_bot_arena.generation_right_wins = 0;
            initBotArenaRound();
            return;
        }

        g_bot_arena.total_matches += 1;
        g_bot_arena.last_winner_side = 1;
        g_bot_arena.champion_setup = clampArenaSetup(g_bot_arena.champion_setup);
        g_bot_arena.champion_wins += 1;
        g_bot_arena.last_winner_generation = g_bot_arena.champion_generation;
        g_bot_arena.generation_stage = BOT_ARENA_STAGE_CHAMPION;
        g_bot_arena.gauntlet_target_index = 0;
        g_bot_arena.generation_round = 0;
        g_bot_arena.generation_left_wins = 0;
        g_bot_arena.generation_right_wins = 0;
        g_bot_arena.stock_round = 0;
        g_bot_arena.stock_left_wins = 0;
        g_bot_arena.stock_right_wins = 0;
        saveBotDuelsFile();
        initBotArenaRound();
        return;
    }

    g_bot_arena.stock_round += 1;
    if winner_side == 1 {g_bot_arena.stock_left_wins += 1;} else {g_bot_arena.stock_right_wins += 1;}

    bool stock_stage_done = false;
    if g_bot_arena.stock_left_wins >= arenaRequiredWins(BOT_ARENA_STOCK_MAX_ROUNDS, BOT_ARENA_STOCK_MAX_LOSSES) {stock_stage_done = true;}
    if g_bot_arena.stock_right_wins >= (BOT_ARENA_STOCK_MAX_LOSSES + 1) {stock_stage_done = true;}
    if g_bot_arena.stock_round >= BOT_ARENA_STOCK_MAX_ROUNDS {stock_stage_done = true;}

    if !stock_stage_done {
        initBotArenaRound();
        return;
    }

    g_bot_arena.total_matches += 1;
    bool challenger_passed_stock_gate = false;
    challenger_passed_stock_gate = g_bot_arena.stock_left_wins >= arenaRequiredWins(BOT_ARENA_STOCK_MAX_ROUNDS, BOT_ARENA_STOCK_MAX_LOSSES);

    if challenger_passed_stock_gate {
        g_bot_arena.last_winner_side = 2;
        pushChampionToHistory();
        g_bot_arena.champion_setup = g_bot_arena.candidate_setup;
        g_bot_arena.champion_generation = g_bot_arena.candidate_generation;
        g_bot_arena.champion_wins = 1;
        g_bot_arena.last_winner_generation = g_bot_arena.candidate_generation;
        copyI32Array(&g_bot_arena_champion_tuning[0], &g_bot_arena_candidate_tuning[0], AI_TUNE_COUNT);
    } else {
        g_bot_arena.last_winner_side = 2;
        g_bot_arena.champion_setup = clampArenaSetup(g_bot_arena.champion_setup);
        g_bot_arena.champion_wins += 1;
        g_bot_arena.last_winner_generation = g_bot_arena.champion_generation;
    }

    g_bot_arena.generation_stage = BOT_ARENA_STAGE_CHAMPION;
    g_bot_arena.gauntlet_target_index = 0;
    g_bot_arena.generation_round = 0;
    g_bot_arena.generation_left_wins = 0;
    g_bot_arena.generation_right_wins = 0;
    g_bot_arena.stock_round = 0;
    g_bot_arena.stock_left_wins = 0;
    g_bot_arena.stock_right_wins = 0;
    g_bot_arena.champion_setup = clampArenaSetup(g_bot_arena.champion_setup);
    saveBotDuelsFile();
    initBotArenaRound();
}

fun startBotDuelsMode() >> void {
    if !BOTDEVMODE {return;}
    g_game = g_game.with_screen(SCREEN_GAME);
    startGameMode(MODE_BOT_DUELS);
}

fun updateBotArenaSide(side: i32, opponent: i32, dt: f32) >> void {
    i32 opponent_pending = g_bot_arena_left.runtime.pending_garbage;
    if opponent == BOT_ARENA_RIGHT {opponent_pending = g_bot_arena_right.runtime.pending_garbage;}
    applyAiTuning(arenaTuningPtr(side));
    loadBotArenaSideIntoScratch(side, opponent_pending);

    g_bot.place_meter += dt * botActionRate(dt);
    if g_bot.place_meter > 12.0 {g_bot.place_meter = 12.0;}

    for (g_bot.place_meter >= 1.0) {
        g_bot.place_meter -= 1.0;

        if !botPerformPlannedAction() {
            g_bot.game_over = true;
            break;
        }
        g_bot.actions_taken += 1;
        if g_bot.game_over {break;}
    }

    if opponent == BOT_ARENA_LEFT {g_bot_arena_left.runtime.pending_garbage = saveScratchIntoBotArenaSide(side);}
    else {g_bot_arena_right.runtime.pending_garbage = saveScratchIntoBotArenaSide(side);}
}

fun updateBotDuelsMode(dt: f32) >> void {
    if !BOTDEVMODE {return;}
    if IsKeyPressed(KEY_ONE) {
        g_bot_arena.compare_stock = !g_bot_arena.compare_stock;
        g_bot_arena.last_winner_side = 0;
        g_bot_arena.last_winner_generation = 0;
        g_bot_arena.generation_stage = BOT_ARENA_STAGE_CHAMPION;
        g_bot_arena.gauntlet_target_index = 0;
        g_bot_arena.generation_round = 0;
        g_bot_arena.generation_left_wins = 0;
        g_bot_arena.generation_right_wins = 0;
        g_bot_arena.stock_round = 0;
        g_bot_arena.stock_left_wins = 0;
        g_bot_arena.stock_right_wins = 0;
        if g_bot_arena.compare_stock {
            g_bot_arena.compare_stock_wins = 0;
            g_bot_arena.compare_stock_losses = 0;
        }
        initBotArenaRound();
        return;
    }

    if !g_duel_running {return;}

    for i32 step = 0; step < BOT_DUELS_SIM_STEPS; step++ {
        if !g_duel_running {break;}

        g_rt.run_timer += dt;

        if !g_bot_arena_left.runtime.game_over {updateBotArenaSide(BOT_ARENA_LEFT, BOT_ARENA_RIGHT, dt);}
        if g_bot_arena_right.runtime.game_over {
            g_duel_running = false;
            resolveBotArenaMatch(1);
            break;
        }

        if !g_bot_arena_right.runtime.game_over {updateBotArenaSide(BOT_ARENA_RIGHT, BOT_ARENA_LEFT, dt);}
        if g_bot_arena_left.runtime.game_over {
            g_duel_running = false;
            resolveBotArenaMatch(2);
            break;
        }
    }
}

fun updateBotSetupScreen() >> void {
    if IsKeyPressed(KEY_ESCAPE) {
        g_game = g_game.with_screen(SCREEN_MENU);
        return;
    }

    if !canOpenBotSetupUi() {return;}

    i32 max_index = botSetupRowCount() - 1;
    if g_bot_setup.index > max_index {g_bot_setup.index = max_index;}

    if IsKeyPressed(KEY_UP) {
        g_bot_setup.index -= 1;
        if g_bot_setup.index < 0 {g_bot_setup.index = max_index;}
    }
    if IsKeyPressed(KEY_DOWN) {
        g_bot_setup.index += 1;
        if g_bot_setup.index > max_index {g_bot_setup.index = 0;}
    }

    i64 slider_x = 176;
    i64 slider_y = 309;
    i64 slider_w = 296;
    i64 row_x = 156;
    i64 row_w = 336;
    i64 row_y0 = 270;
    i64 row_h = 76;
    f32 mx = mouseBaseX();
    f32 my = mouseBaseY();
    i32 row_count = botSetupRowCount();
    for i32 i = 0; i < row_count; i++ {
        i64 y = row_y0 + (i as i64) * row_h;
        if pointInBaseRectLocal(mx, my, row_x, y, row_w, 58) {g_bot_setup.index = i;}
    }
    bool slider_hover = mx >= (slider_x as f32) && mx <= ((slider_x + slider_w) as f32) && my >= ((slider_y - 10) as f32) && my <= ((slider_y + 20) as f32);
    bool messiness_slider_hover = mx >= (slider_x as f32) && mx <= ((slider_x + slider_w) as f32) && my >= ((slider_y + row_h - 10) as f32) && my <= ((slider_y + row_h + 20) as f32);
    if slider_hover && IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {g_bot_setup.index = 0;}
    if g_bot_setup.index == 0 && slider_hover && IsMouseButtonDown(MOUSE_BUTTON_LEFT) {
        f32 norm = (mx - (slider_x as f32)) / (slider_w as f32);
        setBotTargetApmNorm(norm);
    }
    if messiness_slider_hover && IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {g_bot_setup.index = 1;}
    if g_bot_setup.index == 1 && messiness_slider_hover && IsMouseButtonDown(MOUSE_BUTTON_LEFT) {
        g_bot_setup.garbage_messiness = ((mx - (slider_x as f32)) / (slider_w as f32)) * 100.0;
        clampBotGarbageMessiness();
    }
    i32 burst_row = botSetupPanicRow();
    i32 start_row = botSetupStartRow();
    i32 back_row = botSetupBackRow();
    if pointInBaseRectLocal(mx, my, row_x, row_y0 + row_h * (burst_row as i64), row_w, 58) && IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {
        g_bot_setup.panic_burst_enabled = !g_bot_setup.panic_burst_enabled;
    }
    i32 weights_row = botSetupWeightsRow();
    if BOTDEVMODE {
        if pointInBaseRectLocal(mx, my, row_x, row_y0 + row_h * (weights_row as i64), row_w, 58) && IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {
            if g_bot_setup.weights_mode == BOT_WEIGHTS_STOCK {g_bot_setup.weights_mode = BOT_WEIGHTS_CHAMPION;} else {g_bot_setup.weights_mode = BOT_WEIGHTS_STOCK;}
        }
    }
    if pointInBaseRectLocal(mx, my, row_x, row_y0 + row_h * (start_row as i64), row_w, 58) && IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {startBotDuel(); return;}
    if pointInBaseRectLocal(mx, my, row_x, row_y0 + row_h * (back_row as i64), row_w, 58) && IsMouseButtonPressed(MOUSE_BUTTON_LEFT) {g_game = g_game.with_screen(SCREEN_MENU); return;}
    g_bot_setup.high_stack_tolerance = false;

    if g_bot_setup.index == 0 {
        if IsKeyPressed(KEY_LEFT) {g_bot_setup.target_apm -= 5.0;}
        if IsKeyPressed(KEY_RIGHT) {g_bot_setup.target_apm += 5.0;}
        clampBotTargetApm();
    } else if g_bot_setup.index == 1 {
        if IsKeyPressed(KEY_LEFT) {g_bot_setup.garbage_messiness -= 5.0;}
        if IsKeyPressed(KEY_RIGHT) {g_bot_setup.garbage_messiness += 5.0;}
        clampBotGarbageMessiness();
    } else if g_bot_setup.index == 2 {
        if IsKeyPressed(KEY_LEFT) || IsKeyPressed(KEY_RIGHT) {
            g_bot_setup.panic_burst_enabled = !g_bot_setup.panic_burst_enabled;
        }
    } else if BOTDEVMODE && g_bot_setup.index == weights_row {
        if IsKeyPressed(KEY_LEFT) || IsKeyPressed(KEY_RIGHT) {
            if g_bot_setup.weights_mode == BOT_WEIGHTS_STOCK {g_bot_setup.weights_mode = BOT_WEIGHTS_CHAMPION;} else {g_bot_setup.weights_mode = BOT_WEIGHTS_STOCK;}
        }
    }

    if (IsKeyPressed(KEY_ENTER) || IsKeyPressed(KEY_SPACE)) {
        if g_bot_setup.index == 2 {
            g_bot_setup.panic_burst_enabled = !g_bot_setup.panic_burst_enabled;
        }
        if BOTDEVMODE && g_bot_setup.index == weights_row {
            if g_bot_setup.weights_mode == BOT_WEIGHTS_STOCK {g_bot_setup.weights_mode = BOT_WEIGHTS_CHAMPION;} else {g_bot_setup.weights_mode = BOT_WEIGHTS_STOCK;}
        }
        if g_bot_setup.index == start_row {startBotDuel();}
        if g_bot_setup.index == back_row {g_game = g_game.with_screen(SCREEN_MENU);}
    }
}

fun drawSidebar(font: Font, theme: Theme, split_layout: bool) >> void {
    if (split_layout) {
        i64 left_panel_x = -214;
        i64 right_panel_x = SIDEBAR_X;
        if isVsBotMode() {
            left_panel_x = vsBotPlayerLeftPanelX();
            right_panel_x = currentCenterSidebarX();
        }

        fillRect(left_panel_x, 120, 184, 510, alphaColor(theme.panel_bg, 0.92));
        strokeRect(left_panel_x, 120, 184, 510, alphaColor(theme.panel_stroke, 0.78));

        drawTextColor(font, "ZLTRIS", left_panel_x + 20, 146, 24, theme.text_main);
        drawTextColor(font, "first strike", left_panel_x + 20, 180, 11, theme.text_muted);

        drawTextColor(font, "HOLD", left_panel_x + 20, 230, 14, theme.text_main);
        fillRect(left_panel_x + 36, 256, 112, 112, alphaColor(theme.board_bg, 0.92));
        strokeRect(left_panel_x + 36, 256, 112, 112, alphaColor(theme.panel_stroke, 0.78));
        if g_hold_kind >= 0 {drawMiniPieceCentered(theme, g_hold_kind, left_panel_x + 36, 256, 112, 112, 16);}

        drawTextColor(font, TextFormat("SCORE\n%i", g_play.score), left_panel_x + 20, 404, 16, theme.text_main);
        drawTextColor(font, TextFormat("LINES\n%i", g_play.lines), left_panel_x + 20, 468, 16, theme.text_main);
        drawTextColor(font, TextFormat("PPS: %.2f", currentPps()), left_panel_x + 20, 532, 16, theme.text_main);
        if isFreePlayMode() || isVsBotMode() {drawTextColor(font, TextFormat("APM: %.1f", currentApm()), left_panel_x + 20, 548, 12, theme.panel_stroke);}
        if g_rt.combo > 0 {drawTextColor(font, TextFormat("COMBO x%i", g_rt.combo), left_panel_x + 20, 560, 11, theme.panel_stroke);}
        if g_rt.back_to_back_count > 0 {drawTextColor(font, TextFormat("B2B x%i", g_rt.back_to_back_count), left_panel_x + 20, 574, 11, theme.panel_stroke);}
        if isFortyLinesMode() {drawTextColor(font, TextFormat("TIME\n%02i:%02i.%02i", ((g_rt.mode_timer * 100.0) as i32) / 6000, (((g_rt.mode_timer * 100.0) as i32) / 100) % 60, ((g_rt.mode_timer * 100.0) as i32) % 100), left_panel_x + 20, 600, 14, theme.panel_stroke);}
        if isBlitzMode() {drawTextColor(font, TextFormat("LEFT\n%02i:%02i.%02i", ((blitzTimeLeft() * 100.0) as i32) / 6000, (((blitzTimeLeft() * 100.0) as i32) / 100) % 60, ((blitzTimeLeft() * 100.0) as i32) % 100), left_panel_x + 20, 600, 14, theme.panel_stroke);}

        fillRect(right_panel_x, 120, 178, 510, theme.panel_bg);
        strokeRect(right_panel_x, 120, 178, 510, theme.panel_stroke);
        drawTextColor(font, "NEXT", right_panel_x + 20, 150, 14, theme.text_main);
        for i32 i = 0; i < PREVIEW_COUNT; i++ {
            i64 panel_y = 186 + (i as i64) * 88;
            fillRect(right_panel_x + 35, panel_y, 108, 72, alphaColor(theme.board_bg, 0.86));
            strokeRect(right_panel_x + 35, panel_y, 108, 72, alphaColor(theme.panel_stroke, 0.55));
            drawMiniPieceCentered(theme, g_queue[i], right_panel_x + 35, panel_y, 108, 72, 13);
        }

        if isVsBotMode() {
            i64 bot_panel_x = vsBotBotPanelX();
            f32 bot_apm = 0.0;
            if g_rt.run_timer > 0.001 {bot_apm = ((g_bot.attack_sent as f32) * 60.0) / g_rt.run_timer;}

            fillRect(bot_panel_x, 120, 178, 510, theme.panel_bg);
            strokeRect(bot_panel_x, 120, 178, 510, theme.panel_stroke);
            drawTextColor(font, "BOT BAG", bot_panel_x + 20, 150, 14, theme.text_main);
            for i32 i = 0; i < PREVIEW_COUNT; i++ {
                i64 panel_y = 186 + (i as i64) * 88;
                fillRect(bot_panel_x + 35, panel_y, 108, 72, alphaColor(theme.board_bg, 0.86));
                strokeRect(bot_panel_x + 35, panel_y, 108, 72, alphaColor(theme.panel_stroke, 0.55));
                drawMiniPieceCentered(theme, g_bot_queue[i], bot_panel_x + 35, panel_y, 108, 72, 13);
            }
            drawTextColor(font, TextFormat("APM %.1f", bot_apm), bot_panel_x + 20, 580, 12, theme.panel_stroke);
            drawTextColor(font, TextFormat("LINES %i", g_bot.lines), bot_panel_x + 20, 600, 12, theme.text_muted);
        }
        return;
    }

    fillRect(SIDEBAR_X, 82, 178, 756, theme.panel_bg);
    strokeRect(SIDEBAR_X, 82, 178, 756, theme.panel_stroke);

    drawTextColor(font, "ZLTRIS", SIDEBAR_X + 20, 108, 24, theme.text_main);
    drawTextColor(font, "first strike", SIDEBAR_X + 20, 142, 11, theme.text_muted);

    drawTextColor(font, "HOLD", SIDEBAR_X + 20, 190, 14, theme.text_main);
    if isFortyLinesMode() {drawTextColor(font, TextFormat("TIME %02i:%02i.%02i", ((g_rt.mode_timer * 100.0) as i32) / 6000, (((g_rt.mode_timer * 100.0) as i32) / 100) % 60, ((g_rt.mode_timer * 100.0) as i32) % 100), SIDEBAR_X + 20, 166, 11, theme.panel_stroke);}
    if isBlitzMode() {drawTextColor(font, TextFormat("LEFT %02i:%02i.%02i", ((blitzTimeLeft() * 100.0) as i32) / 6000, (((blitzTimeLeft() * 100.0) as i32) / 100) % 60, ((blitzTimeLeft() * 100.0) as i32) % 100), SIDEBAR_X + 20, 166, 11, theme.panel_stroke);}
    fillRect(SIDEBAR_X + 20, 216, 88, 88, alphaColor(theme.board_bg, 0.9));
    strokeRect(SIDEBAR_X + 20, 216, 88, 88, alphaColor(theme.panel_stroke, 0.8));
    if g_hold_kind >= 0 {drawMiniPieceCentered(theme, g_hold_kind, SIDEBAR_X + 20, 216, 88, 88, 14);}
    if g_rt.combo > 0 {drawTextColor(font, TextFormat("COMBO x%i", g_rt.combo), SIDEBAR_X + 20, 308, 10, theme.panel_stroke);}
    if g_rt.back_to_back_count > 0 {drawTextColor(font, TextFormat("B2B x%i", g_rt.back_to_back_count), SIDEBAR_X + 20, 320, 10, theme.panel_stroke);}

    drawTextColor(font, "NEXT", SIDEBAR_X + 20, 334, 14, theme.text_main);
    for i32 i = 0; i < PREVIEW_COUNT; i++ {
        i64 panel_y = 360 + (i as i64) * 82;
        fillRect(SIDEBAR_X + 20, panel_y, 88, 70, alphaColor(theme.board_bg, 0.86));
        strokeRect(SIDEBAR_X + 20, panel_y, 88, 70, alphaColor(theme.panel_stroke, 0.55));
        drawMiniPieceCentered(theme, g_queue[i], SIDEBAR_X + 20, panel_y, 88, 70, 12);
    }

    drawTextColor(font, TextFormat("SCORE\n%i", g_play.score), SIDEBAR_X + 7, 796, 16, theme.text_main);
    drawTextColor(font, TextFormat("LINES\n%i", g_play.lines), SIDEBAR_X + 95, 796, 16, theme.text_main);
    if isFreePlayMode() {drawTextColor(font, TextFormat("APM %.1f", currentApm()), SIDEBAR_X + 20, 772, 11, theme.panel_stroke);}
}

fun drawColorDebugOverlay(font: Font, theme: Theme) >> void {
    fillRect(28, 76, 504, 674, alphaColor(theme.bg_outer, 0.95));
    strokeRect(28, 76, 504, 674, theme.panel_stroke);

    drawTextColor(font, "COLOR DEBUG (F3)", 52, 104, 19, theme.text_main);
    drawTextColor(font, TextFormat("theme: %s idx:%i", themeName(g_game.theme_index), g_game.theme_index), 52, 136, 14, theme.text_muted);

    for i32 i = 0; i < 7; i++ {
        u32 c = pieceColor(theme, i);
        i64 y = 176 + (i as i64) * 68;
        fillRect(52, y, 42, 42, c);
        strokeRect(52, y, 42, 42, alphaColor(c, 0.45));
        drawTextColor(
            font,
            TextFormat("kind %i 0x%08X rgb(%i,%i,%i)", i, c, colorR(c), colorG(c), colorB(c)),
            108,
            y + 13,
            12,
            theme.text_main
        );
    }

    drawTextColor(
        font,
        TextFormat("current kind %i  color 0x%08X", g_piece_kind, pieceColor(theme, g_piece_kind)),
        52,
        654,
        14,
        theme.panel_stroke
    );
    ??drawTextColor(font, "If swatch is purple but piece is cyan, bug is in draw path.", 52, 684, 12, theme.text_muted);
    ??drawTextColor(font, "If swatch itself is cyan, bug is in theme/color path.", 52, 706, 12, theme.text_muted);
}

fun drawFortyLinesOverlay(font: Font, theme: Theme) >> void {
    if !modeUsesRoundState() {return;}

    i64 board_left = currentPlayerBoardLeft();
    i64 board_top = currentBoardTop();

    if (g_play.round_state == ROUND_COUNTDOWN) {
        ptr<u8> text = "3";
        i64 size = 86;
        i64 box_x = board_left + 62;
        i64 box_y = board_top + 224;
        i64 box_w = 196;
        i64 box_h = 196;
        f32 seg = g_rt.countdown_timer - 3.0;

        if (g_rt.countdown_timer <= 3.0 && g_rt.countdown_timer > 2.0) {
            text = "2";
            seg = g_rt.countdown_timer - 2.0;
        } else if (g_rt.countdown_timer <= 2.0 && g_rt.countdown_timer > 1.0) {
            text = "1";
            seg = g_rt.countdown_timer - 1.0;
        } else if (g_rt.countdown_timer <= 1.0) {
            text = "BUILD";
            size = 46;
            box_x = board_left + 24;
            box_y = board_top + 246;
            box_w = 272;
            box_h = 152;
            seg = g_rt.countdown_timer;
        }

        if seg < 0.0 {seg = 0.0;}
        if seg > 1.0 {seg = 1.0;}
        f32 fade = 0.18 + seg * 0.82;

        fillRect(box_x, box_y, box_w, box_h, alphaColor(rgba(8, 11, 18, 255), 0.86));
        strokeRect(box_x, box_y, box_w, box_h, alphaColor(theme.panel_stroke, 0.90));
        drawTextCenteredInRect(font, text, box_x, box_y, box_w, box_h, size, alphaColor(theme.text_main, fade));
        return;
    }

    if (g_play.round_state == ROUND_FINISHED) {
        fillRect(board_left + 18, board_top + 224, 284, 178, alphaColor(rgba(8, 11, 18, 255), 0.88));
        strokeRect(board_left + 18, board_top + 224, 284, 178, theme.panel_stroke);
        if (isFortyLinesMode()) {
            drawTextColor(font, "40 DONE", board_left + 76, board_top + 248, 24, theme.text_main);
            drawTextColor(font, TextFormat("TIME %02i:%02i.%02i", ((g_rt.mode_timer * 100.0) as i32) / 6000, (((g_rt.mode_timer * 100.0) as i32) / 100) % 60, ((g_rt.mode_timer * 100.0) as i32) % 100), board_left + 62, board_top + 294, 14, theme.panel_stroke);
        }
        if (isBlitzMode()) {
            drawTextColor(font, "BLITZ END", board_left + 60, board_top + 248, 24, theme.text_main);
            drawTextColor(font, TextFormat("SCORE %i", g_play.score), board_left + 62, board_top + 294, 14, theme.panel_stroke);
        }
        drawTextColor(font, "R retry  ESC menu", board_left + 62, board_top + 334, 12, theme.text_muted);
    }
}

fun drawApp(font: Font) >> void {
    g_game = g_game.refresh_screen_size();
    setScaleAlignX(scaleAlignCenter());
    i32 shake_x = 0;
    i32 shake_y = 0;
    if g_game.screen == SCREEN_GAME {
        shake_x = boardShakeX();
        shake_y = boardShakeY();
    }
    if (g_game.screen == SCREEN_GAME && (isVsBotMode() || isBotDuelsMode())) {
        setScaleExtraX(vsBotLayoutExtraX() + shake_x);
    } else if (g_game.screen == SCREEN_GAME && canUseDoubleRowLayout()) {
        setScaleExtraX(uiS(131) + shake_x);
    } else {
        setScaleExtraX(shake_x);
    }
    setScaleExtraY(shake_y);

    Theme theme = currentTheme();
    BeginDrawing();
    clearWithColor(theme.bg_outer);

    if (g_game.screen == SCREEN_MENU) {
        drawMenu(font, theme);
        if g_debug_colors {drawColorDebugOverlay(font, theme);}
        EndDrawing();
        return;
    }

    if (g_game.screen == SCREEN_SETTINGS) {
        drawSettings(font, theme, g_game.theme_index, g_arr_frames, g_das_frames, g_dcd_frames, g_sdf_multiplier, g_board_bounciness, g_bg_stars_amount, g_bg_star_react_mode, g_star_peak_target_dps, g_star_intensity, g_double_row_ui, g_instant_restart);
        if g_debug_colors {drawColorDebugOverlay(font, theme);}
        EndDrawing();
        return;
    }

    if (g_game.screen == SCREEN_BOT_SETUP) {
        drawBotSetupScreen(font, theme);
        if g_debug_colors {drawColorDebugOverlay(font, theme);}
        EndDrawing();
        return;
    }

    if isBotDuelsMode() {drawBotDuelsFrame(font);} else {drawGameFrame(font);}
    EndDrawing();
}

fun updateApp() >> void {
    g_game = g_game.refresh_screen_size();

    if (g_debug_colors && IsKeyPressed(KEY_G)) {
        g_ai_armed = true;
        printf("[zltris] AI armed (close F3 to start)\n");
    }

    if (IsKeyPressed(KEY_F3)) {
        bool was_debug_open = g_debug_colors;
        g_debug_colors = !g_debug_colors;
        Theme theme = currentTheme();
        if (g_debug_colors) {
            printf("[zltris] F3 debug ON\n");
            printColorDebug(theme);
        } else {
            printf("[zltris] F3 debug OFF\n");
            printColorDebug(theme);
        }

        if (was_debug_open && !g_debug_colors && g_ai_armed) {
            g_ai_enabled = true;
            g_ai_armed = false;
            printf("[zltris] AI bot started\n");
        }
    }

    if (g_game.screen == SCREEN_MENU) {
        i32 action = menuUpdate();
        if (action == menuActionStartFreePlay()) {
            g_game = g_game.with_screen(SCREEN_GAME);
            startGameMode(MODE_FREE_PLAY);
        } else if (action == menuActionStart40Lines()) {
            g_game = g_game.with_screen(SCREEN_GAME);
            startGameMode(MODE_40_LINES);
        } else if (action == menuActionStartBlitz()) {
            g_game = g_game.with_screen(SCREEN_GAME);
            startGameMode(MODE_BLITZ);
        } else if (action == menuActionOpenBotSetup()) {
            initBotSetupDefaults();
            g_game = g_game.with_screen(SCREEN_BOT_SETUP);
        } else if (action == menuActionStartBotDuels()) {
            if BOTDEVMODE {startBotDuelsMode();}
        } else if (action == menuActionOpenSettings()) {
            g_game = g_game.with_settings_return_screen(SCREEN_MENU);
            settingsInit();
            g_game = g_game.with_screen(SCREEN_SETTINGS);
        }
        return;
    }

    if (g_game.screen == SCREEN_SETTINGS) {
        i32 prev_theme = g_game.theme_index;
        f32 prev_arr = g_arr_frames;
        f32 prev_das = g_das_frames;
        f32 prev_dcd = g_dcd_frames;
        f32 prev_sdf = g_sdf_multiplier;
        i32 prev_board_bounciness = g_board_bounciness;
        i32 prev_bg_amount = g_bg_stars_amount;
        i32 prev_bg_mode = g_bg_star_react_mode;
        f32 prev_peak = g_star_peak_target_dps;
        f32 prev_intensity = g_star_intensity;
        bool prev_double_row = g_double_row_ui;
        bool prev_instant_restart = g_instant_restart;

        i32 settings_action = settingsUpdate(&g_game.theme_index, &g_arr_frames, &g_das_frames, &g_dcd_frames, &g_sdf_multiplier, &g_board_bounciness, &g_bg_stars_amount, &g_bg_star_react_mode, &g_star_peak_target_dps, &g_star_intensity, &g_double_row_ui, &g_instant_restart);
        if (prev_theme != g_game.theme_index ||
            prev_arr != g_arr_frames ||
            prev_das != g_das_frames ||
            prev_dcd != g_dcd_frames ||
            prev_sdf != g_sdf_multiplier ||
            prev_board_bounciness != g_board_bounciness ||
            prev_bg_amount != g_bg_stars_amount ||
            prev_bg_mode != g_bg_star_react_mode ||
            prev_peak != g_star_peak_target_dps ||
            prev_intensity != g_star_intensity ||
            prev_double_row != g_double_row_ui ||
            prev_instant_restart != g_instant_restart) {
            clampSettings();
            saveSettingsFile();
        }
        if settings_action == settingsActionBack() {g_game = g_game.with_screen(g_game.settings_return_screen);}
        return;
    }

    if (g_game.screen == SCREEN_BOT_SETUP) {
        updateBotSetupScreen();
        return;
    }

    updateGameScreen();
}

fun drawGameFrame(font: Font) >> void {
    Theme theme = currentTheme();
    bool split_layout = canUseDoubleRowLayout() || isVsBotMode();
    f32 hint_alpha = 1.0;
    if canShowHoldRestartEffect() {hint_alpha = restartHintAlpha();}
    DrawRectangleGradientV(0, 0, GetScreenWidth(), GetScreenHeight(), toColor(theme.bg_inner), toColor(theme.bg_outer));
    drawBackgroundStars(theme);
    if (isVsBotMode() || isBotDuelsMode()) && !canOpenBotSetupUi() {
        drawBotWidthPopup(font, theme, false);
        if g_debug_colors {drawColorDebugOverlay(font, theme);}
        return;
    }
    drawBoard(theme);
    drawSidebar(font, theme, split_layout);
    if isVsBotMode() {drawBotBoard(theme, font);}
    if canShowHoldRestartEffect() {drawRestartCharge(font, theme);}

    if !(isVsBotMode() && g_bot_setup.high_stack_tolerance) {
        drawTextColor(font, "LEFT/RIGHT move", 48, 24, 12, theme.text_muted);
        drawTextColor(font, "TAB settings  F3 color debug", 48, 42, 12, theme.text_muted);
        drawTextColor(font, "UP/X rotate CW   Z rotate CCW", 48, 806, 12, alphaColor(theme.text_muted, hint_alpha));
        drawTextColor(font, "DOWN soft  SPACE hard  C hold", 48, 831, 12, alphaColor(theme.text_muted, hint_alpha));
    }
    i64 board_left = currentPlayerBoardLeft();
    i64 board_top = currentBoardTop();
    
    if (g_play.game_over) {
        fillRect(board_left + 24, board_top + 224, 272, 140, alphaColor(rgba(8, 11, 18, 255), 0.88));
        strokeRect(board_left + 24, board_top + 224, 272, 140, pieceColor(theme, PIECE_Z));
        drawTextColor(font, "GAME OVER", board_left + 50, board_top + 256, 24, theme.text_main);
        drawTextColor(font, "Press R to restart", board_left + 40, board_top + 304, 14, theme.text_muted);
    }

    drawFortyLinesOverlay(font, theme);

    if isVsBotMode() && !g_duel_running {
        fillRect(board_left + 24, board_top + 224, 272, 140, alphaColor(rgba(8, 11, 18, 255), 0.88));
        strokeRect(board_left + 24, board_top + 224, 272, 140, theme.panel_stroke);
        if g_duel_result == DUEL_RESULT_PLAYER_WIN {drawTextColor(font, "YOU WIN", board_left + 74, board_top + 256, 24, theme.text_main);} else {drawTextColor(font, "YOU LOSE", board_left + 70, board_top + 256, 24, theme.text_main);}
        drawTextColor(font, "R retry  ESC menu", board_left + 48, board_top + 304, 14, theme.text_muted);
    }

    if g_debug_colors {drawColorDebugOverlay(font, theme);}
}

fun updateHorizontalInput(dt: f32) >> void {
    if IsKeyPressed(KEY_LEFT) {g_rt.last_horizontal_press = -1;}
    if IsKeyPressed(KEY_RIGHT) {g_rt.last_horizontal_press = 1;}

    bool left_down = IsKeyDown(KEY_LEFT);
    bool right_down = IsKeyDown(KEY_RIGHT);

    i32 desired_dir = 0;
    if (left_down && !right_down) {
        desired_dir = -1;
    } else if (right_down && !left_down) {
        desired_dir = 1;
    } else if (left_down && right_down) {
        desired_dir = g_rt.last_horizontal_press;
    }

    if (desired_dir == 0) {
        g_rt.shift_dir = 0;
        g_rt.shift_hold_timer = 0.0;
        g_rt.shift_repeat_timer = 0.0;
        return;
    }

    if (desired_dir != g_rt.shift_dir) {
        g_rt.shift_dir = desired_dir;
        g_rt.shift_hold_timer = 0.0;
        g_rt.shift_repeat_timer = 0.0;
        tryMove(desired_dir, 0);
        return;
    }

    if (g_rt.dcd_timer > 0.0) {
        g_rt.dcd_timer -= dt;
        if g_rt.dcd_timer < 0.0 {g_rt.dcd_timer = 0.0;}
        return;
    }

    f32 das_seconds = handlingDasSeconds();
    f32 arr_seconds = handlingArrSeconds();

    f32 prev_hold = g_rt.shift_hold_timer;
    g_rt.shift_hold_timer += dt;

    if (prev_hold < das_seconds && g_rt.shift_hold_timer >= das_seconds) {
        if (arr_seconds <= 0.0001) {
            for (tryMove(desired_dir, 0)) {}
            return;
        }
        tryMove(desired_dir, 0);
        g_rt.shift_repeat_timer = 0.0;
    }

    if g_rt.shift_hold_timer < das_seconds {return;}

    if (arr_seconds <= 0.0001) {
        for (tryMove(desired_dir, 0)) {}
        return;
    }

    g_rt.shift_repeat_timer += dt;
    for (g_rt.shift_repeat_timer >= arr_seconds) {
        if (!tryMove(desired_dir, 0)) {
            g_rt.shift_repeat_timer = 0.0;
            break;
        }
        g_rt.shift_repeat_timer -= arr_seconds;
    }
}

fun updateMovementInput(dt: f32) >> void {
    updateHorizontalInput(dt);

    if IsKeyPressed(KEY_UP) || IsKeyPressed(KEY_X) {tryRotate(1);}
    if IsKeyPressed(KEY_Z) {tryRotate(-1);}
    if IsKeyPressed(KEY_C) {holdCurrent();}
    if IsKeyPressed(KEY_SPACE) {hardDrop();}
}

fun updateSoftDrop(dt: f32) >> void {
    if (!IsKeyDown(KEY_DOWN)) {
        g_rt.soft_timer = 0.0;
        return;
    }

    g_rt.soft_timer += dt;
    f32 soft_interval = gravityInterval() / g_sdf_multiplier;
    if soft_interval < 0.005 {soft_interval = 0.005;}
    for (g_rt.soft_timer >= soft_interval) {
        if (tryMove(0, 1)) {
            g_play.score += 1;
            g_rt.soft_timer -= soft_interval;
        } else {
            break;
        }
    }
}

fun updateGravity(dt: f32) >> void {
    g_rt.gravity_timer += dt;
    f32 interval = gravityInterval();
    for (g_rt.gravity_timer >= interval) {
        if (tryMove(0, 1)) {
            g_rt.gravity_timer -= interval;
        } else {
            break;
        }
    }
}

fun updateLock(dt: f32) >> void {
    if (pieceFits(g_piece_kind, g_piece_rotation, g_piece_x, g_piece_y + 1)) {
        g_rt.lock_timer = 0.0;
        return;
    }

    g_rt.lock_timer += dt;
    if g_rt.lock_timer >= 0.45 {stepLock();}
}

fun botLevel() >> i32 {
    i32 level = (g_bot.lines / 10) + 1;
    if level < 1 {level = 1;}
    return level;
}

fun botCurrentApm() >> f32 {
    return aiBotCurrentApm(g_bot.attack_sent, g_rt.run_timer);
}

fun botAttackPerPiece() >> f32 {
    return aiBotAttackPerPiece(g_bot.attack_sent, g_bot.pieces_placed);
}

fun botActionsPerPiece() >> f32 {
    return aiBotActionsPerPiece(g_bot.actions_taken, g_bot.pieces_placed);
}

fun botActionRate(dt: f32) >> f32 {
    f32 raw_rate = aiBotActionRate(&g_bot_board[0], g_bot_setup.target_apm, g_bot_pending_garbage, g_bot.attack_sent, g_bot.pieces_placed, g_bot.actions_taken, g_rt.run_timer, g_bot_setup.panic_burst_enabled);
    if g_bot.rate_smooth <= 0.01 {g_bot.rate_smooth = raw_rate;}

    f32 smooth_gain = planTune(31) as f32;
    if !g_bot_setup.panic_burst_enabled {smooth_gain = planTune(32) as f32;}
    f32 smooth_alpha = dt * smooth_gain;
    f32 smooth_min = (planTune(33) as f32) * 0.01;
    if smooth_alpha < smooth_min {smooth_alpha = smooth_min;}
    if smooth_alpha > 0.40 {smooth_alpha = 0.40;}
    g_bot.rate_smooth += (raw_rate - g_bot.rate_smooth) * smooth_alpha;
    return g_bot.rate_smooth;
}

fun botLockCurrentPiece() >> void {
    for i32 i = 0; i < 4; i++ {
        i32 x = g_bot.piece_x + minoX(g_bot.piece_kind, g_bot.piece_rotation, i);
        i32 y = g_bot.piece_y + minoY(g_bot.piece_kind, g_bot.piece_rotation, i);
        if y >= 0 && y < BOARD_H && x >= 0 && x < BOARD_W {botBoardSet(x, y, g_bot.piece_kind + 1);}
    }
}

fun botApplyLockScore(lines_cleared: i32, spin: bool, mini: bool, all_clear: bool) >> void {
    i32 level = botLevel();

    i32 base = 0;
    if spin {
        if mini {base = miniSpinBasePoints(lines_cleared);} else {base = spinBasePoints(lines_cleared);}
    } else {
        base = lineBasePoints(lines_cleared);
    }

    bool difficult = false;
    if lines_cleared == 4 {difficult = true;}
    if spin && lines_cleared > 0 {difficult = true;}
    bool b2b_chain = g_bot.back_to_back_count > 0;

    i32 clear_points = base;
    if difficult && b2b_chain {clear_points = (clear_points * 3) / 2;}

    if lines_cleared > 0 {g_bot.combo += 1;} else {g_bot.combo = -1;}

    i32 combo_points = 0;
    if lines_cleared > 0 {combo_points = g_bot.combo * 50;}
    i32 all_clear_points = 0;
    if all_clear {all_clear_points = 3500;}
    g_bot.score += (clear_points + combo_points + all_clear_points) * level;

    i32 attack = lockAttack(lines_cleared, spin, mini, difficult, b2b_chain, g_bot.combo, all_clear);
    g_bot.attack_sent += attack;
    routeBotAttack(attack);

    if difficult {g_bot.back_to_back_count += 1;} else if lines_cleared > 0 {g_bot.back_to_back_count = 0;}
    g_bot.last_rotate_success = false;
}

fun botStepLock() >> void {
    botLockCurrentPiece();
    g_bot.pieces_placed += 1;
    bool spin = botIsTSpin(g_bot.piece_kind, g_bot.piece_x, g_bot.piece_y);
    i32 lines_cleared = botClearLines();
    bool mini = false;
    bool all_clear = lines_cleared > 0 && botBoardIsEmpty();
    aiLog(TextFormat(" lock kind=%i x=%i rot=%i lines=%i spin=%i all_clear=%i attack_before=%i", g_bot.piece_kind, g_bot.piece_x, g_bot.piece_rotation, lines_cleared, spin as i32, all_clear as i32, g_bot.attack_sent));
    botApplyLockScore(lines_cleared, spin, mini, all_clear);

    if g_bot_pending_garbage > 0 {
        insertGarbageIntoBot(g_bot_pending_garbage);
        g_bot_pending_garbage = 0;
        if g_bot.game_over {return;}
    }

    botSpawnNextPiece();
}

fun botApplyPlannedLock() >> void {
    g_bot.pieces_placed += 1;
    for i32 i = 0; i < BOARD_CELLS; i++ {g_bot_board[i] = g_bot_planned_board[i];}
    if g_bot_planned_lines > 0 {g_bot.lines += g_bot_planned_lines;}
    aiLog(TextFormat(" lock kind=%i x=%i rot=%i lines=%i spin=%i all_clear=%i attack_before=%i", g_bot.piece_kind, g_bot.target_x, g_bot.target_rotation, g_bot_planned_lines, g_bot_planned_spin as i32, g_bot_planned_all_clear as i32, g_bot.attack_sent));
    botApplyLockScore(g_bot_planned_lines, g_bot_planned_spin, false, g_bot_planned_all_clear);

    botSpawnNextPiece();
}

fun updateDuelBot(dt: f32) >> void {
    if !isVsBotMode() {return;}
    if !g_duel_running {return;}
    if g_bot.game_over || g_play.game_over {return;}

    g_bot.place_meter += dt * botActionRate(dt);
    if g_bot.place_meter > 12.0 {g_bot.place_meter = 12.0;}

    for (g_bot.place_meter >= 1.0) {
        g_bot.place_meter -= 1.0;

        if !botPerformPlannedAction() {
            g_bot.game_over = true;
            break;
        }
        g_bot.actions_taken += 1;
        if g_bot.game_over {break;}
    }
}

fun updateAiBot() >> void {
    if !g_ai_enabled {return;}

    i32 level = (g_play.lines / 10) + 1;
    bool b2b = g_rt.back_to_back_count > 0;
    i32 lookahead_count = g_play.queue_count;
    if lookahead_count < 0 {lookahead_count = 0;}

    i32 max_h = 0;
    i32 holes = 0;
    i32 garbage_rows = 0;
    i32 garbage_cover = 0;
    aiBoardStackStats(&g_board[0], &max_h, &holes, &garbage_rows, &garbage_cover);
    i32 garbage_access = aiBoardGarbageAccessScore(&g_board[0]);

    AiMove move = findBestMove(&g_board[0], g_piece_kind, g_piece_y, &g_queue[0], lookahead_count, g_rt.combo, b2b, level, 0, 0, 0);

    if !move.valid {
        aiLog(TextFormat("fp plan invalid kind=%i lines=%i max_h=%i holes=%i garbage_rows=%i cover=%i access=%i", g_piece_kind, g_play.lines, max_h, holes, garbage_rows, garbage_cover, garbage_access));
        hardDrop();
        return;
    }

    aiLog(TextFormat("fp plan kind=%i x=%i rot=%i tspin=%i lines=%i max_h=%i holes=%i garbage_rows=%i cover=%i access=%i lookahead=%i", g_piece_kind, move.x, move.rotation, move.tspin as i32, g_play.lines, max_h, holes, garbage_rows, garbage_cover, garbage_access, lookahead_count));

    g_piece_rotation = move.rotation;
    g_piece_x = move.x;
    if move.tspin {
        g_rt.last_rotate_success = true;
        g_rt.last_rotate_kick_test = 1;
    } else {
        g_rt.last_rotate_success = false;
        g_rt.last_rotate_kick_test = -1;
    }

    if !currentFitsAt(g_piece_x, g_piece_y, g_piece_rotation) {
        hardDrop();
        return;
    }

    g_piece_y = currentGhostY();
    stepLock();
}

fun updateGameScreen() >> void {
    f32 dt = GetFrameTime();
    updateBackgroundStarReaction(dt);
    updateBoardShake(dt);
    updateRestartAfterglow(dt);

    if isVsBotMode() && !canOpenBotSetupUi() {
        if IsKeyPressed(KEY_ESCAPE) {
            g_rt.restart_afterglow = 0.0;
            g_game = g_game.with_screen(SCREEN_MENU);
            menuInit();
        }
        return;
    }

    if (g_instant_restart && IsKeyPressed(KEY_R)) {
        restartCurrentModeWithShake();
        return;
    }

    if (IsKeyPressed(KEY_TAB)) {
        g_rt.restart_charge = 0.0;
        g_rt.restart_hold_latched = false;
        g_rt.hold_action = HOLD_ACTION_NONE;
        g_game = g_game.with_settings_return_screen(SCREEN_GAME);
        settingsInit();
        g_game = g_game.with_screen(SCREEN_SETTINGS);
        return;
    }

    if (!canShowHoldRestartEffect()) {
        g_rt.restart_charge = 0.0;
        g_rt.restart_hold_latched = false;
        g_rt.hold_action = HOLD_ACTION_NONE;
        if (IsKeyPressed(KEY_ESCAPE)) {
            g_rt.restart_afterglow = 0.0;
            g_game = g_game.with_screen(SCREEN_MENU);
            menuInit();
            return;
        }
    }

    if canShowHoldRestartEffect() && updateRestartCharge(dt) {return;}

    if (modeUsesRoundState()) {
        if (g_play.round_state == ROUND_COUNTDOWN) {
            g_rt.countdown_timer -= dt;
            if (g_rt.countdown_timer <= 0.0) {
                g_rt.countdown_timer = 0.0;
                g_play = g_play.with_round_state(ROUND_RUNNING);
                g_rt.mode_timer = 0.0;
            }
            return;
        }

        if (g_play.round_state == ROUND_FINISHED) {
            if IsKeyPressed(KEY_R) {restartCurrentModeWithShake();}
            return;
        }

        g_rt.mode_timer += dt;
        if (isBlitzMode() && g_rt.mode_timer >= BLITZ_DURATION_SECONDS) {
            g_rt.mode_timer = BLITZ_DURATION_SECONDS;
            g_play = g_play.with_round_state(ROUND_FINISHED);
            return;
        }
    }

    if (!g_play.game_over && !isBotDuelsMode()) {
        if !modeUsesRoundState() || g_play.round_state == ROUND_RUNNING {g_rt.run_timer += dt;}
    }

    if isBotDuelsMode() {
        updateBotDuelsMode(dt);
        return;
    }

    if isVsBotMode() && g_duel_running {updateDuelBot(dt);}
    if isVsBotMode() && g_duel_running {
        if g_bot.game_over {
            g_duel_running = false;
            g_duel_result = DUEL_RESULT_PLAYER_WIN;
        } else if g_play.game_over {
            g_duel_running = false;
            g_duel_result = DUEL_RESULT_PLAYER_LOSE;
        }
    }

    if isVsBotMode() && !g_duel_running {
        if IsKeyPressed(KEY_R) {restartCurrentModeWithShake();}
        return;
    }

    if (g_play.game_over) {
        if IsKeyPressed(KEY_R) {restartCurrentModeWithShake();}
        return;
    }

    if isFreePlayMode() && IsKeyPressed(KEY_L) {
        addFreePlayGarbageLine();
        if g_play.game_over {return;}
    }

    if g_ai_enabled {
        updateAiBot();
        return;
    }

    updateMovementInput(dt);
    if g_play.game_over {return;}

    updateSoftDrop(dt);
    updateGravity(dt);
    if !g_play.game_over {updateLock(dt);}
}

fun shouldQuitApp() >> bool {
    bool ctrl_down = IsKeyDown(KEY_LEFT_CONTROL) || IsKeyDown(KEY_RIGHT_CONTROL);
    if ctrl_down && IsKeyPressed(KEY_Q) {return true;}
    return false;
}

fun main() >> i32 {
    SetConfigFlags(FLAG_WINDOW_RESIZABLE);
    InitWindow(WINDOW_W, WINDOW_H, "zltris");
    SetExitKey(KEY_NULL);
    SetWindowMinSize(420, 620);
    SetTargetFPS(60);
    setScaleBase(UI_BASE_W, UI_BASE_H);

    Font ui_font = LoadFontEx("assets/fonts/PressStart2P.ttf", 48, 0 as ptr<i32>, 0);
    bool custom_font_loaded = IsFontValid(ui_font);
    if (custom_font_loaded) {
        SetTextureFilter(ui_font.texture, TEXTURE_FILTER_POINT);
        printf("[zltris] loaded font: assets/fonts/PressStart2P.ttf\n");
    } else {
        ui_font = GetFontDefault();
        SetTextureFilter(ui_font.texture, TEXTURE_FILTER_POINT);
        printf("[zltris] failed to load custom font, using default\n");
    }

    g_game.theme_index = 0;
    initAiLogFile();
    loadSettingsFile();
    loadBotDuelsFile();
    applyChampionAiTuning();
    clampSettings();
    startGameMode(MODE_FREE_PLAY);
    initBotSetupDefaults();
    initBackgroundStars();
    g_game = g_game.with_screen(SCREEN_MENU);
    g_game = g_game.with_settings_return_screen(SCREEN_MENU);
    menuInit();
    settingsInit();

    for (true) {
        if WindowShouldClose() || shouldQuitApp() {break;}
        updateApp();
        drawApp(ui_font);
    }

    if custom_font_loaded {UnloadFont(ui_font);}
    CloseWindow();
    return 0;
}
